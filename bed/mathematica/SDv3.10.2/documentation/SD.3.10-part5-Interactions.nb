   3.575612659404794*^9}},ExpressionUUID->"56cf7bfb-ef59-4745-9f41-\
89d3231bd11c"],

Cell[TextData[{
 "The direct dipole-dipole coupling between two nuclei separated by a given \
distance is calculated using ",
 StyleBox["DirectDipolarCoupling.",
  FontWeight->"Bold"]
}], "Text",
 CellChangeTimes->{{3.575612332283169*^9, 3.575612453547675*^9}, {
  3.575612665774852*^9, 
  3.575612701534893*^9}},ExpressionUUID->"70f00759-e36a-4349-89d0-\
0119d7f99c96"],

Cell[TextData[{
 "The general syntax is ",
 StyleBox["DirectDipolarCoupling[{",
  FontWeight->"Bold"],
 StyleBox["nuclide1",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 StyleBox[", ",
  FontWeight->"Bold"],
 StyleBox["nuclide2",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 StyleBox["}, ",
  FontWeight->"Bold"],
 StyleBox["distance",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 StyleBox["] ",
  FontWeight->"Bold"],
 "where ",
 StyleBox["distance",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 StyleBox[" ",
  FontWeight->"Bold"],
 "is specified in meters. "
}], "Text",
 CellChangeTimes->{{3.575612332283169*^9, 3.575612453547675*^9}, {
  3.575612665774852*^9, 
  3.575612777204555*^9}},ExpressionUUID->"61346d24-16d1-4a40-ae90-\
35f0572ce660"],

Cell[TextData[{
 "The syntax ",
 StyleBox["DirectDipolarCoupling[",
  FontWeight->"Bold"],
 StyleBox["nuclide",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 StyleBox[", ",
  FontWeight->"Bold"],
 StyleBox["distance",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 StyleBox["] ",
  FontWeight->"Bold"],
 "assumes a homonuclear dipole-dipole coupling."
}], "Text",
 CellChangeTimes->{{3.575612332283169*^9, 3.575612453547675*^9}, {
  3.575612665774852*^9, 
  3.575612825275248*^9}},ExpressionUUID->"7a44fc67-d2ae-4542-87c9-\
2c9f6422690b"],

Cell[TextData[{
 StyleBox[" ",
  FontWeight->"Bold"],
 "The result is returned in units of rad\[NonBreakingSpace]",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["s", 
    RowBox[{"-", "1"}]], TraditionalForm]],ExpressionUUID->
  "061705cb-b231-4d85-99ad-4ff346539b4b"],
 ", including the sign. The dipole-dipole coupling in Hz is generated by \
division by 2\[Pi]:"
}], "Text",
 CellChangeTimes->{{3.575612332283169*^9, 3.575612453547675*^9}, {
  3.575612665774852*^9, 
  3.575612781279853*^9}},ExpressionUUID->"b46c7b0c-9c72-4060-819f-\
