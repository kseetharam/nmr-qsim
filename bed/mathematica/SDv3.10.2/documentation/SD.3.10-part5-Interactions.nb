Cell[TextData[{
 "The Larmor frequency of a nuclide in a given magnetic field is generated by \
",
 StyleBox["LarmorFrequency[",
  FontWeight->"Bold"],
 StyleBox["nuclide",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 StyleBox[", ",
  FontWeight->"Bold"],
 StyleBox["field [in Tesla]",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 StyleBox["]. ",
  FontWeight->"Bold"],
 "The result is returned in units of rad\[NonBreakingSpace]",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["s", 
    RowBox[{"-", "1"}]], TraditionalForm]],ExpressionUUID->
  "094dec0c-b1de-4a31-b0cd-5331e0204171"],
 ", including the sign. The Larmor frequency in Hz is generated by division \
by 2\[Pi]:"
}], "Text",
