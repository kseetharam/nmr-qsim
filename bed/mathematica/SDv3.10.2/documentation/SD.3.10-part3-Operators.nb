Cell[TextData[{
 "If a number is used for the axis specification, an axis in the xy-plane is \
implied. This is represented in ",
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 " as a sandwich of rotations about orthogonal axes:"
}], "Text",
