Cell[CellGroupData[{

Cell["SingleTransitionOperator", "Subsection",
 CellChangeTimes->{{3.546623484483712*^9, 3.54662349185001*^9}, {
   3.5466243022386007`*^9, 3.5466243057329206`*^9}, {3.546624672045741*^9, 
   3.546624673644374*^9}, 3.547018031544866*^9, {3.547023953049498*^9, 
   3.54702395347169*^9}, {3.547029340428948*^9, 3.547029344857666*^9}, {
   3.5474893495090857`*^9, 3.547489349995867*^9}, {3.547490045970718*^9, 
   3.547490075824801*^9}, {3.547575629546226*^9, 3.547575633952305*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"d5fb1795-3f61-48e6-906d-c06a94888c31"],

Cell[TextData[{
 "A single transition operator (also known as a fictitious spin-1/2 operator) \
refer to operators involving only 2 states in a multistate system. The \
classic references to single transition operators are S. Vega, J. Chem. Phys. \
",
 StyleBox["68",
  FontWeight->"Bold"],
 ", 5518-55127 (1978) and A. Wokaun and R. R. Ernst, J. Chem. Phys. ",
 StyleBox["67",
  FontWeight->"Bold"],
 ", 1752-1758 (1977)."
}], "Text",
 CellChangeTimes->{{3.547575639072649*^9, 3.547575803587484*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"8233cb83-4803-44a9-8d21-6c7439fa5452"],

Cell[TextData[{
 "For example, the operator ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["I", "x", 
    RowBox[{"(", "rs", ")"}]], TraditionalForm]],ExpressionUUID->
  "137e8342-2685-4a9b-b1f7-1b3792b602c2"],
 "is defined as ",
 Cell[BoxData[
  FormBox[
   FractionBox["1", "2"], TraditionalForm]],ExpressionUUID->
  "8a712d4e-9976-45e7-9446-e55984671ca3"],
 "(|",
 StyleBox["r",
  FontSlant->"Italic"],
 "><",
 StyleBox["s",
  FontSlant->"Italic"],
 "|+|",
 StyleBox["r",
  FontSlant->"Italic"],
 "><",
 StyleBox["s",
  FontSlant->"Italic"],
 "|). "
}], "Text",
 CellChangeTimes->{{3.547576211911515*^9, 3.547576261742261*^9}, {
  3.5475763051046658`*^9, 3.547576373408552*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"40aca761-7cf3-4178-a40f-638b0ca0c722"],

Cell[TextData[{
 "In ",
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 ", single operators may be written in the form \
SingleTransitionOperator[{ketr,kets},\[Mu]], where \[Mu] can be \
\[OpenCurlyDoubleQuote]x\[CloseCurlyDoubleQuote], \[OpenCurlyDoubleQuote]y\
\[CloseCurlyDoubleQuote], \[OpenCurlyDoubleQuote]z\[CloseCurlyDoubleQuote], \
\[OpenCurlyDoubleQuote]+\[OpenCurlyDoubleQuote] or \[OpenCurlyDoubleQuote]-\
\[OpenCurlyDoubleQuote]. "
}], "Text",
 CellChangeTimes->{{3.547576386474664*^9, 3.547576451568564*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"6f3ae890-7057-47aa-a3dc-773031b3b63d"],

Cell["\<\
The following example defines a x-single-transition operator between the \
singlet state and the central triplet state in a 2-spin-1/2 system:\
\>", "Text",
 CellChangeTimes->{{3.7583570516604857`*^9, 3.758357089753083*^9}, {
  3.758357178259191*^9, 
  3.758357179776964*^9}},ExpressionUUID->"495d5b98-8397-4723-b6c3-\
7e1a61a0a055"],

