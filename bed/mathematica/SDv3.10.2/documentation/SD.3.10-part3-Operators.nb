Cell["\<\
a set of basis kets, ordered as in the SpinDynamics book, may be generated as \
follows:\
\>", "Text",
 CellChangeTimes->{{3.6342029246208887`*^9, 
  3.634202953847983*^9}},ExpressionUUID->"deae45dc-88b9-4c05-ae40-\
6a119179ff35"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ReorderedKets", "=", 
  RowBox[{"Flatten", "@", 
   RowBox[{"Outer", "[", 
    RowBox[{"ProductKet", ",", 
     RowBox[{"Sequence", "@@", 
      RowBox[{"Map", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"BasisKets", "[", 
          RowBox[{"ZeemanBasis", "[", 
           RowBox[{"{", "#", "}"}], "]"}], "]"}], "&"}], ",", 
        RowBox[{"SpinSystem", "[", "]"}]}], "]"}]}]}], "]"}]}]}]], "Input",
