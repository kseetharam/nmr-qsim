Cell[TextData[{
 "The spherical tensor content of any operator may be derived by applying ",
 StyleBox["SphericalTensorIndices",
  FontWeight->"Bold"],
 ". The example below shows that in a 3-spin-1/2 system, the operator ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["I", 
    RowBox[{"1", "z"}]], TraditionalForm]],ExpressionUUID->
  "d5c63209-22ed-40e9-8679-d54d2c26a4e7"],
