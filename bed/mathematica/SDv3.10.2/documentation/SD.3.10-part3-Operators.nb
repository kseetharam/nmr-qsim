  3.574271950930069*^9, 3.583691082931636*^9, 3.5880729615632567`*^9, 
  3.6149268297009*^9, 3.6167580039923687`*^9, 3.621613854368021*^9, 
  3.657793511031625*^9, 3.709551589190051*^9, 3.718535086409673*^9, 
