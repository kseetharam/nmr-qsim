Cell[TextData[{
 "BasisTransformationMatrix remembers prior evaluations, saving computational \
time (at the expense of memory). In the example below, the basis \
transformation matrix is evaluated once for a rather complex operator, and \
the timing reported using ",
 StyleBox["Timing",
  FontWeight->"Bold"],
 ". The second evaluation is much faster. "
}], "Text",
 CellChangeTimes->{{3.547530941603049*^9, 3.547531032119336*^9}, {
   3.5475312810641203`*^9, 3.547531284046936*^9}, {3.547531414727553*^9, 
