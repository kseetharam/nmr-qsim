Cell["\<\
Note that only the zz terms remain between pairs of spins of different \
isotopic type.\
\>", "Text",
 CellChangeTimes->{{3.630585916259978*^9, 3.6305859417499*^9}, {
  3.630586731241442*^9, 3.630586735561536*^9}, {3.630656861842505*^9, 
  3.630656870988083*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"f0b89409-079e-421a-b9c2-53a73c616bdb"]
}, Open  ]],

Cell[CellGroupData[{

Cell[" Secularization using an arbitrary Hamiltonian", "Subsubsection",
 CellChangeTimes->{{3.630585998413261*^9, 3.630586028702196*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"54b8a1cc-85f1-4b7a-a3db-1679cdb35494"],

Cell[TextData[{
 "Secularization may also be performed using an arbitrary Hamiltonian. The \
syntax is ",
 StyleBox["Secularize[op,H0]",
  FontWeight->"Bold"],
 ". The routine expresses the operator ",
 StyleBox["op",
  FontWeight->"Bold"],
 " in the eigenbasis of the Hamiltonian ",
 StyleBox["H0",
  FontWeight->"Bold"],
 ", and then removes off-diagonal elements between non-degenerate eigenstates \
of ",
 StyleBox["H0.",
  FontWeight->"Bold"],
 " "
}], "Text",
 CellChangeTimes->{{3.630585946118877*^9, 3.630585982679777*^9}, {
  3.630586046287116*^9, 3.630586114532208*^9}, {3.630586177853979*^9, 
  3.630586194168524*^9}, {3.630586759464789*^9, 3.630586903930685*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"193ed446-2449-49cd-acc2-746a5520fd7c"],

Cell["\<\
 In the examples below, a scalar coupling interaction is secularized against \
a Zeeman interaction for two spins-1/2, using an explicit Zeeman Hamiltonian \
definition.\
\>", "Text",
 CellChangeTimes->{{3.630585946118877*^9, 3.630585982679777*^9}, {
  3.630586046287116*^9, 3.630586114532208*^9}, {3.630586177853979*^9, 
  3.630586194168524*^9}, {3.630586759464789*^9, 3.630586761950295*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"e51960bf-c250-49cd-9c9d-f09f5586b3d3"],

Cell["\<\
In the first case, the chemical shifts of the two spins are identical. \
Secularization has no effect in this case. This corresponds to magnetic \
equivalence.\
\>", "Text",
 CellChangeTimes->{{3.630586196884996*^9, 3.630586228353619*^9}, {
  3.6305869114168453`*^9, 3.630586917133588*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"1906070a-f792-4cd9-9370-71e59add8225"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SetSpinSystem", "[", "2", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Secularize", "[", 
  RowBox[{
   RowBox[{"2", "\[Pi]", " ", "10", " ", 
    RowBox[{
     RowBox[{"opI", "[", "1", "]"}], ".", 
     RowBox[{"opI", "[", "2", "]"}]}]}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"2", "\[Pi]", " ", "100", " ", 
     RowBox[{"opI", "[", 
      RowBox[{"1", ",", "\"\<z\>\""}], "]"}]}], "+", 
    RowBox[{"2", "\[Pi]", " ", "100", " ", 
     RowBox[{"opI", "[", 
      RowBox[{"2", ",", "\"\<z\>\""}], "]"}]}]}]}], "\[IndentingNewLine]", 
  "]"}]}], "Input",
