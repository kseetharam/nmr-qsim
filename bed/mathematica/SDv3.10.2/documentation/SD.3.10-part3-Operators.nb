Cell[TextData[{
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 " provides routines for defining and manipulating kets, bras, operators and \
Hilbert space bases. Specific routines for angular momentum operators, \
rotation operators, spherical tensor operators, single-transition operators, \
and spin-exchange operators are provided. "
}], "Text",
 CellChangeTimes->{{3.574272203212277*^9, 3.574272297327836*^9}, {
  3.7893115516565957`*^9, 
  3.789311552984474*^9}},ExpressionUUID->"fd113dda-c0bb-479f-97e9-\
4b7b3df240fb"],

Cell[CellGroupData[{

Cell["Setup", "Section",
 CellChangeTimes->{{3.5443597793686047`*^9, 3.544359783063039*^9}, {
  3.544548974396888*^9, 3.544548975857535*^9}, {3.574259751532483*^9, 
  3.5742597537390747`*^9}},ExpressionUUID->"4a7ebe81-074a-476c-b5aa-\
d40db295ba9b"],

Cell[TextData[{
 "The code in this notebook requires the installation and initialization of ",
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 ", as described in part 1 of the documentation"
}], "Text",
 CellChangeTimes->{{3.574259758883033*^9, 3.574259781441057*^9}, {
  3.574271269426249*^9, 
  3.57427128356705*^9}},ExpressionUUID->"430861e5-2f20-4849-9ca0-\
e53be7bad3c1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Needs", "[", "\"\<SpinDynamica`\>\"", "]"}], ";"}]], "Input",
 CellChangeTimes->{{3.574259784142119*^9, 3.574259799274408*^9}, {
  3.574271286079638*^9, 3.574271286543647*^9}},
 CellLabel->"In[26]:=",ExpressionUUID->"e540668f-c5d2-4e05-8cd8-bf941a8a4273"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Ket", "Section",
 CellChangeTimes->{{3.54435961135287*^9, 3.544359628871992*^9}, {
   3.544359721544903*^9, 3.54435977179224*^9}, {3.544371371929467*^9, 
   3.5443713742960377`*^9}, {3.546621551497593*^9, 3.546621558135754*^9}, 
   3.546621992694211*^9},
 Background->None,ExpressionUUID->"ae865ae0-4c7c-4599-9fe5-89871789ad27"],

Cell[TextData[{
 "The quantum mechanical ket |\[Psi]> describing the state of a nuclear spin \
system is defined using the symbol ",
 StyleBox["Ket",
  FontWeight->"Bold"],
 "."
}], "Text",
 CellChangeTimes->{{3.546621565515342*^9, 3.546621578478991*^9}, {
  3.5466216241115522`*^9, 
  3.546621662997705*^9}},ExpressionUUID->"8554cc31-b3e5-4629-b4be-\
9c0fa95cc110"],

Cell[TextData[{
 "The general syntax is Ket[{{",
 StyleBox["j",
  FontSlant->"Italic"],
 ",",
 Cell[BoxData[
  FormBox[
   SubscriptBox["M", "j"], TraditionalForm]],ExpressionUUID->
  "5389ec36-bf56-4cf0-87e0-87bb8d23a578"],
 "},{",
 StyleBox["k",
  FontSlant->"Italic"],
 ",",
 Cell[BoxData[
  FormBox[
   SubscriptBox["M", "k"], TraditionalForm]],ExpressionUUID->
  "b5981b65-9e37-4a89-88ea-a02ae739ec8b"],
 "}..}, ",
 StyleBox["spinsystem",
  FontSlant->"Italic"],
 "] where ",
 StyleBox["eigensystem",
  FontSlant->"Italic"],
 " has the syntax {{",
 StyleBox["j",
  FontSlant->"Italic"],
 ",",
 Cell[BoxData[
  FormBox[
   SubscriptBox["I", "j"], TraditionalForm]],ExpressionUUID->
  "26b77a0d-eda0-407f-bf67-e9aa3c594e07"],
 "},{",
 StyleBox["k",
  FontSlant->"Italic"],
 ",",
 Cell[BoxData[
  FormBox[
   SubscriptBox["I", "k"], TraditionalForm]],ExpressionUUID->
  "8fd2e679-8491-4745-bddd-b9456d27e09c"],
 "}..} and defines the labels for the spins ",
 StyleBox["{j,k,..} ",
  FontSlant->"Italic"],
 "and their angular momentum quantum numbers {",
 Cell[BoxData[
  FormBox[
   SubscriptBox["I", "j"], TraditionalForm]],ExpressionUUID->
  "53b85a08-0818-44a7-ab51-c311e6248752"],
 ",",
 Cell[BoxData[
  FormBox[
   SubscriptBox["I", "k"], TraditionalForm]],ExpressionUUID->
  "86985f90-5513-4b57-bbdb-645bc0f5e8cf"],
 "..}. If ",
 StyleBox["spinsystem",
  FontSlant->"Italic"],
 " is absent the current spin system is assumed. "
}], "Text",
 CellChangeTimes->{{3.546621665533702*^9, 3.546621911694927*^9}, 
   3.8971563772092953`*^9},ExpressionUUID->"0b36b065-9989-4656-8628-\
2c02c292cd42"],

Cell["\<\
There are various abbreviated forms for Ket which are explained below.\
\>", "Text",
 CellChangeTimes->{{3.546622926221671*^9, 
  3.54662293787664*^9}},ExpressionUUID->"b94fca5e-6308-49ff-b9d9-\
3e66ed365872"],

Cell[CellGroupData[{

Cell["single spin-1/2", "Subsection",
 CellChangeTimes->{{3.546622145292104*^9, 3.5466221510255404`*^9}, {
  3.5466229071018467`*^9, 3.5466229095177307`*^9}, {3.547014825474204*^9, 
  3.5470148301192493`*^9}},ExpressionUUID->"87bad31e-4bcd-42e9-8cd2-\
0b7a3bc2e5be"],

Cell[TextData[{
 "In the case of spin-1/2, the symbols \[Alpha] and \[Beta] denote ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["M", "j"], "=", 
    RowBox[{
     RowBox[{"\[PlusMinus]", "1"}], "/", "2."}]}], TraditionalForm]],
  ExpressionUUID->"1711a77c-cd53-4307-a624-74ea2f56ea7a"]
}], "Text",
 CellChangeTimes->{{3.546621936272396*^9, 3.54662197963421*^9}, 
   3.547014839382621*^9, {3.547016047995575*^9, 
   3.547016053039084*^9}},ExpressionUUID->"0d73f8d8-8f80-4679-9500-\
d1e252ecdc8b"],

Cell["For example, consider a single spin-1/2, with label 1: ", "Text",
