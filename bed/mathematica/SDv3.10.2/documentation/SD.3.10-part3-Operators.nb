Cell[CellGroupData[{

Cell["Irreducible spherical tensor operators: opT", "Subsection",
 CellChangeTimes->{{3.546623484483712*^9, 3.54662349185001*^9}, {
   3.5466243022386007`*^9, 3.5466243057329206`*^9}, {3.546624672045741*^9, 
   3.546624673644374*^9}, 3.547018031544866*^9, {3.547023953049498*^9, 
   3.54702395347169*^9}, {3.547029340428948*^9, 3.547029344857666*^9}, {
   3.5474893495090857`*^9, 3.547489349995867*^9}, {3.547490045970718*^9, 
   3.547490075824801*^9}, {3.5475770342828836`*^9, 3.547577036447612*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"e47cdfd0-24bf-4dbf-9254-957cb830c5e7"],

Cell["\<\
Irreducible spherical tensor operators (ISTOs) are widely used in magnetic \
resonance theory. They are sets of operators which span irreducible \
representations of the full rotation group. \
\>", "Text",
 CellChangeTimes->{{3.547531637669057*^9, 3.547531689151039*^9}, {
  3.547531788053895*^9, 3.547531798965916*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"5f96a2e5-efd1-4c86-8d29-6078d23a8bf9"],

Cell[TextData[{
 "In ",
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 ", the general syntax for a spherical tensor operator is ",
 StyleBox["opT[spins,{rank,component}]",
  FontWeight->"Bold"],
 ". If the argument ",
 StyleBox["spins",
  FontWeight->"Bold"],
 " is omitted, a sum is taken over all spins in the current ",
 StyleBox["SpinSystem",
  FontWeight->"Bold"],
 ". "
}], "Text",
 CellChangeTimes->{{3.547531694543215*^9, 3.5475317414665437`*^9}, {
  3.640698315240127*^9, 3.640698360119049*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"591ad508-c815-4a9f-8372-e50e4b78e687"],

Cell[CellGroupData[{

