Cell[TextData[{
 "The last line indicates that the operator ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["I", "y"], TraditionalForm]],ExpressionUUID->
  "7b15ee07-2c6b-4593-bb59-72292dd578a4"],
 " may be written as ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      FractionBox["3", "10"], ")"}], 
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["I", "x"], "+", 
       RowBox[{"3", 
        SubscriptBox["I", "y"]}]}], ")"}]}], " ", "+", " ", 
    RowBox[{"[", 
     RowBox[{"orthogonal", " ", "operators"}], "]"}]}], TraditionalForm]],
  ExpressionUUID->"d804f433-895e-442b-b521-24d312b840f2"],
 " - which is not obvious, but true!"
}], "Text",
 CellChangeTimes->{{3.547488783969225*^9, 3.5474888094699078`*^9}, {
  3.547488853736038*^9, 3.547488895360196*^9}, {3.547613880092442*^9, 
  3.547613887072841*^9}},ExpressionUUID->"dd23f4fa-2fe3-415b-883a-\
7d7fe4c3d94e"]
}, Open  ]],

