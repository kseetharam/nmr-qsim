782ea48276f1"],

Cell[TextData[{
 "The full functionality of ",
 StyleBox["ExpressOperator",
  FontWeight->"Bold"],
 " is described in part 4 of the documentation. Briefly, ",
 StyleBox["ExpressOperator",
  FontWeight->"Bold"],
 " can be used to write a given spin operator in terms of sets of defined \
operators. A particularly useful form is ",
 StyleBox["ExpressOperator[op,CartesianProductOperatorBasis[]]",
  FontWeight->"Bold"],
 " which writes a general operator as a set of Cartesian product operators. "
}], "Text",
 CellChangeTimes->{{3.5474887332798347`*^9, 3.547488774550622*^9}, {
   3.54748891715944*^9, 3.547488960756341*^9}, 
   3.5742719590443153`*^9},ExpressionUUID->"c239fcfe-11e3-43a1-9739-\
7e23f57453d4"],

Cell[TextData[{
 "The example below expresses the operator ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["I", "1", "+"], 
    SubsuperscriptBox["I", "2", "-"], 
    SubsuperscriptBox["I", "3", "+"]}], TraditionalForm]],ExpressionUUID->
  "fdaa0a8b-e1b9-4195-ae0b-02d0b9059bd6"],
 " as a superposition of Cartesian product operators:"
}], "Text",
 CellChangeTimes->{{3.547488968579781*^9, 3.547488970268971*^9}, {
  3.5474904307987833`*^9, 
  3.547490497536599*^9}},ExpressionUUID->"ceccca23-040a-46e2-a43e-\
70b2b8262950"],

