Cell[TextData[{
 "The default basis in ",
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 " is the ",
 StyleBox["ZeemanBasis",
  FontWeight->"Bold"],
 ". The general syntax is ",
 StyleBox["ZeemanBasis[spinsystem,options]",
  FontWeight->"Bold"],
 ". The set of rules ",
 StyleBox["options",
  FontSlant->"Italic"],
 " may contain a definition for ",
 StyleBox["BasisLabels",
  FontWeight->"Bold"],
 ". "
}], "Text",
 CellChangeTimes->{{3.5466234980974607`*^9, 3.546623606517234*^9}, 
   3.547017710156606*^9},ExpressionUUID->"1492cf5a-35b4-4119-872c-\
cb2516553908"],

