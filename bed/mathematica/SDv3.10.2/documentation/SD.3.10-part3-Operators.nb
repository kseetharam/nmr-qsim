Cell["\<\
We can specify that the ordering of the eigenbasis kets should be as close as \
possible to those of the SingletTripletBasis as follows:\
\>", "Text",
 CellChangeTimes->{
  3.75835680951267*^9, {3.7583568818058653`*^9, 
   3.758356907961125*^9}},ExpressionUUID->"69056af3-0693-4bce-8e00-\
c24866cd8582"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"DefineBasis", "[", 
  RowBox[{"basis", ",", "\[IndentingNewLine]", 
   RowBox[{"Eigenbasis", "[", 
    RowBox[{"H", ",", " ", 
     RowBox[{"TargetBasis", "\[Rule]", 
      RowBox[{"SingletTripletBasis", "[", "]"}]}]}], "]"}]}], 
  "\[IndentingNewLine]", "]"}]], "Input",
 CellChangeTimes->{{3.758356472904031*^9, 3.7583564797011433`*^9}, {
  3.758356523048471*^9, 3.758356534218863*^9}},
 CellLabel->
