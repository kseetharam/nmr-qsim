Cell[TextData[{
 "The basis used for ",
 StyleBox["NDiagonalize",
  FontWeight->"Bold"],
 " may be specified explicitly. Although the form of the matrices ",
 StyleBox["X",
  FontWeight->"Bold"],
 " and ",
 StyleBox["Xinv",
  FontWeight->"Bold"],
 " depend on the basis, the operator output of ",
 StyleBox["NDiagonalize",
  FontWeight->"Bold"],
 " is basis independent: "
}], "Text",
 CellChangeTimes->{{3.5868636116852427`*^9, 3.5868636522989893`*^9}, {
  3.586864033134171*^9, 3.586864041501548*^9}},
