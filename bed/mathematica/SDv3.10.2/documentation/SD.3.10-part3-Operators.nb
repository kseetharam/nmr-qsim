Cell[TextData[{
 "A population operator is defined as |",
 StyleBox["r",
  FontSlant->"Italic"],
 "><",
 StyleBox["r",
  FontSlant->"Italic"],
 "| where |",
 StyleBox["r",
  FontSlant->"Italic"],
 "> is a ket of a given basis. This is implemented in ",
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 " by PopulationOperator[r,",
 StyleBox["basis",
  FontSlant->"Italic"],
 "].  If ",
 StyleBox["basis",
  FontSlant->"Italic"],
 " is missing, the current basis is used. "
}], "Text",
 CellChangeTimes->{{3.547575639072649*^9, 3.547575803587484*^9}, {
  3.7583572281421437`*^9, 3.758357293752836*^9}, {3.758357356092925*^9, 
  3.758357392687059*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"ceee2162-d5ca-4c0e-8720-570e7940dc73"],

