Cell[TextData[{
 "A coherence operator is defined as |",
 StyleBox["r",
  FontSlant->"Italic"],
 "><",
 StyleBox["s",
  FontSlant->"Italic"],
 "| where |",
 StyleBox["r",
  FontSlant->"Italic"],
 "> and |",
 StyleBox["s",
  FontSlant->"Italic"],
 "> are kets of a given basis. This is implemented in ",
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 " by CoherenceOperator[{r,s},",
 StyleBox["basis",
  FontSlant->"Italic"],
 "]. If ",
 StyleBox["basis",
  FontSlant->"Italic"],
 " is missing, the current basis is used. "
}], "Text",
 CellChangeTimes->{{3.547575639072649*^9, 3.547575803587484*^9}, {
   3.7583572281421437`*^9, 3.758357293752836*^9}, 3.758357424179694*^9},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"494d4aa7-4585-4c6b-a94a-4f3b5cd0abaf"],

