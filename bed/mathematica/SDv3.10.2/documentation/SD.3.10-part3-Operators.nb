 RowBox[{
  RowBox[{"SetSpinSystem", "[", "2", "]"}], ";", 
  RowBox[{"ProductKet", "[", 
   RowBox[{
    RowBox[{"Ket", "[", 
     RowBox[{"\"\<\[Alpha]\>\"", ",", 
      RowBox[{"{", 
       RowBox[{"{", 
        RowBox[{"1", ",", 
         RowBox[{"1", "/", "2"}]}], "}"}], "}"}]}], "]"}], ",", 
    RowBox[{"Ket", "[", 
     RowBox[{"\"\<\[Beta]\>\"", ",", 
      RowBox[{"{", 
