Cell[TextData[{
 StyleBox["BasisTransformationMatrix[basis2,basis1] ",
  FontWeight->"Bold"],
 "provides the matrix which transforms the kets of basis1 into the kets of \
basis2. The output of ",
 StyleBox["BasisTransformationMatrix",
  FontWeight->"Bold"],
 " is a ",
 StyleBox["SparseArray",
  FontWeight->"Bold"],
 " which may be visualized using ",
 StyleBox["MatrixForm",
  FontWeight->"Bold"],
 "."
}], "Text",
 CellChangeTimes->{{3.547530684828831*^9, 3.547530735149652*^9}, {
  3.547530899575399*^9, 3.547530923664888*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"827f42a7-2ab7-4abb-89d6-ca36024b703e"],

