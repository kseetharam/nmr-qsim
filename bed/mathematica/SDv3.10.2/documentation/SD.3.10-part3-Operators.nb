 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"742d76e5-9154-4148-b3b7-6a5582e6f001"],

Cell[TextData[{
 "The lines below define the symbol ",
 StyleBox["op",
  FontWeight->"Bold"],
 " to be an operator with a defined 2\[Cross]2 matrix representation in the \
Zeeman basis, for a single spin-1/2:"
}], "Text",
 CellChangeTimes->{{3.547481464367172*^9, 3.547481516608315*^9}, {
   3.547481743431353*^9, 3.547481759248089*^9}, 3.547483576385385*^9},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"70e0b526-d2fd-4dab-87ed-3efc2000257a"],

