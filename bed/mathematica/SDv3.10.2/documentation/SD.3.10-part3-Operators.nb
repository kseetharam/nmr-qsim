  FormBox[
   SubscriptBox["I", 
    RowBox[{"3", "z"}]], TraditionalForm]],ExpressionUUID->
  "a161632e-2846-4c9e-af2e-8f834c16a9ec"],
 "contains spherical components with {rank,component} values {1,0} and {3,0}. "
}], "Text",
 CellChangeTimes->{{3.639289250045246*^9, 3.6392893636387777`*^9}, {
  3.639289398968322*^9, 3.6392894198381367`*^9}, {3.639291057505595*^9, 
