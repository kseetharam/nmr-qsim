Cell[CellGroupData[{

Cell["alternative Zeeman basis ordering", "Subsubsection",
 CellChangeTimes->{{3.6341966317997417`*^9, 3.634196647686926*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"de429a49-7698-4368-8165-784ecb39259b"],

Cell[TextData[{
 "The default ordering of the ZeemanBasis kets in ",
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 " differs slightly from that in the book \[OpenCurlyDoubleQuote]Spin \
Dynamics\[CloseCurlyDoubleQuote] and some other software packages such as \
SIMPSON and SPINEVOLUTION. A basis state ordering which is compatible with \
the \[OpenCurlyDoubleQuote]Spin Dynamics\[CloseCurlyDoubleQuote] book may be \
imposed by using ",
 StyleBox["DefineBasis",
  FontWeight->"Bold"],
 " (described below). "
}], "Text",
 CellChangeTimes->{{3.634196577971828*^9, 3.634196601281002*^9}, {
  3.634196660967641*^9, 3.634196767268875*^9}, {3.634203067013164*^9, 
  3.634203105900196*^9}},ExpressionUUID->"38c5bb6e-4ddc-44e9-ac8e-\
28db3d1afc45"]
}, Open  ]]
}, Open  ]],

