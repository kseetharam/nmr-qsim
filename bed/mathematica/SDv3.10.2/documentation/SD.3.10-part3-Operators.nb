Cell["\<\
Note that the non-secular second term in the operator has been removed.\
\>", "Text",
 CellChangeTimes->{{3.630587061628914*^9, 3.630587073907306*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"d17d2e34-d5d7-46da-b9ae-2b582d6a1cbd"],

Cell["\<\
In heteronuclear spin systems, it is often useful to secularize an operator \
by assuming a heteronuclear Zeeman interaction with very different Larmor \
frequencies for the two spin species. In the example below, a four-spin \
system is defined, with two I-spins and two S-spins. A set of coupling \
Hamiltonians is secularized with respect to these two groups of spins. \
\>", "Text",
 CellChangeTimes->{{3.630585684827426*^9, 3.630585775366746*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"fc887572-d453-4876-b0c2-6cf9e80b7346"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SetSpinSystem", "[", "4", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Ispins", "=", 
   RowBox[{"{", 
    RowBox[{"1", ",", "2"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Sspins", "=", 
   RowBox[{"{", 
    RowBox[{"3", ",", "4"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Secularize", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"2", "\[Pi]", " ", 
     SubscriptBox["J", "12"], " ", 
     RowBox[{
      RowBox[{"opI", "[", "1", "]"}], ".", 
      RowBox[{"opI", "[", "2", "]"}]}]}], "+", 
    RowBox[{"2", "\[Pi]", " ", 
     SubscriptBox["J", "13"], " ", 
     RowBox[{
      RowBox[{"opI", "[", "1", "]"}], ".", 
