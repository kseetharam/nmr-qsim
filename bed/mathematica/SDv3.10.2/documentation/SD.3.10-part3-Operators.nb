Cell[TextData[{
 "The matrix representation of an operator in a given basis is calculated \
using ",
 StyleBox["MatrixRepresentation",
  FontWeight->"Bold"],
 ". \nThe output of ",
 StyleBox["MatrixRepresentation",
  FontWeight->"Bold"],
 " is a ",
 StyleBox["SparseArray",
