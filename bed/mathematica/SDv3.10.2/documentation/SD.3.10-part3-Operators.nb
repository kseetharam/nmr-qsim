Cell[CellGroupData[{

Cell["TargetBasis", "Subsubsection",
 CellChangeTimes->{{3.75835631550354*^9, 3.758356318720566*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"06d599c3-97f0-4097-a3b9-fb6c92f773d0"],

Cell[TextData[{
 "The ordering of the kets in an eigenbasis may be controlled by using the \
TargetBasis option. Specifying TargetBasis\[Rule]",
 StyleBox["tbasis",
  FontSlant->"Italic"],
 " ensures that the kets of the eigenbasis are ordered so as to give a best \
possible match to the basis ",
 StyleBox["tbasis",
  FontSlant->"Italic"],
 ". "
}], "Text",
 CellChangeTimes->{{3.758356328363171*^9, 
  3.758356393681593*^9}},ExpressionUUID->"61139ec2-c1e1-4a0b-8eb4-\
7d8fe447ab97"],

Cell["\<\
For example, consider a 2-spin-1/2 system, with the Hamiltonian defined \
below: \
\>", "Text",
 CellChangeTimes->{{3.758356402727464*^9, 3.758356463545282*^9}, {
  3.758356796472729*^9, 
  3.758356806407934*^9}},ExpressionUUID->"e0a26910-4757-4a15-8277-\
94be8830dd63"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"SetSpinSystem", "[", "2", "]"}], "\[IndentingNewLine]", 
 RowBox[{"H", " ", "=", " ", 
  RowBox[{
   RowBox[{"2", "\[Pi]", " ", "100", " ", 
    RowBox[{
     RowBox[{"opI", "[", "1", "]"}], ".", 
     RowBox[{"opI", "[", "2", "]"}]}]}], "+", 
   RowBox[{"2", "\[Pi]", " ", "10", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"opI", "[", 
       RowBox[{"1", ",", "\"\<z\>\""}], "]"}], "-", 
      RowBox[{"opI", "[", 
       RowBox[{"2", ",", "\"\<z\>\""}], "]"}]}], ")"}]}]}]}]}], "Input",
 CellChangeTimes->{{3.758356465198998*^9, 3.758356514936371*^9}, {
