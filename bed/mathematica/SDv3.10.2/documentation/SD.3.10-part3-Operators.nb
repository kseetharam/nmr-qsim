}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"OperatorAmplitude", "[", 
  RowBox[{
   RowBox[{"opI", "[", "\"\<y\>\"", "]"}], "\[Rule]", 
   RowBox[{
    RowBox[{"opI", "[", "\"\<x\>\"", "]"}], "+", 
    RowBox[{"3", 
