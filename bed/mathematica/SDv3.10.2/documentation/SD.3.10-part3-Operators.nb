  1, 0.925, 0.925],ExpressionUUID->"a4bc72ef-ba02-4c1a-880f-72d60b5e10d7"],

Cell[CellGroupData[{

Cell["Zeeman secularization", "Subsubsection",
 CellChangeTimes->{{3.630585998413261*^9, 3.630586008646352*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"d567fb97-c816-413a-8329-e7650963c0f9"],

Cell["\<\
In the syntax below, the components of a coupling Hamiltonian that are \
non-secular with respect to a high-field Zeeman interaction, are removed. In \
this case it is assumed implicitly that all spins in the system are of the \
same isotopic type.\
\>", "Text",
 CellChangeTimes->{{3.630585534604411*^9, 3.630585581222332*^9}, {
  3.630586606759924*^9, 3.630586626931375*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"8fa0017b-08f8-4777-8c31-060e2fcf88c9"],

Cell[CellGroupData[{

Cell[BoxData[{
 StyleBox[
  RowBox[{
   RowBox[{"SetSpinSystem", "[", "2", "]"}], ";"}],
  FontWeight->"Bold"], "\[IndentingNewLine]", 
 RowBox[{"Secularize", "[", 
  RowBox[{
   RowBox[{"\[Omega]sec", " ", 
    RowBox[{
     RowBox[{"opI", "[", 
      RowBox[{"1", ",", "\"\<z\>\""}], "]"}], ".", 
     RowBox[{"opI", "[", 
      RowBox[{"2", ",", "\"\<z\>\""}], "]"}]}]}], "+", 
   RowBox[{"\[Omega]nonsec", " ", 
    RowBox[{
     RowBox[{"opI", "[", 
      RowBox[{"1", ",", "\"\<z\>\""}], "]"}], ".", 
     RowBox[{"opI", "[", 
      RowBox[{"2", ",", "\"\<x\>\""}], "]"}]}]}]}], " ", "]"}]}], "Input",
