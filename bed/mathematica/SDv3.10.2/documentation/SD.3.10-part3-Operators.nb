ec60ae99dbef"],

Cell[TextData[{
 "In ",
 StyleBox["SpinDynamica,",
  FontSlant->"Italic"],
 StyleBox[" ",
  FontWeight->"Bold"],
 "bases are sets of orthogonal kets, used to define the Hilbert space for \
spin dynamical calculations. There are several built-in bases, and it is also \
possible to define bases oneself."
}], "Text",
 CellChangeTimes->{{3.546623405210875*^9, 3.546623477707198*^9}, {
  3.547017211813644*^9, 3.547017231524936*^9}, {3.5742713890915403`*^9, 
