Cell[CellGroupData[{

Cell["OperatorAmplitude", "Subsection",
 CellChangeTimes->{{3.546623484483712*^9, 3.54662349185001*^9}, {
   3.5466243022386007`*^9, 3.5466243057329206`*^9}, {3.546624672045741*^9, 
   3.546624673644374*^9}, 3.547018031544866*^9, {3.547023953049498*^9, 
   3.54702395347169*^9}, {3.5474814250567408`*^9, 3.5474814259128036`*^9}, {
   3.547487990706607*^9, 3.547487991257677*^9}, {3.547488118655695*^9, 
   3.547488121799039*^9}, {3.547488177877768*^9, 
   3.547488180651355*^9}},ExpressionUUID->"c71fdb03-9a25-446a-a10b-\
6ed42c4034d5"],

Cell[TextData[{
 "OperatorAmplitude provides the answer to a question such as \
\[OpenCurlyDoubleQuote]how much of operator B is contained in operator A\
\[CloseCurlyDoubleQuote]. The general syntax for answering the question above \
is ",
 StyleBox["OperatorAmplitude[A\[Rule]B].",
  FontWeight->"Bold"]
}], "Text",
 CellChangeTimes->{{3.5474881852593403`*^9, 3.547488256760065*^9}, {
  3.614927047056628*^9, 
  3.6149270827949147`*^9}},ExpressionUUID->"38a03610-799e-40fb-9bd9-\
00cab889f959"],

Cell[TextData[{
 "Technically, if an operator A may be written as follows:\n\t",
 StyleBox["A = b\[Times]B + C\n",
  FontSlant->"Italic"],
 "where Tr",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SuperscriptBox["B", "\[Dagger]"], "C"}], "}"}], "=", "0"}], 
   TraditionalForm]],ExpressionUUID->"b9b1924b-b771-4e88-a751-5456176e5f9e"],
 ", then the number ",
 StyleBox["b",
  FontSlant->"Italic"],
 " is the result of ",
 StyleBox["OperatorAmplitude[A\[Rule]B]",
  FontWeight->"Bold"],
 ". We can say colloquially that operator A \[OpenCurlyDoubleQuote]contains\
\[CloseCurlyDoubleQuote] b ",
 StyleBox["\[Times]",
  FontSlant->"Italic"],
 " operator B."
}], "Text",
 CellMargins->{{60.800000000000004`, 10.}, {7., 7.}},
 CellChangeTimes->{{3.547490530193348*^9, 3.547490588593425*^9}, {
  3.547490628280912*^9, 3.547490676008299*^9}, {3.547490782512699*^9, 
  3.54749088130096*^9}, {3.614927100291668*^9, 
  3.614927139008147*^9}},ExpressionUUID->"88dc10a3-c8e2-4209-bc91-\
3be1f003af62"],

Cell[TextData[{
 "For example, the instructions below show that the coefficient of the shift \
operator ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["I", "-"], TraditionalForm]],ExpressionUUID->
  "0628ad39-6697-4ae6-b803-3ee789a6c4db"],
 "in the operator ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["I", "y"], TraditionalForm]],ExpressionUUID->
  "8fcd71b9-7793-4051-a3f4-9338b03e13f9"],
 " is ",
 StyleBox["i/2",
  FontSlant->"Italic"],
 ":"
}], "Text",
 CellChangeTimes->{{3.547488220873315*^9, 3.547488223136574*^9}, {
   3.5474882788752*^9, 3.547488339111692*^9}, 3.547488397659412*^9, {
   3.547488453488827*^9, 3.5474884580877857`*^9}, {3.547490584146353*^9, 
   3.547490593584728*^9}},ExpressionUUID->"fdd5ce26-225a-4d11-a52a-\
218abe3889eb"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"OperatorAmplitude", "[", 
  RowBox[{
   RowBox[{"opI", "[", "\"\<y\>\"", "]"}], "\[Rule]", 
   RowBox[{"opI", "[", "\"\<-\>\"", "]"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.547488348291438*^9, 3.547488365335674*^9}},
 CellLabel->
  "In[181]:=",ExpressionUUID->"805071b8-a1d0-40e7-ba3c-1330a0a82fd6"],

Cell[BoxData[
 FractionBox["\[ImaginaryI]", "2"]], "Output",
 CellChangeTimes->{{3.547488365974162*^9, 3.54748839373823*^9}, 
   3.5726320299998193`*^9, 3.57427195080936*^9, 3.583691082865807*^9, 
   3.588072961432507*^9, 3.614926829506521*^9, 3.616758003794269*^9, 
   3.621613854284373*^9, 3.657793494995321*^9, 3.709551589021342*^9, 
   3.718535086362124*^9, 3.728212565286864*^9, 3.728392563118829*^9, 
   3.728633486715717*^9, 3.789311960344027*^9, 3.816869265492822*^9, 
   3.8377826851953*^9, 3.897156361502076*^9, 3.949044400913683*^9, 
   3.9490540691478662`*^9},
 CellLabel->
  "Out[181]=",ExpressionUUID->"b77f18bc-9645-47e1-a47a-16082926fa9f"]
}, Open  ]],

Cell[TextData[{
 "This may be interpreted as saying that ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["I", "y"], TraditionalForm]],ExpressionUUID->
  "6ef394e5-988e-4ad8-8e09-01a28810cf18"],
 " contains (",
 StyleBox["i/2)",
  FontSlant->"Italic"],
 Cell[BoxData[
  FormBox[
   SuperscriptBox["I", "-"], TraditionalForm]],ExpressionUUID->
  "364195dc-eed6-4c90-8543-9a5ac345a641"],
 StyleBox[".",
  FontSlant->"Italic"]
}], "Text",
 CellChangeTimes->{{3.614927158283515*^9, 
  3.614927190782646*^9}},ExpressionUUID->"7cc71f60-ff40-49d8-86ce-\
6d8af70d39af"],

Cell[TextData[{
 "Similarly, the line below shows how much of the shift operator product ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["I", "1", "-"], TraditionalForm]],ExpressionUUID->
  "b76bf339-3d99-42d2-ac6b-7c0c79e84a38"],
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["I", "2", "+"], TraditionalForm]],ExpressionUUID->
  "6b3e6e2d-75b7-48c5-b3ef-341365478165"],
 " is contained in the Cartesian product operator ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", 
    SubscriptBox["I", 
     RowBox[{"1", "y"}]], 
    SubscriptBox["I", 
     RowBox[{"2", "y"}]]}], TraditionalForm]],ExpressionUUID->
  "b775c61d-545b-4ccf-a6de-fe5806c11e9d"],
 "."
}], "Text",
 CellChangeTimes->{{3.547488416722784*^9, 3.547488432544004*^9}, {
  3.547488480511471*^9, 3.5474885347241917`*^9}, {3.547488571660608*^9, 
  3.547488571660677*^9}, {3.547490950584089*^9, 
  3.547490982419515*^9}},ExpressionUUID->"551977f9-a28a-4861-93ee-\
2db32924ce47"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"OperatorAmplitude", "[", 
  RowBox[{
   RowBox[{"2", 
    RowBox[{
     RowBox[{"opI", "[", 
      RowBox[{"1", ",", "\"\<y\>\""}], "]"}], ".", 
     RowBox[{"opI", "[", 
      RowBox[{"2", ",", "\"\<y\>\""}], "]"}]}]}], "\[Rule]", 
   RowBox[{
    RowBox[{"opI", "[", 
     RowBox[{"1", ",", "\"\<-\>\""}], "]"}], ".", 
    RowBox[{"opI", "[", 
     RowBox[{"2", ",", "\"\<+\>\""}], "]"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.5474885419038887`*^9, 3.547488586187915*^9}},
 CellLabel->
  "In[182]:=",ExpressionUUID->"918b5d92-3ac0-4e2c-aea1-a90a3c6752ce"],

Cell[BoxData[
 FractionBox["1", "2"]], "Output",
 CellChangeTimes->{{3.547488551720837*^9, 3.5474885870824842`*^9}, 
   3.572632030099324*^9, 3.574271950892008*^9, 3.583691082894785*^9, 
   3.588072961527919*^9, 3.614926829640613*^9, 3.616758003912953*^9, 
   3.621613854301084*^9, 3.657793500135489*^9, 3.709551589138355*^9, 
   3.718535086378166*^9, 3.728212567897034*^9, 3.728392563143632*^9, 
   3.728633486733264*^9, 3.789311960382875*^9, 3.816869265554887*^9, 
   3.837782685227179*^9, 3.897156361552522*^9, 3.9490444009608793`*^9, 
   3.949054069152534*^9},
 CellLabel->
  "Out[182]=",ExpressionUUID->"2afcaf86-a724-4ad9-89e9-6a2690c767c8"]
}, Open  ]],

Cell["\<\
It is possible to calculate the amplitudes of several operators \
\[OpenCurlyDoubleQuote]contained inside\[CloseCurlyDoubleQuote] another \
operator at the same time, using the following syntax:\
\>", "Text",
 CellChangeTimes->{{3.614926699126377*^9, 3.614926752733943*^9}, {
  3.614926869085867*^9, 
  3.614926881752007*^9}},ExpressionUUID->"dd128e4d-7bab-43bd-bbf2-\
e3a2bd8a9b92"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"OperatorAmplitude", "[", 
  RowBox[{
   RowBox[{"opI", "[", 
    RowBox[{"1", ",", "\"\<y\>\""}], "]"}], "\[Rule]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"opI", "[", 
      RowBox[{"1", ",", "\"\<-\>\""}], "]"}], ",", 
     RowBox[{"opI", "[", 
      RowBox[{"1", ",", "\"\<+\>\""}], "]"}], ",", 
     RowBox[{"opI", "[", 
      RowBox[{"2", ",", "\"\<z\>\""}], "]"}]}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.547488348291438*^9, 3.547488365335674*^9}, {
  3.61492677827164*^9, 3.614926800659161*^9}, {3.614926954060297*^9, 
  3.614926962000249*^9}},
 CellLabel->
  "In[183]:=",ExpressionUUID->"0cca3c63-6d66-4bc6-865d-3ee5f7e8fa24"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox["\[ImaginaryI]", "2"], ",", 
   RowBox[{"-", 
    FractionBox["\[ImaginaryI]", "2"]}], ",", "0"}], "}"}]], "Output",
 CellChangeTimes->{{3.547488365974162*^9, 3.54748839373823*^9}, 
   3.5726320299998193`*^9, 3.57427195080936*^9, 3.583691082865807*^9, 
   3.588072961432507*^9, 3.614926829786681*^9, 3.614926962839861*^9, 
   3.616758003959723*^9, 3.6216138543346*^9, 3.657793504924122*^9, 
   3.7095515891513777`*^9, 3.718535086380673*^9, 3.728212570002085*^9, 
   3.728392563172634*^9, 3.728633486760437*^9, 3.78931196039473*^9, 
   3.816869265595638*^9, 3.8377826852603693`*^9, 3.897156361605379*^9, 
   3.9490444009689407`*^9, 3.949054069162459*^9},
 CellLabel->
  "Out[183]=",ExpressionUUID->"cf04d36f-145d-4da5-b10d-ad019a027e9c"]
}, Open  ]],

Cell[TextData[{
 "This means that the operator ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["I", 
    RowBox[{"1", "y"}]], TraditionalForm]],ExpressionUUID->
  "ef61b68c-3a29-4ab7-8eb0-37a829548407"],
 " \[OpenCurlyDoubleQuote]contains\[CloseCurlyDoubleQuote] (i/2)",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["I", "1", "-"], TraditionalForm]],ExpressionUUID->
  "2d7b2461-4db8-4b8c-9602-5b1181c4c6e6"],
 ", and also (-i/2)",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["I", "1", "-"], TraditionalForm]],ExpressionUUID->
  "ccb89d99-21ff-458c-a57c-e3c50b464b66"],
 ", but no ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["I", 
    RowBox[{"2", "z"}]], TraditionalForm]],ExpressionUUID->
  "296e570c-c133-4345-9b96-0a29c2044380"],
 "."
}], "Text",
 CellChangeTimes->{{3.614926896865891*^9, 3.614927009554386*^9}, 
   3.614927225545119*^9},ExpressionUUID->"2410709d-e121-454e-b216-\
7bf5e6465606"],

Cell["\<\
One must always be careful about the order of the operators in \
OperatorAmplitude. The opposite calculation gives a different result: \
\>", "Text",
 CellChangeTimes->{{3.547488597697365*^9, 
  3.5474886387284603`*^9}},ExpressionUUID->"f24317b2-c159-4262-83e1-\
479c4ae240b7"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"OperatorAmplitude", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"opI", "[", "\"\<x\>\"", "]"}], "+", 
    RowBox[{"3", 
     RowBox[{"opI", "[", "\"\<y\>\"", "]"}]}]}], "\[Rule]", 
   RowBox[{"opI", "[", "\"\<y\>\"", "]"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.547488643982419*^9, 3.54748866261094*^9}},
 CellLabel->
  "In[184]:=",ExpressionUUID->"85da3b0c-14be-414c-8de5-c22623a10bc2"],

