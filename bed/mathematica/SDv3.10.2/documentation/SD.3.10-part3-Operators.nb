Cell[TextData[{
 "A numerical threshold is used to determine whether two eigenvalues are \
degenerate or not. By default this is equal to ",
 StyleBox["$ChopThreshold",
  FontWeight->"Bold"],
 ", which is a very small number (see \[OpenCurlyDoubleQuote]global settings\
\[CloseCurlyDoubleQuote] in Part 1 of the documentation). Hence the default \
syntax ",
 StyleBox["Secularize[op,H0]",
  FontWeight->"Bold"],
 " essentially uses exact degeneracy as a secularization criterion. \n\
However, it is also possible to specify the degeneracy threshold using a \
third numerical argument for ",
 StyleBox["Secularize",
  FontWeight->"Bold"],
 ". The example below is the same as the one above, but using a large \
threshold of 200\[NonBreakingSpace]Hz for the degeneracy criterion. The \
removal of off-diagonal elements is thereby suppressed."
}], "Text",
 CellChangeTimes->{{3.630586290778126*^9, 3.630586565984457*^9}, {
  3.6305869324667997`*^9, 3.630587031453268*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"9d002ca0-b242-4b18-8f88-9aeb4c7820d8"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SetSpinSystem", "[", "2", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Secularize", "[", 
  RowBox[{
   RowBox[{"2", "\[Pi]", " ", "10", " ", 
    RowBox[{
     RowBox[{"opI", "[", "1", "]"}], ".", 
     RowBox[{"opI", "[", "2", "]"}]}]}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"2", "\[Pi]", " ", "100", " ", 
     RowBox[{"opI", "[", 
      RowBox[{"1", ",", "\"\<z\>\""}], "]"}]}], "-", 
    RowBox[{"2", "\[Pi]", " ", "100", " ", 
     RowBox[{"opI", "[", 
      RowBox[{"2", ",", "\"\<z\>\""}], "]"}]}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"2", "\[Pi]", " ", "200"}]}], "\[IndentingNewLine]", 
  "]"}]}], "Input",
 CellChangeTimes->{{3.630586117314494*^9, 3.630586166443419*^9}, 
   3.630586231284102*^9, 3.6305862682510247`*^9, {3.6305865336585827`*^9, 
