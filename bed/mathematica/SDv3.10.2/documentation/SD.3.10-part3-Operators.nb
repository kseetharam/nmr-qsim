Cell[TextData[{
 "Single-transition operators may also be generated by using the ",
 StyleBox["BasisLabels",
  FontWeight->"Bold"],
 " to define the states. The example below defines the single-transition \
x-operator between the states with labels 3 and 4 in the ZeemanBasis:"
}], "Text",
 CellChangeTimes->{{3.54757656610926*^9, 3.5475766409230976`*^9}, {
  3.547577568178622*^9, 3.547577624590684*^9}, {3.547577715141637*^9, 
  3.547577721852096*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"f8c54284-feed-4e2f-b7cd-e0193a3ec10c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"op", "=", 
   RowBox[{"SingleTransitionOperator", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"3", ",", "4"}], "}"}], ",", 
       RowBox[{"ZeemanBasis", "[", "]"}]}], "}"}], ",", "\"\<x\>\""}], 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"MatrixRepresentation", "[", "op", "]"}], "//", 
  "MatrixForm"}]}], "Input",
