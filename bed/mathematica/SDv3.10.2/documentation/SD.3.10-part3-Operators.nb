Cell[TextData[{
 StyleBox["NDiagonalize",
  FontWeight->"Bold"],
 " may be used to convert any operator into a form which is diagonalized in a \
specified basis (or in the current basis, by default). The output of ",
 StyleBox["NDiagonalize",
  FontWeight->"Bold"],
 " is a special form of ",
 StyleBox["Operator ",
  FontWeight->"Bold"],
 "which may be used just like any other operator. Certain routines run faster \
when operators have been pre-converted into a diagonalized form. "
}], "Text",
 CellChangeTimes->{{3.586862213480266*^9, 3.586862265428812*^9}, {
   3.58686231998557*^9, 3.586862390470214*^9}, {3.5868627775022497`*^9, 
   3.586862807892778*^9}, 3.8377831065041533`*^9},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"5599662a-fadc-435b-ad21-deacbfe954f1"],

