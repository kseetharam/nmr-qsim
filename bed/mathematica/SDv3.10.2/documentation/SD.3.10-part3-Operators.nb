Cell[CellGroupData[{

Cell["output of NDiagonalize", "Subsubsection",
 CellChangeTimes->{{3.586863559670701*^9, 3.58686357920504*^9}, {
  3.5868638969895678`*^9, 3.586863900725639*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"83ca794d-e55d-40d2-9c63-d3c17d8f1580"],

Cell[TextData[{
 "The output of ",
 StyleBox["NDiagonalize",
  FontWeight->"Bold"],
 ", when applied to an operator,  has the form ",
 StyleBox["Operator[{X,evals,Xinv}, basis...] ",
  FontWeight->"Bold"],
 "where ",
 StyleBox["evals",
  FontWeight->"Bold"],
 " is the vector of eigenvalues, ",
 StyleBox["X",
  FontWeight->"Bold"],
 " is a matrix whose columns are the eigenvectors of the matrix \
representation of the operator in the basis ",
 StyleBox["basis",
  FontWeight->"Bold"],
 ", and ",
 StyleBox["Xinv",
  FontWeight->"Bold"],
 " is the inverse of ",
 StyleBox["X",
  FontWeight->"Bold"],
 ". The elements ",
 StyleBox["{X,evals,Xinv}",
  FontWeight->"Bold"],
 " may be inspected by applying ",
 StyleBox["First",
  FontWeight->"Bold"],
 " to the output of ",
 StyleBox["NDiagonalize",
  FontWeight->"Bold"]
}], "Text",
 CellChangeTimes->{{3.586862410072285*^9, 3.586862507015058*^9}, {
  3.58686308322983*^9, 3.586863097074376*^9}, {3.586864193793495*^9, 
  3.586864208678784*^9}, {3.586864264857398*^9, 3.586864286255115*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"6cb1f9cb-0f04-43ca-84e9-7c4335b4d57f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"{", 
   RowBox[{"X", ",", "evals", ",", "Xinv"}], "}"}], "=", 
  RowBox[{"First", "[", "op", "]"}]}]], "Input",
