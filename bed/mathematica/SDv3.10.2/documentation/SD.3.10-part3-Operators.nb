Cell[TextData[{
 "The norm of an operator is the Frobenius norm of its matrix representation \
(square root of the sum of the square moduli of all matrix elements). ",
 StyleBox["OperatorNorm",
  FontWeight->"Bold"],
 " evaluates the norm of an operator,  in the current basis. "
}], "Text",
