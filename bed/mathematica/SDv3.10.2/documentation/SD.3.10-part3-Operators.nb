Cell[TextData[{
 StyleBox["Secularize",
  FontWeight->"Bold"],
 " removes non-secular components of an operator, defined according to \
various criteria."
}], "Text",
 CellChangeTimes->{{3.547577069030706*^9, 3.5475770833581457`*^9}, {
  3.630585454394038*^9, 3.630585529355701*^9}, {3.630586582906356*^9, 
