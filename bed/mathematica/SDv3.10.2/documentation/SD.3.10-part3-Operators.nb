 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"cf2c470d-c39c-4622-9e20-894b8f712f40"],

Cell[TextData[{
 "A general way of defining an operator in ",
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 " is to use the routine ",
 StyleBox["Operator",
  FontWeight->"Bold"],
 " together with the matrix representation in a certain basis. "
}], "Text",
 CellChangeTimes->{{3.547481427968403*^9, 3.547481457175408*^9}, {
  3.547490325016986*^9, 3.54749035498428*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"3a2eedc9-2002-4006-8173-02967a8d8a4d"],

Cell["\<\
An operator defined this way is basis-independent. The stored information may \
be used to derive the matrix representation of the operator in any desired \
basis. \
\>", "Text",
 CellChangeTimes->{{3.547490288941255*^9, 3.5474903072921886`*^9}, {
  3.5474903519604483`*^9, 3.547490360278167*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"4c9d0803-d0e9-410a-a873-d977de8729d1"],

