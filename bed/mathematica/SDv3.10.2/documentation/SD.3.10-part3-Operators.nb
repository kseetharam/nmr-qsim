  1, 0.925, 0.925],ExpressionUUID->"0dfdd6a0-a0dc-4210-84ce-9071fd28863c"],

Cell[TextData[{
 "A single spin ",
 StyleBox["I ",
  FontSlant->"Italic"],
 "can support an ISTOs with ranks from 0 up to ",
 StyleBox["2I",
  FontSlant->"Italic"],
 StyleBox[".",
  FontWeight->"Bold",
  FontSlant->"Italic"]
}], "Text",
 CellChangeTimes->{{3.547531746411751*^9, 3.547531801961059*^9}, {
