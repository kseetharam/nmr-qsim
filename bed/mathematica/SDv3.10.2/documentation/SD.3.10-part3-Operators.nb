Cell[TextData[{
 "The vector representation of a Ket or a Bra in a given basis is calculated \
using ",
 StyleBox["VectorRepresentation",
  FontWeight->"Bold"],
 ". \nThe output of ",
 StyleBox["VectorRepresentation",
  FontWeight->"Bold"],
 " is a ",
 StyleBox["SparseArray",
  FontWeight->"Bold"],
 ". "
}], "Text",
