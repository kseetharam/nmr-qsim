Cell["\<\
SpinPermutationOperator is the operator for a permutation of spins. The \
general syntax is SpinPermutationOperator[{j,k,l,..m}] which indicates a \
cyclic permutation of spins, i.e. j\[Rule]k, k\[Rule]l, .., m\[Rule]j. \
\>", "Text",
 CellChangeTimes->{{3.547576801229944*^9, 3.547576846662156*^9}, {
  3.590670143392371*^9, 3.590670252225925*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"c0e8c3cf-8783-4ead-95da-38763f3cb4e4"],

