Cell[CellGroupData[{

Cell[TextData[StyleBox["Molecular point groups to spin permutation groups",
 FontWeight->"Bold"]], "Subsubsection",
 CellChangeTimes->{{3.588074747297937*^9, 3.58807475427406*^9}, 
   3.681107655503767*^9, {3.681108144544858*^9, 3.6811081457025437`*^9}, {
   3.728222855607125*^9, 3.72822285863028*^9}, {3.852186464306465*^9, 
   3.8521864668422637`*^9}, {3.852199377000857*^9, 3.852199379919329*^9}, {
   3.852199428603524*^9, 3.852199428852949*^9}, {3.8522001733718586`*^9, 
   3.8522001849139867`*^9}},ExpressionUUID->"f043528f-74cd-4db1-b160-\
afc9b7315014"],

Cell[TextData[{
 StyleBox["SpinPermutationGroup",
  FontWeight->"Bold"],
 " also supports the use of molecular points groups, which are automatically \
translated into their spin permutation group analog (this is always possible \
by virtue of Cayley\[CloseCurlyQuote]s theorem).\n\nFor example the molecular \
point group ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["C", 
    RowBox[{"3", "v"}]], TraditionalForm]],ExpressionUUID->
  "28035bb1-72c6-48f7-a0a5-caa70ab67ff0"],
 " (Schoenflies notation) is really the same group as ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "3"], TraditionalForm]],ExpressionUUID->
  "25fd58d1-5718-454a-9b1d-8c0d86a1aaf9"],
 " (the two groups are isomorphic). So instead of using the group ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "3"], TraditionalForm]],ExpressionUUID->
  "b37aca5b-19ff-42f3-bdf0-b7ee428556ab"],
 " ",
 StyleBox["SpinPermutationGroup",
  FontWeight->"Bold"],
 " also allows to work with molecular point groups. Unfortunately ",
 StyleBox["Mathematica ",
  FontSlant->"Italic"],
 "does not support Schoenflies notation, instead the information of the \
molecular point group ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["C", 
    RowBox[{"3", "v"}]], TraditionalForm]],ExpressionUUID->
  "dd32250a-aa07-45c8-8a9e-994c16e1624c"],
 " is accessed under the {\[OpenCurlyDoubleQuote]CrystallographicPointGroup\
\[CloseCurlyDoubleQuote] 18}, which indicates that ",
 StyleBox["Mathematica ",
  FontSlant->"Italic"],
 "simply enumerates all the 32 fundamental point groups."
}], "Text",
 CellChangeTimes->{{3.728220896380918*^9, 3.728221063488654*^9}, {
   3.7282211222267337`*^9, 3.728221130577482*^9}, {3.7282211686435347`*^9, 
