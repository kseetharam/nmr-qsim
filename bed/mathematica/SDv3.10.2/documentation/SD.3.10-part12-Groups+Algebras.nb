Cell[TextData[{
 "Given a set of operators ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    SubscriptBox["Q", "1"]}], TraditionalForm]],ExpressionUUID->
  "f9449877-4629-4007-ac61-7e346042f210"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["Q", "2"], TraditionalForm]],ExpressionUUID->
  "d706d9cd-d193-4b8f-bb08-602a2d3c640a"],
 ", ...} the ",
 StyleBox["Bicommutant ",
  FontWeight->"Bold"],
 "routine calculates the commutant of the commutant of the operators ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    SubscriptBox["Q", "1"]}], TraditionalForm]],ExpressionUUID->
  "02c25520-9485-4863-afc6-ac17d93ee153"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["Q", "2"], TraditionalForm]],ExpressionUUID->
  "12199f70-82d7-4c86-bfaf-2300c259f938"],
 ", ...} , in example ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["C", "2"], TraditionalForm]],ExpressionUUID->
  "7de4b878-eebb-4b9d-b33b-10a7ef6e7a5e"],
 "(",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    SubscriptBox["Q", "1"]}], TraditionalForm]],ExpressionUUID->
  "582e2f0b-76dd-41d9-8f5b-7efca7ed3727"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["Q", "2"], TraditionalForm]],ExpressionUUID->
  "df6749b1-b103-4f01-a118-c9af170c0b91"],
 ", ...} )=C(C(",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    SubscriptBox["Q", "1"]}], TraditionalForm]],ExpressionUUID->
  "a4994ffc-a092-4489-a7fb-090b3bb5f52c"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["Q", "2"], TraditionalForm]],ExpressionUUID->
  "20fc3b14-050f-4074-b352-d5d9a6601caf"],
 ", ...})).",
 StyleBox[" The general syntax is given by:\n\nBic",
  FontWeight->"Bold"],
 StyleBox["ommutant[",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    SubscriptBox["Q", "1"]}], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"26c38032-0f61-4506-9b4f-f6db1c086231"],
 StyleBox[", ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   SubscriptBox["Q", "2"], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"b62690d9-a4d6-46f0-ac62-751edc11d946"],
 StyleBox[", ...}, opts]",
  FontWeight->"Bold"],
 StyleBox["\n\n",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   RowBox[{"where", " ", 
    RowBox[{"{", 
     SubscriptBox["Q", "1"]}]}], TraditionalForm]],
  FontWeight->"Plain",ExpressionUUID->
  "a2e0d7de-c3e7-4781-8542-e8f6df289fc8"],
 StyleBox[", ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   SubscriptBox["Q", "2"], TraditionalForm]],
  FontWeight->"Plain",ExpressionUUID->
  "cbac708a-1ac2-4843-a7ba-996fdac88335"],
 StyleBox[", ...} ",
  FontWeight->"Bold"],
 "refers to the initial set of operators and opts to any additional options. ",
 StyleBox["\n\n",
  FontWeight->"Bold"],
 "The ",
 StyleBox["Bicommutant",
  FontWeight->"Bold"],
 " routine is particularly useful for the calculation of long-lived spin \
states of a permutation symmetric spin-relaxation process."
}], "Text",
