Cell[TextData[{
 "The results above indicate that ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["I", 
    RowBox[{"1", "y"}]], TraditionalForm]],ExpressionUUID->
  "da2d0295-d3a1-4fbd-a5dd-41a36af5e239"],
 " (viewed on its own) is accessible from ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["I", 
     RowBox[{"1", "z"}]], "+", 
    SubscriptBox["I", 
     RowBox[{"2", "z"}]]}], TraditionalForm]],ExpressionUUID->
  "c4f5e476-b96b-4633-ae75-c9195523c9f5"],
 " under a Hamiltonian proportional to ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["I", 
     RowBox[{"1", "x"}]], "+", 
    SubscriptBox["I", 
     RowBox[{"2", "x"}]]}], TraditionalForm]],ExpressionUUID->
  "3c9dc7ab-1246-495b-b7bf-323bdf186b94"],
 ". The anti-symmetric combination ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["I", 
     RowBox[{"1", "y"}]], "-", 
    SubscriptBox["I", 
     RowBox[{"2", "y"}]]}], TraditionalForm]],ExpressionUUID->
  "b9d820fb-f70b-451c-9818-d0753beef98f"],
 " however is inaccessible from the symmetric operator ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["I", 
     RowBox[{"1", "z"}]], "+", 
    SubscriptBox["I", 
     RowBox[{"2", "z"}]]}], TraditionalForm]],ExpressionUUID->
  "af2f51d7-cdfb-486d-969d-be2b90740254"],
 " under symmetric evolution generated by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["I", 
     RowBox[{"1", "x"}]], "+", 
    SubscriptBox["I", 
     RowBox[{"2", "x"}]]}], TraditionalForm]],ExpressionUUID->
  "92298f22-0ff8-4ab8-9e37-387e0014bb18"],
 ". "
}], "Text",
 CellChangeTimes->{{3.728220896380918*^9, 3.728221063488654*^9}, {
