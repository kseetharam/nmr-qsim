Cell[TextData[{
 "The irreducible representation ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalD]", "1"], TraditionalForm]],ExpressionUUID->
  "f09a00eb-4e5d-4383-b66b-fde0dd03d796"],
 " is uniquely associated with Young-Tableau (2,0), whereas the irreducible \
representation ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalD]", "0"], TraditionalForm]],ExpressionUUID->
  "e3387db8-9b66-4d72-bb9b-23e1e14b29d6"],
 " is uniquely associated with Young-Tableau (1,1). We may thus identify the \
Young-Tableau (2,0) with the symmetric representation g, and the \
Young-Tableau (1,1) with the anti-symmetric representation u."
}], "Text",
 CellChangeTimes->{{3.728220896380918*^9, 3.728221063488654*^9}, {
