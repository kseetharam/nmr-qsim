9111c5f18fee"],

Cell[TextData[{
 "Omitting any arguments for ",
 StyleBox["SymmetryAdaptedBasis",
  FontWeight->"Bold"],
 " will always default to a symmetry-adapted basis for the symmetric group \
taking all active spins into account:"
}], "Text",
 CellChangeTimes->{{3.728220896380918*^9, 3.728221063488654*^9}, {
   3.7282211222267337`*^9, 3.728221130577482*^9}, {3.7282211686435347`*^9, 
