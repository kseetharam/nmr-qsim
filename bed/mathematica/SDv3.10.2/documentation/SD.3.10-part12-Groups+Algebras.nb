Cell[TextData[{
 "The anti-symmetric combination ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["I", 
     RowBox[{"1", "y"}]], "-", 
    SubscriptBox["I", 
     RowBox[{"2", "y"}]]}], TraditionalForm]],ExpressionUUID->
  "6d5846b7-33b0-4f9d-a5d7-8c2b51a83dac"],
 " however becomes accessible under symmetric evolution if the initial state \
is also anti-symmetric."
}], "Text",
 CellChangeTimes->{{3.728220896380918*^9, 3.728221063488654*^9}, {
