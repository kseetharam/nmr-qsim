 RowBox[{"SetSpinSystem", "[", "1", "]"}]], "Input",
 CellChangeTimes->{{3.681107956465792*^9, 3.681107972619151*^9}, {
   3.681108259242586*^9, 3.681108300339578*^9}, {3.72822902224256*^9, 
