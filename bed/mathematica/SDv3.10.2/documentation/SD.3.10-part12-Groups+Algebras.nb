Cell[CellGroupData[{

Cell[TextData[StyleBox["examples",
 FontWeight->"Bold"]], "Subsubsection",
 CellChangeTimes->{{3.588074747297937*^9, 3.58807475427406*^9}, 
   3.681107655503767*^9, {3.681108144544858*^9, 3.6811081457025437`*^9}, {
   3.728222855607125*^9, 3.72822285863028*^9}, {3.852186464306465*^9, 
   3.8521864668422637`*^9}, {3.852193965900177*^9, 3.8521939668995667`*^9}, {
   3.8522000668830233`*^9, 3.852200078151818*^9}, 3.852901234970566*^9, {
   3.8529013517387743`*^9, 3.852901353571132*^9}, {3.8529034960378633`*^9, 
   3.8529034971468773`*^9}},ExpressionUUID->"ca1e760a-d917-4994-bf5f-\
44a9a78b1279"],

Cell[TextData[{
 "Given a set of operators ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    SubscriptBox["Q", "1"]}], TraditionalForm]],ExpressionUUID->
  "8633dab2-5f78-4065-ab8c-a7d3a94f6e03"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["Q", "2"], TraditionalForm]],ExpressionUUID->
  "f00be9dd-cb7b-40c6-976e-28bad9dfb020"],
 ", ...} the ",
 StyleBox["Commutant ",
  FontWeight->"Bold"],
 "routine returns the commutant C(",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    SubscriptBox["Q", "1"]}], TraditionalForm]],ExpressionUUID->
  "51213390-df61-4bb5-89fc-67b721764157"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["Q", "2"], TraditionalForm]],ExpressionUUID->
  "5a9fce6b-599b-49a7-973c-5c7cb0ebd5bc"],
 ", ...}). Elements of C(",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    SubscriptBox["Q", "1"]}], TraditionalForm]],ExpressionUUID->
  "ac717f39-d869-4971-bfa8-0b3f390bb186"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["Q", "2"], TraditionalForm]],ExpressionUUID->
  "9333531b-a54a-41bd-978e-7d5a983b00a6"],
 ", ...}) commute with every element in ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    SubscriptBox["Q", "1"]}], TraditionalForm]],ExpressionUUID->
  "cec7ca0d-1e47-4895-9ac5-59b484b7bd90"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["Q", "2"], TraditionalForm]],ExpressionUUID->
  "646defbc-8a4d-403f-9998-7d4c7f00e1d6"],
 ", ...}. If the operators ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    SubscriptBox["Q", "1"]}], TraditionalForm]],ExpressionUUID->
  "8e629f5f-ccf9-414b-bf9a-108b26b14502"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["Q", "2"], TraditionalForm]],ExpressionUUID->
  "5c354c76-a845-4ca4-a579-dfe611e49125"],
 ", ...} represent a decomposition of the Hamiltonian, the operators C(",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    SubscriptBox["Q", "1"]}], TraditionalForm]],ExpressionUUID->
  "5a6efd75-6e5a-441c-af97-ebaa604113c9"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["Q", "2"], TraditionalForm]],ExpressionUUID->
  "a1e1ded1-be1a-49da-89d3-f2a10e6fb99c"],
 ", ...}) represent the constants of motion, in example the time-invariant \
spin density operator components. The general syntax is given by:\n\n",
 StyleBox["Commutant[",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    SubscriptBox["Q", "1"]}], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"137f57ed-56df-4a9b-ae9b-4da6fab8c8b8"],
 StyleBox[", ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   SubscriptBox["Q", "2"], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"83583845-5554-4c93-a1c7-e96861639aff"],
 StyleBox[", ...}, opts]",
  FontWeight->"Bold"],
 "\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{"where", " ", 
    RowBox[{"{", 
     SubscriptBox["Q", "1"]}]}], TraditionalForm]],
  FontWeight->"Plain",ExpressionUUID->
  "5a215fd0-eafe-46d6-9cc7-9c3d5ee5e0fa"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["Q", "2"], TraditionalForm]],
  FontWeight->"Plain",ExpressionUUID->
  "6dfff2a0-2029-4922-82b8-b6d403948d29"],
 ", ...} refers to the initial set of operators and opts to any additional \
options. \n\nConsider for example a strongly coupled spin-1/2 system, the \
corresponding Hamiltonian is generated by the following set of operators "
}], "Text",
 CellChangeTimes->{{3.728220896380918*^9, 3.728221063488654*^9}, {
