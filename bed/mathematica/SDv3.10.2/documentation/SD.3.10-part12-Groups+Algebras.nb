Cell[TextData[{
 "An operator is ",
 StyleBox["G",
  FontSlant->"Italic"],
 "-symmetric if it commutes with all element of the group ",
 StyleBox["G",
  FontSlant->"Italic"],
 ". For the group ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "3"], TraditionalForm]],ExpressionUUID->
  "dba990d9-646a-49a6-802c-95772ad21a98"],
 " this means",
 StyleBox["\n\n",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   SuperscriptBox["Q", "*"], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"47e3d009-19dc-4e29-8074-a431c4e06d92"],
 StyleBox[" \[DoubleLeftRightArrow] [",
  FontWeight->"Bold"],
 StyleBox["p",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 StyleBox[" , ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox["Q", TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"0cbdc152-1451-4188-836a-219956371df7"],
 StyleBox["] = 0 \[ForAll] ",
  FontWeight->"Bold"],
 StyleBox["p",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 StyleBox[" \[Element] ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "3"], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"a49252c5-022c-4ea5-8c12-fffd36bd489c"],
 "\n\nWe use a star to indicate the invariance under a given group. "
}], "Text",
