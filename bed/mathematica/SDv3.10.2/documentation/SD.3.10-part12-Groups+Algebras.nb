Cell[TextData[{
 "The routine ",
 StyleBox["DualPairing ",
  FontWeight->"Bold"],
 "may be used to calculate irreducible representation pairings of the \
symmetric group ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "N"], TraditionalForm]],ExpressionUUID->
  "36a5ac59-51df-468a-9d0a-ff4d3b61be6c"],
 " and",
 StyleBox[" ",
  FontWeight->"Bold"],
 "SO(3) considered as a subgroup of  ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    RowBox[{"[", 
     RowBox[{"SU", "(", 
      RowBox[{
       RowBox[{"2", "I"}], "+", "1"}], ")"}], "]"}], 
    RowBox[{"\[CircleTimes]", "N"}]], TraditionalForm]],ExpressionUUID->
  "0bf121b1-1a48-4941-b949-54909deff29a"],
 ". The irreducible representations of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "N"], TraditionalForm]],ExpressionUUID->
  "453d3643-4ec2-4b40-b5bb-d59118b28665"],
 " are represented by their corresponding Young-Tableau, the irreducible \
representations of SO(3) are labelled according to their total angular \
momentum value ",
 StyleBox["I.",
  FontSlant->"Italic"]
}], "Text",
 CellChangeTimes->{{3.728220896380918*^9, 3.728221063488654*^9}, {
