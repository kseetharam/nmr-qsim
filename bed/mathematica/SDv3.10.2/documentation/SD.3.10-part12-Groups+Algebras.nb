Cell[TextData[{
 "Our method is based on the work of Hermann Jahn (see ",
 StyleBox["https://doi.org/10.1098/rspa.1950.0076) by iteratively building up \
the dual-pairings.",
  CodeAssistOptions->{"AutoDetectHyperlinks"->False}]
}], "Text",
