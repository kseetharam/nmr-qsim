Cell[TextData[StyleBox["InaccesibleOperatorQ",
 FontWeight->"Bold"]], "Subsection",
 CellChangeTimes->{{3.588074747297937*^9, 3.58807475427406*^9}, 
   3.681107655503767*^9, {3.681108144544858*^9, 3.6811081457025437`*^9}, {
