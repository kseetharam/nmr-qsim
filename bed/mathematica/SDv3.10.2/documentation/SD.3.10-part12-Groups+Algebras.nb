   3.7282294120074787`*^9, 3.728229417559917*^9}, {3.7282303594705896`*^9, 
   3.728230434903668*^9}, {3.728230485980367*^9, 3.728230543135809*^9}, {
   3.7282309201428328`*^9, 3.7282309210407505`*^9}, 3.728288104927692*^9, {
   3.8521925058492513`*^9, 3.852192596464199*^9}, {3.852192634097455*^9, 
   3.852192634359012*^9}, {3.852192987699496*^9, 3.852193044092457*^9}, {
