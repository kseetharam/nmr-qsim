Cell[TextData[{
 "A verification that this spin permutation group is indeed equivalent to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "3"], TraditionalForm]],ExpressionUUID->
  "e8c15ddd-1f2e-4ac2-8fc5-7206e3b7c0b9"],
 " may be found in the section about ",
 StyleBox["SpinPermutationGroupElements",
  FontWeight->"Bold"],
 StyleBox[".",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 "\n\nA list of all supported molecular point groups (and more) may be found \
under by executing \[OpenCurlyDoubleQuote]FiniteGroupData[]\
\[CloseCurlyDoubleQuote]."
}], "Text",
