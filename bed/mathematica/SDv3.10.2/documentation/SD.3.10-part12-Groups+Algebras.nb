   3.852194221449384*^9}, {3.8521942849777355`*^9, 3.8521942962580347`*^9}, {
   3.8521943263127995`*^9, 3.852194561311738*^9}, {3.852194669407348*^9, 
   3.852194675126835*^9}, {3.852194741557253*^9, 3.852194892549411*^9}, {
   3.8521949248218307`*^9, 3.8521949481479487`*^9}, {3.8521998284229736`*^9, 
   3.852199889435523*^9}, {3.852199957107192*^9, 3.852200002467275*^9}, 
   3.852200203482871*^9, {3.85287619859599*^9, 3.852876203094891*^9}, {
   3.852876955001315*^9, 3.852876970309342*^9}, {3.8528770307741523`*^9, 
   3.852877067682029*^9}, {3.852877100050228*^9, 3.8528771241379147`*^9}, {
   3.8528771691614447`*^9, 3.8528772799954753`*^9}, {3.8528774091012716`*^9, 
   3.852877519144457*^9}, 3.852877552347235*^9, {3.852877606879518*^9, 
   3.852877968722057*^9}, {3.852878005017574*^9, 3.852878056162317*^9}, {
   3.852878164329419*^9, 3.8528782210432816`*^9}, {3.852878261322253*^9, 
   3.852878276884858*^9}, {3.852878310297349*^9, 3.852878544872446*^9}, {
   3.852878676684327*^9, 3.8528787456159143`*^9}, {3.852888446973951*^9, 
   3.852888447118563*^9}, {3.852889629346108*^9, 3.85288965985179*^9}, {
