Cell[TextData[{
 "The result above shows that ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalD]", 
    RowBox[{"1", "/", "2"}]], TraditionalForm]],ExpressionUUID->
  "225d7092-bab9-4a4c-9682-b5bef805a42a"],
 " is uniquely associated with (2,1,0), which corresponds to ",
 StyleBox["E",
  FontSlant->"Italic"],
 ", and ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalD]", 
    RowBox[{"3", "/", "2"}]], TraditionalForm]],ExpressionUUID->
  "f31abef3-c106-4ea2-8a04-c28c1b712a1d"],
 StyleBox[" ",
  FontSlant->"Italic"],
 "is uniquely associated with (3,0,0), which correspond to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["A", "1"], TraditionalForm]],ExpressionUUID->
  "83901e36-6c35-4f97-b0f3-4c203c7a2dc1"],
 ". But what about ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["A", "2"], TraditionalForm]],ExpressionUUID->
  "fdbc1ad6-6770-492e-b131-3b7cf84c6a0f"],
 "? The ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["A", "2"], TraditionalForm]],ExpressionUUID->
  "b42607f1-f317-43f7-b72d-a2418d99f15b"],
 " irreducible representation represents spin-states which are totally \
anti-symmetry under ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "3"], TraditionalForm]],ExpressionUUID->
  "ae399f2a-5ed5-4c59-88f4-a200096ae85f"],
 ", however since there are only two elementary spins states \[Alpha] and \
\[Beta] for a spin-1/2, it is impossible to generate a function which is \
totally under symmetric under ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "3"], TraditionalForm]],ExpressionUUID->
  "8d6e3957-2a12-4a38-9687-8ae86e7370e4"],
 ", hence the irreducible representation ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["A", "2"], TraditionalForm]],ExpressionUUID->
  "a3f9050b-00c2-4a43-bb80-5469488e7e0d"],
 " is not supported by three identical spin-1/2 systems. \n\nThis suggests \
that at least three distinct spin states are required to generate the \
irreducible representation ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["A", "2"], TraditionalForm]],ExpressionUUID->
  "fc9615c8-8841-40ae-992e-648b3067abc1"],
 ", indeed this is the case as can be seen by considering the dual pairings \
of a three-spin-1 system:"
}], "Text",
 CellChangeTimes->{{3.728220896380918*^9, 3.728221063488654*^9}, {
