Cell[TextData[{
 "Assume for simplicity a fully symmetric three-spin-1/2 system, a rapidly \
rotating methyl group in solution for example. The symmetry of the \
three-spin-1/2 system may be described by the symmetric group ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "3"], TraditionalForm]],ExpressionUUID->
  "1fb55cc8-8437-4aef-a27f-6a5886b672ac"],
 ":"
}], "Text",
