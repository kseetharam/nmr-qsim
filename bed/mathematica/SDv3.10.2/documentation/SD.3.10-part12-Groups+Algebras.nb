40d02932042c"],

Cell[TextData[{
 "Starting from an initial set of ",
 StyleBox["commuting",
  FontVariations->{"Underline"->True}],
 " operators ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    SubscriptBox["A", "1"]}], TraditionalForm]],ExpressionUUID->
  "0a9eb88f-0eaa-47e0-9ec2-a1da686b7beb"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["A", "2"], TraditionalForm]],ExpressionUUID->
  "00828415-70f7-4853-ae5c-20483756498b"],
 ", ...} the ",
 StyleBox["AbelianLieAlgebra ",
  FontWeight->"Bold"],
 "routine extends the initial abelian set to a maximal abelian set with \
respect to some basis operators ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    SubscriptBox["B", "1"]}], TraditionalForm]],ExpressionUUID->
  "2fe4de3a-7eb9-4baa-8e1a-9a5acf451935"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["B", "2"], TraditionalForm]],ExpressionUUID->
  "c8974703-2248-4d80-93cd-726a5e3b5fdf"],
 ", ...}. The general syntax is given by:\n\n",
 StyleBox["AbelianLieAlgebra[",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"{", 
     SubscriptBox["A", "1"]}]}], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"57ccb72b-16d6-48d9-813f-83732d655359"],
 StyleBox[", ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   SubscriptBox["A", "2"], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"cb8f956a-4e67-4215-aa5e-a4b939b4aa16"],
 StyleBox[", ...}, ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    SubscriptBox["B", "1"]}], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"a3265528-090e-4f09-90bb-b08e9f9bd963"],
 StyleBox[", ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   SubscriptBox["B", "2"], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"b15a6ad4-263a-443d-be7f-e88e3358b539"],
 StyleBox[", ...}}, opts]\n\n",
  FontWeight->"Bold"],
 "The general syntax:",
 StyleBox["\n\nAbelianLieAlgebra[",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    SubscriptBox["A", "1"]}], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"8c315be8-3f0b-4d69-beb9-c7b214cd1f0d"],
 StyleBox[", ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   SubscriptBox["A", "2"], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"fc45806b-5633-451f-807c-84817565d25d"],
 StyleBox[", ...}, opts]\n\n",
  FontWeight->"Bold"],
 "extends the set ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    SubscriptBox["A", "1"]}], TraditionalForm]],ExpressionUUID->
  "cf826916-6e45-4ae5-bfde-de186cfac265"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["A", "2"], TraditionalForm]],ExpressionUUID->
  "ff3c083c-4873-4344-a2c0-75d785f31e77"],
 ", ...} to a maximal abelian subalgebra with respect to all of Liouville \
space."
}], "Text",
