   3.852183498642605*^9}, {3.852183538026187*^9, 3.852183538489395*^9}, {
   3.8521842443486505`*^9, 3.852184247123907*^9}, {3.8521859261899233`*^9, 
   3.85218614859033*^9}, {3.8521862200400743`*^9, 3.8521862206960087`*^9}, {
   3.852186267551491*^9, 3.8521862913972793`*^9}, {3.852186484753127*^9, 
   3.852186510161694*^9}, {3.852188484369107*^9, 3.852188716791542*^9}, {
   3.852188795446547*^9, 3.852188867069899*^9}, {3.852190842861116*^9, 
   3.8521908435493913`*^9}, {3.852192331682128*^9, 3.852192502312131*^9}, {
   3.852192845413659*^9, 3.852192944564212*^9}, {3.8521930324036064`*^9, 
   3.852193124803052*^9}, {3.852193612934735*^9, 3.8521937740146537`*^9}, {
