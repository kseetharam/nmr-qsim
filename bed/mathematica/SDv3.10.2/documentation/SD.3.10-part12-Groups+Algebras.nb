Cell[CellGroupData[{

Cell[TextData[StyleBox["SymmetryAdaptedBasis",
 FontWeight->"Bold"]], "Subsection",
 CellChangeTimes->{{3.588074747297937*^9, 3.58807475427406*^9}, 
   3.681107655503767*^9, {3.681108144544858*^9, 3.6811081457025437`*^9}, {
   3.728222855607125*^9, 3.72822285863028*^9}, {3.852186464306465*^9, 
   3.8521864668422637`*^9}, {3.852193965900177*^9, 3.8521939668995667`*^9}, {
   3.852293375008384*^9, 
   3.8522933782566395`*^9}},ExpressionUUID->"876202f2-ce3a-4485-8192-\
20365ad2e796"],

Cell[TextData[{
 "The symbol ",
 StyleBox["SymmetryAdaptedBasis ",
  FontWeight->"Bold"],
 "may be used to construct a set of basis kets that has been symmetrized with \
respect to a spin permutation group.\n\n",
 StyleBox["SymmetryAdaptedBasis",
  FontWeight->"Bold"],
 " currently provides special support for symmetric and cyclic groups. In \
this case the syntax takes the form:\n\n",
 StyleBox["SymmetryAdaptedBasis[{{spin1, I1}, {spin2 ,I2}, ...}, {\
\[OpenCurlyDoubleQuote]grouplabel\[CloseCurlyDoubleQuote], groupdegree}]\n\n",
  
  FontWeight->"Bold"],
 "Here, ",
 StyleBox["{spin1,I1}, {spin2,I2}",
  FontWeight->"Bold"],
 ",... refers to the spins of interest. The ",
 StyleBox["\[OpenCurlyDoubleQuote]grouplabel\[CloseCurlyDoubleQuote]",
  FontWeight->"Bold"],
 " refers to either \[OpenCurlyDoubleQuote]SymmetricGroup\
\[CloseCurlyDoubleQuote] or \[OpenCurlyDoubleQuote]CyclicGroup\
\[CloseCurlyDoubleQuote], note a string is expected.  The ",
 StyleBox["groupdegree",
  FontWeight->"Bold"],
 " is an integer referring to the degree of the group.\n\nFor arbitrary \
symmetry groups more information is required and the syntax takes the form:\n\
\n",
 StyleBox["SymmetryAdaptedBasis[{{spin1, I1}, {spin2 ,I2}, ...}, {{\
\[OpenCurlyDoubleQuote]grouplabel\[CloseCurlyDoubleQuote], \
groupdegree},Gops}]\n\n",
  FontWeight->"Bold"],
 "The",
 StyleBox[" grouplabel ",
  FontWeight->"Bold"],
 "is now a free string, and may be chosen by the user, but the ",
 StyleBox["groupdegree",
  FontWeight->"Bold"],
 " should match the number of spins. The additional input of",
 StyleBox[" Gops ",
  FontWeight->"Bold"],
 "refers to a list of the group operators. \n\nA short-hand syntax is \
possible if all the active spins are to be considered in the construction of \
a symmetry-adapted basis:\n\n",
 StyleBox["SymmetryAdaptedBasis[{\[OpenCurlyDoubleQuote]grouplabel\
\[CloseCurlyDoubleQuote], groupdegree}]",
  FontWeight->"Bold"],
 "\n",
 StyleBox["SymmetryAdaptedBasis[{{\[OpenCurlyDoubleQuote]grouplabel\
\[CloseCurlyDoubleQuote], groupdegree},Gops}]",
  FontWeight->"Bold"]
}], "Text",
 CellChangeTimes->{{3.728220896380918*^9, 3.728221063488654*^9}, {
   3.7282211222267337`*^9, 3.728221130577482*^9}, {3.7282211686435347`*^9, 
