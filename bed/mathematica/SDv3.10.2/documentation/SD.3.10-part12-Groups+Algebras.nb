Cell[CellGroupData[{

Cell[TextData[StyleBox["Schur-Weyl duality",
 FontWeight->"Bold"]], "Subsection",
 CellChangeTimes->{{3.588074747297937*^9, 3.58807475427406*^9}, 
   3.681107655503767*^9, {3.681108144544858*^9, 3.6811081457025437`*^9}, {
   3.728222855607125*^9, 3.72822285863028*^9}, {3.852186464306465*^9, 
   3.8521864668422637`*^9}, {3.852193965900177*^9, 3.8521939668995667`*^9}, {
