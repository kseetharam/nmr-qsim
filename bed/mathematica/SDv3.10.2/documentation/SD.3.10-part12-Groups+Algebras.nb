Cell[TextData[{
 "Consider the following question:\n\nWhat set of operators ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    SubscriptBox["F", "1"]}], TraditionalForm]],ExpressionUUID->
  "757c087f-fe56-41b6-84fe-ba27eda1b6c3"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["F", "2"], TraditionalForm]],ExpressionUUID->
  "bd2f87ee-01fa-4d90-8875-adbe13e35d87"],
 ", ...} is ",
 StyleBox["inaccessible",
  FontVariations->{"Underline"->True}],
 " from a given initial operator ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["Q", "i"], TraditionalForm]],ExpressionUUID->
  "bc059526-7f6b-4566-a1d6-191696627ae1"],
 " under Hamiltonian evolution described by the set of operators ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["H", "1"], ",", " ", 
     SubscriptBox["H", "2"]}]}], TraditionalForm]],ExpressionUUID->
  "2a08447a-28a6-46fc-9273-733206314d80"],
 ", ...}?\n\nThe answer to this question may be determined through the use of \
",
 StyleBox["InaccesibleQ ",
  FontWeight->"Bold"],
 "routine. The general syntax follows:\n\n",
 StyleBox["InaccessibleOperatorQ[",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   StyleBox[
    SubscriptBox["Q", "i"],
    FontWeight->"Bold"], TraditionalForm]],ExpressionUUID->
  "673b9359-beac-4204-9de4-dd839255f4d2"],
 " \[Rule] ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    SubscriptBox["F", "1"]}], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"9911c8c6-34ac-4f96-8d26-36821e6cd8a9"],
 StyleBox[", ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   SubscriptBox["F", "2"], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"6612f95c-0285-4728-91aa-6b3d0b7aaed0"],
 StyleBox[", ...},",
  FontWeight->"Bold"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["H", "1"], ",", " ", 
     SubscriptBox["H", "2"]}]}], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"3037e993-a25c-4c7f-966e-b218e1bd304c"],
 StyleBox[", ...}, opts]",
  FontWeight->"Bold"],
 "\n"
}], "Text",
