Cell[TextData[{
 "The spin permutation symmetry of the methyl group Hamiltonian is described \
by the symmetric group of degree 3 ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    SubscriptBox["S", "3"]}], TraditionalForm]],ExpressionUUID->
  "d42f3337-159c-4fc7-8d83-d5a95f6751aa"],
 "). This group ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "3"], TraditionalForm]],ExpressionUUID->
  "57613016-425d-47c5-bed3-ee5fd0ba3f3b"],
 " is isomorphic to the molecular point group ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["C", 
    RowBox[{"3", "v"}]], TraditionalForm]],ExpressionUUID->
  "37e561f9-7873-45b8-b8b6-47edfe5b95fd"],
 ", which may be used to describe the local molecular symmetry of a methyl \
group."
}], "Text",
 CellChangeTimes->{{3.728220896380918*^9, 3.728221063488654*^9}, {
