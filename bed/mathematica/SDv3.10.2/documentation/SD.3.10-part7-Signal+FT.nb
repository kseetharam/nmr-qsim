Cell[TextData[{
 "Note that Expand is not needed here: ",
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 " is programmed so that ListPlot \[OpenCurlyDoubleQuote]knows\
\[CloseCurlyDoubleQuote] to apply Expand without being told explicitly. "
}], "Text",
 CellChangeTimes->{{3.629276837432014*^9, 
  3.629276896455419*^9}},ExpressionUUID->"e9d906d8-1a4d-491e-9707-\
e7574b591966"],

Cell[TextData[{
 "By default, the time-domain data is subjected to a default value of ",
 StyleBox["LineBroadening",
  FontWeight->"Bold"],
 " so as to improve the presentation of the spectrum after \
FourierTransformation (see below). In addition small manipulations of the \
peak frequencies are performed (see ",
 StyleBox["DigitalFrequencyResolution",
  FontWeight->"Bold"],
 " below). If you need an accurate representation of the \
\[OpenCurlyDoubleQuote]pure\[CloseCurlyDoubleQuote] time-domain data, both of \
these options may be disabled as follows:"
}], "Text",
 CellChangeTimes->{{3.6292801774029837`*^9, 3.629280320174094*^9}, {
  3.6292808643280354`*^9, 3.629280864646922*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"5b0cc07c-e2d9-4f89-8726-f8b48ad9a7f3"],

