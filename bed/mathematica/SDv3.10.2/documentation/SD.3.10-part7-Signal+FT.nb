Cell[TextData[{
 "By default, the time-domain data is subjected to a default value of ",
 StyleBox["LineBroadening",
  FontWeight->"Bold"],
 " so as to improve the presentation of the spectrum after \
FourierTransformation. As in the frequency-domain case, ",
 StyleBox["LineBroadening",
  FontWeight->"Bold"],
 "\[Rule]",
 StyleBox["None",
  FontWeight->"Bold"],
 " may be used to suppress this. "
}], "Text",
 CellChangeTimes->{{3.6292801774029837`*^9, 3.629280320174094*^9}, {
  3.6292808643280354`*^9, 3.629280864646922*^9}, {3.629281097682993*^9, 
  3.629281135152633*^9}},ExpressionUUID->"5b502833-a167-442d-9b0d-\
6fddd3351d65"],

