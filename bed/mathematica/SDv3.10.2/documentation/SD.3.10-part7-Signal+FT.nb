Cell[CellGroupData[{

Cell["ZeroFill and LineBroadening", "Subsubsection",
 CellChangeTimes->{{3.629276618471558*^9, 3.629276627709407*^9}, {
  3.6292766920839653`*^9, 3.62927671535539*^9}, {3.629276942487337*^9, 
  3.6292769533652167`*^9}, {3.629277330867655*^9, 3.629277335547448*^9}, {
  3.6292774850572863`*^9, 3.629277495329228*^9}, {3.629278414265274*^9, 
  3.6292784169994287`*^9}, {3.629281441154294*^9, 
  3.62928144491993*^9}},ExpressionUUID->"cf06d3cb-2d2c-4161-8000-\
b0ada2b33e7f"],

Cell[TextData[{
 "The processing options ",
 StyleBox["ZeroFill",
  FontWeight->"Bold"],
 " and ",
 StyleBox["LineBroadening",
  FontWeight->"Bold"],
 " may be used on a time-domain signal in exactly the same way as for a \
frequency-domain signal (see above). "
}], "Text",
 CellChangeTimes->{{3.629281450273161*^9, 
  3.629281481071002*^9}},ExpressionUUID->"7325799e-ee16-46c2-886e-\
a0adaa282d73"],

Cell[TextData[{
 "The option ",
 StyleBox["DigitalFrequencyResolution",
  FontWeight->"Bold"],
 " has no effect in the case of a time-domain signal. "
}], "Text",
 CellChangeTimes->{{3.629281484400346*^9, 3.629281501365556*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"7a7700ed-9ae8-49f0-a3bf-21fe8c335940"]
}, Open  ]]
}, Open  ]]
}, Closed]],

