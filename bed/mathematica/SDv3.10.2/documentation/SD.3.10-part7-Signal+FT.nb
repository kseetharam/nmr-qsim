Cell[CellGroupData[{

Cell["multiplying Signal after FT", "Subsubsection",
 CellChangeTimes->{{3.629283502931065*^9, 
  3.629283519696984*^9}},ExpressionUUID->"7d439538-49cd-42a0-b05a-\
339448d0a1e3"],

Cell["\<\
The same manipulation may be done after FT: However in this case, a more \
complex syntax is needed, since the complex multiplication must only be \
performed on the signal amplitudes, and not upon the frequency coordinates:\
\>", "Text",
 CellChangeTimes->{{3.6292824870767803`*^9, 
  3.629282542634858*^9}},ExpressionUUID->"9dc69aa7-fbab-476a-9799-\
48698983fc6f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListPlot", "@", 
  RowBox[{"Re", "@", 
   RowBox[{"(", 
    RowBox[{"Map", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"1", ",", 
           RowBox[{"Exp", "[", 
            RowBox[{"I", " ", 
             RowBox[{"\[Pi]", "/", "4"}]}], "]"}]}], "}"}], "*", "#"}], ")"}],
        "&"}], ",", 
      RowBox[{"FT", "@", "sig"}]}], "]"}], ")"}]}]}]], "Input",
 CellChangeTimes->{{3.629282555338584*^9, 3.62928265528925*^9}},
 CellLabel->
  "In[108]:=",ExpressionUUID->"c0e2a0d5-9a16-46c4-809e-ad740165eb06"],

