Cell[TextData[{
 "The format is as follows:\n\t{LineShapeType,{ {",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "1"], TraditionalForm]],ExpressionUUID->
  "4be74536-8c18-4147-85d0-083221f7021b"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Omega]", "1"], TraditionalForm]],ExpressionUUID->
  "0104bcff-7d13-4caf-b1f0-8932a5e91309"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Lambda]", "1"], TraditionalForm]],ExpressionUUID->
  "375475d8-53f2-430a-962e-d88c65427260"],
 "}, {",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "2"], TraditionalForm]],ExpressionUUID->
  "0029a6c5-7ef5-42c7-af43-5be9981e48e2"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Omega]", "2"], TraditionalForm]],ExpressionUUID->
  "a08c3502-443a-40e7-9570-3496d954c6fc"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Lambda]", "2"], TraditionalForm]],ExpressionUUID->
  "bfd2f725-a4d4-4228-be17-28356be487f6"],
 "},..}}\nwhere LineShapeType is a String (here equal to \
\[OpenCurlyDoubleQuote]Lorentzian\[CloseCurlyDoubleQuote]), and each spectral \
peak is specified as a list of the form {",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "i"], TraditionalForm]],ExpressionUUID->
  "02a2ac9d-f4f8-453c-8138-edcdbca5fcc9"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Omega]", "i"], TraditionalForm]],ExpressionUUID->
  "291adc80-cbb1-4ff8-9e6f-736d42c2de11"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Lambda]", "i"], TraditionalForm]],ExpressionUUID->
  "fbaabb00-32b7-458e-b524-4986f7207365"],
 "}. \t\t"
}], "Text",
 CellChangeTimes->{{3.629276122707454*^9, 3.629276227528717*^9}, {
  3.629276259873251*^9, 3.62927630327877*^9}, {3.629276397980416*^9, 
  3.629276398708295*^9}, {3.629276434900563*^9, 
  3.629276508125381*^9}},ExpressionUUID->"da03ff2f-a60c-45ba-ab4c-\
17b3d1dce819"],

Cell[TextData[{
 "The amplitude ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "i"], TraditionalForm]],ExpressionUUID->
  "a3d675b9-39a0-4c79-8299-1a2f6a3c8a37"],
 " is, in general, a complex number; a real value generates an \
absorption-mode peak upon processing, while an imaginary value generates a \
dispersion-mode peak upon processing. "
}], "Text",
 CellChangeTimes->{{3.629276334279495*^9, 3.629276384548407*^9}, {
  3.629276431443224*^9, 3.62927643216322*^9}, {3.629276518620974*^9, 
  3.629276527856719*^9}},ExpressionUUID->"04ee65bd-3d10-489f-bb9d-\
fc58dbb100c1"],

Cell[TextData[{
 "The centre frequency of the peak ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Omega]", "i"], TraditionalForm]],ExpressionUUID->
  "ac02895f-efaf-4796-84b8-d3f1544aff5e"],
 " is specified in rad ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["s", 
     RowBox[{"-", "1"}]], "."}], TraditionalForm]],ExpressionUUID->
  "32383dcb-540e-4440-829d-228f1071920a"]
}], "Text",
 CellChangeTimes->{{3.629276392589992*^9, 3.629276415005436*^9}, {
  3.629276535079288*^9, 
  3.6292765358984613`*^9}},ExpressionUUID->"d44aa374-1b76-4590-8513-\
e1353c67c318"],

Cell[TextData[{
 "The width of the peak ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Lambda]", "i"], TraditionalForm]],ExpressionUUID->
  "c67c77a6-5296-451f-a58e-ed3bbc8477e1"],
 " is also specified in rad ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["s", 
     RowBox[{"-", "1"}]], "."}], TraditionalForm]],ExpressionUUID->
  "d0c4e192-581a-4bf8-af59-ff402de83f86"],
 " In the case of a Lorentzian peak, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Lambda]", "i"], TraditionalForm]],ExpressionUUID->
  "16091c6e-24c2-462d-bd9a-aa182bf73d55"],
 " is the half-width at half-height, in rad ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["s", 
     RowBox[{"-", "1"}]], "."}], TraditionalForm]],ExpressionUUID->
  "a9cd8ef0-5f4f-49e5-97ad-abefb11609fd"]
}], "Text",
 CellChangeTimes->{{3.629276418677434*^9, 3.629276424211151*^9}, {
  3.629276543148387*^9, 
  3.629276590524336*^9}},ExpressionUUID->"8725092a-2a21-4655-a3fa-\
649601845859"]
}, Open  ]],

