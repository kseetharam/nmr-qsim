Cell[CellGroupData[{

Cell["format of Signal (frequency domain)", "Subsubsection",
 CellChangeTimes->{{3.629276618471558*^9, 3.629276627709407*^9}, {
  3.629281275881401*^9, 
  3.629281278684915*^9}},ExpressionUUID->"a1dcba37-dbdf-4096-9947-\
a136754bb4d8"],

Cell[TextData[{
 "The first argument of ",
 StyleBox["Signal",
  FontWeight->"Bold"],
 " is given by the sampling specifications {tmin, tmax, \[Delta]t}, where \
tmin and tmax are the time-coordinates of the first and last data point, and \
\[Delta]t is the sampling interval (\[OpenCurlyDoubleQuote]dwell time\
\[CloseCurlyDoubleQuote])"
}], "Text",
 CellChangeTimes->{{3.62927599152557*^9, 
  3.629276047245263*^9}},ExpressionUUID->"ac7e5c3f-7868-495e-8024-\
7fa472f2b227"],

