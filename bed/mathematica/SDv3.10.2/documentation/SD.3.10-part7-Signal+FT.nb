Cell[TextData[{
 "In some cases, ",
 StyleBox["Signal1D",
  FontWeight->"Bold"],
 " will choose ",
 StyleBox["SignalCalculationMethod\[Rule]\[CloseCurlyDoubleQuote]Direct\
\[CloseCurlyDoubleQuote] ",
  FontWeight->"Bold"],
 "automatically (see Part 2 of the documentation). "
}], "Text",
