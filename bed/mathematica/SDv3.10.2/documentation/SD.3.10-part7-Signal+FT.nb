      RowBox[{
       RowBox[{"{", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"2", "\[Pi]", " ", "600"}], ",", " ", "128"}], "}"}], "}"}],
        ",", "H", ",", 
       RowBox[{"DigitalFrequencyResolution", "\[Rule]", "False"}], ",", 
       RowBox[{"ZeroFill", "\[Rule]", "8"}]}], "]"}]}]}], ",", 
   "\[IndentingNewLine]", 
