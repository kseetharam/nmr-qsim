7fc710e165bd"],

Cell[TextData[{
 "A time-domain ",
 StyleBox["Signal",
  FontWeight->"Bold"],
 " may be converted into the frequency domain using the Fourier transform \
operation ",
 StyleBox["FT. ",
  FontWeight->"Bold"],
 "The result is a set of {frequency, amplitude} pairs, where the frequency \
coordinates are here in Hz:"
}], "Text",
 CellChangeTimes->{{3.629276957909128*^9, 3.6292770528585377`*^9}, {
  3.629281331315809*^9, 
  3.629281342365288*^9}},ExpressionUUID->"85340b01-7432-4f40-8c4c-\
d0de95b11439"],

