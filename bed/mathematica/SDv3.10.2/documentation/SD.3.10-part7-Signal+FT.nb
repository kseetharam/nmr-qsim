Cell[CellGroupData[{

Cell["DigitalFrequencyResolution", "Subsubsection",
 CellChangeTimes->{{3.629276618471558*^9, 3.629276627709407*^9}, {
  3.6292766920839653`*^9, 3.62927671535539*^9}, {3.629276942487337*^9, 
  3.6292769533652167`*^9}, {3.629277330867655*^9, 3.629277335547448*^9}, {
  3.6292774850572863`*^9, 3.629277495329228*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"6be46840-55d9-4202-acbe-852a6eca81f6"],

Cell[TextData[{
 "When Signal is generated in the frequency domain (by using Signal1D with \
SignalCalculationMethod\[Rule]\[CloseCurlyDoubleQuote]Diagonalization\
\[CloseCurlyDoubleQuote] or \[OpenCurlyDoubleQuote]COMPUTE\
\[CloseCurlyDoubleQuote]), the peak frequencies ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Omega]", "i"], TraditionalForm]],ExpressionUUID->
  "c3f6b1d4-3ca3-4a30-9a7b-4829f7fba31f"],
 " are by default automatically \[OpenCurlyDoubleQuote]snapped\
\[CloseCurlyDoubleQuote] to the nearest digitization point in the frequency \
spectrum. This may be seen by plotting the data points on the spectrum: "
}], "Text",
 CellChangeTimes->{{3.629277500781794*^9, 3.629277633531947*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"8fe5bb47-cf04-4f34-acf3-c577b60e3cad"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"H", "=", 
   RowBox[{
    RowBox[{"2", "\[Pi]", " ", "100", " ", 
     RowBox[{"opI", "[", 
      RowBox[{"1", ",", "\"\<z\>\""}], "]"}]}], "+", 
    RowBox[{"2", "\[Pi]", " ", 
     RowBox[{"(", 
      RowBox[{"-", "150"}], ")"}], 
     RowBox[{"opI", "[", 
      RowBox[{"2", ",", "\"\<z\>\""}], "]"}]}], "+", 
    RowBox[{"2", "\[Pi]", " ", "50", " ", 
     RowBox[{
      RowBox[{"opI", "[", "1", "]"}], ".", 
      RowBox[{"opI", "[", "2", "]"}]}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"ListPlot", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Re", "@", 
    RowBox[{"FT", "@", 
     RowBox[{"Signal1D", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"2", "\[Pi]", " ", "600"}], ",", " ", "128"}], "}"}], "}"}],
        ",", "H"}], "]"}]}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotRange", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"50", ",", "150"}], "}"}], ",", "All"}], "}"}]}], ",", 
   RowBox[{"PlotMarkers", "->", "Automatic"}]}], "\[IndentingNewLine]", 
  "]"}]}], "Input",
 CellChangeTimes->{{3.62927582991022*^9, 3.629275907930793*^9}, {
