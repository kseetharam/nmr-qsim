Cell[TextData[{
 "In summary, the default options ",
 StyleBox["ZeroFill\[Rule]Automatic",
  FontWeight->"Bold"],
 " and ",
 StyleBox["DigitalFrequencyResolution\[Rule]Automatic",
  FontWeight->"Bold"],
 " give a good compromise between accuracy and computation speed. If higher \
accuracy is needed, ",
 StyleBox["ZeroFill",
  FontWeight->"Bold"],
 " may be set to a high value, and/or ",
 StyleBox["DigitalFrequencyResolution",
  FontWeight->"Bold"],
 " may be set to ",
 StyleBox["False",
  FontWeight->"Bold"],
 "."
}], "Text",
 CellChangeTimes->{{3.629278261380576*^9, 3.6292783913514433`*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"4ce3a0f9-a3d9-4740-982e-db846047680c"]
}, Open  ]],

Cell[CellGroupData[{

Cell["ZeroFill", "Subsubsection",
 CellChangeTimes->{{3.629276618471558*^9, 3.629276627709407*^9}, {
  3.6292766920839653`*^9, 3.62927671535539*^9}, {3.629276942487337*^9, 
  3.6292769533652167`*^9}, {3.629277330867655*^9, 3.629277335547448*^9}, {
  3.6292774850572863`*^9, 3.629277495329228*^9}, {3.629278414265274*^9, 
  3.6292784169994287`*^9}},ExpressionUUID->"1f87b32b-4f2a-4652-8a20-\
a004494be730"],

Cell[TextData[{
 "Zero-filling is a data processing procedure in which zeroes are appended to \
the data before Fourier transformation. This improves the digital frequency \
resolution of the resulting spectrum, at the expense of a modest increase in \
processing time. In ",
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 ", zero-filling is controlled with the option ",
 StyleBox["ZeroFill",
  FontWeight->"Bold"],
 ". "
}], "Text",
 CellChangeTimes->{{3.629278463935781*^9, 3.629278551363971*^9}, {
  3.629278592965413*^9, 
  3.629278612281492*^9}},ExpressionUUID->"a136ed17-3358-4a41-8083-\
adf472f920e0"],

Cell[TextData[{
 "If the time-domain data contains ",
 StyleBox["n",
  FontSlant->"Italic"],
 " complex points, the option ",
 StyleBox["ZeroFill\[Rule]z ",
  FontWeight->"Bold"],
 "appends ",
 StyleBox["(n-1)\[Times]z",
  FontSlant->"Italic"],
 " zeroes to the data before ",
 StyleBox["FT",
  FontWeight->"Bold"],
 ". Hence ",
 StyleBox["ZeroFill\[Rule]1",
  FontWeight->"Bold"],
 " does nothing and ",
 StyleBox["ZeroFill\[Rule]4",
  FontWeight->"Bold"],
 " multiplies the length of the data by 4."
}], "Text",
 CellChangeTimes->{{3.629278648011468*^9, 3.629278715623204*^9}, {
  3.629284532258636*^9, 
  3.629284558020836*^9}},ExpressionUUID->"924ac13b-861d-402f-a7b3-\
d55b6969480b"],

Cell[TextData[{
 "By default, ",
 StyleBox["Signal1D",
  FontWeight->"Bold"],
 " generates a ",
 StyleBox["Signal",
  FontWeight->"Bold"],
 " with the option ",
 StyleBox["ZeroFill\[Rule]Automatic",
  FontWeight->"Bold"],
 ". This is equivalent to ",
 StyleBox["ZeroFill\[Rule]2",
  FontWeight->"Bold"],
 ", appending the same number of zeroes as the length of the data, before \
Fourier transformation. "
}], "Text",
 CellChangeTimes->{{3.629278423352681*^9, 3.6292784605416718`*^9}, {
  3.629278572958537*^9, 3.629278637665266*^9}, {3.629278731721984*^9, 
  3.629278775109309*^9}},ExpressionUUID->"d26656d1-8eaa-4d84-9f6c-\
1b7e81723c5a"],

Cell[TextData[{
 "Zero-filling may be suppressed by specifying ",
 StyleBox["ZeroFill\[Rule]False",
  FontWeight->"Bold"]
}], "Text",
 CellChangeTimes->{{3.629278836446197*^9, 
  3.629278855395515*^9}},ExpressionUUID->"6f3dde36-3cbf-42f4-bfc9-\
a36d74a7d518"],

Cell["\<\
In the following simulation, zero-filling and DigitalFrequencyResolution are \
both suppressed. The resulting spectrum is not attractive:\
\>", "Text",
 CellChangeTimes->{{3.629277500781794*^9, 3.629277633531947*^9}, {
  3.6292787800058126`*^9, 3.6292788049167*^9}, {3.629278858102104*^9, 
  3.6292788963944893`*^9}, {3.629284603319695*^9, 
  3.629284606628038*^9}},ExpressionUUID->"1fd51fe0-59c8-4ddf-a4ac-\
0c43eb9126f0"],

