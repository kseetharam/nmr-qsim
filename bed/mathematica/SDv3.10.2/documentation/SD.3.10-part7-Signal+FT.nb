Cell[TextData[{
 "The option ",
 StyleBox["DigitalFrequencyResolution",
  FontWeight->"Bold"],
 ", on the other hand, must be executed at the time of ",
 StyleBox["Signal1D",
  FontWeight->"Bold"],
 ". "
}], "Text",
 CellChangeTimes->{{3.629280719506715*^9, 3.6292807413943167`*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"00a1e99c-d41d-48f4-8da4-7de3852d6c29"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Signal as a time-domain object", "Subsection",
 CellChangeTimes->{{3.588074747297937*^9, 3.58807475427406*^9}, {
  3.629275315634701*^9, 
  3.629275342031214*^9}},ExpressionUUID->"2420501b-22c6-4e3b-ad26-\
5f0646333a82"],

Cell[TextData[{
 "In the following simulation, ",
 StyleBox["Signal1D",
  FontWeight->"Bold"],
 " is used with the explicit option ",
 StyleBox["SignalCalculationMethod\[Rule]\[CloseCurlyDoubleQuote]Direct\
\[CloseCurlyDoubleQuote]",
  FontWeight->"Bold"],
 ". In this case, the result is a ",
 StyleBox["Signal",
  FontWeight->"Bold"],
 " object, in the time-domain format."
}], "Text",
 CellChangeTimes->{{3.629275733031224*^9, 3.629275825827037*^9}, {
  3.6292759874977913`*^9, 3.629275988510665*^9}, {3.629277394518138*^9, 
  3.6292773962583513`*^9}, {3.629280903503418*^9, 
  3.6292809425249047`*^9}},ExpressionUUID->"0a7ed5bb-8ce4-48df-bb32-\
1ed71b1d4750"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"H", "=", 
   RowBox[{
    RowBox[{"2", "\[Pi]", " ", "100", " ", 
     RowBox[{"opI", "[", 
      RowBox[{"1", ",", "\"\<z\>\""}], "]"}]}], "+", 
    RowBox[{"2", "\[Pi]", " ", 
     RowBox[{"(", 
      RowBox[{"-", "150"}], ")"}], 
     RowBox[{"opI", "[", 
      RowBox[{"2", ",", "\"\<z\>\""}], "]"}]}], "+", 
    RowBox[{"2", "\[Pi]", " ", "50", " ", 
     RowBox[{
      RowBox[{"opI", "[", "1", "]"}], ".", 
      RowBox[{"opI", "[", "2", "]"}]}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"sig", "=", 
  RowBox[{"Signal1D", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"2", "\[Pi]", " ", "600"}], ",", " ", "128"}], "}"}], "}"}], 
    ",", "H", ",", 
    RowBox[{"SignalCalculationMethod", "\[Rule]", "\"\<Direct\>\""}]}], 
   "]"}]}]}], "Input",
 CellChangeTimes->{{3.62927582991022*^9, 3.629275907930793*^9}, {
  3.62927666371328*^9, 3.6292766639828463`*^9}, {3.629280946529152*^9, 
  3.629280952998663*^9}},
 CellLabel->"In[62]:=",ExpressionUUID->"ccbf19c8-60e2-41e1-a24c-0617a7ece19a"],

