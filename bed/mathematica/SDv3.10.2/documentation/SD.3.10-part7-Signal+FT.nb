Cell[CellGroupData[{

Cell["combining Signal objects", "Subsection",
 CellChangeTimes->{{3.588074747297937*^9, 3.58807475427406*^9}, {
  3.629275315634701*^9, 3.629275342031214*^9}, {3.629283881161835*^9, 
  3.629283886758902*^9}},ExpressionUUID->"c0a5822c-4869-41f5-97cf-\
bf47c5107593"],

Cell[TextData[{
 "Two or more Signal objects may be combined together using ",
 StyleBox["CombineData.",
  FontWeight->"Bold"],
 " The general syntax is:\n\t",
 StyleBox["CombineData[{sig1,sig2..},{w1,w2..}]",
  FontWeight->"Bold"],
 "\nwhere {w1,w2..} are weighting factors. \nThe result is formally sig = \
sig1*w1 + sig2*w2 +..."
}], "Text",
 CellChangeTimes->{{3.629283888951074*^9, 3.629284009844107*^9}, 
   3.629284403685051*^9},ExpressionUUID->"84f59a10-e3b5-4b92-a009-\
90633a160222"],

Cell["If the weights are omitted, uniform weighting is assumed. ", "Text",
 CellChangeTimes->{{3.629283923451455*^9, 3.629283926025179*^9}, {
  3.629284012735276*^9, 
  3.6292840284667892`*^9}},ExpressionUUID->"2530d8dd-6ade-475d-ba1a-\
4df186946446"],

Cell["\<\
In the example below, two simulations are performed, with different spin \
Hamiltonians:\
\>", "Text",
 CellChangeTimes->{{3.629284031620897*^9, 
  3.629284081770146*^9}},ExpressionUUID->"38b62179-7a9f-4b46-81a0-\
2c821aeb44b6"],

