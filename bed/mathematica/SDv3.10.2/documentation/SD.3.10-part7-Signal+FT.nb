Cell[CellGroupData[{

Cell["Signal", "Section",
 CellChangeTimes->{{3.575611915027603*^9, 3.575611926367559*^9}, {
  3.575613134956509*^9, 3.575613135881061*^9}, {3.5880743881239867`*^9, 
  3.588074393316068*^9}, {3.629275150014858*^9, 
  3.6292751509164762`*^9}},ExpressionUUID->"96b7f0f4-11c2-4b50-8ac7-\
17db407bf866"],

Cell[TextData[{
 "The output of ",
 StyleBox["Signal1D",
  FontWeight->"Bold"],
 " is a ",
 StyleBox["Signal",
  FontWeight->"Bold"],
 " object. This is not just a set of times and signal amplitudes, but a \
software object which contains the information needed for the signal \
processing and plotting. "
}], "Text",
 CellChangeTimes->{{3.629275171833329*^9, 3.629275292560647*^9}, {
  3.629281573993197*^9, 
  3.629281590852054*^9}},ExpressionUUID->"30c2a16a-7ac2-4004-a521-\
53c9a6bd6cf9"],

Cell[TextData[{
 "The ",
 StyleBox["Signal",
  FontWeight->"Bold"],
 " object may either contain frequency-domain information, or time-domain \
information. The choice depends upon the algorithm used by ",
 StyleBox["Signal1D",
  FontWeight->"Bold"],
 ". If ",
 StyleBox["Signal1D",
  FontWeight->"Bold"],
 " is run with the option ",
 StyleBox["SignalCalculationMethod\[Rule]\[CloseCurlyDoubleQuote]\
Diagonalization\[CloseCurlyDoubleQuote]",
  FontWeight->"Bold"],
 " or ",
 StyleBox["SignalCalculationMethod\[Rule]\[CloseCurlyDoubleQuote]Compute\
\[CloseCurlyDoubleQuote]",
  FontWeight->"Bold"],
 ", the output of ",
 StyleBox["Signal1D",
  FontWeight->"Bold"],
 " is in the frequency domain. If ",
 StyleBox["Signal1D",
  FontWeight->"Bold"],
 " is run with ",
 StyleBox["SignalCalculationMethod\[Rule]\[CloseCurlyDoubleQuote]Direct\
\[CloseCurlyDoubleQuote]",
  FontWeight->"Bold"],
 ", the output of ",
 StyleBox["Signal1D",
  FontWeight->"Bold"],
 " is in the time domain."
}], "Text",
 CellChangeTimes->{{3.629275350571323*^9, 3.629275540929411*^9}, {
  3.629275578422402*^9, 
  3.629275586310932*^9}},ExpressionUUID->"2befdd48-9473-4ff3-a54c-\
a25f954343e4"],

Cell[TextData[{
 StyleBox["If ",
  FontSlant->"Plain"],
 StyleBox["Signal1D",
  FontWeight->"Bold",
  FontSlant->"Plain"],
 StyleBox[" is run with the default option ",
  FontSlant->"Plain"],
 StyleBox["SignalCalculationMethod\[Rule]Automatic",
  FontWeight->"Bold",
  FontSlant->"Plain"],
 StyleBox[", the algorithm is chosen by the software, with the results as \
described above.",
  FontSlant->"Plain"]
}], "Text",
 CellChangeTimes->{{3.629275607490888*^9, 3.6292756641988683`*^9}},
 FontSlant->"Italic",ExpressionUUID->"e90954aa-e745-46e5-81f3-471c07f12606"],

Cell["\<\
In most cases the user does not need to know the type of format, since the \
syntax for the subsequent processing is identical. In some cases, however, \
more detailed knowledge is useful. This is given below.\
\>", "Text",
 CellChangeTimes->{{3.629275350571323*^9, 3.629275540929411*^9}, {
  3.629275578422402*^9, 3.6292755884251833`*^9}, {3.629275671266957*^9, 
  3.629275723669081*^9}, {3.629280798852044*^9, 3.629280831464119*^9}, {
  3.629285146450245*^9, 
  3.6292851617336617`*^9}},ExpressionUUID->"cad130ed-ca43-4b6c-b829-\
65febb5729d9"],

Cell[CellGroupData[{

Cell["Signal as a frequency-domain object", "Subsection",
 CellChangeTimes->{{3.588074747297937*^9, 3.58807475427406*^9}, {
  3.629275315634701*^9, 
  3.629275344863223*^9}},ExpressionUUID->"4f2faba1-1492-41b3-9ab4-\
84bdb4d4c66f"],

Cell[TextData[{
 "In the following simulation, ",
 StyleBox["Signal1D",
  FontWeight->"Bold"],
 " is used to calculate the spectrum generated by a Hamiltonian for a \
strongly-coupled 2-spin-1/2 system. The option ",
 StyleBox["SignalCalculationMethod\[Rule]\[CloseCurlyDoubleQuote]\
Diagonalization\[CloseCurlyDoubleQuote]",
  FontWeight->"Bold"],
 " is chosen automatically in this case, and the result is a ",
 StyleBox["Signal",
  FontWeight->"Bold"],
 " object, in the frequency-domain format. "
}], "Text",
 CellChangeTimes->{{3.629275733031224*^9, 3.629275825827037*^9}, {
  3.6292759874977913`*^9, 3.629275988510665*^9}, {3.629277394518138*^9, 
  3.6292773962583513`*^9}},ExpressionUUID->"68a66036-7b69-426e-8b98-\
e826452ea5b4"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"H", "=", 
   RowBox[{
    RowBox[{"2", "\[Pi]", " ", "100", " ", 
     RowBox[{"opI", "[", 
      RowBox[{"1", ",", "\"\<z\>\""}], "]"}]}], "+", 
    RowBox[{"2", "\[Pi]", " ", 
     RowBox[{"(", 
      RowBox[{"-", "150"}], ")"}], 
     RowBox[{"opI", "[", 
      RowBox[{"2", ",", "\"\<z\>\""}], "]"}]}], "+", 
    RowBox[{"2", "\[Pi]", " ", "50", " ", 
     RowBox[{
      RowBox[{"opI", "[", "1", "]"}], ".", 
      RowBox[{"opI", "[", "2", "]"}]}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"sig", "=", 
  RowBox[{"Signal1D", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"2", "\[Pi]", " ", "600"}], ",", " ", "128"}], "}"}], "}"}], 
    ",", "H"}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.62927582991022*^9, 3.629275907930793*^9}, {
  3.62927666371328*^9, 3.6292766639828463`*^9}},
 CellLabel->"In[27]:=",ExpressionUUID->"cdf7f51a-b7d9-4b7d-83d3-66025b008707"],

