Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"H", "=", 
   RowBox[{
    RowBox[{"2", "\[Pi]", " ", "100", " ", 
     RowBox[{"opI", "[", 
      RowBox[{"1", ",", "\"\<z\>\""}], "]"}]}], "+", 
    RowBox[{"2", "\[Pi]", " ", 
     RowBox[{"(", 
      RowBox[{"-", "150"}], ")"}], 
     RowBox[{"opI", "[", 
      RowBox[{"2", ",", "\"\<z\>\""}], "]"}]}], "+", 
    RowBox[{"2", "\[Pi]", " ", "50", " ", 
     RowBox[{
      RowBox[{"opI", "[", "1", "]"}], ".", 
      RowBox[{"opI", "[", "2", "]"}]}]}]}]}], ";"}], "\[IndentingNewLine]", 
