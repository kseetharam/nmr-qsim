Cell[CellGroupData[{

Cell["LineBroadening", "Subsubsection",
 CellChangeTimes->{{3.629276618471558*^9, 3.629276627709407*^9}, {
  3.6292766920839653`*^9, 3.62927671535539*^9}, {3.629276942487337*^9, 
  3.6292769533652167`*^9}, {3.629277330867655*^9, 3.629277335547448*^9}, {
  3.6292774850572863`*^9, 3.629277495329228*^9}, {3.629278414265274*^9, 
  3.6292784169994287`*^9}, {3.629279225476324*^9, 
  3.629279228690099*^9}},ExpressionUUID->"fbd8120e-6e69-401f-a744-\
0db6e1857975"],

Cell[TextData[{
 "Artifical Lorentzian broadening may be added to the signal by using the \
option ",
 StyleBox["LineBroadening",
  FontWeight->"Bold"],
 " within ",
 StyleBox["Signal1D",
  FontWeight->"Bold"],
 ". The value of ",
 StyleBox["LineBroadening ",
  FontWeight->"Bold"],
 "is the half-width and half-height of the Lorentzian broadening function, in \
rad\[NonBreakingSpace]",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["s", 
     RowBox[{"-", "1"}]], ".", " "}], TraditionalForm]],ExpressionUUID->
  "accfbed2-8cd2-49ba-9154-ff41c51d9a38"]
}], "Text",
 CellChangeTimes->{{3.629279233763702*^9, 
  3.6292793393193607`*^9}},ExpressionUUID->"a3624a10-3d4f-40e8-8453-\
dba1fca55d92"],

Cell[TextData[{
 "The default option ",
 StyleBox["LineBroadening",
  FontWeight->"Bold"],
 "\[Rule]",
 StyleBox["Automatic",
  FontWeight->"Bold"],
 " applies an exponential decay function to the time-domain data which starts \
at 1.0 and reaches the value 0.01 at the end of the acquired data points. The \
resulting value of ",
 StyleBox["LineBroadening",
  FontWeight->"Bold"],
 StyleBox[" ",
  FontSlant->"Italic"],
 "is reported when ",
 StyleBox["Signal1D",
  FontWeight->"Bold"],
 " is run. In the case below a line-broadening with half-width at half-height \
of 6.93 Hz is applied:"
}], "Text",
 CellChangeTimes->{{3.629279368208024*^9, 3.629279474699623*^9}, {
   3.629279516868512*^9, 3.629279556017295*^9}, 
   3.629454209362852*^9},ExpressionUUID->"9fc77e2a-ab6e-4a7d-ab94-\
6c35d3cd2975"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"H", "=", 
   RowBox[{
    RowBox[{"2", "\[Pi]", " ", "100", " ", 
     RowBox[{"opI", "[", 
      RowBox[{"1", ",", "\"\<z\>\""}], "]"}]}], "+", 
    RowBox[{"2", "\[Pi]", " ", 
     RowBox[{"(", 
      RowBox[{"-", "150"}], ")"}], 
     RowBox[{"opI", "[", 
      RowBox[{"2", ",", "\"\<z\>\""}], "]"}]}], "+", 
    RowBox[{"2", "\[Pi]", " ", "50", " ", 
     RowBox[{
      RowBox[{"opI", "[", "1", "]"}], ".", 
      RowBox[{"opI", "[", "2", "]"}]}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"ListPlot", "[", "\[IndentingNewLine]", 
  RowBox[{"Re", "@", 
   RowBox[{"Signal1D", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"2", "\[Pi]", " ", "600"}], ",", " ", "128"}], "}"}], "}"}], 
     ",", "H"}], "]"}]}], "\[IndentingNewLine]", "]"}]}], "Input",
