Cell["\<\
The peaks are shifted slightly so that there is a data point at each peak \
maximum. This gives an attractive spectral representation, with good \
representation of the peak heights. However the small artificial shifts in \
the peak frequencies may be undesirable in some cases. \
\>", "Text",
 CellChangeTimes->{{3.6292777186994*^9, 3.629277800367374*^9}, {
  3.629278207472599*^9, 3.62927821306073*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"bb11942f-9857-4b4f-a3bc-2dd3fd26c132"],

Cell["\<\
Peak \[OpenCurlyDoubleQuote]snapping\[CloseCurlyDoubleQuote] allows much \
faster processing of data with a large number of peaks in the spectrum.\
\>", "Text",
 CellChangeTimes->{{3.6292779681705112`*^9, 3.6292779900666037`*^9}, {
  3.6292782167588787`*^9, 3.62927821733246*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"6f6e14b7-29a5-4225-afb5-11c1e129649e"],

Cell[TextData[{
 "The \[OpenCurlyDoubleQuote]snapping\[CloseCurlyDoubleQuote] of the peaks to \
the nearest data point in the frequency domain may be suppressed by running \
Signal1D with the option ",
 StyleBox["DigitalFrequencyResolution\[Rule]False",
  FontWeight->"Bold"]
}], "Text",
 CellChangeTimes->{{3.62927780553604*^9, 3.629277854479408*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"7e51eade-6ec0-4eeb-a679-70292788f4ae"],

