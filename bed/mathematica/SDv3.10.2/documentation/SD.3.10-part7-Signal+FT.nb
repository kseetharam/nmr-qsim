Cell[CellGroupData[{

Cell["multiplying Signal before FT", "Subsubsection",
 CellChangeTimes->{{3.629283502931065*^9, 
  3.629283510040588*^9}},ExpressionUUID->"737a1c53-6e8d-45ce-a474-\
56e3fb9b8fac"],

Cell["\<\
A Signal object may be multiplied by a complex number. This is a convenient \
way to scale up or down the signal, and to perform a phase adjustment. \
\>", "Text",
 CellChangeTimes->{{3.629282341273908*^9, 
  3.629282399718749*^9}},ExpressionUUID->"15275bac-0275-436a-b127-\
b3841732e0e2"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"H", "=", 
   RowBox[{
    RowBox[{"2", "\[Pi]", " ", "100", " ", 
     RowBox[{"opI", "[", 
      RowBox[{"1", ",", "\"\<z\>\""}], "]"}]}], "+", 
    RowBox[{"2", "\[Pi]", " ", 
     RowBox[{"(", 
      RowBox[{"-", "150"}], ")"}], 
     RowBox[{"opI", "[", 
      RowBox[{"2", ",", "\"\<z\>\""}], "]"}]}], "+", 
    RowBox[{"2", "\[Pi]", " ", "50", " ", 
     RowBox[{
      RowBox[{"opI", "[", "1", "]"}], ".", 
      RowBox[{"opI", "[", "2", "]"}]}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"sig", "=", 
  RowBox[{"Signal1D", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"2", "\[Pi]", " ", "600"}], ",", " ", "\"\<1k\>\""}], "}"}], 
     "}"}], ",", "H"}], "]"}]}]}], "Input",
