Cell[CellGroupData[{

Cell["about this documentation", "Section",
 CellChangeTimes->{{3.54435961135287*^9, 3.544359638758511*^9}, {
  3.544363941411948*^9, 
  3.544363944401976*^9}},ExpressionUUID->"43828a85-59bd-4298-b68d-\
331c3a06b231"],

Cell["\<\
This documentation is by no means exhaustive. It is intended as a quick guide \
to the basic concepts and the most useful top-level routines. More detailed \
documentation on the individual functions, and the lower-level routines such \
as Hilbert space and Liouville space bases, will appear later.\
\>", "Text",
 CellChangeTimes->{{3.544363947186761*^9, 3.544363981640773*^9}, {
  3.5444132588806887`*^9, 3.54441327183038*^9}, {3.544432939333207*^9, 
  3.544432970600341*^9}},ExpressionUUID->"679c493e-e6bb-4c37-af3e-\
24bff285318d"],

