Cell["$Chronology", "Subsection",
 CellChangeTimes->{{3.544371379793201*^9, 3.544371382439694*^9}, {
  3.545057406999844*^9, 3.545057410430038*^9}},
 Background->RGBColor[1, 0.925, 0.925],
 CellTags->
  "$Chronology",ExpressionUUID->"0010e6e2-1363-44b2-a4fb-14f25383fae9"],

Cell["\<\
$Chronology sets the chronological order of all lists of events. The default \
in v3.9.1 is \[OpenCurlyDoubleQuote]LeftToRight\[CloseCurlyDoubleQuote], \
allowing all sequences of events to be defined in \
\[OpenCurlyDoubleQuote]natural\[CloseCurlyDoubleQuote] left-to-right order. \
\>", "Text",
 CellChangeTimes->{{3.545057449179093*^9, 3.545057507356163*^9}, 
   3.563053759382368*^9, {3.5742589762094193`*^9, 3.574258977038831*^9}, {
