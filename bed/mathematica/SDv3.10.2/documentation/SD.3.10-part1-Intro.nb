            Pattern[Tensors`CG`Private`m2, 
             Blank[]]}] :> 
         Condition[0, Abs[Tensors`CG`Private`m3] > Tensors`CG`Private`j3], 
         Tensors`CG`CG[{
            Pattern[Tensors`CG`Private`j3, 
             Blank[]], 
            Pattern[Tensors`CG`Private`m3, 
             Blank[]]}, {
            Pattern[Tensors`CG`Private`j1, 
             Blank[]], 
            Pattern[Tensors`CG`Private`m1, 
             Blank[]]}, {
            Pattern[Tensors`CG`Private`j2, 
             Blank[]], 
            Pattern[Tensors`CG`Private`m2, 
             Blank[]]}] :> 
         Condition[0, Abs[Tensors`CG`Private`m1] > Tensors`CG`Private`j1], 
         Tensors`CG`CG[{
            Pattern[Tensors`CG`Private`j3, 
             Blank[]], 
            Pattern[Tensors`CG`Private`m3, 
             Blank[]]}, {
            Pattern[Tensors`CG`Private`j1, 
             Blank[]], 
            Pattern[Tensors`CG`Private`m1, 
             Blank[]]}, {
            Pattern[Tensors`CG`Private`j2, 
             Blank[]], 
            Pattern[Tensors`CG`Private`m2, 
             Blank[]]}] :> 
         Condition[0, Abs[Tensors`CG`Private`m2] > Tensors`CG`Private`j2], 
         Tensors`CG`CG[{
            Pattern[Tensors`CG`Private`j3, 
             Blank[]], 
            Pattern[Tensors`CG`Private`m3, 
