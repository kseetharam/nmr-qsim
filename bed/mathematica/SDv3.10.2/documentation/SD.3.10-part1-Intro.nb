Cell[TextData[{
 "In this case the resulting object is a TimeDependentGeneratorFunction,  \
which is the syntax used in ",
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 " for specifying general time-dependent events. It is described below."
}], "Text",
 CellChangeTimes->{{3.5443771378918552`*^9, 3.544377171010663*^9}, {
   3.544377451499619*^9, 3.544377453899295*^9}, {3.54437809198326*^9, 
   3.544378092481957*^9}, {3.544380892829032*^9, 3.544380901622257*^9}, {
   3.564575478682007*^9, 3.564575549894147*^9}, {3.6167516568834968`*^9, 
   3.616751659109775*^9}, 3.816848668992199*^9, 3.8168497120414467`*^9, {
   3.816850392418479*^9, 3.816850393436206*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"3d57bd3c-cb40-4fb7-a2bc-ef39bde66cad"],

Cell[TextData[{
 "For the most part, ",
 StyleBox["CombineGenerators",
  FontWeight->"Bold"],
 " is used internally and is invisible to the user. However there are times \
when you may need to use this routine yourself. "
}], "Text",
 CellChangeTimes->{{3.544378490866685*^9, 3.544378549075475*^9}, {
   3.544378581793668*^9, 3.544378597273275*^9}, 3.70954718124529*^9},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"6ff8c9a3-3b37-4c82-8092-9c657d02a144"]
}, Closed]]
}, Closed]],

Cell[CellGroupData[{

Cell["events: pulse sequence syntax", "Section",
 CellChangeTimes->{{3.54435961135287*^9, 3.544359628871992*^9}, {
   3.544359721544903*^9, 3.5443597540943217`*^9}, {3.816850373883328*^9, 
   3.816850377000158*^9}, {3.816850900947584*^9, 3.81685090528106*^9}, {
   3.816854346622479*^9, 3.816854352023761*^9}, 3.816855573192003*^9, {
   3.816855862997229*^9, 3.8168558638732433`*^9}, {3.816856000844832*^9, 
   3.816856005505991*^9}},ExpressionUUID->"cce98597-6641-4fb1-98dc-\
02eec1d08bbd"],

Cell["\<\
Spin-dynamical simulations normally involve sequences of events. These may be \
described using PulseSequence objects (this subsection) or more generally by \
explicit event syntax (next subsection). \
\>", "Text",
