Cell[TextData[{
 "This defines a time-dependent Hamiltonian proportional to the I",
 Cell[BoxData[
  FormBox[
   SubscriptBox["", "x"], TraditionalForm]],ExpressionUUID->
  "030c121d-9cfb-486e-9491-3136b594986c"],
 " operator but with a cosine-modulated amplitude. This does not define a \
single value, but a ",
 StyleBox["function",
  FontSlant->"Italic"],
 ", which may be evaluated at any time, as follows:"
}], "Text",
