 RowBox[{
  RowBox[{"dd", "=", 
   RowBox[{"DiagonalMatrix", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "1"}], ",", 
       RowBox[{"-", "1"}], ",", "2"}], "}"}], "/", "3"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"opI", "[", "1", "]"}], ".", "dd", ".", 
  RowBox[{"opI", "[", "2", "]"}]}]}], "Input",
