Cell[CellGroupData[{

Cell["spin angular momentum operators: opI", "Subsection",
 CellChangeTimes->{{3.54435961135287*^9, 3.544359628871992*^9}, {
   3.544359721544903*^9, 3.544359747254434*^9}, 3.54435989242558*^9, {
   3.544359948339938*^9, 3.544359951240794*^9}, {3.544370227289459*^9, 
