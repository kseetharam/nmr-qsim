Cell[TextData[{
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 " also allows definition of a periodic time-dependent function using ",
 StyleBox["PeriodicFunction",
  FontWeight->"Bold"],
 ", as follows:"
}], "Text",
 CellChangeTimes->{{3.544376324109681*^9, 
  3.544376362895944*^9}},ExpressionUUID->"6228bf44-5585-4abd-a5b4-\
968cf53821bc"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"PeriodicTimeDependentHamiltonian", "=", 
  RowBox[{"PeriodicFunction", "[", 
   RowBox[{"t", ",", 
    RowBox[{"1", "/", "100"}], ",", 
    RowBox[{"Evaluate", "[", 
     RowBox[{"2", "\[Pi]", " ", "200", 
      RowBox[{"opI", "[", "\"\<x\>\"", "]"}], 
      RowBox[{"Cos", "[", 
       RowBox[{"2", "\[Pi]", " ", "100", " ", "t"}], "]"}]}], "]"}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.544376037203208*^9, 3.544376062851448*^9}, {
  3.544376103680152*^9, 3.544376105804461*^9}, {3.544376349567249*^9, 
  3.544376375331744*^9}, {3.657728461731266*^9, 3.657728465586747*^9}},
 CellLabel->"In[59]:=",ExpressionUUID->"79d9bdb1-688a-4976-9066-e7ed14ffbdd8"],

Cell[BoxData[
 RowBox[{"PeriodicFunction", "[", 
  RowBox[{"t", ",", 
   FractionBox["1", "100"], ",", 
   RowBox[{"400", " ", "\[Pi]", " ", 
    RowBox[{"Cos", "[", 
     RowBox[{"200", " ", "\[Pi]", " ", "t"}], "]"}], " ", 
    RowBox[{"(", 
     RowBox[{
      TagBox[
       SubscriptBox["I", 
        RowBox[{"1", "x"}]],
       DisplayForm], "+", 
      TagBox[
       SubscriptBox["I", 
        RowBox[{"2", "x"}]],
       DisplayForm], "+", 
      TagBox[
       SubscriptBox["I", 
        RowBox[{"3", "x"}]],
       DisplayForm]}], ")"}]}]}], "]"}]], "Output",
 CellChangeTimes->{
