  1, 0.925, 0.925],ExpressionUUID->"0adc1e54-559b-4ab5-acec-5a83162a3e80"],

Cell[TextData[{
 "any combinations of evolution generators, including time-independent \
Hamiltonians, time-dependent Hamiltonians, and relaxation superoperators, may \
be combined using the ",
 StyleBox["CombineGenerators",
  FontWeight->"Bold"],
 " routine, for example"
}], "Text",
 CellChangeTimes->{{3.544377033783462*^9, 3.544377080700766*^9}, 
   3.544377113827126*^9, 3.70954710967714*^9},
 Background->RGBColor[
