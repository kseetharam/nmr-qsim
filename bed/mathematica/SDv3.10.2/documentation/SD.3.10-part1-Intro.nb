   3.816855178852008*^9}},ExpressionUUID->"102ad7a9-78a1-4246-b7db-\
9afa50e2a46e"],

Cell["\<\
A sequence of events is created by chaining the events together in a List \
(with chronological order from left to right):\
\>", "Text",
 CellChangeTimes->{{3.81685414380205*^9, 3.81685416494634*^9}, {
  3.816854326868647*^9, 3.8168543376626263`*^9}, {3.816854376879196*^9, 
  3.816854380126031*^9}},ExpressionUUID->"57183c57-f48e-4801-9ea7-\
5605588d3d64"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"spinechosequence", "=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"Pulse", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Pi]", "/", "2"}], ",", "\"\<x\>\""}], "}"}], "]"}], ",", 
    RowBox[{"Delay", "[", "0.5", "]"}], ",", 
    RowBox[{"Pulse", "[", 
     RowBox[{"{", 
      RowBox[{"\[Pi]", ",", "\"\<y\>\""}], "}"}], "]"}], ",", 
    RowBox[{"Delay", "[", "0.5", "]"}]}], "}"}]}]], "Input",
 CellChangeTimes->{{3.816854167815022*^9, 3.816854226979523*^9}},
 CellLabel->"In[96]:=",ExpressionUUID->"f37f451a-653b-491f-b0e8-e2038ac6d398"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"Pulse", "[", 
    RowBox[{"Automatic", ",", 
     RowBox[{"{", 
      RowBox[{
       FractionBox["\[Pi]", "2"], ",", "\<\"x\"\>"}], "}"}]}], "]"}], ",", 
   RowBox[{"Delay", "[", 
    RowBox[{"0.5`", ",", "None"}], "]"}], ",", 
   RowBox[{"Pulse", "[", 
    RowBox[{"Automatic", ",", 
     RowBox[{"{", 
      RowBox[{"\[Pi]", ",", "\<\"y\"\>"}], "}"}]}], "]"}], ",", 
   RowBox[{"Delay", "[", 
    RowBox[{"0.5`", ",", "None"}], "]"}]}], "}"}]], "Output",
 CellChangeTimes->{{3.8168542019177847`*^9, 3.816854227709524*^9}, 
   3.816854923029114*^9, 3.8377804188817053`*^9, 3.910151840515066*^9, 
   3.916897496381659*^9, 3.916897560423038*^9, 3.949039237632628*^9},
 CellLabel->"Out[96]=",ExpressionUUID->"791a24ec-4518-4aee-b437-59a1d0ef615e"]
}, Open  ]],

