 RowBox[{"TimeDependentGeneratorFunction", "[", 
  RowBox[{"t", ",", 
   RowBox[{"{", 
    RowBox[{"{", 
     RowBox[{"SD`Generators`Private`\[Tau]$100105", ",", "None"}], "}"}], 
    "}"}], ",", 
   FractionBox["1", "100"], ",", 
   RowBox[{
    RowBox[{"400", " ", "\[Pi]", " ", 
     RowBox[{"Cos", "[", 
      RowBox[{"200", " ", "\[Pi]", " ", "t"}], "]"}], " ", 
     TagBox[
      SubscriptBox["I", 
       RowBox[{"1", "x"}]],
      DisplayForm]}], "+", 
    RowBox[{"400", " ", "\[Pi]", " ", 
     RowBox[{"Cos", "[", 
      RowBox[{"200", " ", "\[Pi]", " ", "t"}], "]"}], " ", 
     TagBox[
      SubscriptBox["I", 
       RowBox[{"2", "x"}]],
      DisplayForm]}], "+", 
    RowBox[{"400", " ", "\[Pi]", " ", 
     RowBox[{"Cos", "[", 
      RowBox[{"200", " ", "\[Pi]", " ", "t"}], "]"}], " ", 
     TagBox[
      SubscriptBox["I", 
       RowBox[{"3", "x"}]],
      DisplayForm]}]}]}], "]"}]], "Output",
 CellChangeTimes->{{3.949039051106284*^9, 3.949039056293478*^9}},
 CellLabel->"Out[64]=",ExpressionUUID->"0a599e40-8483-4350-944d-9a9b9bb8a021"]
}, Open  ]]
}, Closed]],

