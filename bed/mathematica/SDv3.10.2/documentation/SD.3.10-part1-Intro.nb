Cell[CellGroupData[{

Cell["Terms of use", "Subsubsection",
 CellChangeTimes->{{3.544413113452461*^9, 3.544413117891059*^9}, {
  3.5444131619808064`*^9, 
  3.544413163521791*^9}},ExpressionUUID->"b0a51622-b52c-4a54-989e-\
782fb3e850b6"],

Cell[TextData[{
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 " is open source. If you employ ",
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 " in a published work, please acknowledge your use of ",
 StyleBox["SpinDynamica: ",
  FontSlant->"Italic"],
 "\n\nChristian Bengs, Malcolm H. Levitt, ",
 StyleBox["SpinDynamica: Symbolic and numerical magnetic resonance in a \
Mathematica environment",
  FontSlant->"Italic"],
 ", Magn. Reson. Chem, 2017. (DOI: 10.1002/mrc.4642)\n\nIf you use ",
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 " for a published work, please consider depositing a self-contained notebook \
example on the ",
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 " forum, or ",
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 " website. Otherwise place the file on a server of your choice and send the \
link to mhl@soton.ac.uk so that it can be publicized on the ",
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 " website. Include the DOI of the published article. Thanks!"
}], "Text",
 CellChangeTimes->{{3.5444131709219933`*^9, 3.544413229001012*^9}, {
  3.544432704434553*^9, 3.544432717793069*^9}, {3.5444327846707172`*^9, 
  3.544432788781315*^9}, {3.5444328358312397`*^9, 3.544432836632821*^9}, {
  3.544432884532355*^9, 3.54443291706989*^9}, {3.545670856017129*^9, 
  3.545670906388402*^9}, {3.572631099463995*^9, 3.572631108869796*^9}, {
  3.5748477932064867`*^9, 3.574847803552973*^9}, {3.590671107867929*^9, 
  3.59067120712473*^9}, {3.631448068796311*^9, 3.631448169656414*^9}, {
  3.7119976061963673`*^9, 3.711997610892335*^9}, {3.711997696407984*^9, 
  3.711997714732964*^9}, {3.711997757982085*^9, 3.711997768052594*^9}, {
  3.7119978322401066`*^9, 
  3.711997870580819*^9}},ExpressionUUID->"898516ec-a540-42b6-94f1-\
