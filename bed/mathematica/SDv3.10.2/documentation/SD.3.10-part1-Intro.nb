Cell[TextData[{
 "The syntax CoherenceOrderFiltrationSuperoperator[{",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["p", "1"], ",", 
      SubscriptBox["p", "2"], ",", ".."}], "}"}], " "}], TraditionalForm]],
  ExpressionUUID->"e68cc358-76d7-412a-b261-e8ffb624bdd4"],
 "] defines filtration through a set of coherence orders, also belonging to \
all spins."
}], "Text",
