Cell[TextData[{
 "I therefore had to use a different symbol and I settled on the rather \
clumsy ",
 StyleBox["opI",
  FontWeight->"Bold"],
 ". "
}], "Text",
 CellChangeTimes->{{3.544371260224999*^9, 
  3.544371274893442*^9}},ExpressionUUID->"f4c49c01-9ca5-44fd-99cb-\
2bab79cd9a94"],

Cell[TextData[{
 "The symbol ",
 StyleBox["opI ",
  FontWeight->"Bold"],
 "supports several different syntaxes. The main ones are listed here:"
}], "Text",
 CellChangeTimes->{{3.54437041289708*^9, 3.544370443352144*^9}, {
  3.544379213874692*^9, 
  3.544379214862731*^9}},ExpressionUUID->"ea2c9245-b436-49c8-8f0e-\
a32260ceeb49"],

