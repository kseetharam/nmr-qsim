Cell["\<\
For example, a pulse with a Gaussian amplitude shape, of total duration 1\
\[NonBreakingSpace]s, maximum amplitude corresponding to a nutation frequency \
of 10 kHz, and standard deviation of 0.3\[NonBreakingSpace]s for the Gaussian \
shape, with maximum amplitude at the centre of the pulse, may be specified as \
follows:\
\>", "Text",
 CellChangeTimes->{{3.816852211919429*^9, 3.816852301256697*^9}, {
  3.8168524406944027`*^9, 
  3.816852460959845*^9}},ExpressionUUID->"33057fc7-cb7a-4450-82ef-\
7f04426f9bec"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"gaussianpulse", "=", 
  RowBox[{"ShapedPulse", "[", 
   RowBox[{"1", ",", 
    RowBox[{"{", 
     RowBox[{"\[Tau]", ",", 
      RowBox[{"2", "\[Pi]", " ", "10", " ", 
       SuperscriptBox["10", "3"], " ", 
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", "0.3"}], " ", 
         RowBox[{"\[Tau]", "^", "2"}]}], "]"}]}]}], "}"}]}], "]"}]}]], "Input",\

 CellChangeTimes->{{3.816852305097238*^9, 3.816852362527409*^9}, {
  3.816853717570565*^9, 3.816853719074957*^9}},
 CellLabel->"In[86]:=",ExpressionUUID->"d2791184-73ef-4b37-a4f8-6455529d64c4"],

Cell[BoxData[
 RowBox[{"ShapedPulse", "[", 
  RowBox[{"Automatic", ",", "1", ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"\[Tau]", ",", 
       FractionBox["1", "2"]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"20000", " ", 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{
          RowBox[{"-", "0.3`"}], " ", 
          SuperscriptBox["\[Tau]", "2"]}]], " ", "\[Pi]"}], ",", "0", ",", 
       "0"}], "}"}]}], "}"}]}], "]"}]], "Output",
 CellChangeTimes->{
  3.816852363209734*^9, 3.816853287819729*^9, 3.816853720622651*^9, 
   3.816853762184637*^9, 3.816853989310933*^9, 3.8377803889725*^9, 
