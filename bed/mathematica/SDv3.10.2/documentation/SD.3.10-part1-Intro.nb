Cell[CellGroupData[{

Cell["ShapedPulse", "Subsection",
 CellChangeTimes->{{3.544359859953731*^9, 3.544359868408318*^9}, {
  3.544378222100853*^9, 3.544378224633845*^9}, {3.5443789412840242`*^9, 
  3.544378943562585*^9}, {3.544379038483877*^9, 3.544379039283505*^9}, {
  3.816851060962555*^9, 3.816851075134488*^9}, {3.816852057728499*^9, 
  3.816852059781728*^9}},ExpressionUUID->"649a4fc4-217e-4f9d-bf04-\
1b2c7aedd9cb"],

Cell["\<\
The ShapedPulse symbol allows specification of a pulse with an arbitrary \
dependence of amplitude, frequency, or phase, on time. \
\>", "Text",
 CellChangeTimes->{{3.816852062936603*^9, 3.816852082494144*^9}, {
  3.816852172401696*^9, 
  3.816852192947044*^9}},ExpressionUUID->"04aadd14-9e25-4f3d-ba2f-\
7936086f72db"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"?", "ShapedPulse"}]], "Input",
 CellChangeTimes->{{3.816852197237494*^9, 3.816852199394232*^9}},
 CellLabel->"In[85]:=",ExpressionUUID->"9ca53e2e-033c-48c8-9f9a-64112fbfe5c1"],

Cell[BoxData[
 InterpretationBox[
  StyleBox[
   FrameBox[
    DynamicModuleBox[{System`InformationDump`open$$ = False, 
     System`InformationDump`mouseOver$$ = False}, 
     PaneSelectorBox[{True->
      TagBox[GridBox[{
         {
          ItemBox[
           PaneBox[
            StyleBox[
             TagBox[
              TooltipBox[
               StyleBox["\<\" Symbol\"\>", "InformationRowLabel",
                StripOnInput->False],
               "\"Symbol\"",
               TooltipStyle->"TextStyling"],
              Annotation[#, "Symbol", "Tooltip"]& ], "InformationTitleText",
             StripOnInput->False,
             BaseStyle -> None],
            FrameMargins->{{4, 0}, {-1, 1}}],
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False], 
          ItemBox["\<\"\"\>",
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False]},
         {
          ItemBox[
           PaneBox[
            
            StyleBox["\<\"ShapedPulse[spins,\[Tau]p,{\[Tau],{amplitude,phase,\
frequency}},options] specifies a continuously shaped radiofrequency pulse of \
duration \[Tau]p applied to spins spins. The amplitude, phase and frequency \
arguments are arbitrary functions of \[Tau], with the origin of the local \
time variable \[Tau] being in the centre of the pulse, by default (for other \
options, see below). The amplitude argument specifies the nutation frequency \
for the selected spins as a function of \[Tau]. The phase argument specifies \
the phase of the radiofrequency field in the rotating frame. The frequency \
argument specifies the frequency offset of the shaped radiofrequency field. \
\\nIf the spins argument is missing, all spins in the current spin system are \
assumed. \\nIf the frequency argument is missing, zero frequency offset is \
assumed. If the phase argument is also missing, zero phase is assumed. \\nThe \
syntax ShapedPulse[spins,\[Tau]p,{\[Tau],amplitude},options] assumes an \
amplitude-modulated rf field as a function of local time variable \[Tau]. For \
example, ShapedPulse[spins,\[Tau]p,{\[Tau],\[Omega]nutmax Cos[\[Omega]mod \
t]}] specifies a cosine-modulated pulse with maximum nutation frequency \
\[Omega]nutmax and modulation frequency \[Omega]mod.\\nSyntax of the form \
ShapedPulse[spins,\[Tau]p,{{\[Tau],x}, {amplitude,phase,frequency}},options] \
indicates that the local time variable \[Tau] has a time origin located at a \
point which is a fraction x of the pulse duration from the start of the \
pulse. A value of x=0 indicates a time origin at the beginning of the pulse; \
a value of x=1 indicates a time origin at the end of the pulse. The default \
is x=1/2 (time origin at the centre of the pulse).  \\nThe options may \
contain rules for AmplitudeFactor and PhaseShift. AmplitudeFactor is used to \
specify the rf field amplitude relative to a nominal value, allowing \
simulation of the effect of rf inhomogeneity. For example AmplitudeFactor\
\[Rule]0.9 indicates a rf field amplitude which is 10% less than the nominal \
value. The PhaseShift\[Rule]\[CapitalPhi] option may be used to impose a \
constant phase shift \[CapitalPhi] on the pulse shape. Both of these options \
may be passed down from the enclosing PulseSequence object.\\nExpand may be \
applied to a ShapedPulse object, in order to convert it into an explicit \
event.\"\>", "InformationUsageText",
             StripOnInput->False,
             LineSpacing->{1.5, 1.5, 3.}],
            FrameMargins->{{10, 10}, {8, 10}}],
           BaseStyle->"InformationUsageSubtitleBackground",
           StripOnInput->False], 
          ItemBox["\<\"\"\>",
           BaseStyle->"InformationUsageSubtitleBackground",
           StripOnInput->False]},
         {
          PaneBox[
           TagBox[GridBox[{
              {
               StyleBox[
                TagBox[
                 TooltipBox[
                  
                  StyleBox["\<\" UpValue Definitions\"\>", 
                   "InformationRowLabel",
                   StripOnInput->False],
                  "\"UpValues\"",
                  TooltipStyle->"TextStyling"],
                 Annotation[#, "UpValues", "Tooltip"]& ], "DialogStyle",
                StripOnInput->False]},
              {
               TemplateBox[{"\"\[ThinSpace]\"", 
                 GridBox[{{
                    RowBox[{
                    RowBox[{"InvolvedSpins", "[", 
                    RowBox[{"ShapedPulse", "[", 
                    
                    RowBox[{
                    "Events`PulseSequence`Private`spins_List", ",", 
                    "Events`PulseSequence`Private`\[Tau]p_", ",", 
                    "Events`PulseSequence`Private`functions_", ",", 
                    "Events`PulseSequence`Private`opts___Rule"}], "]"}], 
                    "]"}], "^:=", "Events`PulseSequence`Private`spins"}]}, {
                   " "}, {
                    RowBox[{
                    RowBox[{"InvolvedSpins", "[", 
                    RowBox[{"ShapedPulse", "[", 
                    
                    RowBox[{
                    "Automatic", ",", "Events`PulseSequence`Private`\[Tau]p_",
                     ",", "Events`PulseSequence`Private`functions_", ",", 
                    "Events`PulseSequence`Private`opts___Rule"}], "]"}], 
                    "]"}], "^:=", "Automatic"}]}, {" "}, {
                    RowBox[{
                    RowBox[{"Duration", "[", 
                    RowBox[{"ShapedPulse", "[", 
                    RowBox[{
                    RowBox[{"Events`PulseSequence`Private`spins", ":", 
                    RowBox[{"_List", "|", "Automatic"}]}], ",", 
                    "Events`PulseSequence`Private`\[Tau]p_", ",", 
                    "Events`PulseSequence`Private`functions_", ",", 
                    "Events`PulseSequence`Private`opts___Rule"}], "]"}], 
                    "]"}], "^:=", "Events`PulseSequence`Private`\[Tau]p"}]}, {
                   " "}, {
                    RowBox[{"ShapedPulse", "/:", 
                    RowBox[{"StandardizeEventSpecification", "[", 
                    RowBox[{
                    RowBox[{"HoldPattern", "[", 
                    RowBox[{"ShapedPulse", "[", 
                    
                    RowBox[{"Automatic", ",", 
                    "Events`PulseSequence`Private`more___"}], "]"}], "]"}], 
                    ",", "Events`PulseSequence`Private`opts___Rule"}], "]"}], 
                    ":=", 
                    RowBox[{"StandardizeEventSpecification", "[", 
                    RowBox[{
                    RowBox[{"ShapedPulse", "[", 
                    RowBox[{"All", ",", "Events`PulseSequence`Private`more"}],
                     "]"}], ",", "Events`PulseSequence`Private`opts"}], 
                    "]"}]}]}, {" "}, {
                    RowBox[{"ShapedPulse", "/:", 
                    RowBox[{"StandardizeEventSpecification", "[", 
                    RowBox[{
                    RowBox[{"ShapedPulse", "[", 
                    
                    RowBox[{"Events`PulseSequence`Private`spins_List", ",", 
                    "Events`PulseSequence`Private`\[Tau]p_", ",", 
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"{", 
                    
                    RowBox[{"Events`PulseSequence`Private`\[Tau]_", ",", 
                    "Events`PulseSequence`Private`x_"}], "}"}], ",", 
                    RowBox[{"{", 
                    
                    RowBox[{"Events`PulseSequence`Private`ampfunc_", ",", 
                    "Events`PulseSequence`Private`phasefunc_", ",", 
                    "Events`PulseSequence`Private`freqfunc_"}], "}"}]}], 
                    "}"}], ",", "Events`PulseSequence`Private`popts___Rule"}],
                     "]"}], ",", "Events`PulseSequence`Private`opts___Rule"}],
                     "]"}], ":=", 
                    RowBox[{"Module", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    
                    RowBox[{"Events`PulseSequence`Private`f", ",", 
                    "Events`PulseSequence`Private`\[CapitalPhi]", ",", 
                    "Events`PulseSequence`Private`t"}], "}"}], ",", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"{", 
                    
                    RowBox[{"Events`PulseSequence`Private`f", ",", 
                    "Events`PulseSequence`Private`\[CapitalPhi]"}], "}"}], 
                    "=", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"AmplitudeFactor", ",", "PhaseShift"}], "}"}], 
                    "/.", "\[VeryThinSpace]", 
                    RowBox[{"{", 
                    
                    RowBox[{"Events`PulseSequence`Private`popts", ",", 
                    "Events`PulseSequence`Private`opts"}], "}"}]}], "/.", 
                    "\[VeryThinSpace]", 
                    RowBox[{"Join", "[", 
                    RowBox[{
                    RowBox[{"Options", "[", "ShapedPulse", "]"}], ",", 
                    RowBox[{"Options", "[", "PulseSequence", "]"}]}], 
                    "]"}]}]}], ";", 
                    RowBox[{"EventSpecifications", "[", 
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"TimeDependentGeneratorFunction", "[", 
                    RowBox[{"Events`PulseSequence`Private`t", ",", 
                    RowBox[{"{", 
                    
                    RowBox[{"Events`PulseSequence`Private`\[Tau]", ",", 
                    "Events`PulseSequence`Private`x"}], "}"}], ",", 
                    RowBox[{
                    
                    RowBox[{"Events`PulseSequence`Private`f", " ", 
                    "Events`PulseSequence`Private`ampfunc", " ", 
                    RowBox[{"opI", "[", 
                    RowBox[{"Events`PulseSequence`Private`spins", ",", 
                    
                    RowBox[{"Events`PulseSequence`Private`\[CapitalPhi]", "+",
                     "Events`PulseSequence`Private`phasefunc"}]}], "]"}]}], 
                    "-", 
                    RowBox[{"Events`PulseSequence`Private`freqfunc", " ", 
                    RowBox[{"opI", "[", 
                    
                    RowBox[{"Events`PulseSequence`Private`spins", ",", 
                    "\"z\""}], "]"}]}]}]}], "]"}], ",", 
                    "Events`PulseSequence`Private`\[Tau]p", ",", 
                    RowBox[{
                    
                    RowBox[{
                    "Events`PulseSequence`Private`\
FilterOptionsOnInterpretation", "[", "ShapedPulse", "]"}], "[", 
                    "Events`PulseSequence`Private`opts", "]"}]}], "}"}], 
                    "]"}]}]}], "]"}]}]}, {" "}, {
                    RowBox[{"ShapedPulse", "/:", 
                    RowBox[{"Expand", "[", 
                    
                    RowBox[{
                    "Events`PulseSequence`Private`shp_ShapedPulse", ",", 
                    "Events`PulseSequence`Private`opts___Rule"}], "]"}], ":=", 
                    RowBox[{
                    RowBox[{"EventSpecifications", "[", 
                    
                    RowBox[{
                    "Events`PulseSequence`Private`shp", ",", 
                    "Events`PulseSequence`Private`opts"}], "]"}], 
                    "\[LeftDoubleBracket]", 
                    RowBox[{"2", ",", "1"}], "\[RightDoubleBracket]"}]}]}, {
                   " "}}, GridBoxAlignment -> {"Columns" -> {{Left}}}, 
                  DefaultBaseStyle -> "Column", 
                  GridBoxItemSize -> {
                   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]},
                "RowDefault"]},
              {
               StyleBox[
                TagBox[
                 TooltipBox[
                  
                  StyleBox["\<\" DownValue Definitions\"\>", 
                   "InformationRowLabel",
                   StripOnInput->False],
                  "\"DownValues\"",
                  TooltipStyle->"TextStyling"],
                 Annotation[#, "DownValues", "Tooltip"]& ], "DialogStyle",
                StripOnInput->False]},
              {
               TemplateBox[{"\"\[ThinSpace]\"", 
                 GridBox[{{
                    RowBox[{
                    RowBox[{
                    
                    RowBox[{
                    "ShapedPulse", "[", 
                    "Events`PulseSequence`Private`args___", "]"}], "/;", 
                    RowBox[{"!", 
                    RowBox[{"FreeQ", "[", 
                    RowBox[{
                    RowBox[{"{", "Events`PulseSequence`Private`args", "}"}], 
                    ",", "$Failed"}], "]"}]}]}], ":=", "$Failed"}]}, {" "}, {
                    RowBox[{
