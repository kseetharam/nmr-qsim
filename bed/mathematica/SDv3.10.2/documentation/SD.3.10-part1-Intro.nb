Cell[TextData[{
 "For example, doing nothing for 0.1 second, followed by an instantaneous \
pulse with flip angle \[Pi]/2 and phase 0, followed by a Hamiltonian 2\[Pi] \
",
 Cell[BoxData[
  FormBox[
   SubscriptBox["I", "x"], TraditionalForm]],ExpressionUUID->
  "d94c7ad5-0ac5-4260-bf68-f39857254c17"],
 " applied for 0.2 seconds, is denoted as follows:"
}], "Text",
 CellChangeTimes->{{3.5443788979875183`*^9, 3.5443789108913198`*^9}, {
  3.544379017533376*^9, 3.544379026869611*^9}, {3.5450577823887467`*^9, 
