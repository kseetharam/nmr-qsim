Cell[TextData[{
 "This indicates three repetitions of an event consisting of a Hamiltonian ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", 
    SubscriptBox["\[Pi]I", "x"]}], TraditionalForm]],ExpressionUUID->
  "2a49e1c3-bce5-4cc0-8343-ac6a211301f3"],
 ", each acting for 100 ms. As usual Duration may be used to calculate the \
overall duration"
}], "Text",
