Cell["Cartesian angular momentum operators", "Subsubsection",
 CellChangeTimes->{{3.544370389219353*^9, 
  3.544370409457418*^9}},ExpressionUUID->"c6b259a6-0b9f-4516-9f64-\
dad140b5071e"],

Cell[TextData[{
 "The syntax ",
 StyleBox["opI[<spin label>, <component>]",
  FontWeight->"Bold"],
 " defines the spin angular momentum operator for an individual spin with the \
chosen component. For example, set the spin system to 3 spins-1/2, labelled 1 \
& 2:"
}], "Text",
 CellChangeTimes->{{3.544370398757922*^9, 3.54437039899428*^9}, {
