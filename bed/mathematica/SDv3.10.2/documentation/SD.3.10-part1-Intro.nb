Cell[TextData[{
 "defines 10 repetitions of a two-element sequence, consisting of selection \
of zero-quantum coherences, followed by evolution under a spin Hamiltonian ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", 
    SubscriptBox["\[Pi]I", "x"]}], TraditionalForm]],ExpressionUUID->
  "98319f19-60c4-4fbc-93b4-430aa8d8939e"],
 " for 100 ms."
}], "Text",
 CellChangeTimes->{{3.544547675916464*^9, 
  3.544547774427599*^9}},ExpressionUUID->"9e399295-cb8c-4e99-a1ea-\
77026fec93b9"],

Cell["The following two definitions are formally equivalent:", "Text",
 CellChangeTimes->{{3.544547796574214*^9, 
  3.5445478046135273`*^9}},ExpressionUUID->"1b62edef-edc6-487d-b12d-\
41d7c84f0523"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"sequence1", "=", 
   RowBox[{"Repeat", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"2", "\[Pi]", " ", 
        RowBox[{"opI", "[", "\"\<x\>\"", "]"}]}], ",", 
       RowBox[{"100", " ", 
        RowBox[{"10", "^", 
         RowBox[{"-", "3"}]}]}]}], "}"}], ",", "100"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sequence2", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"2", "\[Pi]", " ", 
        RowBox[{"opI", "[", "\"\<x\>\"", "]"}]}], ",", 
       RowBox[{"100", " ", 
        RowBox[{"10", "^", 
         RowBox[{"-", "3"}]}]}]}], "}"}], ",", 
     RowBox[{"{", "100", "}"}]}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.544547813431558*^9, 3.544547880430737*^9}, {
  3.544548028192616*^9, 3.544548030833559*^9}, {3.7095474780040674`*^9, 
  3.709547478634387*^9}},
 CellLabel->
  "In[154]:=",ExpressionUUID->"27672ab5-03ea-44f2-bf68-4ea9eb30e829"],

Cell["\<\
where sequence2 uses the Mathematica Table function to construct a \
repetition. Although formally equivalent, computations of sequence1 use \
different algorithms to  sequence2, and will usually be faster.  \
\>", "Text",
 CellChangeTimes->{{3.544547888067634*^9, 3.54454791953318*^9}, {
  3.544547949704708*^9, 3.544548094424116*^9}, {3.544548136432825*^9, 
  3.5445481407266397`*^9}},ExpressionUUID->"7c1399b3-85de-4124-b298-\
3544171366fc"],

Cell["\<\
Repeat may contain events that are themselves Repeat instructions. \
\>", "Text",
 CellChangeTimes->{{3.544548102409825*^9, 3.544548116056072*^9}, {
  3.709547487744951*^9, 
  3.709547490123179*^9}},ExpressionUUID->"746a37ae-1eaa-4309-b747-\
1de03838d934"]
}, Closed]],

