Cell[CellGroupData[{

Cell["sequences of pulses and delays", "Subsection",
 CellChangeTimes->{{3.544379401151694*^9, 3.544379435793702*^9}, 
   3.8168538487718773`*^9, {3.816854122683815*^9, 3.816854132564571*^9}, {
