Cell[CellGroupData[{

Cell["instantaneous transformations", "Subsection",
 CellChangeTimes->{{3.544359859953731*^9, 
  3.544359880360364*^9}},ExpressionUUID->"836f24b5-e924-4de9-b2a1-\
b46e54bafee6"],

Cell["\<\
SpinDynamica supports some events which act instantaneously and last an \
infinitesimal amount of time. These are specified as superoperators. \
\>", "Text",
 CellChangeTimes->{{3.544379357479244*^9, 
  3.544379421470456*^9}},ExpressionUUID->"a400b4e1-aca4-4652-bcab-\
02b9c36e15b8"],

Cell[CellGroupData[{

Cell["RotationSuperoperator", "Subsubsection",
 CellChangeTimes->{{3.544379401151694*^9, 
  3.544379407239154*^9}},ExpressionUUID->"d4be3399-22a2-433e-ad76-\
dcb03eca286e"],

Cell["\<\
The symbol RotationSuperoperator causes an instantaneous rotation of one or \
more spins, through a defined axis and angle. This may be used to express the \
effect of an ideal, infinitely strong and short, radiofrequency pulse. 
Several different syntaxes are supported. \
\>", "Text",
 CellChangeTimes->{{3.544379441665528*^9, 3.5443795020427036`*^9}, {
  3.544379892933017*^9, 
  3.544379936046382*^9}},ExpressionUUID->"927f166a-70f9-4f33-94f7-\
4b651f2bcf1f"],

Cell["\<\
The syntax RotationSuperoperator[<spin label>,{angle,axis}] rotates a single \
spin about a specified axis, for example\
\>", "Text",
 CellChangeTimes->{{3.544379506638544*^9, 
  3.544379556716182*^9}},ExpressionUUID->"10f83d58-9816-486a-a465-\
36201e9f966d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"RotationSuperoperator", "[", 
  RowBox[{"1", ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Pi]", "/", "2"}], ",", "\"\<x\>\""}], "}"}]}], "]"}]], "Input",\

 CellChangeTimes->{{3.544379559699987*^9, 3.544379569233999*^9}},
 CellLabel->
  "In[118]:=",ExpressionUUID->"ed468da4-da60-4927-9936-9c5722026d22"],

