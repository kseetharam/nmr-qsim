   3.544370456344334*^9}},ExpressionUUID->"c16ccbee-9d8b-40f1-bc2b-\
3a9f07e7efd8"],

Cell[TextData[{
 "In ",
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 " the symbol ",
 StyleBox["opI",
  FontWeight->"Bold"],
 " handles most of the functionality of spin operators. "
}], "Text",
 CellChangeTimes->{{3.5443702310547457`*^9, 3.544370301914056*^9}, 
   3.544380803897625*^9, 3.544381407523819*^9, 
   3.574847882275888*^9},ExpressionUUID->"0cdbd7df-f9a0-483b-883f-\
872ba68e0881"],

Cell[TextData[{
 "I would have preferred to use the symbol ",
 StyleBox["I",
  FontWeight->"Bold"],
 " for the nuclear angular momentum operator, but ",
 StyleBox["I",
  FontWeight->"Bold"],
 " is already reserved as the imaginary number in ",
 StyleBox["Mathematica,",
  FontSlant->"Italic"],
 " for example:"
}], "Text",
 CellChangeTimes->{{3.544370309954721*^9, 3.544370356975738*^9}, 
   3.544371298135187*^9},ExpressionUUID->"1e2fc1ad-d9b3-47a0-be88-\
4bad81a34706"],

