Cell[TextData[{
 "Any of the huge range of mathematical functions built into ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " may be used in the definition of the modulation. "
}], "Text",
 CellChangeTimes->{{3.544376235164432*^9, 
  3.544376263404007*^9}},ExpressionUUID->"f9bcde64-d219-40d4-a136-\
95e4bcefe313"],

Cell[TextData[{
 "Note that the time variable in the examples above is a ",
 StyleBox["global time variable ",
  FontSlant->"Italic"],
 "taken relative to the time point ",
 StyleBox["t=0 ",
  FontSlant->"Italic"],
 "of the sequence of events you are analyzing. In many cases, you want to use \
a ",
 StyleBox["local time variable",
  FontSlant->"Italic"],
 " instead. This is described in part 2 of the documentation."
}], "Text",
 CellChangeTimes->{{3.789286880677584*^9, 
  3.78928698225254*^9}},ExpressionUUID->"5df77316-81db-4d3c-b904-\
1e1929b5caf7"]
}, Open  ]],

