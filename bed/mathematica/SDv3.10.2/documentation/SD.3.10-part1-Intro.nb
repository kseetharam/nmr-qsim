Cell[CellGroupData[{

Cell["spin systems", "Section",
 CellChangeTimes->{{3.54435961135287*^9, 3.544359628871992*^9}, {
  3.544359721544903*^9, 
  3.5443597307257843`*^9}},ExpressionUUID->"cb6440eb-cdef-4442-8160-\
4f76cbfdc4a6"],

Cell[TextData[{
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 " sets up a computational environment based on small numbers of coupled \
spins. You need to tell ",
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 " what the spin system is before doing anything else. "
}], "Text",
 CellChangeTimes->{{3.54437763055672*^9, 
  3.544377672546232*^9}},ExpressionUUID->"547efe61-e271-42f4-b141-\
fc9bf78e7bf6"],

Cell[TextData[{
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 " runs slowly and needs a lot of memory for more than about 6 spins. It is \
not optimized for large spin simulations. "
}], "Text",
 CellChangeTimes->{{3.544377690042226*^9, 3.5443777128233356`*^9}, {
  3.544413345921252*^9, 
  3.544413346220973*^9}},ExpressionUUID->"6bbb2ffc-3a20-4561-a2a8-\
9bc9965c1f92"],

Cell[CellGroupData[{

Cell[TextData[StyleBox["SetSpinSystem",
 FontWeight->"Bold"]], "Subsection",
 CellChangeTimes->{{3.54436910484036*^9, 3.54436912900701*^9}, 
   3.544377626716278*^9},ExpressionUUID->"53860a66-ec57-4e0f-a04b-\
8d58d33cd22c"],

Cell[TextData[{
 "To start using ",
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 " you need to define the spin system you are working with. This is done with \
the command ",
 StyleBox["SetSpinSystem. ",
  FontWeight->"Bold"]
}], "Text",
 CellChangeTimes->{{3.544368885655274*^9, 3.54436889243661*^9}, {
  3.54436901372359*^9, 3.544369049943773*^9}, {3.544370095110139*^9, 
  3.544370095764268*^9}},ExpressionUUID->"0a9e0df0-d3fd-4ebe-a2d4-\
482189839c84"],

Cell[TextData[{
 "In ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " commands are defined to handle many different syntax constructions, which \
overlay one another. For example, ",
 StyleBox["SetSpinSystem",
  FontWeight->"Bold"],
 " may be used in at least two different ways"
}], "Text",
 CellChangeTimes->{{3.544370098940194*^9, 
  3.5443701530011044`*^9}},ExpressionUUID->"615b7e29-27ff-4ea8-99c9-\
497a2d3a6468"],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["SetSpinSystem",
  FontWeight->"Bold"],
 ": general syntax"
}], "Subsubsection",
 CellChangeTimes->{{3.54436910484036*^9, 
  3.54436912900701*^9}},ExpressionUUID->"041a5b61-10bb-4209-bfdd-\
a79b90d86510"],

Cell[TextData[{
 "The most general syntax is\n",
 StyleBox["SetSpinSystem[\n\t{\t{<spin label #1>,<spin quantum number #1>}, \n\
\t\t{<spin label #2>,<spin quantum number #2>}\n\t\t...\n\t}]\n",
  FontWeight->"Bold"],
 "which tells ",
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 StyleBox[" ",
  FontWeight->"Bold"],
 "what the spins are called and what their spin quantum numbers are. For \
example:",
 StyleBox["\t",
  FontWeight->"Bold"]
}], "Text",
 CellChangeTimes->{{3.544369087997899*^9, 3.544369092790071*^9}, {
  3.544369142931804*^9, 
  3.544369266331036*^9}},ExpressionUUID->"3d3860da-0d43-488e-8326-\
b2820193d9a6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"SetSpinSystem", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\"\<I\>\"", ",", 
      RowBox[{"1", "/", "2"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"\"\<S\>\"", ",", 
      RowBox[{"3", "/", "2"}]}], "}"}]}], "}"}], "]"}]], "Input",
 CellChangeTimes->{{3.5443692694908457`*^9, 3.544369286845113*^9}},
 CellLabel->"In[14]:=",ExpressionUUID->"4bad006a-55b9-423c-adce-c27c4a565428"],

