Cell["\<\
another way of doing this shown below: First clear the definitions for the \
frequencies:\
\>", "Text",
 CellChangeTimes->{{3.616744385280387*^9, 3.616744404326778*^9}, {
  3.7095467870672646`*^9, 
  3.709546788555635*^9}},ExpressionUUID->"87a1b212-6cd7-404a-bea1-\
29b6f287d572"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   SubscriptBox["\[CapitalOmega]", "1"], "=."}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   SubscriptBox["\[CapitalOmega]", "2"], "=."}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   SubscriptBox["J", "12"], "=."}], ";"}]}], "Input",
 CellChangeTimes->{{3.616751063739751*^9, 3.61675109450918*^9}},
 CellLabel->"In[49]:=",ExpressionUUID->"50f139c6-dc1d-4f3c-9ae4-d40ac9b8ea0a"],

Cell["and define a set of substitution rules:", "Text",
 CellChangeTimes->{{3.6167511198677588`*^9, 3.616751130341871*^9}, {
  3.616751280572543*^9, 
  3.616751280965103*^9}},ExpressionUUID->"80a3c116-6f2c-4f34-9199-\
2e3cc85accd7"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"parameters", "=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{
     SubscriptBox["\[CapitalOmega]", "1"], "\[Rule]", 
     RowBox[{"2", "\[Pi]", " ", "100"}]}], ",", " ", 
    RowBox[{
     SubscriptBox["\[CapitalOmega]", "2"], "\[Rule]", 
     RowBox[{"2", "\[Pi]", " ", "50"}]}], ",", " ", 
