34076854f9f3"],

Cell[CellGroupData[{

Cell[TextData[{
 "install ",
 StyleBox["SpinDynamica",
  FontSlant->"Italic"]
}], "Subsection",
 CellChangeTimes->{{3.5443641699881887`*^9, 3.544364179699353*^9}, {
  3.544381276256859*^9, 3.544381282647319*^9}, {3.789284585328868*^9, 
  3.789284585781183*^9}},ExpressionUUID->"297a5c39-40b3-4771-9ac0-\
251773a0cb1b"],

Cell[TextData[{
 "download the zip file from  ",
 ButtonBox["www.spindynamica.soton.ac.uk",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://www.spindynamica.soton.ac.uk"], None},
  ButtonNote->"http://www.spindynamica.soton.ac.uk"],
 " and unpack it. Place the entire SpinDynamica directory at any desired \
location on your computer. "
}], "Text",
 CellChangeTimes->{{3.5443641983037357`*^9, 
  3.544364241350045*^9}},ExpressionUUID->"96bfbaa2-7d21-4116-89c2-\
67eaacabea03"]
}, Closed]],

Cell[CellGroupData[{

Cell["set $Path", "Subsection",
 CellChangeTimes->{{3.5443641699881887`*^9, 3.544364190290912*^9}, {
   3.789284583154743*^9, 3.789284583590458*^9}, 3.9490385822041187`*^9},
 CellTags->
  "setting $Path",ExpressionUUID->"589e1821-9a6d-41ae-8f34-2bd6055a2463"],

Cell[TextData[{
 "To run SpinDynamica you have to inform the ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " kernel where it is located. This can be done locally within the notebook \
you are working on, or globally for all ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " sessions started on your computer.  "
}], "Text",
 CellChangeTimes->{{3.544364246960327*^9, 
  3.544364336826374*^9}},ExpressionUUID->"346f8a75-0e35-47dc-9134-\
46b8c5311c17"],

Cell[CellGroupData[{

Cell["local (instructions in the same notebook)", "Subsubsection",
 CellChangeTimes->{{3.544364339916782*^9, 3.5443643427703886`*^9}, {
  3.544368745391081*^9, 
  3.5443687531708508`*^9}},ExpressionUUID->"21cc4127-1e78-44fe-8b7e-\
5c9a22fa2316"],

Cell[TextData[{
 "$Path is the ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " variable that tells the ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " kernel where to locate the files it needs. If you execute $Path you should \
see something like this:"
}], "Text",
 CellChangeTimes->{{3.544364349834369*^9, 3.544364350250147*^9}, {
  3.544364466123471*^9, 
  3.544364522566843*^9}},ExpressionUUID->"248bea68-263b-48d0-b14d-\
c7a4a8572f76"],

