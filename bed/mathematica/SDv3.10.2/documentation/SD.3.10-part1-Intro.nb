Cell[CellGroupData[{

Cell["Cartesian tensor product", "Subsubsection",
 CellChangeTimes->{{3.544370389219353*^9, 3.544370409457418*^9}, {
  3.544370874073452*^9, 3.5443708747682047`*^9}, {3.544370927261118*^9, 
  3.544370941980739*^9}, {3.544371108217072*^9, 3.544371110213256*^9}, {
  3.6149291414575*^9, 3.614929162120321*^9}, {3.614929227968199*^9, 
  3.614929244287017*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"1bcee726-cada-4745-a2ea-316696be4289"],

Cell["\<\
The spin Hamiltonians of anisotropic interactions are often constructed by \
taking the dot product between spin operators and a second-rank Cartesian \
tensor, written as a 3\[Times]3 matrix. An example is as follows:\
\>", "Text",
 CellChangeTimes->{{3.6149286921024117`*^9, 3.614928860555089*^9}, {
  3.6149289998107777`*^9, 3.614929085962308*^9}, {3.614929315026866*^9, 
  3.614929329344132*^9}, {3.614929397919614*^9, 3.614929448676936*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"6705eccf-c0cc-4149-bc1c-817caae34480"],

Cell[BoxData[
 RowBox[{
  RowBox[{"matrix", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["m", "xx"], ",", 
       SubscriptBox["m", "xy"], ",", 
       SubscriptBox["m", "xz"]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["m", "yx"], ",", 
       SubscriptBox["m", "yy"], ",", 
       SubscriptBox["m", "yz"]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["m", "zx"], ",", 
       SubscriptBox["m", "zy"], ",", 
       SubscriptBox["m", "zz"]}], "}"}]}], "}"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.614928896465722*^9, 3.614928976308857*^9}},
 Background->RGBColor[1, 0.925, 0.925],
 CellLabel->"In[34]:=",ExpressionUUID->"54cd2c25-e3c2-428e-b345-ff74c4c93173"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"opI", "[", "1", "]"}], ".", "matrix", ".", 
  RowBox[{"opI", "[", "2", "]"}]}]], "Input",
 CellChangeTimes->{{3.614928979505108*^9, 3.614928986811479*^9}},
 CellLabel->"In[35]:=",ExpressionUUID->"268551cb-c2e4-4f51-abfe-eeab4f9b793b"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"(", 
    TagBox[
     RowBox[{
      TagBox[
       SubscriptBox["I", 
        RowBox[{"1", "x"}]],
       DisplayForm], 
      AdjustmentBox["\[Bullet]",
       BoxMargins->{{-0.3, 0}, {0, 0}}], 
      TagBox[
       SubscriptBox["I", 
        RowBox[{"2", "x"}]],
       DisplayForm]}],
     DisplayForm], ")"}], " ", 
   SubscriptBox["m", "xx"]}], "+", 
  RowBox[{
