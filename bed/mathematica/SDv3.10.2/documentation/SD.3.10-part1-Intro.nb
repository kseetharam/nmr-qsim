Cell[TextData[{
 "This has the same essential meaning as the ",
 StyleBox["Function",
  FontWeight->"Bold"],
 " syntax",
 StyleBox[" ",
  FontWeight->"Bold"],
 "described above, but with the period (in the case above 1/100 second) being \
specified as well. The information on the period is used by some of the \
internal routines of ",
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 " to make calculations more efficient and to reuse previous calculations. "
}], "Text",
 CellChangeTimes->{{3.5443763826966343`*^9, 3.544376559056587*^9}, {
  3.544376603609214*^9, 3.544376604596281*^9}, {3.544376753050019*^9, 
  3.544376754520765*^9}, {3.544377391395751*^9, 
  3.5443773973189583`*^9}},ExpressionUUID->"0f265467-9fdc-4ee5-8d23-\
ecd4751097e4"],

Cell[TextData[{
 "In general it is best to use ",
 StyleBox["PeriodicFunction",
  FontWeight->"Bold"],
 " instead of ",
 StyleBox["Function",
  FontWeight->"Bold"],
 " if the time-dependence is periodic and you know what the period is. \
However, it\[CloseCurlyQuote]s up to the user to specify the period \
correctly. If it is incorrectly specified, incorrect results may be \
generated. "
}], "Text",
 CellChangeTimes->{{3.544376540888595*^9, 3.544376542327374*^9}, {
  3.544376609313705*^9, 
  3.544376680244304*^9}},ExpressionUUID->"3a44df88-11ac-46ff-b01c-\
cd4de5705f78"],

Cell["\<\
PeriodicFunction works just like Function and may be evaluated at any time, \
for example\
\>", "Text",
 CellChangeTimes->{{3.544376687926502*^9, 
  3.544376704436392*^9}},ExpressionUUID->"23dc919c-d086-412e-a3e6-\
c6854c7ece2b"],

