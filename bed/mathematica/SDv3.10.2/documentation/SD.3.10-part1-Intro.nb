Cell[TextData[{
 "The last example shows that ",
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 " generates an error and informs you if a spin is used that does not belong \
to the current spin system. "
}], "Text",
 CellChangeTimes->{{3.544370628574959*^9, 
  3.544370671621951*^9}},ExpressionUUID->"045b2efb-796e-4906-828b-\
b9c4968cfb89"],

