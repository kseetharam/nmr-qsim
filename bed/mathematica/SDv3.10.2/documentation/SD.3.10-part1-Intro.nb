Cell["\<\
defines a cosine-modulated Gaussian pulse where the Gaussian envelope \
function is defined using a local time variable (with a time origin at the \
start of the event), but the cosine modulation function is defined using a \
global time variable. This syntax allows modulations to retain \
phase-coherence, even though they are applied at different times during a \
pulse sequence. \
\>", "Text",
 CellChangeTimes->{{3.544464973636594*^9, 3.5444651246487484`*^9}, {
  3.544465167765949*^9, 3.544465191261477*^9}, {3.54446526341437*^9, 
  3.544465280672508*^9}},ExpressionUUID->"d7589818-bae3-4447-b9ce-\
815708d46057"],

Cell["\<\
The durations of such events are calculated using Duration as usual:\
\>", "Text",
 CellChangeTimes->{{3.789287529538031*^9, 
  3.789287545073059*^9}},ExpressionUUID->"ec570e93-6395-4a79-9bd0-\
47d310d97507"],

