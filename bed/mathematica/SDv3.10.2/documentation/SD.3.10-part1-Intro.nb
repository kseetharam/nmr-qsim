  3.544465443848958*^9}},ExpressionUUID->"fee11fc2-a416-4fc3-b9d7-\
405b574ecaae"],

Cell[TextData[{
 "A time-dependent Hamiltonian defined by ",
 ButtonBox["Function",
  BaseStyle->"Hyperlink",
  ButtonData->"Function"],
 " may be paired with a time interval to specify an event, for example"
}], "Text",
 CellChangeTimes->{{3.544462660440214*^9, 3.54446269522932*^9}, {
  3.544463035026141*^9, 3.544463040000497*^9}, {3.54446324048441*^9, 
  3.544463240485268*^9}},ExpressionUUID->"5dd9058d-7809-4f49-874c-\
77c02c581416"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"T", "=", 
   RowBox[{"10", "^", 
    RowBox[{"-", "3"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"event1", "=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"Function", "[", 
     RowBox[{"t", ",", 
      RowBox[{"Evaluate", "[", 
       RowBox[{"2", "\[Pi]", " ", "200", 
        RowBox[{"opI", "[", "\"\<x\>\"", "]"}], 
        RowBox[{"Cos", "[", 
         RowBox[{"2", "\[Pi]", " ", "100", " ", "t"}], "]"}]}], "]"}]}], 
     "]"}], ",", "T"}], "}"}]}]}], "Input",
 CellChangeTimes->{{3.544462698107684*^9, 3.544462755487043*^9}, {
   3.544462880926053*^9, 3.5444628839829817`*^9}, 3.544463265358247*^9, {
   3.657728609811777*^9, 3.6577286137900267`*^9}},
 CellLabel->
  "In[137]:=",ExpressionUUID->"213bf816-2a18-4309-8960-20daeefcd7c6"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"Function", "[", 
    RowBox[{"t", ",", 
     RowBox[{"400", " ", "\[Pi]", " ", 
      RowBox[{"Cos", "[", 
       RowBox[{"200", " ", "\[Pi]", " ", "t"}], "]"}], " ", 
      RowBox[{"(", 
       RowBox[{
        TagBox[
         SubscriptBox["I", 
          RowBox[{"1", "x"}]],
         DisplayForm], "+", 
        TagBox[
         SubscriptBox["I", 
          RowBox[{"2", "x"}]],
         DisplayForm], "+", 
        TagBox[
         SubscriptBox["I", 
          RowBox[{"3", "x"}]],
         DisplayForm]}], ")"}]}]}], "]"}], ",", 
   FractionBox["1", "1000"]}], "}"}]], "Output",
 CellChangeTimes->{{3.544462752103109*^9, 3.544462756156721*^9}, 
   3.5444628850015097`*^9, 3.544463266184578*^9, 3.544547443779653*^9, 
   3.544594585356039*^9, 3.54460444522563*^9, 3.5447917044546146`*^9, 
