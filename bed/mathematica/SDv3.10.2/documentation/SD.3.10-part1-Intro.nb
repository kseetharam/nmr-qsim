Cell[TextData[{
 "This shows that the Cartesian product operator 4",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["I", 
     RowBox[{"1", "x"}]], 
    SubscriptBox["I", 
     RowBox[{"2", "y"}]], 
    SubscriptBox["I", 
     RowBox[{"3", "y"}]]}], TraditionalForm]],ExpressionUUID->
  "ec728837-973d-4ee6-b986-fb896bc1ce73"],
 " contains (-1/2) times the three-quantum operator ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["I", "1", "+"], 
    SubsuperscriptBox["I", "2", "+"], 
    SubsuperscriptBox["I", "3", "+"]}], TraditionalForm]],ExpressionUUID->
  "4c83257f-0643-462d-917e-ed60340e98b7"],
