  BaseStyle->"Hyperlink",
  ButtonData->"$Chronology"],
 "\[CloseCurlyDoubleQuote]LeftToRight\[CloseCurlyDoubleQuote] is used, \
sequences of events are written in chronological order from ",
 "left to right",
 ". "
}], "Text",
