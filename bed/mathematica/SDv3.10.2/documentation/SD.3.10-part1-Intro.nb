8920ad60075d"],

Cell[TextData[{
 "If you just give ",
 StyleBox["SetSpinSystem",
  FontWeight->"Bold"],
 " a number, it will by default construct a spin system with that number of \
spins-1/2, labelled 1, 2, 3 .. etc. For example:"
}], "Text",
 CellChangeTimes->{{3.544369087997899*^9, 3.544369092790071*^9}, {
  3.544369928316368*^9, 3.544369959023774*^9}, {3.5443699966338987`*^9, 
