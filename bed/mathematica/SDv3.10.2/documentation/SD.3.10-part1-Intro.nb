Cell[TextData[{
 "the frequencies may be given numerical values, in units of rad\
\[NonBreakingSpace]",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["s", 
     RowBox[{"-", "1"}]], "."}], TraditionalForm]],ExpressionUUID->
  "a40ca007-568e-4299-b185-526e66dc1bc5"],
 " The following assignments set ",
 Cell[BoxData[
  SubscriptBox["\[CapitalOmega]", "1"]],
  CellChangeTimes->{{3.544375834896636*^9, 3.5443758690848007`*^9}},
  ExpressionUUID->"9dd0f969-0dec-425a-af3d-a2b34a03dce7"],
 " to 100 Hz, ",
 Cell[BoxData[
  SubscriptBox["\[CapitalOmega]", "2"]],
  CellChangeTimes->{{3.544375834896636*^9, 3.5443758690848007`*^9}},
  ExpressionUUID->"8cb0b341-1c20-4fae-8dd0-5ad242acb7aa"],
 " to 50 Hz, and ",
 Cell[BoxData[
  SubscriptBox["J", "12"]],
  CellChangeTimes->{{3.544375834896636*^9, 3.5443758690848007`*^9}},
  ExpressionUUID->"c68f78de-73c0-4592-a958-f9b2fa9b1c5e"],
 " to 20 Hz:"
}], "Text",
 CellChangeTimes->{{3.616751169966383*^9, 
  3.616751269298195*^9}},ExpressionUUID->"4daa78e8-8a61-4a6d-8cd3-\
1037340aa699"],

