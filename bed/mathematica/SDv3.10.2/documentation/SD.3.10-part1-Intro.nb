Cell[CellGroupData[{

Cell["about SpinDynamica", "Section",
 CellChangeTimes->{{3.54435961135287*^9, 
  3.544359638758511*^9}},ExpressionUUID->"da09a657-291e-4122-a3f5-\
be16f6967ebd"],

Cell[TextData[{
 "SpinDynamica is a set of ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " routines for spin dynamical calculations, programmed by Malcolm Levitt \
over about 15 years. The aim of SpinDynamica is to provide a convenient and \
flexible numeric & symbolic platform for a very wide range of spin dynamical \
calculations in magnetic resonance, embedded in the powerful symbolic, \
computational and graphical environment provided by ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 ". "
}], "Text",
 CellChangeTimes->{{3.544360047035702*^9, 3.544360126480299*^9}, {
   3.544360167460754*^9, 3.544360255679728*^9}, {3.544360288052086*^9, 
   3.544360319585131*^9}, {3.544360455660133*^9, 3.544360472474537*^9}, {
   3.544412527505041*^9, 3.544412559296817*^9}, {3.545042887503911*^9, 
   3.545042896816412*^9}, 
   3.564598365175675*^9},ExpressionUUID->"bad2bcd1-3bd0-4ce5-a6cc-\
a1feff733b13"],

Cell[TextData[{
 "It is recommended to read our article on ",
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 " before using it, see doi.org/10.1002/mrc.4642"
}], "Text",
 CellChangeTimes->{{3.816849797628506*^9, 
  3.816849833008111*^9}},ExpressionUUID->"0f3fdebd-2418-42d1-b6fb-\
1146e54cc6ce"],

