Cell[CellGroupData[{

Cell["getting started", "Section",
 CellChangeTimes->{{3.54435961135287*^9, 
  3.544359614640751*^9}},ExpressionUUID->"abbb7014-0cff-4918-9218-\
dab9b40bdce6"],

Cell[TextData[{
 "Before starting with SpinDynamica you should familiarize yourself with ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " and its basic functionality. There are tutorials on the Wolfram website. \
The learning curve for ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " is quite steep but it is worth it. "
}], "Text",
 CellChangeTimes->{{3.544363994113643*^9, 3.54436403465611*^9}, {
  3.5443641154954*^9, 3.544364127685561*^9}, {3.544413296807768*^9, 
  3.544413318021525*^9}},ExpressionUUID->"027a8cca-e735-416a-8cba-\
fdc7822a2c02"],

Cell[TextData[{
 "To start SpinDynamica you need to: \n\t(1) install ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " and a license; \n\t(2) install ",
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 " \n\t(3) inform ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " where ",
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 " is located, by setting $Path; \n\t(4) load ",
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 " "
}], "Text",
 CellChangeTimes->{{3.544364134670019*^9, 3.544364166107555*^9}, {
  3.544380468513789*^9, 3.544380485967574*^9}, {3.544381229383484*^9, 
