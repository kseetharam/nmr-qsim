Cell[TextData[{
 "This shows the location of the current version of ",
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 " at the end of $Path. "
}], "Text",
 CellChangeTimes->{{3.544380587744323*^9, 
  3.5443806045588927`*^9}},ExpressionUUID->"b6faa104-5bae-4dfd-8bc7-\
