Cell[TextData[{
 "An arbitrarily time-dependent Hamiltonian is defined using the ",
 StyleBox["Function",
  FontWeight->"Bold"],
 " symbol of ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 ", for example"
}], "Text",
 CellChangeTimes->{{3.544375994159613*^9, 
