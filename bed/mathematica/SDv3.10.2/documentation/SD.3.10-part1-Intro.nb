Cell[CellGroupData[{

Cell["specifying an rf amplitude error", "Subsubsection",
 CellChangeTimes->{{3.816851274987287*^9, 3.816851279690624*^9}, 
   3.816851400338879*^9, {3.816851490919512*^9, 3.816851493409133*^9}, {
   3.816856060149412*^9, 3.816856074450877*^9}, {3.83778036273013*^9, 
   3.837780363521133*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"938b467f-098a-4dec-ad57-4bd7af7c0e50"],

Cell["\<\
Simulation of rf inhomogeneity effects requires that the rf amplitudes of \
pulses deviate from their nominal values. This deviation may be implemented \
by using the AmplitudeFactor option. \
\>", "Text",
 CellChangeTimes->{{3.816856323926148*^9, 
  3.816856371395107*^9}},ExpressionUUID->"8c0e1d90-af6f-45b0-936b-\
ad678968c4c8"],

Cell["\<\
AmplitudeFactor\[Rule]1 is the default and indicates that the rf field of the \
pulse is exactly as expected from its duration and flip angle. \
AmplitudeFactor\[Rule]0.9 indicates an rf field amplitude that is 10% weaker \
than its nominal value. \
\>", "Text",
 CellChangeTimes->{{3.816856077742062*^9, 3.816856200838221*^9}, 
   3.816856373810442*^9},ExpressionUUID->"6a1ff294-27ad-44b8-8979-\
3e16fefeb103"],

Cell["\<\
A finite pulse with flip angle \[Pi]/2, phase 0, nominal nutation frequency \
of 10kHz, but with an rf field deviating in amplitude by -10% is specified as \
follows:\
\>", "Text",
 CellChangeTimes->{{3.544378948458902*^9, 3.544378966769018*^9}, {
  3.544379043685028*^9, 3.544379061620667*^9}, {3.544550058002099*^9, 
  3.544550066657694*^9}, {3.816850966535419*^9, 3.816850976522173*^9}, {
  3.816851107719922*^9, 3.816851160458822*^9}, {3.816851497177545*^9, 
  3.816851501599999*^9}, {3.8168515740620537`*^9, 3.816851604109289*^9}, {
  3.816856393641609*^9, 
  3.816856424531118*^9}},ExpressionUUID->"2efdaee8-9784-4081-8e29-\
34ada4503aad"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"pulse", "=", 
  RowBox[{"Pulse", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\[Pi]", "/", "2"}], ",", "\"\<x\>\""}], "}"}], ",", 
    RowBox[{"NutationFrequency", "\[Rule]", 
     RowBox[{"2", "\[Pi]", " ", "10", " ", 
      SuperscriptBox["10", "3"]}]}], ",", 
    RowBox[{"AmplitudeFactor", "\[Rule]", "0.9"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.816851220286483*^9, 3.816851234989758*^9}, {
  3.816851608446891*^9, 3.81685162028479*^9}, {3.8168562118973227`*^9, 
  3.816856227025996*^9}},
 CellLabel->"In[80]:=",ExpressionUUID->"bd12673a-c3aa-4cbb-a3b8-05e425b2c8f5"],

Cell[BoxData[
 RowBox[{"Pulse", "[", 
  RowBox[{"Automatic", ",", 
   RowBox[{"{", 
    RowBox[{
     FractionBox["\[Pi]", "2"], ",", "\<\"x\"\>"}], "}"}], ",", 
   RowBox[{"NutationFrequency", "\[Rule]", 
    RowBox[{"20000", " ", "\[Pi]"}]}], ",", 
   RowBox[{"AmplitudeFactor", "\[Rule]", "0.9`"}]}], "]"}]], "Output",
 CellChangeTimes->{
  3.816851235648534*^9, 3.816851350687264*^9, 3.816851621274962*^9, 
   3.816853989016818*^9, {3.816856215338974*^9, 3.816856228187889*^9}, 
   3.816856277080008*^9, 3.837780367737221*^9, {3.910151825400051*^9, 
   3.910151840386011*^9}, 3.916897496247377*^9, 3.916897560272814*^9, 
   3.949039122275611*^9},
 CellLabel->"Out[80]=",ExpressionUUID->"c5018781-d1db-4089-93f0-dde731e32c8c"]
}, Open  ]],

Cell["\<\
The duration of such a pulse is the same as specified by the flip angle and \
the NutationFrequency\
\>", "Text",
 CellChangeTimes->{{3.816851664100203*^9, 3.816851710489599*^9}, {
  3.8168562384279003`*^9, 
  3.816856268430797*^9}},ExpressionUUID->"c93e3a89-aedd-462f-9e12-\
47b8f00a3aa5"],

