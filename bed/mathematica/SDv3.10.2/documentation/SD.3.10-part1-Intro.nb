Cell[CellGroupData[{

Cell["general time-dependent Hamiltonians", "Subsubsection",
 CellChangeTimes->{{3.54435961135287*^9, 3.544359628871992*^9}, {
   3.544359721544903*^9, 3.544359747254434*^9}, 3.54435989242558*^9, {
   3.544359960915506*^9, 3.544359986988394*^9}, {3.544375970824707*^9, 
   3.544375978692292*^9}, {3.544376315615467*^9, 3.54437632033388*^9}, 
   3.544379274749704*^9, {3.544463148470115*^9, 3.544463151358266*^9}, {
   3.816850320107925*^9, 3.8168503207270303`*^9}, {3.816850411622062*^9, 
   3.816850428325907*^9}, 3.816850818840517*^9},
 Background->RGBColor[1, 0.925, 0.925],
 CellTags->{
  "Function", 
   "PeriodicFunction"},ExpressionUUID->"28cda93d-bf4c-4e3a-9d41-fe1efa6551d8"],

Cell[TextData[{
 StyleBox["The ",
  FontSlant->"Italic"],
 "TimeDependentGeneratorFunction",
 StyleBox[" of SpinDynamica",
  FontSlant->"Italic"],
 " may be used to specify Hamiltonians (or other generators) which depend on \
both local and global time variables. For a description of how these time \
variables are used, see our article: doi.org/10.1002/mrc.4642, and also the \
description of time-dependent events below. "
}], "Text",
 CellChangeTimes->{{3.816850506481749*^9, 3.8168505579674473`*^9}, {
  3.81685059812907*^9, 3.816850668285469*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"d23cfffc-be9f-409a-8d52-227818870e9f"],

Cell["\<\
The time-dependent Hamiltonians described above may be converted to the more \
general TimeDependentGeneratorFunction form by using Expand:\
\>", "Text",
 CellChangeTimes->{{3.81685068387677*^9, 3.816850718832591*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"7e14c825-841c-4110-99ef-d113d6df7c77"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Expand", "@", "PeriodicTimeDependentHamiltonian"}]], "Input",
 CellChangeTimes->{{3.949039054159243*^9, 3.949039055717402*^9}},
 CellLabel->"In[64]:=",ExpressionUUID->"d4b2930f-eef2-41ee-8952-a9aa80cc1bcf"],

