Cell[TextData[{
 "Note however that syntax such as ",
 StyleBox["SetSpinSystem[2]",
  FontWeight->"Bold"],
 " does not generate a spin system containing a single spin-2, but a set of \
two spins-1/2, as described above"
}], "Text",
 CellChangeTimes->{{3.640698156548828*^9, 
