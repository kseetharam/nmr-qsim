Cell["\<\
For example, the Hamiltonian for the dipole-dipole interaction between two \
spins, expressed in the principal axis frame of the dipole-dipole \
interaction, may be written as follows\
\>", "Text",
 CellChangeTimes->{{3.614929103092072*^9, 3.614929128264134*^9}, {
  3.614929166999135*^9, 3.6149291755035048`*^9}, {3.614929254760545*^9, 
