Cell[TextData[{
 "This defines a time-dependent Hamiltonian, proportional to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["I", "x"], TraditionalForm]],ExpressionUUID->
  "a80b02b1-114a-4646-921b-333563d7d57d"],
 ", and amplitude-modulated at 100 Hz, applied for an interval ",
 "T",
 ", which is set equal to 1 ms. "
}], "Text",
 CellChangeTimes->{{3.5444627603538837`*^9, 
  3.544462877482591*^9}},ExpressionUUID->"312cbc6c-87a4-4dbd-85c6-\
aaa9f5ad5df8"],

Cell[TextData[{
 "When using an event of this kind, care must be taken over the definition of \
the time variable t.  Consult the article at doi.org/10.1002/mrc.4642 for an \
explanation of time variables in ",
 StyleBox["SpinDynamica. ",
  FontSlant->"Italic"]
}], "Text",
 CellChangeTimes->{{3.544462865341385*^9, 3.544463102175668*^9}, {
  3.5444633394387293`*^9, 3.544463348429847*^9}, {3.544463455114345*^9, 
  3.544463486793601*^9}, {3.816849854975599*^9, 
  3.816849883524044*^9}},ExpressionUUID->"e864ec06-de4c-4157-bb48-\
fcd00da77255"],

Cell[TextData[{
 "An event specified in the way above uses a global time variable which \
increases through the entire sequence of events. The origin t=0 of the time \
variable depends on the context in which the sequence of events is used. In \
most cases t=0 is defined to be the start of the sequence of events.  However \
in some cases (for example,  Preparation in Signal1D,  t=0 is defined to be \
at the ",
 StyleBox["end",
  FontSlant->"Italic"],
 " of the sequence of events). "
}], "Text",
 CellChangeTimes->{{3.544462865341385*^9, 3.544463102175668*^9}, {
  3.5444633394387293`*^9, 3.544463348429847*^9}, {3.544463455114345*^9, 
  3.544463486793601*^9}, {3.816849854975599*^9, 3.816850042608969*^9}},
 Background->RGBColor[
  0.94, 0.88, 0.94],ExpressionUUID->"0067a9cd-9458-4cab-ba3a-3c1adec57758"]
}, Open  ]],

Cell[CellGroupData[{

Cell["PeriodicFunction events", "Subsubsection",
 CellChangeTimes->{{3.544462570428117*^9, 3.54446258319403*^9}, {
  3.544462620567831*^9, 3.54446264918418*^9}, {3.544463256517033*^9, 
