}, Open  ]],

Cell["You can also use symbols for the frequencies, for example:", "Text",
 CellChangeTimes->{{3.5443757389301867`*^9, 3.54437577625285*^9}, 
   3.616751166681589*^9, {3.657728377951178*^9, 3.657728378923801*^9}, 
   3.9168974455922832`*^9},ExpressionUUID->"a540e523-731c-467e-b945-\
be3ca69a490b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Hamiltonian", "=", 
  RowBox[{
   RowBox[{
    SubscriptBox["\[CapitalOmega]", "1"], " ", 
    RowBox[{"opI", "[", 
     RowBox[{"1", ",", "\"\<z\>\""}], "]"}]}], "+", 
   RowBox[{
    SubscriptBox["\[CapitalOmega]", "2"], " ", 
    RowBox[{"opI", "[", 
     RowBox[{"2", ",", "\"\<z\>\""}], "]"}]}], "+", 
   RowBox[{"2", "\[Pi]", " ", 
    SubscriptBox["J", "12"], " ", 
    RowBox[{
     RowBox[{"opI", "[", "1", "]"}], ".", 
     RowBox[{"opI", "[", "2", "]"}]}]}]}]}]], "Input",
 CellChangeTimes->{{3.544375785441774*^9, 3.544375825325629*^9}},
 CellLabel->"In[44]:=",ExpressionUUID->"b532a242-ba45-42c4-b57e-6fd97239e585"],

