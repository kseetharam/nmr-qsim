Cell[BoxData[{
 RowBox[{
  RowBox[{
   SubscriptBox["\[CapitalOmega]", "1"], " ", "=", 
   RowBox[{"2", "\[Pi]", " ", "100"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   SubscriptBox["\[CapitalOmega]", "2"], " ", "=", 
   RowBox[{"2", "\[Pi]", " ", "50"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   SubscriptBox["J", "12"], "=", "20"}], 
  ";"}], "\[IndentingNewLine]", "Hamiltonian"}], "Input",
 CellChangeTimes->{{3.544375834896636*^9, 3.5443758690848007`*^9}},
 CellLabel->"In[45]:=",ExpressionUUID->"88b8fe47-c87d-4439-9887-160fcfa591aa"],

