  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"None", ",", "0.1"}], "}"}], ",", 
    RowBox[{"RotationSuperoperator", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Pi]", "/", "2"}], ",", "0"}], "}"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"2", "\[Pi]", " ", 
       RowBox[{"opI", "[", "\"\<x\>\"", "]"}]}], ",", "0.2"}], "}"}]}], 
   "}"}]}]], "Input",
