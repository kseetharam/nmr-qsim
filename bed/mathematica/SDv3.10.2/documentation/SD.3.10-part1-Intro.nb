  3.5444654503048067`*^9}},ExpressionUUID->"25d523f3-6b7f-4190-8480-\
85c6964b1039"],

Cell[TextData[{
 "A ",
 ButtonBox["PeriodicFunction",
  BaseStyle->"Hyperlink",
  ButtonData->"PeriodicFunction"],
 " may be used to specify an event in the same way as ",
 ButtonBox["Function",
  BaseStyle->"Hyperlink",
  ButtonData->"Function"],
 ", for example: "
}], "Text",
 CellChangeTimes->{{3.544463363736221*^9, 
  3.544463408803595*^9}},ExpressionUUID->"274c149c-5c8b-4712-a3a1-\
30a244f2bd74"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"T", "=", 
   RowBox[{"10", "^", 
    RowBox[{"-", "3"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"event2", "=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"PeriodicFunction", "[", 
     RowBox[{"t", ",", 
      RowBox[{"1", "/", "100"}], ",", 
      RowBox[{"Evaluate", "[", 
       RowBox[{"2", "\[Pi]", " ", "200", 
        RowBox[{"opI", "[", "\"\<x\>\"", "]"}], 
        RowBox[{"Cos", "[", 
         RowBox[{"2", "\[Pi]", " ", "100", " ", "t"}], "]"}]}], "]"}]}], 
     "]"}], ",", "T"}], "}"}]}]}], "Input",
 CellChangeTimes->{{3.544462698107684*^9, 3.544462755487043*^9}, {
   3.544462880926053*^9, 3.5444628839829817`*^9}, 3.544463265358247*^9, {
   3.5444634197053547`*^9, 3.544463426596071*^9}, {3.65772862864482*^9, 
   3.657728632739627*^9}},
 CellLabel->
  "In[140]:=",ExpressionUUID->"d8cb44d2-9688-4231-9198-a99c3fb7dc41"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"PeriodicFunction", "[", 
    RowBox[{"t", ",", 
     FractionBox["1", "100"], ",", 
     RowBox[{"400", " ", "\[Pi]", " ", 
      RowBox[{"Cos", "[", 
       RowBox[{"200", " ", "\[Pi]", " ", "t"}], "]"}], " ", 
      RowBox[{"(", 
       RowBox[{
        TagBox[
         SubscriptBox["I", 
          RowBox[{"1", "x"}]],
         DisplayForm], "+", 
        TagBox[
         SubscriptBox["I", 
          RowBox[{"2", "x"}]],
         DisplayForm], "+", 
        TagBox[
         SubscriptBox["I", 
          RowBox[{"3", "x"}]],
         DisplayForm]}], ")"}]}]}], "]"}], ",", 
   FractionBox["1", "1000"]}], "}"}]], "Output",
 CellChangeTimes->{{3.544462752103109*^9, 3.544462756156721*^9}, 
   3.5444628850015097`*^9, 3.544463266184578*^9, 3.544463429695196*^9, 
   3.544547443812476*^9, 3.544594585386672*^9, 3.544604445262021*^9, 
   3.544791704504311*^9, 3.544791745618285*^9, 3.56457559609129*^9, 
   3.564811440058318*^9, 3.572631439109307*^9, 3.574259437480487*^9, 
   3.583347143540283*^9, 3.586353300223834*^9, 3.587554131181064*^9, 
   3.588071443121312*^9, 3.588071675305251*^9, 3.6058080944871483`*^9, 
   3.616751723628977*^9, 3.62058046289589*^9, 3.620580500877972*^9, 
   3.621573038297874*^9, 3.657728635298091*^9, 3.709547365373168*^9, 
   3.7119980364805098`*^9, 3.718534086696115*^9, 3.728129800807705*^9, 
   3.728129847338274*^9, 3.728392044693122*^9, 3.72863316683012*^9, 
   3.758303602211529*^9, 3.789287463849379*^9, 3.816522670135282*^9, 
   3.816848715678256*^9, 3.8168500607504263`*^9, 3.8377804643009233`*^9, 
   3.910151907077909*^9, 3.9168975607782793`*^9, 3.949039325523829*^9},
 CellLabel->
  "Out[141]=",ExpressionUUID->"3446b389-7042-43eb-ab99-6d2e9011ee0d"]
}, Open  ]],

Cell["\<\
This has the same effect as an event specified using Function, but with the \
difference that SpinDynamica is informed about the periodicity of the \
Hamiltonian and may use this information to improve the efficiency of the \
calculation. \
\>", "Text",
 CellChangeTimes->{{3.544463497930507*^9, 3.544463554597204*^9}, {
  3.544463694251792*^9, 
  3.544463696545485*^9}},ExpressionUUID->"3d425924-bf6a-4f3a-ac27-\
1facfdfbb200"],

Cell[TextData[{
 "The time variable in a {",
 ButtonBox["PeriodicFunction",
  BaseStyle->"Hyperlink",
  ButtonData->"PeriodicFunction"],
 ", interval} event works in the same way as in a {",
 ButtonBox["Function",
  BaseStyle->"Hyperlink",
  ButtonData->"Function"],
 ", interval} event.  "
}], "Text",
 CellChangeTimes->{{3.544463557072468*^9, 3.5444635998999043`*^9}, {
  3.544463639149178*^9, 
  3.544463677248895*^9}},ExpressionUUID->"244cf906-d44f-4656-ace1-\
e587c3fb8405"]
}, Open  ]],

Cell[CellGroupData[{

Cell["TimeDependentGeneratorFunction events", "Subsubsection",
 CellChangeTimes->{{3.544462570428117*^9, 3.544462590712843*^9}, {
   3.54446262642469*^9, 3.544462653647873*^9}, {3.544463611296722*^9, 
   3.544463615004216*^9}, {3.544465452540286*^9, 3.544465456008657*^9}, 
   3.816848669069767*^9, {3.81685009098599*^9, 3.81685009364523*^9}},
 Background->RGBColor[0.94, 0.88, 0.94],
 CellTags->
  "ShapeFunction",ExpressionUUID->"2caa4ca7-8f47-4c66-8868-d37495fe4255"],

Cell["\<\
Events based on Function and PeriodicFunction use a global time variable \
which increases through the entire sequence of events. However, in many \
cases, this is not what one wants. Consider, for example, a shaped pulse with \
a Gaussian amplitude function. It would be natural to define this using \
Function, for example:\
\>", "Text",
 CellChangeTimes->{{3.544463723036073*^9, 
  3.544463816915942*^9}},ExpressionUUID->"5a7cb831-26ae-41d7-a845-\
83299286549c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"IncorrectGaussianPulse", "=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"Function", "[", 
     RowBox[{"t", ",", 
      RowBox[{"Evaluate", "[", 
       RowBox[{"\[Omega]1max", " ", 
        RowBox[{"opI", "[", "\"\<x\>\"", "]"}], 
        RowBox[{"Exp", "[", 
         RowBox[{
          RowBox[{"-", "\[Sigma]"}], " ", 
          RowBox[{"t", "^", "2"}]}], "]"}]}], "]"}]}], "]"}], ",", "T"}], 
   "}"}]}]], "Input",
 CellChangeTimes->{{3.544463819396822*^9, 3.544463898546743*^9}, {
   3.54446411212868*^9, 3.5444641152218027`*^9}, 3.564575613106921*^9, {
   3.65772865880201*^9, 3.657728664283324*^9}},
 CellLabel->
  "In[142]:=",ExpressionUUID->"9e2301d1-bb89-4b03-b01a-6cdbb6fcb940"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"Function", "[", 
    RowBox[{"t", ",", 
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{
        RowBox[{"-", 
         SuperscriptBox["t", "2"]}], " ", "\[Sigma]"}]], " ", "\[Omega]1max", 
      " ", 
      RowBox[{"(", 
       RowBox[{
        TagBox[
         SubscriptBox["I", 
          RowBox[{"1", "x"}]],
         DisplayForm], "+", 
        TagBox[
         SubscriptBox["I", 
          RowBox[{"2", "x"}]],
         DisplayForm], "+", 
        TagBox[
         SubscriptBox["I", 
          RowBox[{"3", "x"}]],
         DisplayForm]}], ")"}]}]}], "]"}], ",", 
   FractionBox["1", "1000"]}], "}"}]], "Output",
 CellChangeTimes->{
  3.5645756136352663`*^9, 3.564811440119261*^9, 3.5726314391474543`*^9, 
   3.574259444562028*^9, 3.58334714357454*^9, 3.58635330025989*^9, 
   3.587554131220881*^9, 3.588071443171833*^9, 3.588071675345921*^9, 
   3.605808094518922*^9, 3.616751723661854*^9, 3.620580462928346*^9, 
   3.620580508733839*^9, 3.6215730423311367`*^9, {3.657728656361678*^9, 
   3.657728665200111*^9}, 3.709547376214478*^9, 3.7119980364990225`*^9, 
   3.718534086726548*^9, {3.728129817625832*^9, 3.728129847357462*^9}, 
   3.728392044720484*^9, 3.7286331668371615`*^9, 3.7583036022344694`*^9, 
   3.789287475762642*^9, 3.789288077402176*^9, 3.789288477660152*^9, 
   3.816522670143384*^9, 3.816848715685899*^9, 3.816850100103884*^9, 
   3.837780464311325*^9, 3.910151907083249*^9, 3.916897560781846*^9, 
   3.94903932553303*^9},
 CellLabel->
  "Out[142]=",ExpressionUUID->"723baf73-51f9-4742-a496-b873df2e3e88"]
}, Open  ]],

Cell["\<\
the intention here is to define a Gaussian-shaped pulse with maximum \
amplitude proportional to \[Omega]1max, with a time-domain width proportional \
to \[Sigma], and a total duration T. However, in general, this would not work \
properly, since the shape is defined using a global time variable t which is \
referenced to the sequence of events as a whole, and not to the event itself. \
The pulse would attain its maximum amplitude at the global time origin t=0, \
which might even be outside the event itself. \
\>", "Text",
 CellChangeTimes->{{3.54446390422744*^9, 3.54446409786101*^9}, {
  3.544464181553607*^9, 3.54446419673528*^9}, {3.544464436332293*^9, 
  3.544464467930915*^9}},ExpressionUUID->"002c1284-cf87-4c0e-ad24-\
160c7127498d"],

Cell["\<\
The symbol TimeDependentGeneratorFunction provides a way of defining events \
using a local time variable which is referenced to the event itself. The \
correct way of specifying a Gaussian pulse is as follows:\
\>", "Text",
 CellChangeTimes->{{3.544464202135953*^9, 3.54446426214132*^9}, 
   3.81684866912152*^9, {3.8168501501857433`*^9, 
   3.816850154679718*^9}},ExpressionUUID->"7b1a82f2-95e4-4502-b029-\
1c5642c97f29"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"GaussianPulse", "=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"TimeDependentGeneratorFunction", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"tloc", ",", 
        RowBox[{"1", "/", "2"}]}], "}"}], ",", 
      RowBox[{"Evaluate", "[", 
       RowBox[{"\[Omega]1max", " ", 
        RowBox[{"opI", "[", "\"\<x\>\"", "]"}], 
        RowBox[{"Exp", "[", 
         RowBox[{
          RowBox[{"-", "\[Sigma]"}], " ", 
          RowBox[{"tloc", "^", "2"}]}], "]"}]}], "]"}]}], "]"}], ",", "T"}], 
   "}"}]}]], "Input",
 CellChangeTimes->{{3.54446427050379*^9, 3.5444643377735643`*^9}, 
   3.564575616295518*^9, {3.6577286753307047`*^9, 3.657728679707573*^9}, 
   3.81684866912641*^9, 3.816850160130021*^9},
 CellLabel->
  "In[143]:=",ExpressionUUID->"a83a5b72-56a0-4149-9c17-d5b3c4a1bc79"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"TimeDependentGeneratorFunction", "[", 
    RowBox[{"SD`Generators`Private`t$107632", ",", 
     RowBox[{"{", 
      RowBox[{"{", 
       RowBox[{"tloc", ",", 
        FractionBox["1", "2"]}], "}"}], "}"}], ",", "All", ",", 
     RowBox[{
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"-", 
          SuperscriptBox["tloc", "2"]}], " ", "\[Sigma]"}]], " ", 
       "\[Omega]1max", " ", 
       TagBox[
        SubscriptBox["I", 
         RowBox[{"1", "x"}]],
        DisplayForm]}], "+", 
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"-", 
          SuperscriptBox["tloc", "2"]}], " ", "\[Sigma]"}]], " ", 
       "\[Omega]1max", " ", 
       TagBox[
        SubscriptBox["I", 
         RowBox[{"2", "x"}]],
        DisplayForm]}], "+", 
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"-", 
          SuperscriptBox["tloc", "2"]}], " ", "\[Sigma]"}]], " ", 
       "\[Omega]1max", " ", 
       TagBox[
        SubscriptBox["I", 
         RowBox[{"3", "x"}]],
        DisplayForm]}]}]}], "]"}], ",", 
   FractionBox["1", "1000"]}], "}"}]], "Output",
 CellChangeTimes->{3.81684871571704*^9, 3.816850165012387*^9, 
  3.837780464339366*^9, 3.910151907091389*^9, 3.9168975607850313`*^9, 
  3.9490393255380383`*^9},
 CellLabel->
  "Out[143]=",ExpressionUUID->"b13c085e-69dd-4750-a6e5-f8bf0ca6b315"]
}, Open  ]],

Cell["\<\
The syntax {tloc,1/2} in the specification above indicates the use of a local \
time variable with an origin (tloc=0) in the centre of the event. This syntax \
ensures that the maximum amplitude of the Gaussian pulse is attained at the \
exact centre of the event. \
\>", "Text",
 CellChangeTimes->{{3.544464317024456*^9, 
  3.544464409698352*^9}},ExpressionUUID->"a7db584f-2c0c-437e-bd59-\
7987daf44018"],

Cell["\<\
In general, the syntax is TimeDependentGeneratorFunction[{tloc,x}, \
<expression containing tloc>] where x is a number between 0 (specifying a \
time origin at the start of the event) and 1 (specifying a time origin at the \
end of the event. \
\>", "Text",
 CellChangeTimes->{{3.544464414049046*^9, 3.544464415464907*^9}, {
   3.544464483340399*^9, 3.5444645835421247`*^9}, {3.54446465595837*^9, 
   3.544464658989511*^9}, 3.816848669203651*^9, 
   3.816850178499761*^9},ExpressionUUID->"68188fb9-2c35-4944-8a88-\
8c454eb5d566"],

Cell["\<\
It is possible to use several different local time variables within the same \
event. The syntax TimeDependentGeneratorFunction[{{tloc1,x1},{tloc2,x2}}, \
<expression containing tloc1 and tloc2>] generates an event with a shape \
dependent on two different local time variables, which may have different \
time origins. For example, the syntax\
\>", "Text",
 CellChangeTimes->{{3.544464587926863*^9, 3.544464731379068*^9}, {
   3.5444647729236*^9, 3.544464788682551*^9}, 3.816848669253167*^9, 
   3.816850188335319*^9},ExpressionUUID->"37a351d1-8557-4a45-b185-\
a7accb8c1c06"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ModulatedGaussianPulse1", "=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"TimeDependentGeneratorFunction", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"tloc1", ",", 
          RowBox[{"1", "/", "2"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"tloc2", ",", "0"}], "}"}]}], "}"}], ",", 
      RowBox[{"Evaluate", "[", 
       RowBox[{"\[Omega]1max", " ", 
        RowBox[{"opI", "[", "\"\<x\>\"", "]"}], 
        RowBox[{"Exp", "[", 
         RowBox[{
          RowBox[{"-", "\[Sigma]"}], " ", 
          RowBox[{"tloc1", "^", "2"}]}], "]"}], 
        RowBox[{"Cos", "[", 
         RowBox[{"2", "\[Pi]", " ", "100", " ", "tloc2"}], "]"}]}], "]"}]}], 
     "\[IndentingNewLine]", "]"}], ",", "T"}], "}"}]}]], "Input",
 CellChangeTimes->{{3.54446427050379*^9, 3.5444643377735643`*^9}, {
   3.544464800005106*^9, 3.544464842259379*^9}, 3.544464923943858*^9, 
