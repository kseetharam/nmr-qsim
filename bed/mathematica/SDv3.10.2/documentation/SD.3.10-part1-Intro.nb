   3.583347143506353*^9, 3.58635330019263*^9, 3.587554131088998*^9, 
   3.5880714430705643`*^9, 3.5880716752226*^9, 3.605808094453814*^9, 
   3.616751723527078*^9, 3.620580462857568*^9, 3.620580495669142*^9, 
   3.621573035198014*^9, 3.6577286145844393`*^9, 3.709547347805413*^9, 
