Cell[CellGroupData[{

Cell["events: explicit syntax", "Section",
 CellChangeTimes->{{3.54435961135287*^9, 3.544359628871992*^9}, {
  3.544359721544903*^9, 3.5443597540943217`*^9}, {3.816850361373277*^9, 
  3.816850364452154*^9}, {3.816850892430049*^9, 3.816850899154366*^9}, {
  3.816855852644043*^9, 3.816855852842602*^9}, {3.816855966513257*^9, 
  3.816855967673074*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"636cd07f-9d77-484b-ab04-b9fd652a0d2a"],

Cell["\<\
Events may also be specified by an explicit syntax, in which Hamiltonians, \
Liouvillians, etc., and their durations, are specified. This allows full \
generality.  \
\>", "Text",
 CellChangeTimes->{{3.816855591622974*^9, 3.8168556361215477`*^9}, {
  3.816855974175626*^9, 
  3.81685598473772*^9}},ExpressionUUID->"c7ba6c56-b692-4b0e-b915-\
e2f765d718d9"],

Cell["\<\
Events with explicit syntax may be freely mixed with pulse sequence events. \
\>", "Text",
 CellChangeTimes->{{3.816855819700569*^9, 3.816855846347124*^9}, {
  3.8168559901890774`*^9, 
  3.816855991624531*^9}},ExpressionUUID->"9c6247b2-0b7d-4bd9-ad23-\
29e1a226e73b"],

