Cell[TextData[{
 "The routine ",
 StyleBox["OperatorAmplitude",
  FontWeight->"Bold"],
 " determines \[OpenCurlyDoubleQuote]how much\[CloseCurlyDoubleQuote] of one \
operator is found in another one. In general, ",
 StyleBox["OperatorAmplitude[a\[Rule]b]",
  FontWeight->"Bold"],
 " returns a value equal to how much of operator ",
 StyleBox["b",
  FontWeight->"Bold"],
 " is contained in operator ",
 StyleBox["a",
  FontWeight->"Bold"],
 ". "
}], "Text",
 CellChangeTimes->{{3.544553685459487*^9, 3.544553773334875*^9}, {
   3.544553861229269*^9, 3.54455387774743*^9}, {3.54455393226014*^9, 
   3.544553932436298*^9}, {3.614929529255603*^9, 3.614929530490223*^9}, 
   3.61492961182584*^9},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"7c11bab7-40eb-4612-9b1c-ce85ffaa3733"],

