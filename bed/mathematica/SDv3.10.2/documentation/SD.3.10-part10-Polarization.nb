Cell[TextData[{
 "The routines ",
 StyleBox["PolarizationLevelOperator",
  FontWeight->"Bold"],
 " and ",
 StyleBox["SingletPolarizationLevelOperator",
  FontWeight->"Bold"],
 " may be used to determine the level of polarization from a given density \
operator. They may also be used to simulate the polarization level under a \
sequence of events. "
}], "Text",
 CellChangeTimes->{{3.681108661285332*^9, 3.68110874426728*^9}, 
