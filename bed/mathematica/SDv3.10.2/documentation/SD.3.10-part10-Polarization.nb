Cell[CellGroupData[{

Cell[TextData[StyleBox["determining the polarization levels of a density \
operator",
 FontWeight->"Bold"]], "Subsection",
 CellChangeTimes->{{3.588074747297937*^9, 3.58807475427406*^9}, 
   3.681107655503767*^9, {3.68110876442845*^9, 
   3.68110877456396*^9}},ExpressionUUID->"4b8ff086-1e91-4d2c-b832-\
5a078901d547"],

Cell[TextData[{
 "A given density operator may be projected onto a ",
 StyleBox["PolarizationLevelOperator[..]",
  FontWeight->"Bold"],
 " to determine the corresponding degree of spin orientation along a certain \
axis. "
}], "Text",
 CellChangeTimes->{{3.681108777579522*^9, 3.6811088234797983`*^9}, {
  3.728213953306784*^9, 3.728214004025496*^9}, {3.72821408495247*^9, 
  3.728214091394145*^9}},ExpressionUUID->"4d0afb40-ebd9-4005-8489-\
df01312d3332"],

Cell["\<\
For example, consider the following density operator, which corresponds to \
full polarization along the z-axis\
\>", "Text",
 CellChangeTimes->{{3.681108828272808*^9, 
  3.6811088473525896`*^9}},ExpressionUUID->"0b24f199-e752-4e61-8e41-\
f1e09e3c87db"],

