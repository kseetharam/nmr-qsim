 RowBox[{
  RowBox[{"SetSpinSystem", "[", "1", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"\[Rho]eq", "=", 
  RowBox[{"ThermalEquilibriumDensityOperator", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"LarmorFrequency", "[", 
      RowBox[{"1", ",", "11.4"}], "]"}], " ", 
     RowBox[{"opI", "[", "\"\<z\>\"", "]"}]}], ",", "300"}], 
   "]"}]}]}], "Input",
