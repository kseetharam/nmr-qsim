Cell["\<\
The result is -1/3 since the singlet state is completely depleted if the spin \
system is completely polarized.\
\>", "Text",
 CellChangeTimes->{{3.681109029211243*^9, 
  3.681109049618989*^9}},ExpressionUUID->"b3fb12a8-f878-4e1f-93c0-\
1fa7dd6ef2dd"],

Cell[TextData[{
 StyleBox["PolarizationLevelOperators",
  FontWeight->"Bold"],
 " may also be used for determining the thermal equilibrium polarization \
level. The example below is for protons in a field of \
11.4\[NonBreakingSpace]T at 300\[NonBreakingSpace]K."
}], "Text",
 CellChangeTimes->{{3.68110907601259*^9, 3.6811090999455*^9}, {
  3.6811091740132027`*^9, 3.681109198998883*^9}, {3.728214155418001*^9, 
