Cell["\<\
This shows that the thermal polarization level of nuclear spins is very small.\
\>", "Text",
 CellChangeTimes->{{3.681111347555043*^9, 
  3.681111361538338*^9}},ExpressionUUID->"1374d304-fe45-4ae1-a4c6-\
045ab5dde407"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["simulating polarization levels",
 FontWeight->"Bold"]], "Subsection",
 CellChangeTimes->{{3.588074747297937*^9, 3.58807475427406*^9}, 
   3.681107655503767*^9, {3.68110876442845*^9, 3.68110877456396*^9}, {
   3.6811092174063597`*^9, 
   3.681109226631114*^9}},ExpressionUUID->"362bb3b7-36f1-42bb-a9d6-\
22523a72f2eb"],

Cell[TextData[{
 "The symbols ",
 StyleBox["PolarizationLevelOperator",
  FontWeight->"Bold"],
 " and ",
 StyleBox["SingletPolarizationLevelOperator",
  FontWeight->"Bold"],
 " may also be used in the simulation routines ",
 StyleBox["Trajectory",
  FontWeight->"Bold"],
 ", ",
 StyleBox["TransformationAmplitude",
  FontWeight->"Bold"],
 ", ",
 StyleBox["TransformationAmplitudeTable",
  FontWeight->"Bold"],
 ", and ",
 StyleBox["Signal1D",
  FontWeight->"Bold"],
 ". "
}], "Text",
 CellChangeTimes->{{3.681108777579522*^9, 3.6811088234797983`*^9}, {
  3.68110922964428*^9, 3.681109262730884*^9}, {3.7282142696735477`*^9, 
  3.728214272953047*^9}},ExpressionUUID->"3b03ac83-cb6a-4cef-ac7d-\
5ddf946a908a"],

Cell[TextData[{
 "In the example below, the system is prepared in a completely polarized \
state, and an rf field is applied to rotate the polarization. The evolution \
of the polarization level is followed using ",
 StyleBox["Trajectory",
  FontWeight->"Bold"],
 "."
}], "Text",
 CellChangeTimes->{{3.681108828272808*^9, 3.6811088473525896`*^9}, {
  3.681109281261725*^9, 3.681109328691148*^9}, {3.681111401287294*^9, 
  3.681111413480418*^9}},ExpressionUUID->"fc086c27-80cb-403d-b316-\
7cd1eddb6243"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SetSpinSystem", "[", "1", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Trajectory", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"PolarizedDensityOperator", "[", "]"}], "\[Rule]", 
    RowBox[{"PolarizationLevelOperator", "[", "]"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"2", "\[Pi]", " ", 
      RowBox[{"opI", "[", "\"\<x\>\"", "]"}]}], ",", "1"}], "}"}]}], 
  "\[IndentingNewLine]", "]"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"%", "[", "t", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "1"}], "}"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.6811088491280203`*^9, 3.68110885931251*^9}, {
  3.681109335387054*^9, 3.681109379778251*^9}, {3.728214238396763*^9, 
  3.728214239178088*^9}},
 CellLabel->"In[39]:=",ExpressionUUID->"396e1b3f-8298-4943-8636-34a55120c4a0"],

