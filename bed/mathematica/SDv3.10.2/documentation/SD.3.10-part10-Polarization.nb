Cell["\<\
In the example below, a 2-spin-1/2 system is prepared in a fully polarized \
state, and a rf field is applied to just one of the spins. The simulation \
shows how the polarization level and singlet polarization level evolve:\
\>", "Text",
 CellChangeTimes->{{3.6811094136524158`*^9, 
  3.681109468215167*^9}},ExpressionUUID->"c3e438ac-8c8e-42a2-97d6-\
513ff875af79"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SetSpinSystem", "[", "2", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"{", 
   RowBox[{"ztraj", ",", "straj"}], "}"}], "=", 
  RowBox[{"Trajectory", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"PolarizedDensityOperator", "[", "]"}], "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"PolarizationLevelOperator", "[", "]"}], ",", 
       RowBox[{"SingletPolarizationLevelOperator", "[", "]"}]}], "}"}]}], ",",
     "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"2", "\[Pi]", " ", 
       RowBox[{"opI", "[", 
