 RowBox[{
  RowBox[{"SetSpinSystem", "[", "3", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"\[Rho]", "=", 
  RowBox[{"PolarizedDensityOperator", "[", "]"}]}]}], "Input",
