Cell[CellGroupData[{

Cell["output of NDiagonalize", "Subsubsection",
 CellChangeTimes->{{3.586863559670701*^9, 3.58686357920504*^9}, {
  3.5868638969895678`*^9, 
  3.586863900725639*^9}},ExpressionUUID->"f52f450e-4780-4e52-b5ce-\
461d08c3f47a"],

Cell["\<\
The output of NDiagonalize, when applied to a superoperator, has the form \
Superoperator[{X,evals,Xinv}, opbasis, ...] where evals is the vector of \
eigenvalues, X is a matrix whose columns are the eigenvectors of the matrix \
representation of the superoperator in the operator basis opbasis, and Xinv \
is the inverse of X. The elements {X,evals,Xinv} may be inspected by applying \
First to the output of NDiagonalize.\
\>", "Text",
 CellChangeTimes->{{3.586862410072285*^9, 3.586862507015058*^9}, {
   3.58686306194773*^9, 3.586863068995619*^9}, {3.586863104068532*^9, 
   3.586863123539734*^9}, {3.586864220368934*^9, 3.586864258972683*^9}, 
   3.58686428975111*^9},ExpressionUUID->"9c710100-4b74-49dd-96a1-\
314f810c420b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"{", 
