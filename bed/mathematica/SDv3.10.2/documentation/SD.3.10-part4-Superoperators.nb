Cell["\<\
Any orthonormal set of operators may be defined by the user as an operator \
basis. For example, the following instructions take the basis operators for \
spin #1 in a ShiftAndZOperatorBasis, and multiply them by all basis operators \
for spin #2 in a CartesianProductOperatorBasis. This set of operators is used \
to construct a user-defined operator basis for Liouville space:\
\>", "Text",
 CellChangeTimes->{{3.575553149736061*^9, 3.575553292467414*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"447904e5-3eb6-47fb-9258-e6ffc28dde52"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"SetSpinSystem", "[", "2", "]"}], ";", 
  RowBox[{"ops1", "=", 
   RowBox[{"BasisOperators", "[", 
    RowBox[{"ShiftAndZOperatorBasis", "[", 
     RowBox[{"{", 
      RowBox[{"{", 
       RowBox[{"1", ",", 
        RowBox[{"1", "/", "2"}]}], "}"}], "}"}], "]"}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.5755532950409*^9, 3.5755533112781467`*^9}, {
