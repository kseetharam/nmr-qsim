Cell[TextData[{
 "Two operators are said to be ",
 StyleBox["orthogonal",
  FontSlant->"Italic"],
 " if their Liouville bracket is zero. "
}], "Text",
 CellChangeTimes->{{3.574351486178893*^9, 
  3.574351502464119*^9}},ExpressionUUID->"b2ec9e59-bd2b-49f4-b996-\
1a6640228405"],

Cell[CellGroupData[{

Cell["Liouville bracket for different numbers of spins", "Subsubsection",
 CellChangeTimes->{{3.574351450762384*^9, 3.5743514593613877`*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"8bef7fd9-81b3-409c-88d5-5187f2cb42f1"],

Cell["\<\
In general, the magnitude of the Liouville bracket depends on the dimension \
of the state space, and hence on the number of spins.\
\>", "Text",
 CellChangeTimes->{{3.574351376398624*^9, 3.574351406811214*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"2bfa6db0-5950-4fd3-b711-21b5669e7efc"],

