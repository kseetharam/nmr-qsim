Cell[CellGroupData[{

Cell["operator bases", "Section",
 CellChangeTimes->{{3.574351105440606*^9, 3.574351112824636*^9}, {
   3.574351529893618*^9, 3.574351548498556*^9}, 
   3.575551837278848*^9},ExpressionUUID->"045f8a96-7753-4107-aeae-\
0f1c50dc58c3"],

Cell[TextData[{
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 " includes a variety of preprogrammed operator bases. These bases are always \
",
 StyleBox["orthonormal",
  FontSlant->"Italic"],
 ", meaning that each operator is normalized, and the Liouville bracket of \
any operator with any other is zero. "
}], "Text",
 CellChangeTimes->{{3.574351562685174*^9, 3.5743515865614576`*^9}, {
  3.574353291501131*^9, 
  3.574353322813183*^9}},ExpressionUUID->"5cd25afc-6a34-4b8a-a84c-\
183473b23f3e"],

