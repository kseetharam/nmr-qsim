Cell[TextData[{
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 " provides routines for defining and manipulating superoperators and their \
matrix representations in Liouville space, using predefined operator bases, \
or user-defined operator bases."
}], "Text",
 CellChangeTimes->{{3.574272203212277*^9, 3.574272297327836*^9}, {
  3.574315803167053*^9, 
