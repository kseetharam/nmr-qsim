Cell[CellGroupData[{

Cell["SpinPermutationSuperoperator", "Subsection",
 CellChangeTimes->{{3.546622145292104*^9, 3.5466221510255404`*^9}, {
  3.5466229071018467`*^9, 3.5466229095177307`*^9}, {3.547014825474204*^9, 
  3.5470148301192493`*^9}, {3.574315936505316*^9, 3.574315940766502*^9}, {
  3.574316148054003*^9, 3.574316149274886*^9}, {3.574316311997029*^9, 
  3.574316313018879*^9}, {3.574316375982427*^9, 3.574316377125076*^9}, {
  3.588073391233093*^9, 3.588073399679438*^9}, {3.5906706730035963`*^9, 
  3.590670676001539*^9}},ExpressionUUID->"9c106486-990c-48b5-b94d-\
ce4f8f4926a6"],

Cell["\<\
SpinPermutationSuperoperator is the superoperator for a permutation of spins. \
The general syntax is SpinPermutationSuperoperator[{j,k,l,..m}] which \
indicates a cyclic permutation of spins, i.e. j\[Rule]k, k\[Rule]l, .., m\
\[Rule]j. \
\>", "Text",
 CellChangeTimes->{{3.547576801229944*^9, 3.547576846662156*^9}, {
  3.590670143392371*^9, 3.590670252225925*^9}, {3.59067069218242*^9, 
  3.590670700582244*^9}},ExpressionUUID->"1c035dd7-51a4-406d-8e56-\
1e86c673f7c7"],

Cell["\<\
For example, the effect of cyclically permuting the 3 spins in a product \
operator may be calculated as follows:\
\>", "Text",
 CellChangeTimes->{{3.590670725898082*^9, 
  3.5906707724315586`*^9}},ExpressionUUID->"41586bde-f1d3-4b55-aed2-\
31e15649b2af"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SetSpinSystem", "[", "3", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"SetOperatorBasis", "[", 
  RowBox[{"CartesianProductOperatorBasis", "[", "]"}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"SpinPermutationSuperoperator", "[", 
   RowBox[{"{", 
    RowBox[{"1", ",", "2", ",", "3"}], "}"}], "]"}], "[", 
  RowBox[{"4", " ", 
   RowBox[{
    RowBox[{"opI", "[", 
     RowBox[{"1", ",", "\"\<x\>\""}], "]"}], ".", 
    RowBox[{"opI", "[", 
     RowBox[{"2", ",", "\"\<y\>\""}], "]"}], ".", 
    RowBox[{"opI", "[", 
     RowBox[{"3", ",", "\"\<z\>\""}], "]"}]}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"SpinPermutationSuperoperator", "[", 
   RowBox[{"{", 
    RowBox[{"1", ",", "2", ",", "3"}], "}"}], "]"}], "[", "%", 
  "]"}], "\[IndentingNewLine]", 
