Cell[CellGroupData[{

Cell["ProjectionSuperoperator", "Subsection",
 CellChangeTimes->{{3.546622145292104*^9, 3.5466221510255404`*^9}, {
  3.5466229071018467`*^9, 3.5466229095177307`*^9}, {3.547014825474204*^9, 
  3.5470148301192493`*^9}, {3.574315936505316*^9, 3.574315940766502*^9}, {
  3.574316148054003*^9, 3.574316149274886*^9}, {3.574316311997029*^9, 
  3.574316313018879*^9}, {3.574316375982427*^9, 3.574316377125076*^9}, {
  3.588073391233093*^9, 3.588073399679438*^9}, {3.58807364283258*^9, 
  3.588073644366567*^9}},ExpressionUUID->"f97ca0d6-54f6-4dec-bf96-\
e839b7816ab9"],

Cell["\<\
ProjectionSuperoperator[op] removes the parts of an operator which are \
orthogonal to the operator op. \
\>", "Text",
 CellChangeTimes->{{3.588073647649838*^9, 
  3.588073703473937*^9}},ExpressionUUID->"1667262e-285a-4ba1-a18e-\
73d8e3c35fc7"],

Cell["\<\
For example, in a 2-spin system, the scalar product opI[1].opI[2] contains \
the term opI[1,\[CloseCurlyDoubleQuote]z\[CloseCurlyDoubleQuote]].opI[2,\
\[CloseCurlyDoubleQuote]z\[CloseCurlyDoubleQuote]] as well as orthogonal \
terms:\
\>", "Text",
 CellChangeTimes->{{3.588073712906551*^9, 
  3.588073779134459*^9}},ExpressionUUID->"94d6aede-2542-4542-8ba9-\
d464d99704cb"],

Cell[CellGroupData[{

