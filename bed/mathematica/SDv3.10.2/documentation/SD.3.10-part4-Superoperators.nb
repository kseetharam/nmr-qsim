Cell[CellGroupData[{

Cell["Lindbladian", "Subsection",
 CellChangeTimes->{{3.546622145292104*^9, 3.5466221510255404`*^9}, {
  3.5466229071018467`*^9, 3.5466229095177307`*^9}, {3.547014825474204*^9, 
  3.5470148301192493`*^9}, {3.574315936505316*^9, 3.574315940766502*^9}, {
  3.574316148054003*^9, 3.574316149274886*^9}, {3.816777374055336*^9, 
  3.816777383909443*^9}},
 Background->RGBColor[
  0.94, 0.88, 0.94],ExpressionUUID->"e9e64c52-4a7b-4071-b2d8-d35f81682911"],

Cell[TextData[{
 "The ",
 StyleBox["Lindbladian",
  FontSlant->"Italic"],
 " symbol generates a Lindbladian dissipation superoperator, as described in \
Bengs and Levitt, doi.org/10.1016/j.jmr.2019.106645. The Lindbladian \
dissipator ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox[
     RowBox[{"D", " "}], "^"], 
    RowBox[{"(", 
     RowBox[{"A", ",", "B"}], ")"}], " "}], TraditionalForm]],ExpressionUUID->
  "1e553a11-90c7-4908-876b-974f52843f18"],
 "depends on two operators, ",
 StyleBox["A",
  FontSlant->"Italic"],
 " and ",
 StyleBox["B",
  FontSlant->"Italic"],
 ", and when acting on an operator ",
 StyleBox["C",
  FontSlant->"Italic"],
 ", generates the following expression: ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox[
      RowBox[{"D", " "}], "^"], 
     RowBox[{"(", 
      RowBox[{"A", ",", "B"}], ")"}], " ", 
     RowBox[{"(", "C", ")"}]}], " ", "=", 
    StyleBox[" ",
     FontSlant->"Italic"], 
    RowBox[{
     StyleBox["ACB",
      FontSlant->"Italic"], 
     StyleBox["-",
      FontSlant->"Italic"], 
     RowBox[{
      StyleBox[
       FractionBox["1", "2"],
       FontSlant->"Italic"], 
      RowBox[{
       RowBox[{
        StyleBox["(",
         FontSlant->"Italic"], 
        RowBox[{
         StyleBox["BAC",
          FontSlant->"Italic"], 
         StyleBox["+",
          FontSlant->"Plain"], 
         StyleBox["CBA",
          FontSlant->"Italic"]}], 
        StyleBox[")",
         FontSlant->"Italic"]}], "."}]}]}]}], TraditionalForm]],
  ExpressionUUID->"758cf644-58e5-4254-a8d2-2a6e7c616899"],
 " Lindbladian superoperators provide a rigorous means to treat spin dynamics \
in the presence of relaxation through contact with an environment at finite \
temperature. See the relaxation part of  the documentation for examples. "
}], "Text",
 CellChangeTimes->{{3.546621936272396*^9, 3.54662197963421*^9}, 
   3.547014839382621*^9, {3.547016047995575*^9, 3.547016053039084*^9}, {
   3.574315944879149*^9, 3.574316031563871*^9}, {3.574316151763198*^9, 
   3.574316189987588*^9}, {3.574316240549229*^9, 3.574316248533568*^9}, {
   3.8167773877644243`*^9, 3.816777694499276*^9}, {3.816777727889311*^9, 
   3.8167777369993978`*^9}, {3.816777805584402*^9, 
   3.816777818257997*^9}},ExpressionUUID->"efc88b25-974e-4a54-b1b9-\
bc32f899b856"],

