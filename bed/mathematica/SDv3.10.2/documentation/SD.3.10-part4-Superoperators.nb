Cell[TextData[{
 "Superoperators may be secularized by using the ",
 StyleBox["Secularize",
  FontWeight->"Bold"],
 " operation in ",
 StyleBox["SpinDynamica. ",
  FontSlant->"Italic"],
 "Secularization removes superoperator matrix elements that connect operators \
with different coherence orders. In general, relaxation superoperators must \
usually be secularized before employing in spin dynamical calculations (see \
part 6 of the documentation)"
}], "Text",
 CellChangeTimes->{{3.575611027746936*^9, 3.5756110593302317`*^9}, {
  3.6305871716843247`*^9, 3.63058730723949*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"8d173fc2-9fd8-4fa5-9201-3e8845dfb967"]
