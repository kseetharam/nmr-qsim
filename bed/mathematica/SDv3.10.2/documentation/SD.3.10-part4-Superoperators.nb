Cell[CellGroupData[{

Cell["NDiagonalize in different operator bases", "Subsubsection",
 CellChangeTimes->{{3.586863559670701*^9, 
  3.5868635967721653`*^9}},ExpressionUUID->"a9413a95-4780-439e-a7d0-\
05d52f736a8e"],

Cell["\<\
The operator basis used for NDiagonalize may be specified explicitly. \
Although the form of the matrices X and Xinv depend on the operator basis, \
the superoperator output of NDiagonalize is basis independent: \
\>", "Text",
 CellChangeTimes->{{3.5868636116852427`*^9, 
  3.5868636522989893`*^9}},ExpressionUUID->"d640b148-b689-4db6-bc78-\
fb52b71737f6"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SetSpinSystem", "[", "1", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"OperatorBasis", "[", "]"}], "\[IndentingNewLine]", 
 RowBox[{"sop1", "=", 
  RowBox[{"NDiagonalize", "[", 
   RowBox[{
    RowBox[{"CommutationSuperoperator", "[", 
     RowBox[{"opI", "[", "\"\<x\>\"", "]"}], "]"}], ",", 
    RowBox[{"ShiftAndZOperatorBasis", "[", "]"}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"sop2", "=", 
  RowBox[{"NDiagonalize", "[", 
   RowBox[{
    RowBox[{"CommutationSuperoperator", "[", 
     RowBox[{"opI", "[", "\"\<x\>\"", "]"}], "]"}], ",", 
    RowBox[{"ZeemanKetBraOperatorBasis", "[", "]"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.586863663774083*^9, 3.586863703002965*^9}},
 CellLabel->
  "In[503]:=",ExpressionUUID->"701e1a2b-7f80-4cd1-af2b-ee3fe010c949"],

