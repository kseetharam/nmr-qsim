Cell["\<\
The trajectory of the two z-magnetizations, after inversion of one set of \
spins, is as follows:\
\>", "Text",
 CellChangeTimes->{{3.588078679882417*^9, 
  3.588078694881775*^9}},ExpressionUUID->"c9bd5168-4dcd-4716-ad04-\
aed99aaa2fc4"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"traj1z", ",", "traj2z"}], "}"}], "=", 
   RowBox[{"Trajectory", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"\[Rho]eq", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"opI", "[", 
         RowBox[{"1", ",", "\"\<z\>\""}], "]"}], ",", 
        RowBox[{"opI", "[", 
         RowBox[{"2", ",", "\"\<z\>\""}], "]"}]}], "}"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"None", ",", "5"}], "}"}], ",", 
       RowBox[{"Pulse", "[", 
        RowBox[{"1", ",", 
         RowBox[{"{", 
          RowBox[{"\[Pi]", ",", "\"\<x\>\""}], "}"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"None", ",", "100"}], "}"}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"BackgroundGenerator", "\[Rule]", "\[CapitalGamma]DDLB"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"NormalizationFactor", "\[Rule]", "Meq"}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
