Cell[TextData[{
 "Note the small excess of population in the |\[Alpha]> state relative to the \
|\[Beta]> state. The thermal equilibrium coefficient of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["I", "z"], TraditionalForm]],ExpressionUUID->
  "9a4f1f83-af2c-49f7-a346-d5a459907793"],
 " may be deduced by using ",
 StyleBox["OperatorAmplitude",
  FontWeight->"Bold"],
 ": "
}], "Text",
 CellChangeTimes->{{3.588075389617073*^9, 3.58807539617671*^9}, {
  3.588075461216261*^9, 
  3.588075520825428*^9}},ExpressionUUID->"14371ed7-446d-4eeb-b0b1-\
942d66b0dba9"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  StyleBox["Meq",
   FontWeight->"Bold"], 
  StyleBox["=",
   FontWeight->"Bold"], 
  RowBox[{
   StyleBox["OperatorAmplitude",
    FontWeight->"Bold"], 
   StyleBox["[",
    FontWeight->"Bold"], 
   RowBox[{"\[Rho]eq", "\[Rule]", 
    RowBox[{"opI", "[", "\"\<z\>\"", "]"}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
