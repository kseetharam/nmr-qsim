Cell["\<\
Note the transient enhancement of the magnetization on the non-inverted spin. \
This is a manifestation of the nuclear Overhauser effect.\
\>", "Text",
 CellChangeTimes->{{3.588078227149218*^9, 
  3.588078249950614*^9}},ExpressionUUID->"339b3246-5d07-4727-b2b8-\
7b61584455c6"]
}, Closed]],

Cell[CellGroupData[{

Cell["\<\
Dipole-dipole relaxation (extreme narrowing): heteronuclear case\
\>", "Subsection",
 CellChangeTimes->{{3.588074747297937*^9, 3.58807475427406*^9}, {
  3.588077054648101*^9, 3.588077057422089*^9}, {3.588077394437627*^9, 
  3.588077400179435*^9}, {3.58807768350244*^9, 3.588077686676529*^9}, {
  3.630587358823889*^9, 3.630587389532541*^9}},
 Background->None,ExpressionUUID->"7706cb85-cfee-41c9-b5c0-96ea18144c28"],

Cell[TextData[{
 "When heteronuclear spin systems are involved, it is necessary to secularize \
the relaxation superoperator against the Zeeman Hamiltonian before use. This \
is conveniently done using the ",
 StyleBox["Secularize",
  FontWeight->"Bold"],
 " routine of ",
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 ". "
}], "Text",
 CellChangeTimes->{{3.630587394869652*^9, 
  3.630587456060384*^9}},ExpressionUUID->"900ca68a-6e16-4eb1-be85-\
4a8416bbc313"],

Cell["\<\
