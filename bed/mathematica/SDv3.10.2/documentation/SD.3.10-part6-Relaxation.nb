Cell[TextData[{
 "Dipole-dipole relaxation may be simulated by summing ",
 StyleBox["DoubleCommutationSuperoperator",
  FontWeight->"Bold"],
 " terms involving the second-rank spherical tensor operators for the \
involved spins. For example, for 2 spins-1/2 with a DD coupling \[Omega]DD, \
in the extreme narrowing limit, the appropriate superoperator is as follows:"
}], "Text",
 CellChangeTimes->{{3.588077059666685*^9, 3.588077064326393*^9}, {
  3.5880770975637617`*^9, 3.588077196918937*^9}, {3.588077460115395*^9, 
  3.588077460479046*^9}, {3.5880776921036673`*^9, 
  3.588077757481617*^9}},ExpressionUUID->"28557d25-9873-4b77-9ce8-\
ad9f6390737f"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SetSpinSystem", "[", "2", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"\[CapitalGamma]DD", "=", 
  RowBox[{
   RowBox[{"-", 
    RowBox[{"(", 
     RowBox[{"6", "/", "5"}], ")"}]}], 
   SuperscriptBox["\[Omega]DD", "2"], "\[Tau]c", " ", 
   RowBox[{"Sum", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"-", "1"}], ")"}], "^", "m"}], " ", 
      RowBox[{"DoubleCommutationSuperoperator", "[", 
       RowBox[{
        RowBox[{"opT", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"1", ",", "2"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"2", ",", "m"}], "}"}]}], "]"}], ",", 
        RowBox[{"opT", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"1", ",", "2"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"2", ",", 
            RowBox[{"-", "m"}]}], "}"}]}], "]"}]}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"m", ",", 
       RowBox[{"-", "2"}], ",", "2"}], "}"}]}], "]"}]}]}]}], "Input",
