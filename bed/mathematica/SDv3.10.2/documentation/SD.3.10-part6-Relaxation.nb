Cell[TextData[{
 "The evolution of transverse magnetization under this relaxation \
superoperator is easily calculated using ",
 StyleBox["Trajectory",
  FontWeight->"Bold"],
 ":"
}], "Text",
 CellChangeTimes->{{3.588074710464368*^9, 
  3.588074761690422*^9}},ExpressionUUID->"d95c9e72-a427-4b86-92d3-\
13c3e7866e8f"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"trajx", "=", 
   RowBox[{"Trajectory", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"opI", "[", "\"\<x\>\"", "]"}], "\[Rule]", 
      RowBox[{"opI", "[", "\"\<x\>\"", "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"None", ",", "10"}], "}"}], ",", 
     RowBox[{"BackgroundGenerator", "\[Rule]", "\[CapitalGamma]"}]}], "]"}]}],
   ";"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"trajx", "[", "t", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "10"}], "}"}], ",", 
