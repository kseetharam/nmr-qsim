Cell[TextData[{
 "The result is conveniently scaled to the thermal equilibrium magnetization, \
by using ",
 StyleBox["NormalizationFactor",
  FontWeight->"Bold"],
 ": "
}], "Text",
 CellChangeTimes->{{3.588075800514186*^9, 
  3.588075822875022*^9}},ExpressionUUID->"a534c399-f26c-4870-86c1-\
2de7fd941990"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Hoff", "=", 
   RowBox[{"2", "\[Pi]", " ", "5", " ", 
    RowBox[{"opI", "[", "\"\<z\>\"", "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"trajz", "=", 
   RowBox[{"Trajectory", "[", 
    RowBox[{
     RowBox[{"\[Rho]eq", "\[Rule]", 
      RowBox[{"opI", "[", "\"\<z\>\"", "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"None", ",", 
         RowBox[{"1", "/", "2"}]}], "}"}], ",", 
       RowBox[{"RotationSuperoperator", "[", 
        RowBox[{"{", 
         RowBox[{"\[Pi]", ",", "\"\<x\>\""}], "}"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"None", ",", "10"}], "}"}]}], "}"}], ",", 
     RowBox[{"BackgroundGenerator", "\[Rule]", 
      RowBox[{"CombineGenerators", "[", 
       RowBox[{"Hoff", ",", "\[CapitalGamma]therm"}], "]"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"NormalizationFactor", "\[Rule]", "Meq"}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"trajz", "[", "t", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "10.5"}], "}"}], ",", 
   RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.588074896719246*^9, 3.588074918576542*^9}, {
  3.588074963523673*^9, 3.588074978241796*^9}, {3.588075020152771*^9, 
  3.588075025367127*^9}, {3.588075754527645*^9, 3.588075789830907*^9}, {
