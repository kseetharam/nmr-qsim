Cell["\<\
Note that the two magnetization components now recover back to their thermal \
equilibrium values, with a transient NOE developing on the non-inverted set \
of spins, immediately after the inversion. \
\>", "Text",
 CellChangeTimes->{{3.588078227149218*^9, 3.588078249950614*^9}, {
  3.588078398202031*^9, 3.588078412792614*^9}, {3.588078955601946*^9, 
  3.588078990860204*^9}, {3.588079027206356*^9, 
  3.588079031542576*^9}},ExpressionUUID->"52544741-7cf6-457b-9d49-\
02c7cd0010e7"]
}, Closed]],

Cell[CellGroupData[{

Cell["Dipole-dipole relaxation (with Lindblad thermalization)", "Subsection",
 CellChangeTimes->{{3.588074747297937*^9, 3.58807475427406*^9}, {
  3.588077054648101*^9, 3.588077057422089*^9}, {3.588077394437627*^9, 
  3.588077400179435*^9}, {3.58807768350244*^9, 3.588077686676529*^9}, {
  3.588078471114799*^9, 3.588078483749022*^9}, {3.816778361612398*^9, 
  3.81677839036604*^9}, {3.816779006951377*^9, 
  3.816779014540363*^9}},ExpressionUUID->"c3b9ea18-04b3-413d-ba2b-\
4d7b6fd37c71"],

Cell["\<\
The case of dipole-dipole relaxation may also be thermalized using \
Lindbladian superoperators. As discussed in Bengs and Levitt, \
doi.org/10.1016/j.jmr.2019.106645, this is more rigorous than the \
ThermalizeSuperoperator method, especially in the case of large amounts of \
spin order or far-from-equilibrium spin systems.\
\>", "Text",
 CellChangeTimes->{{3.588078487613492*^9, 3.5880785213992233`*^9}, {
   3.816778334533623*^9, 3.81677844952936*^9}, 3.816778961612742*^9, {
   3.816779038162402*^9, 
   3.816779056437787*^9}},ExpressionUUID->"510c8b26-53b0-4d6b-ba15-\
2f5f0a40afa0"],

Cell["\<\
Consider an ensemble of proton pairs, in a magnetic field of 11.7 T and a \
sample temperature of 300 Kelvin. The dipole-dipole coupling is -20 kHz, and \
the rotational correlation time 10 ps.\
\>", "Text",
 CellChangeTimes->{{3.816778969448097*^9, 3.816779002136613*^9}, {
  3.816779061541439*^9, 
  3.816779087837731*^9}},ExpressionUUID->"48edf4e8-5a16-414f-a92a-\
878f62fedf80"],

Cell[BoxData[
 RowBox[{
  RowBox[{"parameters", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"B0", "\[Rule]", "11.7"}], ",", " ", 
     RowBox[{"T", "\[Rule]", "300"}], ",", 
     RowBox[{"\[Omega]DD", "\[Rule]", 
      RowBox[{"2", "\[Pi]", " ", "20", " ", 
       RowBox[{"10", "^", "3"}]}]}], ",", 
     RowBox[{"\[Tau]c", "\[Rule]", 
      RowBox[{"10", " ", 
       SuperscriptBox["10", 
        RowBox[{"-", "12"}]]}]}]}], "}"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.816779091080653*^9, 3.816779137556512*^9}, 
   3.816779229947342*^9, 3.816844622376906*^9, {3.897157632704403*^9, 
   3.897157635959011*^9}},
 CellLabel->"In[75]:=",ExpressionUUID->"ff09eea6-67c3-4a53-ad5d-d6f05f5b8393"],

Cell["\<\
The Lindbladian form of the thermalized relaxation superoperator, in the \
extreme narrowing limit, is set up as follows:\
\>", "Text",
 CellChangeTimes->{{3.588077059666685*^9, 3.588077064326393*^9}, {
  3.5880770975637617`*^9, 3.588077196918937*^9}, {3.588077460115395*^9, 
  3.588077460479046*^9}, {3.5880776921036673`*^9, 3.588077757481617*^9}, {
  3.588078285474763*^9, 3.5880783077381477`*^9}, {3.588078525503663*^9, 
  3.5880785389682903`*^9}, {3.58807883535632*^9, 3.5880788380265512`*^9}, {
  3.81677846574118*^9, 3.8167784711376653`*^9}, {3.8167791584427853`*^9, 
  3.816779177896118*^9}, {3.816845633584737*^9, 
  3.816845639059581*^9}},ExpressionUUID->"af544209-8986-4c3e-a52c-\
0dab2df813fe"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SetSpinSystem", "[", "2", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"\[CapitalGamma]DDLB", "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"+", 
        RowBox[{"(", 
         RowBox[{"6", "/", "5"}], ")"}]}], 
       SuperscriptBox["\[Omega]DD", "2"], 
       RowBox[{"(", 
        RowBox[{"2", "\[Tau]c"}], ")"}], " ", 
       RowBox[{"Sum", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"-", "1"}], ")"}], "^", "m"}], " ", 
          RowBox[{"Lindbladian", "[", 
           RowBox[{
            RowBox[{"opT", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"1", ",", "2"}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"2", ",", "m"}], "}"}]}], "]"}], ",", 
            RowBox[{"opT", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"1", ",", "2"}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"2", ",", 
                RowBox[{"-", "m"}]}], "}"}]}], "]"}]}], "]"}], 
          RowBox[{"Exp", "[", 
           RowBox[{
            RowBox[{"-", 
             RowBox[{"(", 
              RowBox[{"1", "/", "2"}], ")"}]}], "m", " ", "\[HBar]", " ", 
            RowBox[{"\[Omega]0", "/", 
             RowBox[{"(", 
              RowBox[{"kB", " ", "T"}], ")"}]}]}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"m", ",", 
           RowBox[{"-", "2"}], ",", "2"}], "}"}]}], "]"}]}], "/.", 
      RowBox[{"{", 
       RowBox[{"\[Omega]0", "\[Rule]", 
        RowBox[{"LarmorFrequency", "[", 
         RowBox[{"1", ",", "B0"}], "]"}]}], "}"}]}], "/.", "parameters"}], "/.",
     "PhysicalConstantValues"}], "//", "N"}]}]}], "Input",
