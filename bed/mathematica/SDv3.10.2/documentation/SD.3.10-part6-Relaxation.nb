Cell["\<\
Note that the magnetization components now converge, as they equilibrate \
through cross-relaxation. \
\>", "Text",
 CellChangeTimes->{{3.588078227149218*^9, 3.588078249950614*^9}, {
  3.588078398202031*^9, 
  3.588078412792614*^9}},ExpressionUUID->"be703f03-941e-479d-ab7e-\
fea8e54ddf3d"],

Cell["\<\
The general relaxation superoperator for DD relaxation involves all of the \
terms used in the extreme narrowing case, but weighted by spectral densities. \
Consult the literature for the correct form. \
\>", "Text",
 CellChangeTimes->{{3.588078415618032*^9, 
  3.588078456027351*^9}},ExpressionUUID->"b3efea2b-c00c-4315-a3d7-\
326b5afd4f05"]
}, Closed]],

Cell[CellGroupData[{

Cell["\<\
Dipole-dipole relaxation (with thermalization using ThermalizeSuperoperator)\
\>", "Subsection",
 CellChangeTimes->{{3.588074747297937*^9, 3.58807475427406*^9}, {
  3.588077054648101*^9, 3.588077057422089*^9}, {3.588077394437627*^9, 
  3.588077400179435*^9}, {3.58807768350244*^9, 3.588077686676529*^9}, {
  3.588078471114799*^9, 3.588078483749022*^9}, {3.816778361612398*^9, 
  3.816778370364326*^9}},ExpressionUUID->"1181afc1-1bff-45c1-b915-\
81dadf47a8e4"],

Cell["\<\
The examples above are appropriate for an infinite sample temperature. For a \
finite temperature, the relaxation superoperator must be thermalized. This \
may be done either by using ThermalizeSuperoperator or by using Lindbladian \
superoperators. \
\>", "Text",
 CellChangeTimes->{{3.588078487613492*^9, 3.5880785213992233`*^9}, {
  3.816778334533623*^9, 
  3.816778376240884*^9}},ExpressionUUID->"d136ed03-936e-4bb8-856b-\
114f2b5a7783"],

Cell["Consider a extreme-narrowing-limit relaxation superoperator:", "Text",
 CellChangeTimes->{{3.588077059666685*^9, 3.588077064326393*^9}, {
  3.5880770975637617`*^9, 3.588077196918937*^9}, {3.588077460115395*^9, 
  3.588077460479046*^9}, {3.5880776921036673`*^9, 3.588077757481617*^9}, {
  3.588078285474763*^9, 3.5880783077381477`*^9}, {3.588078525503663*^9, 
  3.5880785389682903`*^9}, {3.58807883535632*^9, 
  3.5880788380265512`*^9}},ExpressionUUID->"741292c5-4e68-4d51-b959-\
2a282333815c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SetSpinSystem", "[", "2", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[CapitalGamma]DD", "=", 
   RowBox[{
    RowBox[{"-", 
     RowBox[{"(", 
      RowBox[{"6", "/", "5"}], ")"}]}], 
    SuperscriptBox["\[Omega]DD", "2"], "\[Tau]c", " ", 
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"-", "1"}], ")"}], "^", "m"}], " ", 
       RowBox[{"DoubleCommutationSuperoperator", "[", 
        RowBox[{
         RowBox[{"opT", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"1", ",", "2"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"2", ",", "m"}], "}"}]}], "]"}], ",", 
         RowBox[{"opT", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"1", ",", "2"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"2", ",", 
             RowBox[{"-", "m"}]}], "}"}]}], "]"}]}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"m", ",", 
        RowBox[{"-", "2"}], ",", "2"}], "}"}]}], "]"}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.588077201195537*^9, 3.588077312579234*^9}, 
   3.588077466955693*^9, {3.588077561973204*^9, 3.5880775628240232`*^9}, {
   3.588077760503139*^9, 3.588077820907819*^9}, {3.588078313474823*^9, 
