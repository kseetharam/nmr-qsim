Cell["\<\
Suppose that the DD coupling is 20 kHz, and the correlation time is 10 ps. If \
the laboratory frame Hamiltonian is appropriate for protons in a magnetic \
field of 11.7 T, and the sample temperature is 300 Kelvin, the thermalized \
relaxation superoperator is as follows:\
\>", "Text",
 CellChangeTimes->{{3.588077356811914*^9, 3.588077376706243*^9}, {
   3.588077407770508*^9, 3.588077437390153*^9}, {3.588077476049389*^9, 
   3.58807749294489*^9}, {3.588077570357916*^9, 3.588077570357993*^9}, {
   3.588077871591682*^9, 3.588077905841632*^9}, {3.58807809905359*^9, 
   3.588078150480771*^9}, {3.588078341535235*^9, 3.588078350061207*^9}, {
   3.588078549682279*^9, 3.588078598692092*^9}, 
   3.588078857733275*^9},ExpressionUUID->"dc4b8a56-7ad1-4384-baf3-\
1f222a197720"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"H0", "=", 
   RowBox[{
    RowBox[{"LarmorFrequency", "[", 
     RowBox[{"1", ",", "11.7"}], "]"}], 
    RowBox[{"opI", "[", "\"\<z\>\"", "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"\[CapitalGamma]DDtherm", "=", 
  RowBox[{"ThermalizeSuperoperator", "[", 
   RowBox[{
    RowBox[{"\[CapitalGamma]DD", "/.", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Omega]DD", "\[Rule]", 
        RowBox[{"2", "\[Pi]", " ", "20", " ", 
         RowBox[{"10", "^", "3"}]}]}], ",", 
       RowBox[{"\[Tau]c", "\[Rule]", 
        RowBox[{"10", " ", 
         SuperscriptBox["10", 
          RowBox[{"-", "12"}]]}]}]}], "}"}]}], ",", "H0", ",", "300"}], 
   "]"}]}]}], "Input",
 CellChangeTimes->{{3.588078605039322*^9, 3.588078640840926*^9}, {
  3.588078704462363*^9, 3.588078712100935*^9}, {3.588078861128047*^9, 
  3.5880788613359613`*^9}},
 CellLabel->"In[69]:=",ExpressionUUID->"9546e6e9-9ed6-4063-89be-da8eb5c96300"],

Cell[BoxData[
 TagBox[
  RowBox[{"\<\"Superoperator[<<..>>, \"\>", \
"\<\"SuperoperatorType\[Rule]\"\>", "None", "\<\"]\"\>"}],
  DisplayForm]], "Output",
 CellChangeTimes->{
  3.588078642382961*^9, 3.588078713653784*^9, 3.588078787853382*^9, {
   3.588078866133829*^9, 3.588078876577591*^9}, 3.6167584917318163`*^9, 
   3.621615024810891*^9, 3.640599762947981*^9, 3.640874711603449*^9, 
   3.657822152889364*^9, 3.659601983550499*^9, 3.709552643516631*^9, 
   3.7185357379319086`*^9, 3.728213384549053*^9, 3.7283929292043757`*^9, 
   3.728633742435634*^9, 3.7583062135868835`*^9, 3.8165237675428*^9, 
   3.816844550472917*^9, 3.816870093443578*^9, 3.827983079218865*^9, 
   3.837832865888245*^9, 3.837839847535435*^9, 3.838009666384775*^9, 
   3.897157162699427*^9, 3.897157669809187*^9, 3.9490550343764563`*^9, 
   3.9490723094569674`*^9},
 CellLabel->"Out[70]=",ExpressionUUID->"3fec46d9-9b51-43e1-bfc5-1640ea2d6d35"]
}, Open  ]],

Cell["\<\
As described above, this thermalization procedure is not rigorous for spin \
systems that are far from equilibrium or contain a large amount of spin \
order. The more rigorous Lindbladian procedure is demonstrated below. \
\>", "Text",
 CellChangeTimes->{{3.816778251443943*^9, 
  3.816778308830882*^9}},ExpressionUUID->"94f25501-23bb-4ba2-af24-\
89ac3ee2ce8e"],

Cell["\<\
The thermal equilibrium density operator under the same conditions is as \
follows:\
\>", "Text",
 CellChangeTimes->{{3.588078649856623*^9, 
  3.588078661095727*^9}},ExpressionUUID->"f0c34446-5bde-4cb5-b634-\
f03cf7badb1b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[Rho]eq", "=", 
  RowBox[{"ThermalEquilibriumDensityOperator", "[", 
   RowBox[{"H0", ",", "300"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.588078663100531*^9, 3.588078674398292*^9}},
 CellLabel->"In[71]:=",ExpressionUUID->"5535ba36-5f50-4924-8ae2-c5c5c6fb3860"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"Operator", "[", 
    RowBox[{
     RowBox[{"<<", ".."}], ">>"}]}], 
   RowBox[{",", " ", 
    RowBox[{"OperatorType", "\[Rule]", "\<\"Hermitian\"\>"}]}], " ", "]"}],
  DisplayForm]], "Output",
 CellChangeTimes->{3.588078675227157*^9, 3.588078720410658*^9, 
  3.588078787942325*^9, 3.588078876624255*^9, 3.616758491853553*^9, 
  3.621615024959453*^9, 3.640599762962689*^9, 3.640874711645483*^9, 
  3.657822155589642*^9, 3.6596019835910177`*^9, 3.709552643536274*^9, 
  3.718535737944442*^9, 3.7282133846287994`*^9, 3.72839292921741*^9, 
  3.728633742454184*^9, 3.758306213608826*^9, 3.816523767569218*^9, 
  3.816844550500289*^9, 3.81687009347493*^9, 3.827983079241302*^9, 
  3.837832865912616*^9, 3.837839847544203*^9, 3.838009666407624*^9, 
  3.897157162744308*^9, 3.89715766986205*^9, 3.9490550343794813`*^9, 
  3.949072309460073*^9},
 CellLabel->"Out[71]=",ExpressionUUID->"eb4077df-bb2f-47bc-a342-3d1c02bf8863"]
}, Open  ]],

Cell["The thermal equilibrium magnetization may be defined:", "Text",
 CellChangeTimes->{{3.588078904334453*^9, 
  3.588078914272428*^9}},ExpressionUUID->"a5a2b39d-8a6d-4134-b475-\
28dd54ef0228"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Meq", "=", 
   RowBox[{"OperatorAmplitude", "[", 
    RowBox[{"\[Rho]eq", "\[Rule]", 
     RowBox[{"opI", "[", 
      RowBox[{"1", ",", "\"\<z\>\""}], "]"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.5880789165702453`*^9, 3.588078935083491*^9}},
 CellLabel->"In[72]:=",ExpressionUUID->"90d3001e-7ec3-4117-a490-16d6a8b7bbbe"],

Cell["\<\
The trajectory of the two z-magnetizations, after inversion of one set of \
spins, is as follows:\
\>", "Text",
 CellChangeTimes->{{3.588078679882417*^9, 
  3.588078694881775*^9}},ExpressionUUID->"2cd008c3-6b89-4eb0-8a63-\
39fd77d77316"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"traj1z", ",", "traj2z"}], "}"}], "=", 
   RowBox[{"Trajectory", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"\[Rho]eq", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"opI", "[", 
         RowBox[{"1", ",", "\"\<z\>\""}], "]"}], ",", 
        RowBox[{"opI", "[", 
         RowBox[{"2", ",", "\"\<z\>\""}], "]"}]}], "}"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"None", ",", "5"}], "}"}], ",", 
       RowBox[{"RotationSuperoperator", "[", 
        RowBox[{"1", ",", 
         RowBox[{"{", 
          RowBox[{"\[Pi]", ",", "\"\<x\>\""}], "}"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"None", ",", "100"}], "}"}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"BackgroundGenerator", "\[Rule]", "\[CapitalGamma]DDtherm"}], 
     ",", "\[IndentingNewLine]", 
     RowBox[{"NormalizationFactor", "\[Rule]", "Meq"}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"traj1z", "[", "t", "]"}], ",", 
     RowBox[{"traj2z", "[", "t", "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "100"}], "}"}], ",", 
   RowBox[{"PlotRange", "\[Rule]", "All"}], ",", 
   RowBox[{"PlotStyle", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"Blue", ",", "Red"}], "}"}]}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.588077913882369*^9, 3.588078084635177*^9}, {
   3.588078153359593*^9, 3.588078163855542*^9}, {3.588078197626861*^9, 
   3.5880782168035393`*^9}, {3.5880783557636223`*^9, 
