Cell[TextData[{
 "A resonance offset term may be included by combining a spin Hamiltonian and \
a relaxation superoperator using ",
 StyleBox["CombineGenerators",
  FontWeight->"Bold"],
 ": "
}], "Text",
 CellChangeTimes->{{3.588074839847555*^9, 3.58807488532999*^9}, 
   3.709552430858292*^9},ExpressionUUID->"459fe865-9789-4fe5-818d-\
04456cb4a44d"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Hoff", "=", 
   RowBox[{"2", "\[Pi]", " ", "5", " ", 
    RowBox[{"opI", "[", "\"\<z\>\"", "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"trajx", "=", 
   RowBox[{"Trajectory", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"opI", "[", "\"\<x\>\"", "]"}], "\[Rule]", 
      RowBox[{"opI", "[", "\"\<x\>\"", "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"None", ",", "10"}], "}"}], ",", 
     RowBox[{"BackgroundGenerator", "\[Rule]", 
      RowBox[{"CombineGenerators", "[", 
       RowBox[{"Hoff", ",", "\[CapitalGamma]"}], "]"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"trajx", "[", "t", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "10"}], "}"}], ",", 
   RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.588074896719246*^9, 3.588074918576542*^9}, {
