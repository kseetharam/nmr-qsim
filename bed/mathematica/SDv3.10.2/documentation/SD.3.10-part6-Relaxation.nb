    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"-", "1"}], ")"}], "^", "m"}], " ", 
      RowBox[{"DoubleCommutationSuperoperator", "[", 
       RowBox[{
        RowBox[{"opT", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"1", ",", "2"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"2", ",", "m"}], "}"}]}], "]"}], ",", 
        RowBox[{"opT", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"1", ",", "2"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"2", ",", 
            RowBox[{"-", "m"}]}], "}"}]}], "]"}]}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"m", ",", 
       RowBox[{"-", "2"}], ",", "2"}], "}"}]}], "]"}]}]}]}], "Input",
