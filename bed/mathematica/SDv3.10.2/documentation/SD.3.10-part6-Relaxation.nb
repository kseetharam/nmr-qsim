Cell["\<\
This superoperator may be used to simulate what happens in a 2-spin-1/2 \
system if the longitudinal magnetization is inverted on just one of the 2 \
spins, and then the spin system is allowed to evolve. For example, suppose \
that the DD coupling is 20 kHz, and the correlation time is 10 ps. The \
trajectories of the longitudinal magnetization components are as follows:\
\>", "Text",
 CellChangeTimes->{{3.588077356811914*^9, 3.588077376706243*^9}, {
  3.588077407770508*^9, 3.588077437390153*^9}, {3.588077476049389*^9, 
  3.58807749294489*^9}, {3.588077570357916*^9, 3.588077570357993*^9}, {
  3.588077871591682*^9, 3.588077905841632*^9}, {3.58807809905359*^9, 
  3.588078150480771*^9}},ExpressionUUID->"7cb89471-5a88-4555-abc9-\
49ac16d72a01"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"traj1z", ",", "traj2z"}], "}"}], "=", 
   RowBox[{"Trajectory", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"-", 
       RowBox[{"opI", "[", 
        RowBox[{"1", ",", "\"\<z\>\""}], "]"}]}], "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"opI", "[", 
         RowBox[{"1", ",", "\"\<z\>\""}], "]"}], ",", 
        RowBox[{"opI", "[", 
         RowBox[{"2", ",", "\"\<z\>\""}], "]"}]}], "}"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"None", ",", "100"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"BackgroundGenerator", "\[Rule]", 
      RowBox[{"(", 
       RowBox[{"\[CapitalGamma]DD", "/.", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"\[Omega]DD", "\[Rule]", 
           RowBox[{"2", "\[Pi]", " ", "20", " ", 
            RowBox[{"10", "^", "3"}]}]}], ",", 
          RowBox[{"\[Tau]c", "\[Rule]", 
           RowBox[{"10", " ", 
            SuperscriptBox["10", 
             RowBox[{"-", "12"}]]}]}]}], "}"}]}], ")"}]}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"traj1z", "[", "t", "]"}], ",", 
     RowBox[{"traj2z", "[", "t", "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "100"}], "}"}], ",", 
   RowBox[{"PlotRange", "\[Rule]", "All"}], ",", 
   RowBox[{"PlotStyle", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"Blue", ",", "Red"}], "}"}]}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.588077913882369*^9, 3.588078084635177*^9}, {
