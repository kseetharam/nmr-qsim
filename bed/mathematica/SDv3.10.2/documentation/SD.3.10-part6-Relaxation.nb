Cell["\<\
Magnetization trajectories after a 90\[Degree] pulse may be simulated in the \
presence of relaxation:\
\>", "Text",
 CellChangeTimes->{{3.5880758929689817`*^9, 3.588075910208228*^9}, {
  3.81677821832246*^9, 
  3.816778218814391*^9}},ExpressionUUID->"ad22d700-09de-4d5b-8cef-\
0b0b5646e524"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Hoff", "=", 
   RowBox[{"2", "\[Pi]", " ", "5", " ", 
    RowBox[{"opI", "[", "\"\<z\>\"", "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"trajx", ",", "trajy", ",", "trajz"}], "}"}], "=", 
   RowBox[{"Trajectory", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"\[Rho]eq", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"opI", "[", "\"\<x\>\"", "]"}], ",", 
        RowBox[{"opI", "[", "\"\<y\>\"", "]"}], ",", 
        RowBox[{"opI", "[", "\"\<z\>\"", "]"}]}], "}"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"RotationSuperoperator", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"\[Pi]", "/", "2"}], ",", "\"\<x\>\""}], "}"}], "]"}], ",", 
       
       RowBox[{"{", 
        RowBox[{"None", ",", "10"}], "}"}]}], "}"}], ",", 
     RowBox[{"BackgroundGenerator", "\[Rule]", 
      RowBox[{"CombineGenerators", "[", 
       RowBox[{"Hoff", ",", "\[CapitalGamma]therm"}], "]"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"NormalizationFactor", "\[Rule]", "Meq"}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"SphereAndAxes", "[", "]"}], ",", "\[IndentingNewLine]", 
   RowBox[{"ParametricPlot3D", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"trajx", "[", "t", "]"}], ",", 
       RowBox[{"trajy", "[", "t", "]"}], ",", 
       RowBox[{"trajz", "[", "t", "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "10"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"Axes", "\[Rule]", "None"}], ",", 
     RowBox[{"PlotStyle", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"{", 
        RowBox[{"Thick", ",", "Blue"}], "}"}], "}"}]}]}], 
    "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
   RowBox[{"Boxed", "\[Rule]", "False"}]}], "\[IndentingNewLine]", 
  "]"}]}], "Input",
