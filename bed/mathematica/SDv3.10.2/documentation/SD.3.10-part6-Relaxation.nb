Cell["\<\
Note that the relaxation of the longitudinal magnetization is towards 0, i.e. \
a state of infinite temperature. This happens because the finite temperature \
of the sample has not yet been taken into account.\
\>", "Text",
 CellChangeTimes->{{3.588075081254024*^9, 
  3.588075126168919*^9}},ExpressionUUID->"a1a6991f-9667-4487-88af-\
14884d82ff33"]
}, Closed]],

Cell[CellGroupData[{

Cell["thermal equilibrium and thermalization", "Subsection",
 CellChangeTimes->{{3.588074747297937*^9, 3.58807475427406*^9}, {
  3.588075142267158*^9, 3.588075145009611*^9}, {3.58807621586224*^9, 
  3.588076218363048*^9}},ExpressionUUID->"f9b56172-833e-41a1-8573-\
238b088bfede"],

Cell[TextData[{
 "The thermal equilibrium density operator at a given temperature, in the \
presence of an arbitrary laboratory frame Hamiltonian, may be calculated \
using ",
 StyleBox["ThermalEquilibriumDensityOperator",
  FontWeight->"Bold"],
 ". For example, suppose that the magnetic field is 11.7\[NonBreakingSpace]T, \
the sample temperature is 300 Kelvin, and the spin-1/2 species are protons. \
The thermal equilibrium density operator is calculated as follows:"
}], "Text",
 CellChangeTimes->{{3.575611930933423*^9, 3.575612002081915*^9}, {
  3.575613144423974*^9, 3.575613156683689*^9}, {3.5880743963242693`*^9, 
  3.588074578927348*^9}, {3.5880747425859766`*^9, 3.5880747433220797`*^9}, {
  3.588075044870097*^9, 3.5880750455904307`*^9}, {3.5880751540428677`*^9, 
  3.588075264169289*^9}, {3.588075300300366*^9, 
  3.5880753173268003`*^9}},ExpressionUUID->"76d8180d-bc0f-4be8-bb77-\
c661c8c4f76c"],

Cell[CellGroupData[{

Cell[BoxData[{
 StyleBox[
  RowBox[{
   RowBox[{"SetSpinSystem", "[", "1", "]"}], ";"}],
  FontWeight->"Bold"], "\[IndentingNewLine]", 
 StyleBox[
  RowBox[{
   RowBox[{"\[Omega]0lab", "=", 
    RowBox[{"LarmorFrequency", "[", 
     RowBox[{"1", ",", "11.7"}], "]"}]}], ";"}],
  FontWeight->"Bold"], "\[IndentingNewLine]", 
 StyleBox[
  RowBox[{
   RowBox[{"Hlab", "=", 
    RowBox[{"\[Omega]0lab", " ", 
     RowBox[{"opI", "[", "\"\<z\>\"", "]"}]}]}], ";"}],
  FontWeight->"Bold"], "\[IndentingNewLine]", 
 StyleBox[
  RowBox[{"\[Rho]eq", "=", 
   RowBox[{"ThermalEquilibriumDensityOperator", "[", 
    RowBox[{"Hlab", ",", "300"}], "]"}]}],
  FontWeight->"Bold"]}], "Input",
 CellChangeTimes->{{3.588075267531481*^9, 3.588075289365234*^9}, {
