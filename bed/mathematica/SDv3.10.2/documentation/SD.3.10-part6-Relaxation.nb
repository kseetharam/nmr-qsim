  3.816523635021957*^9}},ExpressionUUID->"cf61fed5-f360-433a-87bb-\
c75818a79217"],

Cell[TextData[{
 "The evolution of transverse magnetization under this relaxation \
superoperator is easily calculated using ",
 StyleBox["Trajectory",
  FontWeight->"Bold"],
 ":"
}], "Text",
 CellChangeTimes->{{3.588074710464368*^9, 
  3.588074761690422*^9}},ExpressionUUID->"831504f5-524a-4801-8988-\
87e165c4bd7a"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"trajx", "=", 
   RowBox[{"Trajectory", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"opI", "[", "\"\<x\>\"", "]"}], "\[Rule]", 
      RowBox[{"opI", "[", "\"\<x\>\"", "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"None", ",", "10"}], "}"}], ",", 
     RowBox[{"BackgroundGenerator", "\[Rule]", "\[CapitalGamma]"}]}], "]"}]}],
   ";"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"trajx", "[", "t", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "10"}], "}"}], ",", 
   RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.588074767061661*^9, 3.5880748094479036`*^9}, {
