Cell[TextData[{
 "Relaxation may be included in ",
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 " by including an appropriate superoperator as the evolution generator. This \
may be done either phenomenologically (which means just including a term \
which corresponds to the experimental results), or by including the  \
superoperator corresponding to a particular relaxation mechanism, or set of \
mechanisms. "
}], "Text",
 CellChangeTimes->{{3.5756117919836493`*^9, 3.575611857357772*^9}, {
  3.588074281464151*^9, 
  3.588074379371148*^9}},ExpressionUUID->"d49afbdc-baf3-4c5e-ac6c-\
b4f80c7af0f3"]
}, Closed]],

Cell[CellGroupData[{

Cell["Phenomenological Relaxation", "Section",
 CellChangeTimes->{{3.575611915027603*^9, 3.575611926367559*^9}, {
  3.575613134956509*^9, 3.575613135881061*^9}, {3.5880743881239867`*^9, 
  3.588074393316068*^9}, {3.7119992630047035`*^9, 
  3.711999263094565*^9}},ExpressionUUID->"136b7686-2b50-4482-b630-\
46a538043c58"],

Cell[CellGroupData[{

Cell["PhenomenologicalRelaxationSuperoperator", "Subsection",
 CellChangeTimes->{{3.588074747297937*^9, 3.58807475427406*^9}, {
  3.711998240044168*^9, 3.7119982484616313`*^9}},
 Background->None,ExpressionUUID->"071da589-42bc-49e6-b6f6-0f608e25971c"],

Cell[TextData[{
 "A Phenomenological Relaxation Superoperators employing a longitudinal \
relaxation time constant ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["T", "1"], TraditionalForm]],ExpressionUUID->
  "e1843b3a-c5e6-4da9-bc28-b72c986f2c34"],
 " and a transverse relaxation time constant ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["T", "2"], TraditionalForm]],ExpressionUUID->
  "4704522a-f3f6-4163-890f-410494d51f09"],
 " may be constructed using ",
 StyleBox["PhenomenologicalRelaxationSuperoperator",
  FontWeight->"Bold"],
 ". \n\nThe general syntax is ",
 StyleBox["PhenomenologicalRelaxationSuperoperator[{{lab#1,T1#1,T2#1},{lab#2,\
T1#2,T2#2},...}] ",
  FontWeight->"Bold"],
 "where ",
 StyleBox["lab#j ",
  FontWeight->"Bold"],
 "refers to the label of spin j and ",
 StyleBox["T1#j / T2#j ",
  FontWeight->"Bold"],
 "refer to the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["T", "1"], TraditionalForm]],ExpressionUUID->
  "a4a33405-2396-4e63-842e-4ec1ab2a12c3"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["T", "2"], TraditionalForm]],ExpressionUUID->
  "ddf52384-9aaf-461a-b2b7-9c9f2a4c1c94"],
 " time constants of spin j.\n\nConsider, for example, an ensemble of single \
spins-1/2, with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["T", "1"], "=", 
    RowBox[{"2.0", " ", "s"}]}], TraditionalForm]],ExpressionUUID->
