Cell["\<\
The evolution of the z-magnetization may be calculated in a similar way:\
\>", "Text",
 CellChangeTimes->{{3.588075001818243*^9, 
  3.588075011577505*^9}},ExpressionUUID->"87602cea-2d3d-4715-9942-\
e5866778f788"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Hoff", "=", 
   RowBox[{"2", "\[Pi]", " ", "5", " ", 
    RowBox[{"opI", "[", "\"\<z\>\"", "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"trajz", "=", 
   RowBox[{"Trajectory", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"opI", "[", "\"\<z\>\"", "]"}], "\[Rule]", 
      RowBox[{"opI", "[", "\"\<z\>\"", "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"None", ",", "10"}], "}"}], ",", 
     RowBox[{"BackgroundGenerator", "\[Rule]", 
      RowBox[{"CombineGenerators", "[", 
       RowBox[{"Hoff", ",", "\[CapitalGamma]"}], "]"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"trajz", "[", "t", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "10"}], "}"}], ",", 
   RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.588074896719246*^9, 3.588074918576542*^9}, {
  3.588074963523673*^9, 3.588074978241796*^9}, {3.588075020152771*^9, 
