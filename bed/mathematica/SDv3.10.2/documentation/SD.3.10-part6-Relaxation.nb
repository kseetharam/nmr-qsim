   3.6305881834241133`*^9},ExpressionUUID->"36bc0a87-9fb6-460a-9c95-\
7ffe22ff2221"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"traj1z", ",", "traj2z"}], "}"}], "=", 
   RowBox[{"Trajectory", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"-", 
       RowBox[{"opI", "[", 
        RowBox[{"1", ",", "\"\<z\>\""}], "]"}]}], "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"opI", "[", 
         RowBox[{"1", ",", "\"\<z\>\""}], "]"}], ",", 
        RowBox[{"opI", "[", 
         RowBox[{"2", ",", "\"\<z\>\""}], "]"}]}], "}"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"None", ",", "100"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"BackgroundGenerator", "\[Rule]", 
      RowBox[{"(", 
       RowBox[{"\[CapitalGamma]DDsec", "/.", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"\[Omega]DD", "\[Rule]", 
           RowBox[{"2", "\[Pi]", " ", "20", " ", 
            RowBox[{"10", "^", "3"}]}]}], ",", 
          RowBox[{"\[Tau]c", "\[Rule]", 
           RowBox[{"10", " ", 
            SuperscriptBox["10", 
             RowBox[{"-", "12"}]]}]}]}], "}"}]}], ")"}]}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"traj1z", "[", "t", "]"}], ",", 
     RowBox[{"traj2z", "[", "t", "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "100"}], "}"}], ",", 
   RowBox[{"PlotRange", "\[Rule]", "All"}], ",", 
   RowBox[{"PlotStyle", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"Blue", ",", "Red"}], "}"}]}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.588077913882369*^9, 3.588078084635177*^9}, {
   3.588078153359593*^9, 3.588078163855542*^9}, {3.588078197626861*^9, 
