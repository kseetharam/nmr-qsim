Cell[BoxData[{
 RowBox[{
  RowBox[{"SetSpinSystem", "[", "2", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"parameters", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"B0", "\[Rule]", "11.7"}], ",", " ", 
     RowBox[{"T", "\[Rule]", "300"}], ",", 
     RowBox[{"\[Omega]DD", "\[Rule]", 
      RowBox[{"2", "\[Pi]", " ", "20", " ", 
       RowBox[{"10", "^", "3"}]}]}], ",", 
     RowBox[{"\[Tau]c", "\[Rule]", 
      RowBox[{"10", " ", 
       SuperscriptBox["10", 
        RowBox[{"-", "12"}]]}]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"\[CapitalGamma]DDLB", "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"+", 
       RowBox[{"(", 
        RowBox[{"6", "/", "5"}], ")"}]}], 
      SuperscriptBox["\[Omega]DD", "2"], 
      RowBox[{"(", 
       RowBox[{"2", "\[Tau]c"}], ")"}], " ", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"-", "1"}], ")"}], "^", "m"}], " ", 
         RowBox[{"Lindbladian", "[", 
          RowBox[{
           RowBox[{"opT", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"1", ",", "2"}], "}"}], ",", 
             RowBox[{"{", 
