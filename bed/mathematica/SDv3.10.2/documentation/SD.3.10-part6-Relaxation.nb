Cell["The thermal equilibrium density operator is set up:", "Text",
 CellChangeTimes->{{3.816845754375544*^9, 
  3.816845763051867*^9}},ExpressionUUID->"7a6a806a-58fa-4811-a4e1-\
fbba12b0adab"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"H0", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"\[Omega]0", " ", 
      RowBox[{"opI", "[", "\"\<z\>\"", "]"}]}], "/.", 
     RowBox[{"{", 
      RowBox[{"\[Omega]0", "\[Rule]", 
       RowBox[{"LarmorFrequency", "[", 
        RowBox[{"1", ",", "B0"}], "]"}]}], "}"}]}], "/.", "parameters"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Rho]eq", "=", 
   RowBox[{"ThermalEquilibriumDensityOperator", "[", 
    RowBox[{"H0", ",", "300"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Meq", "=", 
   RowBox[{"OperatorAmplitude", "[", 
    RowBox[{"\[Rho]eq", "\[Rule]", 
     RowBox[{"opI", "[", 
      RowBox[{"1", ",", "\"\<z\>\""}], "]"}]}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.588078663100531*^9, 3.588078674398292*^9}, {
  3.816778902612279*^9, 3.816778920866579*^9}, {3.816779308524612*^9, 
  3.816779318641809*^9}, {3.816845772572405*^9, 3.816845791729535*^9}},
 CellLabel->"In[86]:=",ExpressionUUID->"1c1b9bc3-39ce-4e5d-8403-ee1219a881b9"],

Cell["\<\
The trajectories below exhibit transient cross-relaxation effects after \
inverting the magnetization of one of the spin species.\
\>", "Text",
 CellChangeTimes->{{3.816845720232514*^9, 3.816845737000845*^9}, {
  3.816845794981312*^9, 
  3.8168458155204062`*^9}},ExpressionUUID->"2569ffa0-abcb-444e-b647-\
2d3323472788"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"traj1z", ",", "traj2z"}], "}"}], "=", 
   RowBox[{"Trajectory", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"\[Rho]eq", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"opI", "[", 
         RowBox[{"1", ",", "\"\<z\>\""}], "]"}], ",", 
        RowBox[{"opI", "[", 
         RowBox[{"2", ",", "\"\<z\>\""}], "]"}]}], "}"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"None", ",", "5"}], "}"}], ",", 
       RowBox[{"Pulse", "[", 
        RowBox[{"1", ",", 
         RowBox[{"{", 
          RowBox[{"\[Pi]", ",", "\"\<x\>\""}], "}"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"None", ",", "100"}], "}"}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"BackgroundGenerator", "\[Rule]", "\[CapitalGamma]DDLB"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"NormalizationFactor", "\[Rule]", "Meq"}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"traj1z", "[", "t", "]"}], ",", 
     RowBox[{"traj2z", "[", "t", "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "100"}], "}"}], ",", 
   RowBox[{"PlotRange", "\[Rule]", "All"}], ",", 
   RowBox[{"PlotStyle", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"Blue", ",", "Red"}], "}"}]}]}], "]"}]}], "Input",
