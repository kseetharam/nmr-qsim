Cell[TextData[{
 "Note, however, that the ",
 StyleBox["ThermalizeSuperoperator",
  FontWeight->"Bold"],
 " procedure is not rigorous for spin systems that are far from equilibrium \
or contain large amounts of spin order. The correct method is to use \
Lindbladian superoperators, as described in Bengs and Levitt, \
doi.org/10.1016/j.jmr.2019.106645. The ",
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 " implementation of Lindbladians is given in an example below.  "
}], "Text",
 CellChangeTimes->{{3.8167780633654737`*^9, 
  3.8167781824757767`*^9}},ExpressionUUID->"4b5c0ee0-0bb8-440e-ad00-\
17861e5db547"],

Cell["\<\
An inversion-recovery experiment, starting from thermal equilibrium, and \
monitoring the z-magnetization, may be simulated as follows:\
\>", "Text",
 CellChangeTimes->{{3.5880756941328917`*^9, 3.588075723316763*^9}, {
  3.816778194730116*^9, 
  3.816778196002571*^9}},ExpressionUUID->"8692c95b-c756-4e2c-92e3-\
2573ca1c0cc7"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Hoff", "=", 
   RowBox[{"2", "\[Pi]", " ", "5", " ", 
    RowBox[{"opI", "[", "\"\<z\>\"", "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"trajz", "=", 
   RowBox[{"Trajectory", "[", 
    RowBox[{
     RowBox[{"\[Rho]eq", "\[Rule]", 
      RowBox[{"opI", "[", "\"\<z\>\"", "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"None", ",", 
         RowBox[{"1", "/", "2"}]}], "}"}], ",", 
       RowBox[{"RotationSuperoperator", "[", 
        RowBox[{"{", 
         RowBox[{"\[Pi]", ",", "\"\<x\>\""}], "}"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"None", ",", "10"}], "}"}]}], "}"}], ",", 
     RowBox[{"BackgroundGenerator", "\[Rule]", 
      RowBox[{"CombineGenerators", "[", 
       RowBox[{"Hoff", ",", "\[CapitalGamma]therm"}], "]"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"trajz", "[", "t", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "10.5"}], "}"}], ",", 
   RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.588074896719246*^9, 3.588074918576542*^9}, {
  3.588074963523673*^9, 3.588074978241796*^9}, {3.588075020152771*^9, 
  3.588075025367127*^9}, {3.588075754527645*^9, 3.588075789830907*^9}, {
