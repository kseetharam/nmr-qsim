Cell[TextData[{
 "Relaxation towards thermal equilibrium at the finite sample temperature is \
imposed by applying ",
 StyleBox["ThermalizeSuperoperator",
  FontWeight->"Bold"],
 " to the relaxation superoperator:"
}], "Text",
 CellChangeTimes->{{3.588075582086054*^9, 
  3.5880756270389347`*^9}},ExpressionUUID->"4650f62f-6839-48ca-8f98-\
dbc6979f75d2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[CapitalGamma]therm", "=", 
  RowBox[{"ThermalizeSuperoperator", "[", 
   RowBox[{"\[CapitalGamma]", ",", "Hlab", ",", "300"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.5880756128256483`*^9, 3.588075665907872*^9}},
 CellLabel->"In[21]:=",ExpressionUUID->"b9df9896-338c-4428-8b33-7576af9a005e"],

