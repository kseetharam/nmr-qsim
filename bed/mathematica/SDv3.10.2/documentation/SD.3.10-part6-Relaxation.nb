           RowBox[{"opT", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"1", ",", "2"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"2", ",", 
               RowBox[{"-", "m"}]}], "}"}]}], "]"}]}], "]"}], 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{"-", 
            RowBox[{"(", 
             RowBox[{"1", "/", "2"}], ")"}]}], "m", " ", "\[HBar]", " ", 
           RowBox[{"\[Omega]0", "/", 
            RowBox[{"(", 
             RowBox[{"kB", " ", "T"}], ")"}]}]}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"m", ",", 
          RowBox[{"-", "2"}], ",", "2"}], "}"}]}], "]"}]}], "/.", 
