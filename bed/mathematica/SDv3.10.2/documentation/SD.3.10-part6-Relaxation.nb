Cell[TextData[{
 "From this one may see that ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["T", "1"], TraditionalForm]],ExpressionUUID->
  "3932c940-34a1-4072-b420-34fd0463fd50"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["T", "2"], TraditionalForm]],ExpressionUUID->
  "5318f835-f9a3-4990-9966-f8a0db2c07ff"],
 " are equal in this model, and are both given by 1/(",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    SuperscriptBox["\[Omega]rms", "2"], "\[Tau]c"}], ")"}]],
  CellChangeTimes->{{3.588077201195537*^9, 3.588077312579234*^9}},
  ExpressionUUID->"bffc09c5-0155-4ec6-9dcf-0ebce7564e37"],
 "."
}], "Text",
