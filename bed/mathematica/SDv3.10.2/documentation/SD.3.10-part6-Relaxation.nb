  3.588078150480771*^9}, {3.588078341535235*^9, 
  3.588078350061207*^9}},ExpressionUUID->"1ccf10f3-3866-4226-b92b-\
abbbe5aa537c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"traj1z", ",", "traj2z"}], "}"}], "=", 
   RowBox[{"Trajectory", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"-", 
       RowBox[{"opI", "[", 
        RowBox[{"1", ",", "\"\<z\>\""}], "]"}]}], "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"opI", "[", 
         RowBox[{"1", ",", "\"\<z\>\""}], "]"}], ",", 
        RowBox[{"opI", "[", 
         RowBox[{"2", ",", "\"\<z\>\""}], "]"}]}], "}"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"None", ",", "0.4"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"BackgroundGenerator", "\[Rule]", 
      RowBox[{"(", 
       RowBox[{"\[CapitalGamma]DD", "/.", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"\[Omega]DD", "\[Rule]", 
           RowBox[{"2", "\[Pi]", " ", "20", " ", 
            RowBox[{"10", "^", "3"}]}]}], ",", 
          RowBox[{"\[Tau]c", "\[Rule]", 
           RowBox[{"10", " ", 
            SuperscriptBox["10", 
             RowBox[{"-", "9"}]]}]}]}], "}"}]}], ")"}]}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
