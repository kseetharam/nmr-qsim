Cell[CellGroupData[{

Cell["personalized Phenomenological Relaxation Superoperator", "Subsection",
 CellChangeTimes->{{3.588074747297937*^9, 3.58807475427406*^9}, {
  3.588076298274063*^9, 3.588076300872181*^9}, {3.711999111308973*^9, 
  3.711999125066164*^9}},ExpressionUUID->"774e9469-10a4-4530-91b3-\
6fc38fbecc80"],

Cell["\<\
SpinDynamica allows the definition of personalized Phenomenological \
Relaxation Superoperators. The PhenomonologicalRelaxationSuperoperator may \
involve any relaxation rate constants for the relevant spin operators, and \
also any cross-relaxation rate constants between the relevant operators. \
However, care is needed to ensure that the simulated relaxation matrix is \
physically plausible. \
\>", "Text",
 CellChangeTimes->{{3.588076303928969*^9, 3.5880763932217283`*^9}, {
  3.711999142037508*^9, 3.7119991580559216`*^9}, {3.7119991954559946`*^9, 
  3.711999248347395*^9}, {3.816523684464832*^9, 
  3.8165236863776903`*^9}},ExpressionUUID->"18f5f03a-a40c-48df-86da-\
96d552df50f6"],

Cell["\<\
For example, in the case of a 2-spin-1/2 system, there are 16 Cartesian \
product operators:\
\>", "Text",
 CellChangeTimes->{{3.575611930933423*^9, 3.575612002081915*^9}, {
  3.575613144423974*^9, 3.575613156683689*^9}, {3.5880743963242693`*^9, 
  3.588074578927348*^9}, {3.5880747425859766`*^9, 3.5880747433220797`*^9}, {
  3.588075044870097*^9, 3.5880750455904307`*^9}, {3.588076404833838*^9, 
  3.588076424655486*^9}},ExpressionUUID->"3003feba-0557-4001-b5f6-\
a1d0b00641e7"],

