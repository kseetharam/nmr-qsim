Cell[TextData[{
 "The",
 StyleBox[" \[Lambda] ",
  FontWeight->"Bold"],
 "argument may also be a list of spherical tensor ranks. ",
 StyleBox["CartesianToSpherical",
  FontWeight->"Bold"],
 " will then generate a list of spherical tensor objects with given ranks, if \
present."
}], "Text",
 CellChangeTimes->{{3.641635227289846*^9, 3.641635253150863*^9}, {
  3.7121480563206*^9, 3.71214807899119*^9}, {3.712149130158475*^9, 
