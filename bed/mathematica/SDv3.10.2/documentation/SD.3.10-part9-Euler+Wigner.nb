Cell[CellGroupData[{

Cell["SphericalToCartesian", "Section",
 CellChangeTimes->{{3.575611915027603*^9, 3.575611926367559*^9}, {
  3.575613134956509*^9, 3.575613135881061*^9}, {3.5880743881239867`*^9, 
  3.588074393316068*^9}, {3.629275150014858*^9, 3.6292751509164762`*^9}, {
  3.640885005569182*^9, 3.640885012144264*^9}, {3.712000370709639*^9, 
  3.71200038820025*^9}},
 Background->None,ExpressionUUID->"05d7f276-808f-429c-ba3a-d6c0fa9ea26f"],

Cell[TextData[{
 StyleBox["SphericalToCartesian ",
  FontWeight->"Bold"],
 "may be used to transform the spatial components of a spherical tensor \
operator with rank \[Lambda] \[LessEqual] 2 into cartesian tensor form. \n\n\
The syntax of ",
 StyleBox["SphericalToCartesian",
  FontWeight->"Bold"],
 " is given by:\n\n",
 StyleBox["SphericalToCartesian[",
  FontWeight->"Bold"],
 StyleBox["spheric",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 StyleBox["]\n\n",
  FontWeight->"Bold"],
 "The argument ",
 StyleBox["spheric ",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 "should be a vector of Length = 2 \[Lambda] +1 with the components sorted \
according to their m-value in descending order from m = +\[Lambda] to -\
\[Lambda]. "
}], "Text",
 CellChangeTimes->{{3.641635227289846*^9, 3.641635253150863*^9}, {
  3.71214767883041*^9, 3.712147713079739*^9}, {3.712147761065909*^9, 
  3.712147918093693*^9}, {3.712147952693397*^9, 
  3.712148008164256*^9}},ExpressionUUID->"ab62f651-49dc-4b87-b5f0-\
b477d6c11a9e"],

Cell["\<\
For example the spatial components of a spherical tensor with \[Lambda] = 0 \
may be transformed into cartesian form as follows.\
\>", "Text",
 CellChangeTimes->{{3.641635227289846*^9, 3.641635253150863*^9}, {
  3.7121480563206*^9, 
  3.71214807899119*^9}},ExpressionUUID->"db08a4a2-3456-4f91-871b-\
578beaa4ec9c"],

