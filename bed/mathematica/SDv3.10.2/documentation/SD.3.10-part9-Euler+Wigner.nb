Cell[CellGroupData[{

Cell["Products of rotations", "Subsubsection",
 CellChangeTimes->{{3.641661205617436*^9, 3.641661213823855*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"0eea638e-f98f-4d63-834c-880673f49018"],

Cell[TextData[{
 "The WignerD routine may be used to automatically generate the element \
corresponding to a product of rotations. For example, the calculation below \
generates an element of the product of two Wigner matrices:\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["D", "20", "2"], "(", 
    RowBox[{
     SubscriptBox["\[CapitalOmega]", "1"], "\[Times]", " "}]}], 
   TraditionalForm]],ExpressionUUID->"22b66fdc-2a35-4787-b72c-4d9e1d746993"],
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[CapitalOmega]", "2"], TraditionalForm]],ExpressionUUID->
  "de1e1352-3565-46f9-8597-8bdc9d8d2dfc"],
 ") = ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderoverscriptBox["\[Sum]", 
     RowBox[{"\[Mu]", "=", 
      RowBox[{"-", "2"}]}], 
     RowBox[{"+", "2"}]], 
    RowBox[{
     SubsuperscriptBox["D", 
      RowBox[{"2", "\[Mu]"}], "2"], "(", 
     SubscriptBox["\[CapitalOmega]", "1"], ")"}]}], TraditionalForm]],
  ExpressionUUID->"c9b2606e-87c9-4d52-ab19-6ef70da07b46"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["D", "\[Mu]0", "2"], "(", 
    SubscriptBox["\[CapitalOmega]", "2"], ")"}], TraditionalForm]],
  ExpressionUUID->"de8f4256-048b-4984-afab-0a84c90a6bbf"]
}], "Text",
 CellChangeTimes->{{3.641661216345368*^9, 3.641661261951151*^9}, {
  3.641661398308401*^9, 3.641661404859633*^9}, {3.641661442754572*^9, 
  3.641661666867947*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"acebb4c8-1066-4476-a31f-6ded26895214"],

