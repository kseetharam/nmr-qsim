  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"CO2", "=", 
   RowBox[{"Graphics3D", "[", 
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
