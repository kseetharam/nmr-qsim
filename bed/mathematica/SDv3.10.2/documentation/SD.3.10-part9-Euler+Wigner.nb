Cell[CellGroupData[{

Cell["AxesToEuler", "Subsection",
 CellChangeTimes->{{3.575611915027603*^9, 3.575611926367559*^9}, {
  3.575613134956509*^9, 3.575613135881061*^9}, {3.5880743881239867`*^9, 
  3.588074393316068*^9}, {3.629275150014858*^9, 3.6292751509164762`*^9}, {
  3.640885005569182*^9, 3.640885012144264*^9}, {3.640885126789443*^9, 
  3.640885136404727*^9}, {3.640887551349264*^9, 
  3.640887557841632*^9}},ExpressionUUID->"1ace5255-84c9-437d-b7cb-\
11963a58b357"],

Cell[TextData[{
 "The routine ",
 StyleBox["AxesToEuler ",
  FontWeight->"Bold"],
 "provides the Euler angle rotations which bring one right-handed axis system \
into coincidence with another. "
}], "Text",
 CellChangeTimes->{{3.641657535434493*^9, 
  3.641657618713132*^9}},ExpressionUUID->"41cb4ce3-1376-4c01-83a1-\
710451c092ae"],

Cell["\<\
This calculation is often required when setting up the spin Hamiltonians for \
anisotropic spin interactions. \
\>", "Text",
 CellChangeTimes->{{3.641657624065227*^9, 
  3.641657644880562*^9}},ExpressionUUID->"99536baa-db00-4200-9e62-\
600a4956264a"],

Cell[TextData[{
 "In general, ",
 StyleBox["AxesToEuler[system1,system2]",
  FontWeight->"Bold"],
 " returns the set of Euler angles ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["\[Alpha]", "12"], ",", 
      SubscriptBox["\[Beta]", "12"], ",", 
      SubscriptBox["\[Gamma]", "12"]}], "}"}], " "}], TraditionalForm]],
  ExpressionUUID->"7fccf228-4f9e-4fdb-83d5-c34bc2b1afb2"],
 "such that the x-axis of system 1 may be aligned with the x-axis of system 2 \
through the following set of rotations: \n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox[
     StyleBox["e",
      FontWeight->"Bold"], "x", 
     RowBox[{"(", "1", ")"}]], 
    OverscriptBox["\[RightArrow]", 
     RowBox[{
      SubscriptBox["R", "z"], "(", "\[Alpha]", ")"}]], " "}], 
   TraditionalForm]],ExpressionUUID->"28bc5c64-60fa-445d-ba64-b328e5b1db77"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["\[RightArrow]", 
     RowBox[{
      SubscriptBox["R", "y"], "(", "\[Beta]", ")"}]], " "}], 
   TraditionalForm]],ExpressionUUID->"fd1f87a8-332f-4d0d-b7d2-75a2a4e2bf29"],
 Cell[BoxData[
  FormBox[
   OverscriptBox["\[RightArrow]", 
    RowBox[{
     SubscriptBox["R", "z"], "(", "\[Gamma]", ")"}]], TraditionalForm]],
  ExpressionUUID->"a86e5011-df65-4561-ac74-a80a2153075d"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox[" ",
     FontWeight->"Bold"], 
    SubsuperscriptBox[
     StyleBox["e",
      FontWeight->"Bold"], "x", 
     RowBox[{"(", "2", ")"}]]}], TraditionalForm]],ExpressionUUID->
  "0f13ecac-9351-4f4e-b384-5e73bccf3f9f"],
 "\nand similarly for the y and z axes. Remarkably, the three rotations may \
be executed ",
 StyleBox["either",
  FontSlant->"Italic"],
 " about the axes of system 1, or the axes of system 2. The result is the \
same in either case. "
}], "Text",
 CellChangeTimes->{{3.640887598843623*^9, 3.640887969222356*^9}, 
   3.641657653842297*^9, {3.641657698231102*^9, 
   3.641657853387639*^9}},ExpressionUUID->"37ee1c11-8dbf-4159-b5e1-\
d54359fcc2fa"],

Cell["\<\
For example, consider an axis system {x2,y2,z2} generated by subjecting the \
fixed axis system {x1,y1,z1}={ex,ey,ez} to a sequence of Euler rotations:\
\>", "Text",
 CellChangeTimes->{{3.641657911744282*^9, 3.6416579745125504`*^9}, {
  3.64165807794623*^9, 3.641658088579446*^9}, {3.641658202641849*^9, 
  3.641658204409851*^9}, {3.6416583622140613`*^9, 
  3.641658379889167*^9}},ExpressionUUID->"1470e4f5-c694-4c1a-a265-\
3fc94492c749"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"x1", ",", "y1", ",", "z1"}], "}"}], "=", 
   RowBox[{"{", 
    RowBox[{"ex", ",", "ey", ",", "ez"}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"{", 
   RowBox[{"x2", ",", "y2", ",", "z2"}], "}"}], "=", 
  RowBox[{"RotateEuler", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"x1", ",", "y1", ",", "z1"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"45", "\[Degree]"}], ",", 
      RowBox[{"60", "\[Degree]"}], ",", 
      RowBox[{"30", "\[Degree]"}]}], "}"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.641657978954196*^9, 3.641658043429859*^9}, {
  3.641658093722229*^9, 3.641658099497497*^9}, {3.6416581544558983`*^9, 
  3.641658154911976*^9}, {3.641658239438604*^9, 3.641658279482471*^9}, {
  3.641658384004188*^9, 3.641658401283676*^9}, {3.641658500666485*^9, 
  3.6416585146129827`*^9}, {3.6416591243144703`*^9, 3.641659126664001*^9}, {
  3.657822737506568*^9, 3.657822741353074*^9}},
 CellLabel->
  "In[183]:=",ExpressionUUID->"38f9ecd2-d6e0-45a2-bd84-3bbc472bc75d"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      FractionBox[
       SqrtBox[
        FractionBox["3", "2"]], "4"], "-", 
      FractionBox["1", 
       RowBox[{"2", " ", 
        SqrtBox["2"]}]]}], ",", 
     RowBox[{
      FractionBox[
       SqrtBox[
        FractionBox["3", "2"]], "4"], "+", 
      FractionBox["1", 
       RowBox[{"2", " ", 
        SqrtBox["2"]}]]}], ",", 
     RowBox[{"-", 
      FractionBox["3", "4"]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"-", 
       FractionBox[
        SqrtBox[
         FractionBox["3", "2"]], "2"]}], "-", 
      FractionBox["1", 
       RowBox[{"4", " ", 
        SqrtBox["2"]}]]}], ",", 
     RowBox[{
      FractionBox[
       SqrtBox[
        FractionBox["3", "2"]], "2"], "-", 
      FractionBox["1", 
       RowBox[{"4", " ", 
        SqrtBox["2"]}]]}], ",", 
     FractionBox[
      SqrtBox["3"], "4"]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     FractionBox[
      SqrtBox[
       FractionBox["3", "2"]], "2"], ",", 
     FractionBox[
      SqrtBox[
       FractionBox["3", "2"]], "2"], ",", 
     FractionBox["1", "2"]}], "}"}]}], "}"}]], "Output",
 CellChangeTimes->{{3.641658024143093*^9, 3.641658044159233*^9}, 
   3.641658100531612*^9, 3.641658155582797*^9, {3.641658243013835*^9, 
   3.641658280129677*^9}, 3.641658402639433*^9, 3.641658515297365*^9, {
   3.64165912024781*^9, 3.641659127473228*^9}, {3.657822726343326*^9, 
   3.65782274434747*^9}, 3.659602296895314*^9, 3.65960241763583*^9, {
   3.709553118944661*^9, 3.7095531476428337`*^9}, 3.7185361041649284`*^9, 
   3.7282137270599947`*^9, 3.7283931645347776`*^9, 3.75830639879582*^9, 
   3.8378332872592177`*^9, 3.8969499750842304`*^9, 3.94906151826794*^9},
 CellLabel->
  "Out[184]=",ExpressionUUID->"5b87b1fd-28b8-42ec-99e4-1c1ce68e96b8"]
}, Open  ]],

Cell[TextData[{
 "The Euler angles needed to bring {x1,y1,z1} into coincidence with \
{x2,y2,z2} may be deduced ",
 StyleBox["a posteriori",
  FontSlant->"Italic"],
 ", by applying AxesToEuler:"
}], "Text",
 CellChangeTimes->{{3.641658055637388*^9, 3.641658059660212*^9}, {
  3.641658415540787*^9, 3.641658461386381*^9}, {3.641658527219122*^9, 
  3.641658530001196*^9}},ExpressionUUID->"a1113d39-0580-4b07-b5a3-\
3dc8e24fd586"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"AxesToEuler", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"x1", ",", "y1", ",", "z1"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"x2", ",", "y2", ",", "z2"}], "}"}]}], "]"}], "/", 
  "\[Degree]"}]], "Input",
 CellChangeTimes->{{3.641658113918614*^9, 3.641658126879245*^9}, {
  3.641658169440635*^9, 3.641658185686041*^9}, {3.641658468556905*^9, 
  3.64165847231182*^9}},
 CellLabel->
  "In[185]:=",ExpressionUUID->"dd031de2-c278-4d4a-be54-f9f2d41f397a"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"45.`", ",", "59.99999999999999`", ",", "29.999999999999996`"}], 
  "}"}]], "Output",
 CellChangeTimes->{
  3.641658127543806*^9, {3.64165815818894*^9, 3.641658186266433*^9}, {
   3.641658246244817*^9, 3.641658283064144*^9}, 3.64165847289705*^9, 
   3.641658518868827*^9, 3.641659137262155*^9, {3.657822730918192*^9, 
   3.6578227473788643`*^9}, 3.6596022969462757`*^9, 3.659602417709135*^9, {
   3.709553119036724*^9, 3.709553147752832*^9}, 3.718536104224798*^9, 
   3.7282137272503157`*^9, 3.728393164613238*^9, 3.7583063990291977`*^9, 
   3.8378332873491898`*^9, 3.896949975182967*^9, 3.949061518299378*^9},
 CellLabel->
  "Out[185]=",ExpressionUUID->"10b4049e-1cdd-428f-9b56-2c7e9814bc85"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Euler angles and anisotropic spin interactions", "Subsubsection",
 CellChangeTimes->{{3.6416592855914097`*^9, 3.6416592975497913`*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"29310ba5-a8f5-4dde-90cc-e3f471a9156c"],

Cell["\<\
In magnetic resonance applications, one often knows the principal axis system \
of an anisotropic spin interaction, and also the axis system for the \
molecular reference frame. To set up the spin Hamiltonian, the Euler angles \
relating these two frames is needed. \
\>", "Text",
 CellChangeTimes->{{3.641658559263023*^9, 3.641658653484804*^9}, {
  3.641659300689987*^9, 
  3.6416593714384747`*^9}},ExpressionUUID->"ad29376a-77b0-4b17-a881-\
a4d7fb78794b"],

Cell[TextData[{
 "If the system {",
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", "P"], TraditionalForm]],ExpressionUUID->
  "1d62a6ef-9bb2-4bba-a81b-801c2bc43e29"],
 ",",
 Cell[BoxData[
  FormBox[
   SubscriptBox["y", "P"], TraditionalForm]],ExpressionUUID->
  "25c6a4a7-b4f6-4b35-8aa9-177aa5d489db"],
 ",",
 Cell[BoxData[
  FormBox[
   SubscriptBox["z", "P"], TraditionalForm]],ExpressionUUID->
  "99020a59-b947-4849-87bc-0c3476718a2f"],
 "} is the principal axis system of an anisotropic interaction, while {",
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", "M"], TraditionalForm]],ExpressionUUID->
  "47279eb2-331e-48ba-be63-ef3b9d6d102a"],
 ",",
 Cell[BoxData[
  FormBox[
   SubscriptBox["y", "M"], TraditionalForm]],ExpressionUUID->
  "32393e31-b87b-4618-8e9e-7a3bbfe3818c"],
 ",",
 Cell[BoxData[
  FormBox[
   SubscriptBox["z", "M"], TraditionalForm]],ExpressionUUID->
  "4a7019e4-d107-4383-9a85-7303af7858fe"],
 "}  is a molecular reference frame, execution of ",
 StyleBox["AxesToEuler[",
  FontWeight->"Bold"],
 "{",
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", "P"], TraditionalForm]],ExpressionUUID->
  "b96782a8-1761-45bf-aa7c-32ca6928b87d"],
 ",",
 Cell[BoxData[
  FormBox[
   SubscriptBox["y", "P"], TraditionalForm]],ExpressionUUID->
  "7c1ea394-8aec-4fd9-8091-b5a63f7934f2"],
 ",",
 Cell[BoxData[
  FormBox[
   SubscriptBox["z", "P"], TraditionalForm]],ExpressionUUID->
  "68efed36-7a37-49f5-838a-df70e9055a44"],
 "}",
 StyleBox[",",
  FontWeight->"Bold"],
 "{",
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", "M"], TraditionalForm]],ExpressionUUID->
  "7c042b4d-4179-4a73-9551-beec7bc3000e"],
 ",",
 Cell[BoxData[
  FormBox[
   SubscriptBox["y", "M"], TraditionalForm]],ExpressionUUID->
  "b9aa3896-e4bb-45e0-912f-316b4c3dd7e1"],
 ",",
 Cell[BoxData[
  FormBox[
   SubscriptBox["z", "M"], TraditionalForm]],ExpressionUUID->
  "23942844-544f-4952-8709-e7de5a0ebd63"],
 "}",
 StyleBox["] ",
  FontWeight->"Bold"],
 "returns the Euler angle set ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[CapitalOmega]", "PM"], TraditionalForm]],ExpressionUUID->
  "d66ff9d1-36ef-4cba-a5e5-ff1469ffc499"],
 "= {",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Alpha]", "PM"], TraditionalForm]],ExpressionUUID->
  "56ced931-47d3-4fdf-aab2-0d217eca8daa"],
 ",",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Beta]", "PM"], TraditionalForm]],ExpressionUUID->
  "ebc2d9c9-dde1-45b6-ac84-65b58368fabb"],
 ",",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Gamma]", "PM"], TraditionalForm]],ExpressionUUID->
  "678a49fd-3e36-4659-b5ee-ac9e4c15336d"],
 "} which specify the orientation of the principal axis frame, with respect \
to the molecular reference frame.  "
}], "Text",
 CellChangeTimes->{{3.641658559263023*^9, 3.641658653484804*^9}, {
  3.641659300689987*^9, 
  3.6416595952571507`*^9}},ExpressionUUID->"fa24731f-e5f8-4e2f-a160-\
e03463c04479"],

Cell[TextData[{
 "Consider the case discussed in the previous documentation notebook, in \
which a ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["CO", "2"], TraditionalForm]],ExpressionUUID->
  "492e74b4-7c8f-4bb6-b715-346deae40f2d"],
 " fragment, and associated principal axis system for a hypothetical CSA \
tensor are defined as follows:"
}], "Text",
