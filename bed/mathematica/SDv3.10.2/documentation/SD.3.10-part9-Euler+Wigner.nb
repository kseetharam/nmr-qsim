Cell[CellGroupData[{

Cell["CartesianToSpherical", "Section",
 CellChangeTimes->{{3.575611915027603*^9, 3.575611926367559*^9}, {
  3.575613134956509*^9, 3.575613135881061*^9}, {3.5880743881239867`*^9, 
  3.588074393316068*^9}, {3.629275150014858*^9, 3.6292751509164762`*^9}, {
  3.640885005569182*^9, 3.640885012144264*^9}, {3.712000370709639*^9, 
  3.712000379619609*^9}},
 Background->None,ExpressionUUID->"a446090c-979b-420e-8b89-82c4d3113b8b"],

Cell[TextData[{
 StyleBox["CartesianToSpherical ",
  FontWeight->"Bold"],
 "converts a spatial Cartesian tensor into spherical tensor form. The output \
of ",
 StyleBox["CartesianToSpherical ",
  FontWeight->"Bold"],
 "is a",
 StyleBox[" SphericalTensor ",
  FontWeight->"Bold"],
 "object. The basic syntax of ",
 StyleBox["CartesianToSpherical",
  FontWeight->"Bold"],
 " is given by:\n\n",
 StyleBox["CartesianToSpherical[\[Lambda]1",
  FontWeight->"Bold"],
 StyleBox[", cart",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 StyleBox["]\n\n",
  FontWeight->"Bold"],
 "The argument ",
 StyleBox["cart ",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 "may be a scalar, a vector or 3\[Times]3 matrix. The ",
 StyleBox["\[Lambda] ",
  FontWeight->"Bold"],
 "argument may be used to extract a spherical tensor of the specified rank. \
If the ",
 StyleBox["\[Lambda] ",
  FontWeight->"Bold"],
 "argument is omitted a list of all present spherical tensor objects is \
returned. "
}], "Text",
 CellChangeTimes->{{3.641635227289846*^9, 3.641635253150863*^9}, {
  3.71214767883041*^9, 3.712147713079739*^9}, {3.712147761065909*^9, 
  3.712147918093693*^9}, {3.712147952693397*^9, 3.712148008164256*^9}, {
  3.712148399901011*^9, 3.712148403479756*^9}, {3.712148435034216*^9, 
  3.712148464381317*^9}, {3.712148514209364*^9, 3.7121485774584165`*^9}, {
  3.712148681696567*^9, 3.712148800867586*^9}, {3.712149180297866*^9, 
  3.7121492288115444`*^9}, {3.8969500489924*^9, 
  3.896950049164435*^9}},ExpressionUUID->"5fe6a38f-4cb2-43c7-b714-\
b528a96f19ec"],

Cell["\<\
The spherical tensor components of a random 3\[Times]3 may be extracted as \
follows:\
\>", "Text",
