Cell["\<\
The Euler angles defining the orientation of the principal axis system with \
respect to the molecular reference frame (in which the nuclear coordinates \
are defined) may be calculated as follows:\
\>", "Text",
 CellChangeTimes->{{3.641659838195745*^9, 
  3.641659880395626*^9}},ExpressionUUID->"6f5c753b-a850-444c-b93e-\
f0adc3ca0e5a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[CapitalOmega]PM", "=", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Alpha]PM", ",", "\[Beta]PM", ",", "\[Gamma]PM"}], "}"}], "=", 
   RowBox[{"AxesToEuler", "[", 
    RowBox[{"{", 
     RowBox[{"xP", ",", "yP", ",", "zP"}], "}"}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.64165988358082*^9, 3.641659909732151*^9}},
