        RowBox[{"Sphere", "[", 
         RowBox[{
          RowBox[{"coordinate", "[", "\"\<C\>\"", "]"}], ",", "0.2"}], 
         "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"{", 
