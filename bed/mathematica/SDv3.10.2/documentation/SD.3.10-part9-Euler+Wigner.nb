        RowBox[{"Sphere", "[", 
         RowBox[{
          RowBox[{"coordinate", "[", "\"\<O2\>\"", "]"}], ",", "0.25"}], 
         "]"}]}], "}"}], ",", 
      RowBox[{"Tube", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"coordinate", "[", "\"\<C\>\"", "]"}], ",", 
          RowBox[{"coordinate", "[", "\"\<O1\>\"", "]"}]}], "}"}], ",", 
        "0.1"}], "]"}], ",", "\[IndentingNewLine]", 
      RowBox[{"Tube", "[", 
       RowBox[{
        RowBox[{"{", 
