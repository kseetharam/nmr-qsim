23b463a15ece"],

Cell[TextData[{
 "The routine ",
 StyleBox["RotateEuler",
  FontWeight->"Bold"],
 " rotates an object in 3D space by the consecutive rotations ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["R", "z"], "(", "\[Gamma]", ")"}], TraditionalForm]],
  ExpressionUUID->"8606c4c5-daba-4291-886e-eb78aeb6cc86"],
 Cell[BoxData[
  FormBox[
   RowBox[{"\[LongRightArrow]", 
    RowBox[{
     SubscriptBox["R", "y"], "(", "\[Beta]", ")"}]}], TraditionalForm]],
  ExpressionUUID->"da02c103-7c83-4ecc-b2d2-28f89d53ba51"],
 Cell[BoxData[
  FormBox[
   RowBox[{"\[LongRightArrow]", 
    RowBox[{
     SubscriptBox["R", "z"], "(", "\[Alpha]", ")"}]}], TraditionalForm]],
  ExpressionUUID->"7bff81d5-b77d-4581-87b2-3a8fca3e247d"],
 " (reading from left to right), where the rotations are about the axes of \
the fixed \[OpenCurlyDoubleQuote]laboratory\[CloseCurlyDoubleQuote] frame. "
}], "Text",
 CellChangeTimes->{{3.641635066080681*^9, 
  3.6416352222232018`*^9}},ExpressionUUID->"5bfb3588-3d41-4937-b3bf-\
3f9aac305834"],

Cell[TextData[{
 "The general syntax is ",
 StyleBox["RotateEuler[",
  FontWeight->"Bold"],
 StyleBox["object",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 StyleBox[",{\[Alpha],\[Beta],\[Gamma]}]",
  FontWeight->"Bold"]
}], "Text",
 CellChangeTimes->{{3.641635329149105*^9, 3.641635349043541*^9}, {
  3.641635385984694*^9, 
  3.641635388088615*^9}},ExpressionUUID->"48055a53-3a08-436b-a5c5-\
c5731c77e21b"],

Cell[CellGroupData[{

