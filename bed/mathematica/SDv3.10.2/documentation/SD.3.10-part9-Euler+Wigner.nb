}, Open  ]],

Cell[TextData[{
 "The components of a ",
 StyleBox["SphericalTensor",
  FontWeight->"Bold"],
 " may be extracted using the syntax ",
 StyleBox["SphericalTensor[...][m]",
  FontWeight->"Bold"],
 "."
}], "Text",
 CellChangeTimes->{{3.641635227289846*^9, 3.641635253150863*^9}, 
   3.641635307662978*^9, {3.712150169311919*^9, 
