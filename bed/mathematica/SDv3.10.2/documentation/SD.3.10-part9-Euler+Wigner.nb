        RowBox[{"Sphere", "[", 
         RowBox[{
          RowBox[{"coordinate", "[", "\"\<O1\>\"", "]"}], ",", "0.25"}], 
         "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"{", 
