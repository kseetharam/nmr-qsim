       Rational[1, 2] Rational[3, 2]^Rational[1, 2] + 
       Rational[-1, 4] 2^Rational[-1, 2], Rational[1, 2] 
       Rational[3, 2]^Rational[1, 2]}, {
      Rational[-3, 4], Rational[1, 4] 3^Rational[1, 2], Rational[1, 2]}}, {0, 
     0, 0}}, {{{-0.047367172745376496`, -0.7891491309924313, 
     0.6123724356957945}, {0.659739608441171, 0.4355957403991576, 
     0.6123724356957945}, {-0.75, 0.4330127018922193, 0.5}}, {0, 0, 0}}]],
  Boxed->False,
  LabelStyle->Directive[FontFamily -> "Helvetica", FontSize -> 14]]], "Output",\

 CellChangeTimes->{{3.641635464566646*^9, 3.6416354996501923`*^9}, 
