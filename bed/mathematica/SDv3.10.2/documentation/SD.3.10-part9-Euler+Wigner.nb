Cell[TextData[{
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 " contains routines for the Wigner rotation matrices, used to generate the \
rotations of spherical tensors. "
}], "Text",
 CellChangeTimes->{{3.6416603940500517`*^9, 3.641660414817691*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"effd8fa1-ffbd-4523-b7d8-d9ab649df7d9"],

Cell[TextData[{
 "In ",
 StyleBox["SpinDynamica",
  FontSlant->"Italic"],
 ", the built-in ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " routines ",
 StyleBox["WignerD",
  FontWeight->"Bold"],
 " and ",
 StyleBox["Wignerd",
  FontWeight->"Bold"],
 " have been augmented with additional syntax. WignerD generates a message to \
that effect, the first time it is executed. "
}], "Text",
 CellChangeTimes->{{3.641660422166031*^9, 3.641660460491741*^9}, {
  3.641661814153889*^9, 3.641661854661439*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"64e93af1-8f72-4196-b785-6250a2993e7d"],

Cell[CellGroupData[{

Cell["Wignerd", "Subsection",
 CellChangeTimes->{{3.641660463341045*^9, 3.641660465939495*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"c86777bf-5997-404f-8131-d086ec3bd93d"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"Wignerd", "[", 
    RowBox[{"\[Lambda]", ",", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["\[Mu]", "1"], ",", 
       SubscriptBox["\[Mu]", "2"]}], "}"}]}]}], TraditionalForm]],
  ExpressionUUID->"f03ec719-7bda-4aad-8ef2-a0ad78806269"],
 StyleBox["][\[Beta]] ",
  FontWeight->"Bold"],
 "generates the element ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["d", 
      RowBox[{
       SubscriptBox["\[Mu]", "1"], 
       SubscriptBox["\[Mu]", "2"]}], "\[Lambda]"], "(", "\[Beta]", ")"}], 
    " "}], TraditionalForm]],ExpressionUUID->
  "9d7e9f44-e1c4-45c8-b52e-183c3c9ab074"],
 "of the Wigner d-matrix for rank \[Lambda]. Some representative elements of \
the second-rank matrix are as follows:"
}], "Text",
 CellChangeTimes->{{3.641660470277658*^9, 3.641660546337015*^9}, {
  3.6416606347685127`*^9, 3.641660773659213*^9}, {3.641660984637976*^9, 
  3.641660988842249*^9}},
