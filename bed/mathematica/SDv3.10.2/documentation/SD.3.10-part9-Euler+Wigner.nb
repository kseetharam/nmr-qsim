   RowBox[{
    RowBox[{"Cos", "[", "\[Alpha]", "]"}], " ", 
    RowBox[{"Sin", "[", "\[Beta]", "]"}]}], ",", 
   RowBox[{
    RowBox[{"Sin", "[", "\[Alpha]", "]"}], " ", 
    RowBox[{"Sin", "[", "\[Beta]", "]"}]}], ",", 
   RowBox[{"Cos", "[", "\[Beta]", "]"}]}], "}"}]], "Output",
