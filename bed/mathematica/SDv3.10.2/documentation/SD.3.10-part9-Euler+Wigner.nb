Cell["SphericalTensor", "Section",
 CellChangeTimes->{{3.575611915027603*^9, 3.575611926367559*^9}, {
  3.575613134956509*^9, 3.575613135881061*^9}, {3.5880743881239867`*^9, 
  3.588074393316068*^9}, {3.629275150014858*^9, 3.6292751509164762`*^9}, {
  3.640885005569182*^9, 3.640885012144264*^9}, {3.712000370709639*^9, 
  3.712000393218148*^9}},
 Background->None,ExpressionUUID->"8721a3bd-df9c-4aaa-a8e9-335b51e1aa5e"],

Cell[TextData[{
 "Spherical tensor objects may be constructed using ",
 StyleBox["SphericalTensor. SphericalTensor[\[Lambda], comp] ",
  FontWeight->"Bold"],
 "is an irreducible spherical tensor object with rank \[Lambda] and \
components given by ",
 StyleBox["comp ",
  FontWeight->"Bold"],
 "defined with respect to the tensors ",
 StyleBox["principal axis frame",
  FontWeight->"Bold"],
 ". The components should a list of length ",
 StyleBox["2\[Lambda] +1 ",
  FontWeight->"Bold"],
 "with the elements sorted according to their m-value is descending order \
from m=+\[Lambda] to m=-\[Lambda]",
 StyleBox[".",
  FontWeight->"Bold"]
}], "Text",
 CellChangeTimes->{{3.641635227289846*^9, 3.641635253150863*^9}, {
  3.712149943002267*^9, 3.712150128022116*^9}, {3.712150270841479*^9, 
  3.712150285120511*^9}},ExpressionUUID->"ee963ab4-fb2e-4d4f-8fee-\
d768d4f12c46"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"spht", "=", 
  RowBox[{"SphericalTensor", "[", 
   RowBox[{"2", ",", 
    RowBox[{"{", 
     RowBox[{"\[Eta]", ",", "0", ",", "\[Delta]", ",", "0", ",", "\[Eta]"}], 
     "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.641635255876645*^9, 3.641635297089814*^9}, {
  3.712150146664576*^9, 3.712150165824225*^9}, {3.712150223237894*^9, 
  3.7121502298861217`*^9}},
 CellLabel->
  "In[194]:=",ExpressionUUID->"16c47458-e718-4941-861b-81d5b8d61fc9"],

Cell[BoxData[
 RowBox[{"SphericalTensor", "[", 
  RowBox[{"2", ",", 
   RowBox[{"{", 
    RowBox[{"\[Eta]", ",", "0", ",", "\[Delta]", ",", "0", ",", "\[Eta]"}], 
    "}"}]}], "]"}]], "Output",
 CellChangeTimes->{{3.641635267423333*^9, 3.641635297801663*^9}, 
   3.641659093114015*^9, 3.657822684025573*^9, 3.659602296494722*^9, 
   3.709553118715366*^9, {3.7121501559726486`*^9, 3.712150166307843*^9}, {
