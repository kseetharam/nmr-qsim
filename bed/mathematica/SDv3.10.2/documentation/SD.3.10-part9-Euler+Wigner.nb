   NCache[{{{
      Rational[1, 4] Rational[3, 2]^Rational[1, 2] + 
       Rational[-1, 2] 2^Rational[-1, 2], 
       Rational[-1, 2] Rational[3, 2]^Rational[1, 2] + 
       Rational[-1, 4] 2^Rational[-1, 2], Rational[1, 2] 
       Rational[3, 2]^Rational[1, 2]}, {
      Rational[1, 4] Rational[3, 2]^Rational[1, 2] + 
