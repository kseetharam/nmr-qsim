Cell[TextData[{
 "Using the syntax ",
 StyleBox["SphericalTensor[\[Lambda], comp, \[CapitalOmega]] ",
  FontWeight->"Bold"],
 "may be used to construct a spherical tensor object defined in a reference \
frame defined by the euler angles ",
 StyleBox["\[CapitalOmega].",
  FontWeight->"Bold"],
 " The ",
 StyleBox["\[CapitalOmega]",
  FontWeight->"Bold"],
 " argument may be a list of euler angles",
 StyleBox[" {{\[Alpha]1,\[Beta]1,\[Gamma]1}, {\[Alpha]2,\[Beta]2,\[Gamma]2}, \
...}",
  FontWeight->"Bold"],
 " defining a chain of reference frame transformations with the \
transformation specified by ",
 StyleBox["{\[Alpha]1,\[Beta]1,\[Gamma]1}",
  FontWeight->"Bold"],
 " being applied first, etc. Consider for example transforming a spherical \
tensor into laboratory frame given by a set of random euler angles:"
}], "Text",
 CellChangeTimes->{{3.641635227289846*^9, 3.641635253150863*^9}, 
   3.641635307662978*^9, {3.712150169311919*^9, 3.71215020281106*^9}, {
   3.712150343547353*^9, 
   3.7121506296770463`*^9}},ExpressionUUID->"584c92c4-9d7a-4499-bf07-\
a1b970c84ded"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"SphericalTensor", "[", 
  RowBox[{"2", ",", 
   RowBox[{"{", 
    RowBox[{"\[Eta]", ",", "0", ",", "\[Delta]", ",", "0", ",", "\[Eta]"}], 
    "}"}], ",", 
   RowBox[{"RandomReal", "[", 
    RowBox[{"\[Pi]", ",", "3"}], "]"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.641635255876645*^9, 3.641635297089814*^9}, {
  3.712150146664576*^9, 3.712150165824225*^9}, {3.712150223237894*^9, 
  3.7121502298861217`*^9}, {3.712150556325397*^9, 3.712150567478371*^9}},
 CellLabel->
  "In[196]:=",ExpressionUUID->"be75bfb6-10c7-4236-ac1f-d83b1f5e1df0"],

Cell[BoxData[
 RowBox[{"SphericalTensor", "[", 
  RowBox[{"2", ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"0.`", "\[VeryThinSpace]", "+", 
        RowBox[{"0.`", " ", "\[ImaginaryI]"}]}], ")"}], "-", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"0.2656816479671289`", "\[VeryThinSpace]", "+", 
         RowBox[{"0.3443047034660914`", " ", "\[ImaginaryI]"}]}], ")"}], " ", 
       "\[Delta]"}], "+", 
      RowBox[{
       RowBox[{"(", 
