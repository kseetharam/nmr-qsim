        "0.1"}], "]"}]}], "\[IndentingNewLine]", "}"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"{", 
   RowBox[{"xP", ",", "yP", ",", "zP"}], "}"}], "=", 
  RowBox[{"AxisSystem", "[", "\[IndentingNewLine]", 
   RowBox[{"{", 
