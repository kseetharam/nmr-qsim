Cell["\<\
By default, the x-axis of the calculated axes is in the XZ plane of the \
laboratory axes. The plane of the new x-axis may be specified by giving \
another vector as an argument. In the example below, the new x-axis is \
defined as being in the plane of {1,1,1} and the original Y-axis. The \
original axes are shown in black and annoted as {\[OpenCurlyDoubleQuote]X\
\[CloseCurlyDoubleQuote],\[CloseCurlyDoubleQuote]Y\[CloseCurlyDoubleQuote],\
\[CloseCurlyDoubleQuote]Z\[CloseCurlyDoubleQuote]}. The computed axis system \
is shown in blue and annotated as the default {\[OpenCurlyDoubleQuote]x\
\[CloseCurlyDoubleQuote],\[CloseCurlyDoubleQuote]y\[CloseCurlyDoubleQuote],\
\[CloseCurlyDoubleQuote]z\[CloseCurlyDoubleQuote]}. \
\>", "Text",
 CellChangeTimes->{{3.6414608362743077`*^9, 3.641460893098291*^9}, {
  3.641489103138699*^9, 3.641489133793698*^9}, {3.641489196074551*^9, 
  3.641489224063704*^9}, {3.641654316797895*^9, 3.641654326720811*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"0b8a35b3-f7f6-4d0f-b981-1066aceaf7ba"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"newz", "=", 
  RowBox[{"Normalize", "[", 
   RowBox[{"{", 
    RowBox[{"1", ",", "1", ",", "1"}], "}"}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Axes3D", "[", 
      RowBox[{
       RowBox[{"Annotation", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"\"\<X\>\"", ",", "\"\<Y\>\"", ",", "\"\<Z\>\""}], "}"}]}], 
       ",", 
       RowBox[{"Directive", "\[Rule]", "Black"}]}], "]"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"Axes3D", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"ey", ",", "newz"}], "}"}], ",", 
       RowBox[{"Directive", "\[Rule]", "Blue"}]}], "]"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"Graphics3D", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Opacity", "[", "0.8", "]"}], ",", 
        RowBox[{"Polygon", "@", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"ey", " ", 
             RowBox[{"Cos", "[", "\[Phi]", "]"}]}], "+", 
            RowBox[{"newz", " ", 
             RowBox[{"Sin", "[", "\[Phi]", "]"}]}]}], ",", 
           RowBox[{"{", 
            RowBox[{"\[Phi]", ",", "0", ",", 
             RowBox[{"2", "\[Pi]"}], ",", 
             RowBox[{"2", 
              RowBox[{"\[Pi]", "/", "100"}]}]}], "}"}]}], "]"}]}]}], 
       "\[IndentingNewLine]", "}"}], "]"}]}], "\[IndentingNewLine]", "}"}], 
   ",", "\[IndentingNewLine]", 
   RowBox[{"Boxed", "\[Rule]", "False"}]}], "]"}]}], "Input",
