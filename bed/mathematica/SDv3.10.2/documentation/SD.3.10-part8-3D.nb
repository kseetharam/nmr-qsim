Cell[TextData[{
 StyleBox["Ovaloid",
  FontWeight->"Bold"],
 " implements 3D representations of second-rank tensors, as described in \
Young et al. TensorView: A Software Tool for Displaying NMR Tensors. Magnetic \
Resonance in Chemistry 2019, 57 (5), 211\[Dash]223. \
https://doi.org/10.1002/mrc.4793. \n"
}], "Text",
 CellChangeTimes->{{3.640885929940546*^9, 3.640885975747006*^9}, {
  3.641489613831257*^9, 3.641489629748761*^9}, {3.820340267274007*^9, 
