Cell["\<\
SubtendedAngle is a convenient routine for calculating the subtended angle \
between two vectors, specified using the end point coordinates.\
\>", "Text",
 CellChangeTimes->{{3.641698335341516*^9, 3.641698432533265*^9}, {
  3.641698524198612*^9, 3.6416985959426813`*^9}, {3.641698671569383*^9, 
  3.641698690640848*^9}},ExpressionUUID->"0242b2bd-22a3-4647-a8f2-\
93d88311af69"],

Cell["\<\
The general syntax is SubtendedAngle[r1,r2,r3,r4] which generates the angle \
between the vectors r2-r1 and r4-r3, for example:\
\>", "Text",
 CellChangeTimes->{{3.641698335341516*^9, 3.641698432533265*^9}, {
  3.641698524198612*^9, 
  3.641698610522872*^9}},ExpressionUUID->"82eebc8c-fcb3-430b-a448-\
5631935c66b2"],

