Cell[CellGroupData[{

Cell["drawing axes with arbitrary orientation", "Subsubsection",
 CellChangeTimes->{{3.641489276047664*^9, 3.64148929378132*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"0de0b255-79b9-4d98-9595-40f374ae734f"],

Cell["\<\
The z-axis of the drawn axis system may be aligned with any vector in 3D \
space. The x and y vectors are then defined to be perpendicular to it. In the \
picture below, a disk has been added to make the plane clearer. The original \
axes are shown in black and annoted as {\[OpenCurlyDoubleQuote]X\
\[CloseCurlyDoubleQuote],\[CloseCurlyDoubleQuote]Y\[CloseCurlyDoubleQuote],\
\[CloseCurlyDoubleQuote]Z\[CloseCurlyDoubleQuote]}. The computed axis system \
is shown in blue and annotated as the default {\[OpenCurlyDoubleQuote]x\
\[CloseCurlyDoubleQuote],\[CloseCurlyDoubleQuote]y\[CloseCurlyDoubleQuote],\
\[CloseCurlyDoubleQuote]z\[CloseCurlyDoubleQuote]}. \
\>", "Text",
 CellChangeTimes->{{3.6414598818660088`*^9, 3.64145991516875*^9}, {
  3.6414600971054497`*^9, 3.641460117463454*^9}, {3.641460614027891*^9, 
  3.641460617073813*^9}, {3.6414886823536663`*^9, 3.641488708255132*^9}, {
  3.641654252460722*^9, 3.641654308570919*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"08054778-21eb-45cc-9b2e-91eb10ef1308"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"newz", "=", 
  RowBox[{"Normalize", "[", 
   RowBox[{"{", 
    RowBox[{"1", ",", "1", ",", "1"}], "}"}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Axes3D", "[", 
      RowBox[{
       RowBox[{"Annotation", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"\"\<X\>\"", ",", "\"\<Y\>\"", ",", "\"\<Z\>\""}], "}"}]}], 
       ",", 
       RowBox[{"Directive", "\[Rule]", "Black"}]}], "]"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"Axes3D", "[", 
      RowBox[{
       RowBox[{"{", "newz", "}"}], ",", 
       RowBox[{"Directive", "\[Rule]", "Blue"}]}], "]"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"Graphics3D", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Opacity", "[", "0.8", "]"}], ",", 
        RowBox[{"Polygon", "@", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"ex", " ", 
             RowBox[{"Cos", "[", "\[Phi]", "]"}]}], "+", 
            RowBox[{"newz", " ", 
             RowBox[{"Sin", "[", "\[Phi]", "]"}]}]}], ",", 
           RowBox[{"{", 
            RowBox[{"\[Phi]", ",", "0", ",", 
             RowBox[{"2", "\[Pi]"}], ",", 
             RowBox[{"2", 
              RowBox[{"\[Pi]", "/", "100"}]}]}], "}"}]}], "]"}]}]}], 
       "\[IndentingNewLine]", "}"}], "]"}]}], "\[IndentingNewLine]", "}"}], 
   ",", "\[IndentingNewLine]", 
   RowBox[{"Boxed", "\[Rule]", "False"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.641460633747068*^9, 3.641460659389319*^9}, 
   3.641460718907052*^9, 3.641488712190701*^9, {3.64148875532207*^9, 
   3.6414889605605497`*^9}, {3.641488992156497*^9, 3.6414890586408467`*^9}, 
   3.657822597313818*^9},
 Background->RGBColor[1, 0.925, 0.925],
 CellLabel->
  "In[146]:=",ExpressionUUID->"7d42349f-0ea9-4afe-a17e-44faa3431754"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox["1", 
    SqrtBox["3"]], ",", 
   FractionBox["1", 
    SqrtBox["3"]], ",", 
   FractionBox["1", 
    SqrtBox["3"]]}], "}"}]], "Output",
