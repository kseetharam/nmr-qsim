Cell[TextData[{
 "If a single vector is provided to ",
 StyleBox["AxisSystem",
  FontWeight->"Bold"],
 ", the routine returns an orthonormal right-handed axis system with the \
z-axis along the specified vector, and the x-axis in the xz plane of the \
reference frame:"
}], "Text",
 CellChangeTimes->{{3.640885227858282*^9, 3.640885319489051*^9}, {
  3.641489435835969*^9, 3.6414894404655857`*^9}, {3.641699391181837*^9, 
