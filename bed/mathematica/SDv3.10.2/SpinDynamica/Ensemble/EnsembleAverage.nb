Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"PrepareParallel", "[", 
     RowBox[{"opbasis_", ",", "basis_", ",", "opts___Rule"}], "]"}], ":=", 
    "\[IndentingNewLine]", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "parallel", ",", "nkernelsrunning", ",", "nkernelsrequested", ",", 
        "path", ",", "chronology", ",", "stufftodistribute", ",", "ul"}], 
       "}"}], ",", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"parallel", "=", 
         RowBox[{
          RowBox[{"Parallel", "/.", 
           RowBox[{"{", "opts", "}"}]}], "/.", 
          RowBox[{"Options", "[", "PrepareParallel", "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Which", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"MatchQ", "[", 
            RowBox[{"parallel", ",", 
             RowBox[{"True", "|", "All"}]}], "]"}], "&&", 
           RowBox[{"TrueQ", "[", 
            RowBox[{"$ProcessorCount", ">", "$KernelCount"}], "]"}]}], ",", 
          "\[IndentingNewLine]", "\t", 
          RowBox[{"LaunchKernels", "[", 
           RowBox[{"$ProcessorCount", "-", "$KernelCount"}], "]"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"IntegerQ", "[", "parallel", "]"}], "&&", 
           RowBox[{"TrueQ", "[", 
            RowBox[{"parallel", ">", "$ProcessorCount"}], "]"}], "&&", 
           RowBox[{"TrueQ", "[", 
            RowBox[{"parallel", ">", "$KernelCount"}], "]"}]}], ",", 
          "\[IndentingNewLine]", "\t", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Message", "[", 
             RowBox[{"PrepareParallel", "::", "nonparkernels"}], "]"}], ";", 
            "\[IndentingNewLine]", "\t", 
            RowBox[{"LaunchKernels", "[", 
             RowBox[{"parallel", "-", "$KernelCount"}], "]"}]}], ")"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"IntegerQ", "[", "parallel", "]"}], "&&", 
           RowBox[{"TrueQ", "[", 
            RowBox[{"parallel", ">", "$KernelCount"}], "]"}]}], ",", 
          "\[IndentingNewLine]", "\t", 
          RowBox[{"LaunchKernels", "[", 
           RowBox[{"parallel", "-", "$KernelCount"}], "]"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"IntegerQ", "[", "parallel", "]"}], "&&", 
           RowBox[{"TrueQ", "[", 
            RowBox[{"parallel", "<", "$KernelCount"}], "]"}]}], ",", 
          "\[IndentingNewLine]", "\t", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Message", "[", 
             RowBox[{"PrepareParallel", "::", "relaunch"}], "]"}], ";", 
            "\[IndentingNewLine]", "\t", 
            RowBox[{"CloseKernels", "[", "]"}], ";", "\[IndentingNewLine]", 
            "\t", 
            RowBox[{"LaunchKernels", "[", "parallel", "]"}]}], ")"}], ",", 
          "\[IndentingNewLine]", "True", ",", "\[IndentingNewLine]", "\t", 
          "Null"}], "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
        
        RowBox[{"If", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"$KernelID", "==", "0"}], ",", "\[IndentingNewLine]", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"path", "=", "$Path"}], ";", "\[IndentingNewLine]", 
            RowBox[{"chronology", "=", "$Chronology"}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"DistributeDefinitions", "[", 
             RowBox[{"path", ",", "chronology"}], "]"}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"ul", "=", 
             RowBox[{"UserLevel", "[", "]"}]}], ";", "\[IndentingNewLine]", 
            RowBox[{"ParallelEvaluate", "[", 
             RowBox[{"$Path", "=", "path"}], "]"}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"ParallelEvaluate", "[", 
             RowBox[{"$Chronology", "=", "chronology"}], "]"}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"DistributeDefinitions", "[", 
             RowBox[{
              RowBox[{"SpinSystem", "[", "]"}], ",", 
              RowBox[{"Basis", "[", "]"}], ",", 
              RowBox[{"ZeemanKetBraOperatorBasis", "[", "]"}]}], "]"}], ";"}],
            "\[IndentingNewLine]", ")"}]}], "\[IndentingNewLine]", "]"}], ";",
         "\[IndentingNewLine]", 
        RowBox[{"ParallelNeeds", "[", "\"\<SpinDynamica`\>\"", "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"ParallelEvaluate", "[", 
         RowBox[{"Quiet", "@", 
          RowBox[{"SetUserLevel", "[", "ul", "]"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"ParallelEvaluate", "[", 
         RowBox[{"Quiet", "@", 
          RowBox[{"SetSpinSystem", "[", 
           RowBox[{"SpinSystem", "[", "basis", "]"}], "]"}]}], "]"}], ";", 
        "\n", "\t", 
        RowBox[{"ParallelEvaluate", "[", 
         RowBox[{"Quiet", "@", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"basis", "===", 
             RowBox[{"Basis", "[", "]"}]}], ",", "Nothing", ",", 
            RowBox[{"SetBasis", "[", "basis", "]"}]}], "]"}]}], "]"}], ";", 
        "\n", "\t", 
        RowBox[{"ParallelEvaluate", "[", 
         RowBox[{"Quiet", "@", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"opbasis", "===", 
             RowBox[{"OperatorBasis", "[", "]"}]}], ",", "Nothing", ",", 
            RowBox[{"SetOperatorBasis", "[", "opbasis", "]"}]}], "]"}]}], 
         "]"}], ";", "\n", "\t", 
        RowBox[{"stufftodistribute", "=", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"SpinSystem", "[", "]"}], ",", 
           RowBox[{"Basis", "[", "]"}], ",", 
           RowBox[{"OperatorBasis", "[", "]"}], ",", "$RecursionLimit", ",", 
           "$IterationLimit", ",", "$ChopThreshold", ",", "$Chronology"}], 
          "}"}]}], ";", "\n", "\t", 
        RowBox[{"DistributeDefinitions", "[", "stufftodistribute", "]"}], ";",
         "\[IndentingNewLine]", 
        RowBox[{"ParallelEvaluate", "[", "stufftodistribute", "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"DistributeDefinitions", "[", 
         RowBox[{
         "\"\<Global`\>\"", ",", "\"\<General`PhysicalConstants`\>\""}], 
         "]"}], ";"}], "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}], 
  " "}]], "Input",
