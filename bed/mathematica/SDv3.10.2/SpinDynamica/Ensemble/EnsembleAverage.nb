Cell["\<\
takes an EnsembleAverage specification and derives a set of variable \
substitution rules for each element. The substitution rules include arrayed \
forms of multidimensional variables.\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.6429410880697613`*^9, 
  3.6429411427022133`*^9}},ExpressionUUID->"37d7a533-ae8b-4878-93b9-\
48aa9a48ee6d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"EnsembleSubstitutionRules", "[", "expr_", "]"}], "/;", 
    RowBox[{"!", 
     RowBox[{"FreeQ", "[", 
      RowBox[{"expr", ",", "$Failed"}], "]"}]}]}], ":=", "$Failed"}], 
  ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.6429393579744463`*^9, 3.642939375116969*^9}, 
   3.7563037845481157`*^9},ExpressionUUID->"9804cbec-9ff1-4f76-830f-\
b6a588400d04"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"EnsembleSubstitutionRules", "[", 
     RowBox[{"{", 
      RowBox[{"vars_", ",", "valws_"}], "}"}], "]"}], "/;", 
    RowBox[{
     RowBox[{"!", 
      RowBox[{"MatchQ", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"vars", ",", "valws"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"_List", ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"_List", ",", 
              RowBox[{"Except", "[", "_List", "]"}]}], "}"}], ".."}], "}"}]}],
          "}"}]}], "]"}]}], "||", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Length", "[", "vars", "]"}], "\[NotEqual]", 
      RowBox[{"Length", "[", 
       RowBox[{"valws", "\[LeftDoubleBracket]", 
        RowBox[{"1", ",", "1"}], "\[RightDoubleBracket]"}], "]"}]}]}]}], ":=", 
   RowBox[{"EnsembleSubstitutionRules", "@", 
    RowBox[{"StandardizeEnsembleAverage", "[", 
     RowBox[{"{", 
      RowBox[{"vars", ",", "valws"}], "}"}], "]"}]}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.6428462391144257`*^9, 3.642846386386539*^9}, {
  3.642873198313826*^9, 3.6428732005880537`*^9}, {3.75630378455301*^9, 
  3.756303784557246*^9}},ExpressionUUID->"96f18df0-f3df-428d-9c54-\
2e7dd71be8e5"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"EnsembleSubstitutionRules", "[", 
     RowBox[{"{", 
      RowBox[{"vars_", ",", "valws_"}], "}"}], "]"}], "/;", 
    RowBox[{"!", 
     RowBox[{"MatchQ", "[", 
      RowBox[{
       RowBox[{"MultidimensionalEnsembleVariables", "[", 
        RowBox[{"{", 
         RowBox[{"vars", ",", "valws"}], "}"}], "]"}], ",", 
       RowBox[{"{", "}"}]}], "]"}]}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"EnsembleSubstitutionRules", "@", "\[IndentingNewLine]", 
    RowBox[{"StandardizeEnsembleAverage", "[", "\[IndentingNewLine]", 
     RowBox[{"MapAt", "[", 
      RowBox[{"Flatten", ",", "\[IndentingNewLine]", 
       RowBox[{"ReleaseHold", "@", 
        RowBox[{"ExpandMultidimensionalEnsembleVariables", "[", 
         RowBox[{
          RowBox[{"Evaluate", "@", 
           RowBox[{"{", 
            RowBox[{"vars", ",", "valws"}], "}"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"vars", ",", "valws"}], "}"}]}], "]"}]}], ",", 
       "\[IndentingNewLine]", "1"}], "]"}], "\[IndentingNewLine]", "]"}]}]}], 
  ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.6429390159187813`*^9, 3.642939097980088*^9}, {
