 CellChangeTimes->{{3.7556628336389647`*^9, 
  3.755662835285863*^9}},ExpressionUUID->"eb7bb4c3-fee1-4aac-9f6a-\
883b1a703e7d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Parallel", "::", "usage"}], "=", 
   "\"\<Parallel is an option for high-level SpinDynamica routines including \
Signal1D, Trajectory, TransformationAmplitude and \
TransformationAmplitudeTable. If True (which is usually the default), then \
the members of EnsembleAverage are computed in parallel using the available \
kernels. If Parallel\[Rule]<integer>, then the specified number of kernels is \
used. If Parallel\[Rule]False, then the ensemble average computations are \
performed sequentially on a single kernel.\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.5652643379613657`*^9, 3.565264359826251*^9}, {
  3.565264395945901*^9, 3.5652644960987453`*^9}, {3.570346581312025*^9, 
