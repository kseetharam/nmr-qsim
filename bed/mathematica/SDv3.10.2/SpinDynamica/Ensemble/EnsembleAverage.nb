  3.756303784565565*^9}},ExpressionUUID->"bba1fce1-109f-4ec2-a881-\
2a41e906f306"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"EnsembleSubstitutionRules", "[", 
     RowBox[{"{", 
      RowBox[{"vars_", ",", "valws_"}], "}"}], "]"}], "/;", 
    RowBox[{"MatchQ", "[", 
     RowBox[{
      RowBox[{"MultidimensionalEnsembleVariables", "[", 
       RowBox[{"{", 
        RowBox[{"vars", ",", "valws"}], "}"}], "]"}], ",", 
      RowBox[{"{", "}"}]}], "]"}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"vals", ",", "nvar"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"vals", "=", 
        RowBox[{"First", "/@", "valws"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"nvar", "=", 
        RowBox[{"Length", "[", "vars", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Transpose", "@", 
        RowBox[{"Map", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"Function", "[", 
              RowBox[{"val", ",", 
               RowBox[{
                RowBox[{"First", "[", "#", "]"}], "\[Rule]", "val"}]}], "]"}],
              "/@", 
             RowBox[{"Last", "[", "#", "]"}]}], ")"}], "&"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{
              "vars", "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}], 
              ",", 
              RowBox[{
               RowBox[{
                RowBox[{"Part", "[", 
                 RowBox[{"#", ",", "i"}], "]"}], "&"}], "/@", "vals"}]}], 
             "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"i", ",", "1", ",", "nvar"}], "}"}]}], "]"}]}], 
         "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", ")"}]}], 
    "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.64284640698577*^9, 3.6428464409636183`*^9}, {
