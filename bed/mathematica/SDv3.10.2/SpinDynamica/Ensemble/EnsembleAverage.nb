Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"EnsembleAverage", "::", "ambig1Dvar"}], "=", 
    "\"\<The syntax is ambiguous. SpinDynamica will assume that `1` is a \
one-dimensional variable and that {{`2`,`3`}..} specifies a set of \
one-dimensional values and weights. To avoid this ambiguity, use the syntax \
EnsembleAverage\[Rule]{`1`,{{`2`},`3`},..}}. If you intend `1` to be a \
two-dimensional variable taking equally weighted values {{`2`,`3`},..}, use \
the syntax EnsembleAverage\[Rule]{`1`,{{`2`,`3`}},..}}. \n\>\""}], ";"}], 
  " "}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.642749683820735*^9, 3.642749689804624*^9}, {
   3.64274973353588*^9, 3.642749764193712*^9}, {3.642749846741538*^9, 
