Cell[CellGroupData[{

Cell["MaxBatchSize", "Subsection",
 InitializationCell->True,
 CellChangeTimes->{{3.56596035516168*^9, 3.565960383864678*^9}, 
   3.565960533832921*^9},ExpressionUUID->"b1c0f228-75d5-4ee5-8f27-\
b87e1be636b5"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"MaxBatchSize", "::", "usage"}], "=", 
   "\"\<MaxBatchSize is an option associated with EnsembleAverage which \
causes the ensemble average to be divided into batches of dimension not \
larger than MaxBatchSize. The results of each batch are combined first before \
the overall combination is generated. This procedure conserves memory for \
large ensemble averages.\>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 CellChangeTimes->{{3.469878218285511*^9, 3.469878219035956*^9}, {
