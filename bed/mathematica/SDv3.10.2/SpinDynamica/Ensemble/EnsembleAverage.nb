       RowBox[{"valws", "\[LeftDoubleBracket]", 
        RowBox[{"1", ",", "1"}], "\[RightDoubleBracket]"}], "]"}]}]}]}], ":=", 
   RowBox[{"ExpandMultidimensionalEnsembleVariables", "[", 
    RowBox[{"expr", ",", 
     RowBox[{"StandardizeEnsembleAverage", "[", 
      RowBox[{"{", 
       RowBox[{"vars", ",", "valws"}], "}"}], "]"}]}], "]"}]}], 
  ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.6429173408633204`*^9, 3.6429173733101883`*^9}},
 CellLabel->"In[93]:=",ExpressionUUID->"24f1b5c9-ef52-4d70-bb49-bacfa74127f8"],

Cell["\<\
The SetAttributes[..,NHoldFirst] below is needed to prevent {var[1],var[2]..} \
resolutions of a multidimensional variable being converted into \
{var[1.],var[2.]..} forms upon applying N, which cannot be evaluated. \
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.661161479595036*^9, 3.6611615874709253`*^9}, {
  3.661161636173225*^9, 
  3.66116165832467*^9}},ExpressionUUID->"2aa71410-ea3f-43dd-9d6f-\
4301070c97fb"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ExpandMultidimensionalEnsembleVariables", "[", 
    RowBox[{"expr_", ",", 
     RowBox[{"{", 
      RowBox[{"vars_", ",", "valws_"}], "}"}]}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "multidensvar", "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"multidensvar", "=", 
        RowBox[{"MultidimensionalEnsembleVariables", "[", 
         RowBox[{"{", 
          RowBox[{"vars", ",", "valws"}], "}"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"SetAttributes", "[", 
          RowBox[{
           RowBox[{"Evaluate", "[", 
            RowBox[{"First", "[", "#", "]"}], "]"}], ",", "NHoldFirst"}], 
          "]"}], "&"}], "/@", "multidensvar"}], ";", "\[IndentingNewLine]", 
       RowBox[{"ReleaseHold", "[", "\[IndentingNewLine]", 
        RowBox[{"expr", "/.", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"Rule", "[", 
             RowBox[{
              RowBox[{"First", "[", "#", "]"}], ",", 
              RowBox[{"Array", "[", 
               RowBox[{
                RowBox[{"First", "[", "#", "]"}], ",", 
                RowBox[{"Last", "[", "#", "]"}]}], "]"}]}], "]"}], "&"}], "/@",
            "multidensvar"}], ")"}]}], "\[IndentingNewLine]", "]"}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.6429176629458523`*^9, 3.642917679934267*^9}, {
   3.642917778451037*^9, 3.642917814535918*^9}, 3.6429179138830557`*^9, {
   3.642918227408184*^9, 3.64291823280046*^9}, {3.642939823233528*^9, 
