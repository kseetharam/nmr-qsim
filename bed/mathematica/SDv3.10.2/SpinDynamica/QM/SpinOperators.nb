Cell[CellGroupData[{

Cell["CoherenceOrder", "Subsection",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 AspectRatioFixed->
  True,ExpressionUUID->"fc361c54-0656-4f52-babd-8224566ef320"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"CoherenceOrder", "::", "usage"}], "=", 
   "\[IndentingNewLine]", "\"\<CoherenceOrder[op] gives the total coherence \
order of an operator op. CoherenceOrder[spins,op] gives the coherence order \
summed over the defined set of spins. CoherenceOrder[{spins1,spins2...},op] \
gives a list of coherence orders for each of the defined sets of spins. If an \
operator contains more than one coherence order, a list of the contained \
coherence orders is returned.\n\>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.468164438272955*^9, 3.468164449974994*^9}, {
  3.502076781494165*^9, 3.502076799915557*^9}, {3.6305812187803926`*^9, 
  3.630581287343003*^9}},
 CellLabel->
  "In[1193]:=",ExpressionUUID->"428669d4-4265-4949-badf-d9f870448d33"]
}, Closed]],

Cell[CellGroupData[{

Cell["SpinProductRank", "Subsection",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{3.468164500786809*^9},
 AspectRatioFixed->
