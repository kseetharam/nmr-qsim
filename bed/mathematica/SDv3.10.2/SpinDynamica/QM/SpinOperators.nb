Cell[CellGroupData[{

Cell["NormalizeOperator", "Subsection",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.4308939920692368`*^9, 3.430893995066204*^9}, {
  3.43452558636746*^9, 3.434525586931498*^9}, {3.447343231667141*^9, 
  3.447343234368677*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"8670d831-d495-4b5d-a505-28e964782933"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"NormalizeOperator", "::", "usage"}], "=", 
   "\[IndentingNewLine]", "\"\<NormalizeOperator[op, norm, basis] scales an \
operator so that its norm is given by norm in the specified basis. If the \
basis specification is omitted, the current basis is used. If norm is \
omitted, a norm of 1 is assumed. The syntax NormalizeOperator[op1, op2, \
basis], where op2 is also an operator, sets the norm of op1 to equal that of \
op2.\n\>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.430893998221677*^9, 3.430894014980308*^9}, {
  3.434525590977869*^9, 3.434525626453712*^9}, {3.447227127127363*^9, 
  3.447227169088076*^9}, {3.44722770952263*^9, 3.447227715456723*^9}, {
  3.447343237954089*^9, 3.447343296828744*^9}, {3.63285061683628*^9, 
  3.632850757271005*^9}},
 CellLabel->
  "In[1197]:=",ExpressionUUID->"d5b6c907-6881-4e58-a699-24840b53d6ba"]
}, Closed]],

