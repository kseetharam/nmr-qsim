59eb69dc54bb"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"HoldPattern", "@", 
     RowBox[{"OperatorProduct", "[", 
      RowBox[{
       RowBox[{"opsa___", "?", "OperatorQ"}], ",", 
       RowBox[{"Power", "[", 
        RowBox[{"E", ",", 
         RowBox[{"opa_", "?", "OperatorQ"}]}], "]"}], ",", 
       RowBox[{"Power", "[", 
        RowBox[{"E", ",", 
         RowBox[{"opb_", "?", "OperatorQ"}]}], "]"}], ",", 
       RowBox[{"opsb___", "?", "OperatorQ"}], ",", "opts___Rule"}], "]"}]}], "/;", 
    RowBox[{"OperatorsCommuteQ", "[", 
     RowBox[{"opa", ",", "opb"}], "]"}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"OperatorProduct", "[", 
    RowBox[{"opsa", ",", 
