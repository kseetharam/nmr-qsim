Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Operator", "[", 
    RowBox[{"specs_", ",", "basis_", ",", "opts___Rule"}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Operator", "[", "\[IndentingNewLine]", 
     RowBox[{"specs", ",", "basis", ",", "\[IndentingNewLine]", 
      RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"CheckOperatorType", "\[Rule]", "False"}], ",", 
        "\[IndentingNewLine]", "opts"}], "\[IndentingNewLine]", "]"}]}], 
     "\[IndentingNewLine]", "]"}], "/;", 
    RowBox[{
     RowBox[{"MatchQ", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"CheckOperatorType", "/.", 
         RowBox[{"{", "opts", "}"}]}], "/.", 
        RowBox[{"Options", "[", "Operator", "]"}]}], ",", "Automatic"}], 
      "]"}], "&&", 
     RowBox[{"MemberQ", "[", 
      RowBox[{
       RowBox[{"First", "/@", 
        RowBox[{"(", 
         RowBox[{"Assumptions", "/.", 
          RowBox[{"{", "opts", "}"}]}], ")"}]}], ",", "OperatorType"}], 
      "]"}]}]}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.691402203541898*^9, 3.691402297201036*^9}, 
   3.691403115609381*^9, {3.6914034342539372`*^9, 3.691403498653009*^9}, {
