Cell[CellGroupData[{

Cell["Projection and ShiftOperators", "Subsection",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.460294076891525*^9, 3.46029408339401*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"f08d223b-9a99-4c5b-b1b1-9f358d369dec"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ProjectionOperator", "::", "usage"}], 
   "=", "\"\<ProjectionOperator[ket] is the operator for projection onto the \
specified ket, i.e. |ket><ket|. The ket is automatically normalized before \
use. The syntax ProjectionOperator[{{j,mj},{k,mk}..}] constructs a projection \
operator onto the states {mj,mk..} of a subset of spins {j,k..}. A sum is \
taken over the spins not included in the set {j,k..}.\>\""}], ";"}]], "Input",\

 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.450614085287265*^9, 3.450614109002995*^9}, 
   3.450614180007576*^9, {3.4556434524258833`*^9, 3.455643462806561*^9}, {
   3.460294104008157*^9, 3.460294140704196*^9}, {3.460294203446073*^9, 
   3.460294213132286*^9}, {3.460629253023463*^9, 3.460629397805852*^9}, {
   3.460629433374834*^9, 3.460629444421898*^9}},
 CellLabel->
  "In[1185]:=",ExpressionUUID->"48153dc3-7d63-4213-af8e-0d280901297d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ShiftOperator", "::", "usage"}], 
   "=", "\"\<ShiftOperator[ket,bra] is the operator |ket><bra|. Both ket and \
bra are automatically normalized before use.\>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.450614085287265*^9, 3.450614109002995*^9}, {
  3.450614150522191*^9, 3.450614177232225*^9}, {3.4554626340113564`*^9, 
  3.4554626529329844`*^9}, {3.455462696799475*^9, 3.455462721376337*^9}, {
  3.4554628077931542`*^9, 3.45546281258373*^9}, {3.455643414156969*^9, 
  3.455643443863118*^9}, {3.455643580145306*^9, 3.45564359234967*^9}, {
  3.460294158802975*^9, 3.460294198483589*^9}},
 CellLabel->
  "In[1186]:=",ExpressionUUID->"02b7ba59-56fb-4aed-9197-cbedd0a674f6"]
}, Closed]],

Cell[CellGroupData[{

Cell["SpinPermutationOperator", "Subsection",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.460294076891525*^9, 3.46029408339401*^9}, {
   3.502278224749463*^9, 3.502278227891998*^9}, 3.502283900799093*^9, {
   3.590399059341234*^9, 3.590399064146683*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"dac7b2f3-410d-417f-a8c7-870f8a8f89be"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SpinPermutationOperator", "::", "usage"}], 
   "=", "\"\<SpinPermutationOperator[{j,k}] is the operator for exchange of \
spin j with spin k. SpinPermutationOperator[{j,k,l,m..}] is the operator for \
a cyclic permutation of the specified spins, with \
j\[Rule]k,k\[Rule]l,l\[Rule]m, etc. \
SpinPermutationOperator[{..{j2,k2..},{j1,k1..}}] is the operator for \
successive spin exchange operations, with the {j1,k1..} permutation preceding \
the {j2,k2..} permutation, and so on (i.e. right to left order of \
application).\>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.450614085287265*^9, 3.450614109002995*^9}, 
   3.450614180007576*^9, {3.4556434524258833`*^9, 3.455643462806561*^9}, {
