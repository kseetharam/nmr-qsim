Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"opT", "::", "multiple"}], 
   "=", "\"\<There are `1` operators with this specification. A list of all \
possibilities has been returned. Specify a single operator using the form \
opT[interactions,{Lam,M},index] where index is an integer.\>\""}], 
  ";"}]], "Input",
