  3.6392259655997334`*^9}},ExpressionUUID->"7c171bb7-d2cb-4494-bebe-\
d933a9505ede"],

Cell["\<\
In this case the basis must be expanded to take in the \
\[OpenCurlyDoubleQuote]missing\[CloseCurlyDoubleQuote] spins\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.639224859426517*^9, 
  3.639224875941658*^9}},ExpressionUUID->"5ad2cda1-8e3b-4762-b4c0-\
8ef0f4ac2d54"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"HoldPattern", "@", 
    RowBox[{"MatrixRepresentation", "[", 
     RowBox[{
      RowBox[{"op", ":", 
       RowBox[{"Operator", "[", 
        RowBox[{"specs_", ",", "basis1_", ",", "opts1__Rule"}], "]"}]}], ",", 
      "basis2_", ",", "opts2___Rule"}], "]"}]}], ":=", "\[IndentingNewLine]", 
   
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "spinsys1", ",", "spinsys2", ",", "missingspins", ",", 
       "missingspinkets", ",", "missingspinbras", ",", "matrep", ",", "kets", 
       ",", "bras", ",", "ketbraopform", ",", "n"}], "}"}], ",", 
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"missingspins", "=", 
         RowBox[{"Complement", "[", 
          RowBox[{"spinsys2", ",", "spinsys1"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"missingspinkets", "=", 
         RowBox[{"BasisKets", "[", 
          RowBox[{"ZeemanBasis", "[", "missingspins", "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"missingspinbras", "=", 
         RowBox[{"BasisBras", "[", 
          RowBox[{"ZeemanBasis", "[", "missingspins", "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"kets", "=", 
         RowBox[{"BasisKets", "[", 
          RowBox[{"ZeemanBasis", "[", "spinsys1", "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"bras", "=", 
         RowBox[{"BasisBras", "[", 
          RowBox[{"ZeemanBasis", "[", "spinsys1", "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"n", "=", 
         RowBox[{"Length", "[", "kets", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"matrep", "=", 
         RowBox[{"MatrixRepresentation", "[", 
          RowBox[{"op", ",", 
           RowBox[{"ZeemanBasis", "[", "spinsys1", "]"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"ketbraopform", "=", 
         RowBox[{"Plus", "@@", 
          RowBox[{"Flatten", "@", 
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"matrep", "\[LeftDoubleBracket]", 
               RowBox[{"r", ",", "c"}], "\[RightDoubleBracket]"}], "*", 
              RowBox[{
               RowBox[{
               "kets", "\[LeftDoubleBracket]", "r", "\[RightDoubleBracket]"}],
                ".", 
               RowBox[{
               "bras", "\[LeftDoubleBracket]", "c", 
                "\[RightDoubleBracket]"}]}]}], ",", 
             RowBox[{"{", 
              RowBox[{"r", ",", "1", ",", "n"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"c", ",", "1", ",", "n"}], "}"}]}], "]"}]}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"MatrixRepresentation", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"ketbraopform", "/.", 
           RowBox[{
            RowBox[{"ket_Ket", ".", "bra_Bra"}], "\[RuleDelayed]", 
            "\[IndentingNewLine]", 
            RowBox[{"Inner", "[", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"ProductKet", "[", 
                 RowBox[{"ket", ",", "#1"}], "]"}], ".", 
                RowBox[{"ProductBra", "[", 
                 RowBox[{"bra", ",", "#2"}], "]"}]}], "&"}], ",", 
              "\[IndentingNewLine]", "missingspinkets", ",", 
              "missingspinbras"}], "\[IndentingNewLine]", "]"}]}]}], ",", 
          "\[IndentingNewLine]", "basis2"}], "\[IndentingNewLine]", "]"}]}], 
       "\[IndentingNewLine]", ")"}], "/;", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"spinsys1", "=", 
         RowBox[{"SpinSystem", "[", "basis1", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"spinsys2", "=", 
         RowBox[{"SpinSystem", "[", "basis2", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"UnsameQ", "[", 
          RowBox[{"spinsys1", ",", "spinsys2"}], "]"}], "&&", 
         RowBox[{"SubsetQ", "[", 
          RowBox[{"spinsys2", ",", "spinsys1"}], "]"}]}]}], 
       "\[IndentingNewLine]", ")"}]}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.639224892042947*^9, 3.63922489278508*^9}, {
   3.639224955305794*^9, 3.639225021357777*^9}, {3.639225079998189*^9, 
