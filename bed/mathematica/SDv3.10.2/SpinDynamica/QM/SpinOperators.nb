 CellLabel->
  "In[1328]:=",ExpressionUUID->"a43c15cf-8614-41f1-a7f1-927875324b34"],

Cell["\<\
In case of numeric matrices, determine the OperatorType if the dimension is \
not too large\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.5834321822769747`*^9, 3.583432195403837*^9}, {
  3.583432382666816*^9, 3.583432392520463*^9}, {3.586166595514784*^9, 
  3.586166603611122*^9}, {3.586253431742683*^9, 3.5862534385669203`*^9}, {
