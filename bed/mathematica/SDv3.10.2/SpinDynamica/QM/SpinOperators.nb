Cell[BoxData[
 RowBox[{
  RowBox[{"NullOperator", "/:", 
   RowBox[{
    RowBox[{"HoldPattern", "@", 
     RowBox[{"Plus", "[", 
      RowBox[{"n1___", ",", 
       RowBox[{"NullOperator", "[", "]"}], ",", "n2___"}], "]"}]}], "/;", 
    "\[IndentingNewLine]", 
    RowBox[{"!", 
     RowBox[{"And", "@@", 
      RowBox[{"OperatorQ", "/@", 
       RowBox[{"{", 
        RowBox[{"n1", ",", "n2"}], "}"}]}]}]}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"notops", ",", "ops"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"ops", "=", 
        RowBox[{"Cases", "[", 
         RowBox[{
