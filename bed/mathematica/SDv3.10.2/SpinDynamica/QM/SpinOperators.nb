Cell["\<\
routine below tests whether operators commute, and if so, whether they should \
be swapped. \
\>", "Text",
 CellChangeTimes->{{3.969179288499591*^9, 3.96917929853209*^9}, {
  3.969180089527479*^9, 
  3.969180095319405*^9}},ExpressionUUID->"757a1532-28ac-48c1-aebd-\
e2e8d0c6a516"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"swapoperatorsQ", "[", 
    RowBox[{"op1_", ",", "op2_"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"spins1", ",", "spins2"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"spins1", "=", 
        RowBox[{"InvolvedSpins", "[", "op1", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"spins2", "=", 
        RowBox[{"InvolvedSpins", "[", "op2", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Which", "[", "\[IndentingNewLine]", "\t", 
        RowBox[{
         RowBox[{"IntersectingQ", "[", 
          RowBox[{"spins1", ",", "spins2"}], "]"}], ",", 
         "\[IndentingNewLine]", "\t\t", "False", ",", "\[IndentingNewLine]", 
         "\t", 
         RowBox[{
          RowBox[{"OperatorsCommuteQ", "[", 
           RowBox[{"op1", ",", "op2"}], "]"}], "&&", 
          RowBox[{"SpinsOrderedQ", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"First", "@", "spins1"}], ",", 
             RowBox[{"First", "@", "spins2"}]}], "}"}], "]"}]}], ",", 
         "\[IndentingNewLine]", "\t\t", "False", ",", "\[IndentingNewLine]", 
         "\t", 
         RowBox[{
          RowBox[{"OperatorsCommuteQ", "[", 
           RowBox[{"op1", ",", "op2"}], "]"}], "&&", 
          RowBox[{"!", 
           RowBox[{"SpinsOrderedQ", "[", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"First", "@", "spins1"}], ",", 
              RowBox[{"First", "@", "spins2"}]}], "}"}], "]"}]}]}], ",", 
         "\[IndentingNewLine]", "\t\t", "True", ",", "\[IndentingNewLine]", 
         "\t", 
         RowBox[{"!", 
          RowBox[{"OperatorsCommuteQ", "[", 
           RowBox[{"op1", ",", "op2"}], "]"}]}], ",", "\[IndentingNewLine]", 
         "\t\t", "False", ",", "\[IndentingNewLine]", "\t", "True", ",", 
         "\[IndentingNewLine]", "\t\t", "False"}], "\[IndentingNewLine]", 
        "]"}]}], "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.969168462603128*^9, 3.969168534847196*^9}, 
   3.9691685677755003`*^9, 3.969168639751452*^9, {3.969168696325451*^9, 
   3.969168779359749*^9}, {3.969169239191125*^9, 3.9691692847616796`*^9}, {
   3.969169318355158*^9, 3.969169380864256*^9}, {3.9691694234332314`*^9, 
