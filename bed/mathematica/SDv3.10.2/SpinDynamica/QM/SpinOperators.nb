              RowBox[{"Times", "[", 
               RowBox[{"n1", ",", "n2"}], "]"}], "]"}], "]"}]}], "\[Equal]", 
           "0"}], ",", "\"\<AntiHermitian\>\"", ",", "\[IndentingNewLine]", 
          "True", ",", "\"\<Normal\>\""}], "\[IndentingNewLine]", "]"}]}], ",",
        "\[IndentingNewLine]", "opts"}], "\[IndentingNewLine]", "]"}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
