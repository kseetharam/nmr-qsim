Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SpinExchangeOperator", "::", "usage"}], 
   "=", "\"\<SpinExchangeOperator has been superseded by \
SpinPermutationOperator\>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.450614085287265*^9, 3.450614109002995*^9}, 
