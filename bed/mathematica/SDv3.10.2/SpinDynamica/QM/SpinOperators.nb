Cell[BoxData[
 RowBox[{
  RowBox[{"OperatorProduct", "/:", 
   RowBox[{"Format", "[", 
    RowBox[{"HoldPattern", "@", 
     RowBox[{"OperatorProduct", "[", 
      RowBox[{
       RowBox[{"ops", ":", 
        RowBox[{
         RowBox[{"Except", "[", "_Rule", "]"}], ".."}]}], ",", 
       "opts___Rule"}], "]"}]}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "makebox", "}"}], ",", 
     RowBox[{"(", "\n", "\t", 
      RowBox[{
       RowBox[{
        RowBox[{"makebox", "[", "IdotI_ScalarOperatorProduct", "]"}], ":=", 
        RowBox[{"ToBoxes", "[", 
         RowBox[{"DisplayForm", "@", 
          RowBox[{"RowBox", "[", 
           RowBox[{"{", 
            RowBox[{"\"\<(\>\"", ",", 
             RowBox[{"ToBoxes", "[", "IdotI", "]"}], ",", "\"\<)\>\""}], 
            "}"}], "]"}]}], "]"}]}], ";", "\n", "\t", 
       RowBox[{
        RowBox[{"makebox", "[", 
         RowBox[{"op_", "?", "OperatorQ"}], "]"}], ":=", 
        RowBox[{"ToBoxes", "[", 
         RowBox[{"DisplayForm", "@", 
          RowBox[{"ToBoxes", "[", "op", "]"}]}], "]"}]}], ";", "\n", "\t", 
       RowBox[{"DisplayForm", "@", 
        RowBox[{"RowBox", "[", 
         RowBox[{"Riffle", "[", 
          RowBox[{
           RowBox[{"Map", "[", 
            RowBox[{"makebox", ",", 
             RowBox[{"{", "ops", "}"}]}], "]"}], ",", 
           RowBox[{"AdjustmentBox", "[", 
            RowBox[{"\"\<\[Bullet]\>\"", ",", 
             RowBox[{"BoxMargins", "\[Rule]", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"-", "0.3"}], ",", "0"}], "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{"0", ",", "0"}], "}"}]}], "}"}]}]}], "]"}]}], "]"}], 
         "]"}]}]}], "\n", ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
