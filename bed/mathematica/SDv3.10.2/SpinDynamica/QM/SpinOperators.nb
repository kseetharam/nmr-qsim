Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SphericalTensorIndices", "::", "usage"}], 
   "=", "\"\<SphericalTensorIndices[op] gives the spherical rank \[Lambda] \
and coherence order \[Mu] of an operator op, in the form {\[Lambda],\[Mu]}. \
If an operator contains several different spherical tensor components, a list \
of the results is returned. \nThe syntax SphericalTensorIndices[stopb] \
returns a list of the spherical tensor indices in the basis operators of \
stopb, in the case that stopb is a SphericalTensorOperatorBasis. \n\>\""}], 
  ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.429871324201727*^9, 3.429871368663629*^9}, {
  3.468154963801524*^9, 3.468155039700362*^9}, {3.468155341962016*^9, 
