 InitializationGroup->True,
 AspectRatioFixed->
  True,ExpressionUUID->"43f13a14-b0c4-402c-9ef0-de0da29661a3"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"MatrixRepresentation", "::", "usage"}], " ", 
   "=", "\"\<MatrixRepresentation[op,basis] provides the matrix \
representation for an operator in a given basis. The output is a SparseArray \
and may be viewed by applying MatrixForm or MatrixPlot. The current basis is \
used if basis is omitted.\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.547025606968602*^9, 3.547025615213552*^9}, {
  3.682594281787702*^9, 3.682594297089982*^9}},
 CellLabel->
  "In[1189]:=",ExpressionUUID->"adff62fa-d06a-4bad-a845-d1541f7667ff"]
}, Closed]],

Cell[CellGroupData[{

Cell["ProjectedMatrixRepresentation", "Subsection",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 AspectRatioFixed->
  True,ExpressionUUID->"eea239a0-254b-487f-b7bb-feee03c1d6d5"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ProjectedMatrixRepresentation", "::", "usage"}], "=", 
   "\[IndentingNewLine]", \
"\"\<ProjectedMatrixRepresentation[op1,op2,Basis->basis] gives the matrix \
representation of op1 in the defined basis, projected onto the eigensystem of \
op2. The coherences between non-degenerate eigenstates of op2 are \
deleted.\>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.501040733520191*^9, 3.5010407335288873`*^9}, 
   3.547025622690776*^9, 3.547025689500533*^9},
 CellLabel->
  "In[1190]:=",ExpressionUUID->"a03f5a3c-f2aa-4271-b31d-3eac781af7d4"]
}, Closed]],

