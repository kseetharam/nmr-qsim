Cell[CellGroupData[{

Cell["\<\
The defined spin system is a subset of the requested spin system\
\>", "Subsubsection",
 InitializationCell->True,
 CellChangeTimes->{{3.53184316213827*^9, 3.531843194031289*^9}, {
  3.621508979183887*^9, 3.621508986475823*^9}, {3.6215097838063316`*^9, 
  3.6215097886571207`*^9}, {3.639224817799529*^9, 3.639224849975447*^9}, {
