Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"HoldPattern", "@", 
    RowBox[{"MatrixRepresentation", "[", 
     RowBox[{
      RowBox[{"op_", "?", "OperatorQ"}], ",", "basis_", ",", "opts___Rule"}], 
     "]"}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "ibasis", "}"}], ",", 
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"SparseArray", "[", "\[IndentingNewLine]", 
         RowBox[{"Normal", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"BasisTransformationMatrix", "[", 
            RowBox[{"basis", ",", "ibasis"}], "]"}], ".", 
           RowBox[{"MatrixRepresentation", "[", 
            RowBox[{"op", ",", "ibasis"}], "]"}], ".", 
           RowBox[{"BasisTransformationMatrix", "[", 
            RowBox[{"ibasis", ",", "basis"}], "]"}]}], "\[IndentingNewLine]", 
          "]"}], "]"}], "/.", 
        RowBox[{"{", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"HoldPattern", "[", 
            RowBox[{"OperatorProduct", "[", 
             RowBox[{"___", ",", "0", ",", "___"}], "]"}], "]"}], "\[RuleDelayed]",
            "0"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"HoldPattern", "[", 
            RowBox[{"OperatorProduct", "[", 
             RowBox[{"a__", ",", "1", ",", "b___"}], "]"}], "]"}], "\[RuleDelayed]", 
           RowBox[{"OperatorProduct", "[", 
            RowBox[{"a", ",", "b"}], "]"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"HoldPattern", "[", 
            RowBox[{"OperatorProduct", "[", 
             RowBox[{"a___", ",", "1", ",", "b__"}], "]"}], "]"}], "\[RuleDelayed]", 
           RowBox[{"OperatorProduct", "[", 
            RowBox[{"a", ",", "b"}], "]"}]}]}], "\[IndentingNewLine]", 
         "}"}]}], "\[IndentingNewLine]", ")"}], "/;", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"ibasis", "=", 
         RowBox[{"ZeemanBasis", "[", 
          RowBox[{"SpinSystem", "[", "basis", "]"}], "]"}]}], ";", 
        RowBox[{
         RowBox[{"MatchQ", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Method", "/.", 
             RowBox[{"{", "opts", "}"}]}], "/.", 
            RowBox[{"Options", "[", "MatrixRepresentation", "]"}]}], ",", 
           "Automatic"}], "]"}], "&&", 
         RowBox[{"!", 
          RowBox[{"MatchQ", "[", 
           RowBox[{"basis", ",", "ibasis"}], "]"}]}]}]}], ")"}]}]}], "]"}]}], 
  ";"}]], "Input",
