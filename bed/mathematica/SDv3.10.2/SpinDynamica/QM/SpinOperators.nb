Cell[CellGroupData[{

Cell["Operator", "Subsection",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.448291327652368*^9, 3.448291329025457*^9}, 
   3.504109824945512*^9},
 AspectRatioFixed->
  True,ExpressionUUID->"23709340-de4b-4255-9074-80c6867acad5"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Operator", "::", "usage"}], 
   "=", "\"\<Operator[matrep,basis,opts] defines a spin operator that has the \
matrix representation matrep in the specified basis. The current basis is \
assumed if basis is missing. The options may include OperatorType, which may \
be used to define whether the operator is unitary, hermitian, etc. Operator \
may also be called with the format Operator[op,basis,opts], where op is an \
operator expression. The routine will then calculate the matrix \
representation and assign the OperatorType automatically.\nOperator may also \
have the form Operator[{X,evals,Xinv},basis,opts] where X is a matrix whose \
columns are the eigenvectors of the matrix representation of the operator in \
the basis basis, evals are the eigenvalues, and Xinv is the inverse of X. \
This form is generated by applying NDiagonalize to an operator. \n\>\""}], 
  ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.448291333690934*^9, 3.448291357780293*^9}, {
   3.5041098271064596`*^9, 3.504109860910949*^9}, {3.504110177020758*^9, 
   3.504110189617758*^9}, {3.531829191563922*^9, 3.5318291919915*^9}, {
   3.531829256245398*^9, 3.531829349850441*^9}, 3.5319270345165243`*^9, {
   3.531927158408794*^9, 3.5319271595917683`*^9}, 3.547025716497306*^9, {
   3.586080111366419*^9, 3.58608019735291*^9}, {3.586083819447632*^9, 
   3.586083823366138*^9}, {3.586084049255663*^9, 3.586084154661208*^9}, {
   3.586089010983004*^9, 3.586089011938239*^9}},
 CellLabel->
  "In[1167]:=",ExpressionUUID->"699b49e2-e574-4801-b936-9c2047f11f8f"],

