Cell[CellGroupData[{

Cell["local routine: BasisMatching", "Subsubsection",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.4680591120234423`*^9, 3.468059115613844*^9}, {
  3.753296465808298*^9, 3.753296474107251*^9}, {3.756029670634513*^9, 
  3.756029673146693*^9}},ExpressionUUID->"f0a1c9b6-187a-4daf-a3ca-\
f3a1eac42511"],

Cell[BoxData[
 RowBox[{
  RowBox[{"BasisMatching", "[", 
   RowBox[{
    RowBox[{"ketsA_", "\[Rule]", "ketsB_"}], ",", "zb_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"overlap", ",", "perm"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"overlap", "=", 
      RowBox[{"Outer", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"Conjugate", "[", "#1", "]"}], ".", "#2"}], "&"}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"VectorRepresentation", "[", 
           RowBox[{"#", ",", "zb"}], "]"}], "&"}], "/@", "ketsB"}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"VectorRepresentation", "[", 
           RowBox[{"#", ",", "zb"}], "]"}], "&"}], "/@", "ketsA"}], ",", 
        "1"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"perm", "=", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"Abs", "@", 
          RowBox[{"N", "@", "overlap"}]}]}], ")"}], "//", 
       "OptimalBipartiteGraphMatching"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", "I"}], " ", 
        RowBox[{"Arg", "[", 
         RowBox[{"Diagonal", "[", 
          RowBox[{"overlap", "\[LeftDoubleBracket]", 
           RowBox[{"All", ",", "perm"}], "\[RightDoubleBracket]"}], "]"}], 
         "]"}]}], "]"}], 
      RowBox[{
      "ketsA", "\[LeftDoubleBracket]", "perm", 
       "\[RightDoubleBracket]"}]}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.753296573223015*^9, 3.753296800797538*^9}, 
   3.7560296833660965`*^9, {3.756030385463127*^9, 3.756030411614422*^9}, {
   3.756030513005061*^9, 3.756030514206567*^9}, {3.756030577685091*^9, 
   3.75603057946814*^9}, {3.756030664179141*^9, 3.7560306803947983`*^9}, {
