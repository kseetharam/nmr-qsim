Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"OperatorsCommuteQ", "::", "usage"}], 
   "=", "\"\<OperatorsCommuteQ[op1,op2] determines whether two operators \
commute or not. The routine does this by first examining the forms of the \
operators. If that does not yield a definite question, the routine tests the \
commutation of the matrix representations. \>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
