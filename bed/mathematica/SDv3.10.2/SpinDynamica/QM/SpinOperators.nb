Cell[CellGroupData[{

Cell["split into (opI | opR).. runs, and others", "Subsection",
 InitializationCell->True,
 CellChangeTimes->{{3.5906619964611177`*^9, 3.590662051700254*^9}, {
  3.590662669680895*^9, 
  3.590662689102884*^9}},ExpressionUUID->"702c3491-f175-485e-a8d4-\
ab46d9cd33d4"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"MatrixRepresentation", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"HoldPattern", "@", 
       RowBox[{"OperatorProduct", "[", 
        RowBox[{
         RowBox[{"ops___", "?", "OperatorQ"}], ",", "___Rule"}], "]"}]}], ",",
       "\[IndentingNewLine]", "basis_", ",", "opts___Rule"}], 
     "\[IndentingNewLine]", "]"}], "/;", 
    RowBox[{"!", 
     RowBox[{"Equal", "@@", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"MatchQ", "[", 
          RowBox[{"#", ",", 
           RowBox[{"_opI", "|", "_opR"}]}], "]"}], "&"}], "/@", 
        RowBox[{"{", "ops", "}"}]}], ")"}]}]}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"oplists", ",", "matreps"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"oplists", "=", 
        RowBox[{"SplitBy", "[", 
         RowBox[{
          RowBox[{"{", "ops", "}"}], ",", 
          RowBox[{
           RowBox[{"MatchQ", "[", 
            RowBox[{"#", ",", 
             RowBox[{"_opI", "|", "_opR"}]}], "]"}], "&"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"matreps", "=", 
        RowBox[{"Map", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"MatrixRepresentation", "[", 
            RowBox[{
             RowBox[{"OperatorProduct", "@@", "#"}], ",", "basis", ",", 
             "opts"}], "]"}], "&"}], ",", "oplists"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "matreps", "]"}], "\[Equal]", "1"}], ",", 
         RowBox[{"First", "@", "matreps"}], ",", 
         RowBox[{"Fold", "[", 
          RowBox[{"Dot", ",", 
           RowBox[{"First", "@", "matreps"}], ",", 
           RowBox[{"Drop", "[", 
            RowBox[{"matreps", ",", "1"}], "]"}]}], "]"}]}], 
        "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", ")"}]}], 
    "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.590661474117791*^9, 3.590661557230248*^9}, {
   3.590661685314303*^9, 3.59066179393051*^9}, {3.5906618610189342`*^9, 
   3.59066197914988*^9}, {3.5906623557647443`*^9, 3.590662357458332*^9}, {
