Cell[CellGroupData[{

Cell["expand ScalarOperatorProduct before applying Operator", "Subsubsection",
 CellChangeTimes->{{3.949059934606908*^9, 3.949059940235723*^9}, {
  3.949065375250287*^9, 
  3.949065384292039*^9}},ExpressionUUID->"0f63d572-d385-4328-9eac-\
c4278ee36c84"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Operator", "[", 
     RowBox[{
      RowBox[{"op_", "?", "OperatorQ"}], ",", "basis_", ",", "opts___Rule"}], 
     "]"}], "/;", 
    RowBox[{"!", 
     RowBox[{"FreeQ", "[", 
      RowBox[{"op", ",", "ScalarOperatorProduct"}], "]"}]}]}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Operator", "[", "\[IndentingNewLine]", 
    RowBox[{"op", "/.", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"HoldPattern", "@", 
        RowBox[{"ScalarOperatorProduct", "[", 
         RowBox[{
          RowBox[{"opI", "[", 
           RowBox[{"j_", ",", 
            RowBox[{"True", "|", "False"}], ",", "___Rule"}], "]"}], ",", 
          RowBox[{"opI", "[", 
           RowBox[{"k_", ",", 
            RowBox[{"True", "|", "False"}], ",", "___Rule"}], "]"}], ",", 
          "___"}], "]"}]}], ":>", 
       RowBox[{
        RowBox[{"OperatorProduct", "[", 
         RowBox[{
          RowBox[{"opI", "[", 
           RowBox[{"j", ",", "\"\<x\>\""}], "]"}], ",", 
          RowBox[{"opI", "[", 
           RowBox[{"k", ",", "\"\<x\>\""}], "]"}]}], "]"}], "+", 
        RowBox[{"OperatorProduct", "[", 
         RowBox[{
          RowBox[{"opI", "[", 
           RowBox[{"j", ",", "\"\<y\>\""}], "]"}], ",", 
          RowBox[{"opI", "[", 
           RowBox[{"k", ",", "\"\<y\>\""}], "]"}]}], "]"}], "+", 
        RowBox[{"OperatorProduct", "[", 
         RowBox[{
          RowBox[{"opI", "[", 
           RowBox[{"j", ",", "\"\<z\>\""}], "]"}], ",", 
          RowBox[{"opI", "[", 
           RowBox[{"k", ",", "\"\<z\>\""}], "]"}]}], "]"}]}]}], 
      "\[IndentingNewLine]", ")"}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.949059719316264*^9, 3.949059742733218*^9}, {
   3.9490598054974546`*^9, 3.9490599303111067`*^9}, 3.949065360891499*^9, 
