Cell[CellGroupData[{

Cell["SingleTransitionOperator", "Subsection",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.4864573505620213`*^9, 3.486457357320607*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"48d67343-8d3c-4d7d-a1ba-34d5c484c586"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SingleTransitionOperator", "::", "usage"}], 
   "=", "\"\<SingleTransitionOperator[{r,s}, \[Mu]] defines a single \
transition operator within the current basis. Allowed values of \[Mu] are \
\\\"x\\\", \\\"y\\\", \\\"z\\\", \\\"+\\\",\\\"-\\\" or \\\"u\\\", \\\"E\\\", \
\\\"1\\\" for the Unity Operator. The state identifiers {r,s} must be members \
of the BasisLabels for the current basis. The most general form is \
SingleTransitionOperator[{r,s},\[Mu],basis] which constructs a single \
transition operator for kets within any basis. \n\>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.456164621599744*^9, 3.456164763147931*^9}, {
  3.4864573626893253`*^9, 3.486457541361269*^9}, {3.502166302180484*^9, 
  3.5021663034092703`*^9}, {3.665904811723541*^9, 3.665904839297005*^9}, {
  3.756316694554117*^9, 3.756316704645953*^9}},
 CellLabel->
  "In[1177]:=",ExpressionUUID->"c82cfac0-77b9-44a2-b88b-8415b520dfc9"]
}, Closed]],

Cell[CellGroupData[{

Cell["Spherical Tensor Operators opT", "Subsection",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 AspectRatioFixed->
  True,ExpressionUUID->"e46c6dc1-a579-4e12-a085-0386966f0032"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"opT", "::", "usage"}], "=", 
   "\[IndentingNewLine]", "\"\<opT[j,{1,\[Mu]}] defines a component of a \
first-rank spherical tensor operator for spin j.\nopT[{1,\[Mu]}] defaults to \
opT[1,{1,\[Mu]}].\nopT[{j,k},{2,\[Mu]}] defines a component of a second-rank \
spherical tensor operator for spins j and k.\nopT[2,\[Mu]] defaults to \
opT[{1,2},{2,\[Mu]}]\nopT[{{j,\!\(\*SubscriptBox[\(\[Lambda]\), \(j\)]\)},{k,\
\!\(\*SubscriptBox[\(\[Lambda]\), \(k\)]\)}..},{\[CapitalLambda],M}] \
generates a component of a \[CapitalLambda]th rank ISTO by coupling together \
the interactions {{j,\!\(\*SubscriptBox[\(\[Lambda]\), \
\(j\)]\)},{k,\!\(\*SubscriptBox[\(\[Lambda]\), \(k\)]\)}..} where j is a \
symbol identifying the interaction and \!\(\*SubscriptBox[\(\[Lambda]\), \
\(j\)]\) is its rank.\nopT[{j,k..},{\[CapitalLambda],M}] defaults to \
opT[{{j,1},{k,1}..},{\[CapitalLambda],M}].\nThe option Normalize->True may be \
set to generate STOs normalized in the current state basis.\nIn cases where \
there are many possible coupling paths to the requested operator, a message \
is issued and a list of all possible operators is returned. A single operator \
may be returned using the form opT[{{j,\!\(\*SubscriptBox[\(\[Lambda]\), \
\(j\)]\)},{k,\!\(\*SubscriptBox[\(\[Lambda]\), \
\(k\)]\)}..},{\[CapitalLambda],M},n], where n is an integer identifying the \
requested operator. \nAn explicit coupling pathway may also be specified. For \
example, a rank-2 operator generated by coupling together the rank-1 operator \
for spin #1 with the rank-1 operator for spin #2, and then coupling the \
resulting rank-1 operator with a rank-2 operator for spin #3, may be \
specified as follows: opT[{{{{1,1},{2,1}},1},{3,2}},{2,M}].\nA complete \
spherical tensor operator may be generated by using the same syntax but \
omitting the \[Mu] or M label. For example opT[j,1] generates a first rank \
spherical tensor operator of the form SphericalTensor[1,{components..}]. A \
component of the resulting spherical tensor operator with magnetic number \
\[Mu] may be extracted by using the syntax opT[j,1][\[Mu]]. See the usage \
message for SphericalTensor. \n\>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.447339403049444*^9, 3.4473394333381233`*^9}, {
  3.468167290532301*^9, 3.46816736838039*^9}, {3.652866606866288*^9, 
  3.652866643750404*^9}, {3.652866687844325*^9, 3.65286701709854*^9}, {
  3.894189559326448*^9, 3.894189773156331*^9}},
 CellLabel->
  "In[1178]:=",ExpressionUUID->"49276133-44e4-4b92-8b58-0b8e992f34ff"]
}, Closed]],

Cell[CellGroupData[{

Cell["RotationOperator, opR", "Subsection",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.502166468052916*^9, 3.502166471226511*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"720343fe-3731-407e-8604-b5cab3e87b91"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"opR", "::", "usage"}], 
   "=", "\"\<opR[spins,angle] is the operator for rotating a single spin or a \
set of spins through the specified angle. If spins is absent, all spins in \
the current SpinSystem are rotated. The following formats for angle may be \
used: 1. {\[Beta],\[Phi]} indicates a rotation through \[Beta] about an axis \
in the xy plane with the phase \[Phi]. The phase value may either be numeric, \
or be specified using the text codes \\\"x\\\", \\\"y\\\", \\\"-x\\\" for the \
quadrature phases. A code \\\"z\\\" indicates a rotation about the z-axis. 2. \
The format {\[Xi],{\[Theta],\[Phi]}} indicates a rotation through the angle \
\[Xi] about an axis with polar angles \[Theta] and \[Phi]. 3. The format {\
\[Alpha],\[Beta],\[Gamma]} indicates a rotation through the specified Euler \
angles, using the zyz convention.\>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.456164776690061*^9, 3.45616489903903*^9}, {
  3.460365965158004*^9, 3.4603660916347303`*^9}, {3.460366435602494*^9, 
  3.460366450914615*^9}},
 CellLabel->
  "In[1179]:=",ExpressionUUID->"45044f4c-cf17-4ee1-adb0-54dc3550fafc"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"RotationOperator", "::", "usage"}], 
   "=", "\"\<RotationOperator is a synonym for opR\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.4603664635829906`*^9, 3.460366478669361*^9}},
 CellLabel->
  "In[1180]:=",ExpressionUUID->"1500053c-3a33-4c45-9cff-519b4f4e5e13"]
}, Closed]],

Cell[CellGroupData[{

Cell["UnityOperator", "Subsection",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.486462824543583*^9, 3.486462827164761*^9}, 
   3.502166474988965*^9},
 AspectRatioFixed->
  True,ExpressionUUID->"4191c192-aa58-47c8-953c-0c8249850588"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"UnityOperator", "::", "usage"}], 
   "=", "\"\<UnityOperator[] is the unity operator for the entire spin \
system. UnityOperator[j] is the unity operator for an individual spin. \
UnityOperator[{r,s}] is the single-transition unity operator for the pair of \
states with labels {r,s} in the current basis.;  UnityOperator[{{r,s},basis}] \
is the single-transition unity operator for the pair of states with labels \
{r,s} in the basis basis.\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.486463806578838*^9, 3.486463892049707*^9}, {
   3.486464285444785*^9, 3.486464285831566*^9}, {3.486464482906717*^9, 
   3.486464531879726*^9}, 3.48646493173867*^9},
 CellLabel->
  "In[1181]:=",ExpressionUUID->"9282779e-9d48-4efb-9020-3c314af413ce"]
}, Closed]],

