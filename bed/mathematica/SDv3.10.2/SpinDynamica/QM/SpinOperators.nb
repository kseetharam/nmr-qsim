       RowBox[{"op", ":", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"_", "?", "OperatorQ"}], "|", 
          RowBox[{"_", "?", "KetQ"}], "|", 
          RowBox[{"_", "?", "BraQ"}]}], ")"}]}], ",", "basis_", ",", 
       "opts___Rule"}], "]"}]}], "/;", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"!", 
       RowBox[{"MatchQ", "[", 
