Cell[CellGroupData[{

Cell["\<\
Returns a single result if there is only one way of getting the desired rank. \
Otherwise return a list of all operators, and a message\
\>", "Subsubsection",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.434351941700084*^9, 
  3.434351958391111*^9}},ExpressionUUID->"488cc195-46fe-4565-a4ce-\
660e11d9ae4e"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"opT", "[", 
    RowBox[{
     RowBox[{"interactions", ":", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"ID1_", ",", "l1_"}], "}"}], ",", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"_", ",", "_"}], "}"}], "..."}]}], "}"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"Lam_", ",", "M_"}], "}"}], ",", "opts___Rule"}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"IDs", ",", "ranks", ",", "rankhistories"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"IDs", ",", "ranks"}], "}"}], "=", 
        RowBox[{"Transpose", "[", "interactions", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"rankhistories", "=", 
        RowBox[{"Select", "[", 
         RowBox[{
          RowBox[{"RankHistories", "[", "ranks", "]"}], ",", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"Last", "[", "#", "]"}], "\[Equal]", "Lam"}], ")"}], 
           "&"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Switch", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Length", "[", "rankhistories", "]"}], ",", 
         "\[IndentingNewLine]", "\t", "0", ",", 
         RowBox[{"NullOperator", "[", "]"}], ",", "\[IndentingNewLine]", "\t",
          "1", ",", 
         RowBox[{"Simplify", "@", 
          RowBox[{"opT", "[", 
           RowBox[{"interactions", ",", 
            RowBox[{"First", "@", "rankhistories"}], ",", 
            RowBox[{"{", 
             RowBox[{"Lam", ",", "M"}], "}"}], ",", "opts"}], "]"}]}], ",", 
         "\[IndentingNewLine]", "\t", "_", ",", 
         RowBox[{"(", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"Message", "[", 
            RowBox[{
             RowBox[{"opT", "::", "multiple"}], ",", 
             RowBox[{"Length", "[", "rankhistories", "]"}]}], "]"}], ";", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"Simplify", "@", 
               RowBox[{"opT", "[", 
                RowBox[{"interactions", ",", "#", ",", 
                 RowBox[{"{", 
                  RowBox[{"Lam", ",", "M"}], "}"}], ",", "opts"}], "]"}]}], 
              ")"}], "&"}], "/@", "rankhistories"}]}], "\[IndentingNewLine]", 
          ")"}]}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
      ")"}]}], "]"}]}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.434352061435503*^9, 3.434352095046597*^9}, {
