Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"HoldPattern", "@", 
    RowBox[{"MatrixRepresentation", "[", 
     RowBox[{
      RowBox[{"OperatorProduct", "[", 
       RowBox[{
        RowBox[{"ops", ":", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Except", "[", "_Rule", "]"}], ".."}], ")"}]}], ",", 
        "___Rule"}], "]"}], ",", "\[IndentingNewLine]", 
      RowBox[{"basis", ":", 
       RowBox[{"ZeemanBasis", "[", 
        RowBox[{
         RowBox[{"spins_", "?", "MatrixQ"}], ",", "basisopts___Rule"}], 
        "]"}]}], ",", "\[IndentingNewLine]", "opts___Rule"}], "]"}]}], ":=", 
   RowBox[{"SparseArray", "@", 
