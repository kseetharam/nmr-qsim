Cell[BoxData[
 RowBox[{
  RowBox[{"Operator", "/:", 
   RowBox[{
    RowBox[{"Times", "[", 
     RowBox[{
      RowBox[{"n1__", "?", "NumericQ"}], ",", 
      RowBox[{"Operator", "[", 
       RowBox[{"opspecs_", ",", "more__", ",", "opts___Rule"}], "]"}], ",", 
      RowBox[{"n2___", "?", "NumericQ"}]}], "]"}], "/;", 
    RowBox[{"MatchQ", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"OperatorType", "/.", 
        RowBox[{"{", "opts", "}"}]}], "/.", 
       RowBox[{"Options", "[", "Operator", "]"}]}], 
      ",", "\"\<Hermitian\>\""}], "]"}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Operator", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Switch", "[", "\[IndentingNewLine]", 
      RowBox[{"opspecs", ",", "\[IndentingNewLine]", 
       RowBox[{"_", "?", "MatrixQ"}], ",", "\[IndentingNewLine]", "\t", 
       RowBox[{"Times", "[", 
        RowBox[{"n1", ",", "opspecs", ",", "n2"}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"_", "?", "MatrixQ"}], ",", "_List", ",", 
         RowBox[{"_", "?", "MatrixQ"}]}], "}"}], ",", "\[IndentingNewLine]", 
       "\t", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
         "opspecs", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], ",", 
         RowBox[{"Times", "[", 
          RowBox[{"n1", ",", 
           RowBox[{
           "opspecs", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}], 
           ",", "n2"}], "]"}], ",", 
         RowBox[{
         "opspecs", "\[LeftDoubleBracket]", "3", "\[RightDoubleBracket]"}]}], 
        "}"}], ",", "\[IndentingNewLine]", "_", ",", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Message", "[", 
          RowBox[{"Operator", "::", "badsyntax"}], "]"}], ";", "$Failed"}], 
        ")"}]}], "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
     "more", ",", "\[IndentingNewLine]", 
     RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"OperatorType", "\[Rule]", "\[IndentingNewLine]", 
        RowBox[{"Which", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"Chop", "@", 
            RowBox[{"Expand", "[", 
             RowBox[{"Im", "[", 
              RowBox[{"Times", "[", 
               RowBox[{"n1", ",", "n2"}], "]"}], "]"}], "]"}]}], "\[Equal]", 
           "0"}], ",", "\"\<Hermitian\>\"", ",", "\[IndentingNewLine]", 
          RowBox[{
