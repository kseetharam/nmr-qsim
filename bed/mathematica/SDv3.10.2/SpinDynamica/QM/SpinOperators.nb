\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.5860829603371778`*^9, 
  3.586082993483173*^9}},ExpressionUUID->"ff1a9134-e265-42fa-81a9-\
2f93838facca"],

Cell["\<\
If NDiagonalize is used with Assumptions\[Rule]{a\[Rule]b..}, or Assumptions\
\[Rule]None or False, these rules supersede any based on the OperatorType.\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.5860829603371778`*^9, 3.586082993483173*^9}, {
  3.58608341045536*^9, 3.586083433732214*^9}, {3.586083500890614*^9, 
  3.586083505242344*^9}, {3.5860850051935377`*^9, 3.586085013254365*^9}, {
  3.586088751378301*^9, 
  3.586088767338917*^9}},ExpressionUUID->"4125cdb2-f5fb-4eb6-9144-\
e5e7f568d74f"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"NDiagonalize", "[", 
    RowBox[{
     RowBox[{"Operator", "[", 
      RowBox[{
       RowBox[{"mat_", "?", "MatrixQ"}], ",", "basis_", ",", 
       "opopts___Rule"}], "]"}], ",", "basis_", ",", "opts___Rule"}], "]"}], ":=",
    "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"ass1", ",", "ass2"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"ass1", "=", 
        RowBox[{
         RowBox[{"Assumptions", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "NDiagonalize", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"ass2", "=", 
        RowBox[{"Switch", "[", "\[IndentingNewLine]", 
         RowBox[{"ass1", ",", "\[IndentingNewLine]", 
          RowBox[{"None", "|", "False"}], ",", "False", ",", 
          "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{"_Rule", "..."}], "}"}], ",", "ass1", ",", 
          "\[IndentingNewLine]", 
          RowBox[{"Automatic", "|", "True"}], ",", "\[IndentingNewLine]", 
          RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{
            "OrthogonalEigenvectors", "\[Rule]", "\[IndentingNewLine]", 
             RowBox[{"Switch", "[", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{
                RowBox[{"OperatorType", "/.", 
                 RowBox[{"{", "opopts", "}"}]}], "/.", 
                RowBox[{"Options", "[", "Operator", "]"}]}], ",", 
               "\[IndentingNewLine]", "\t", 
               
               RowBox[{"\"\<Hermitian\>\"", "|", "\"\<Unitary\>\"", 
                "|", "\"\<AntiHermitian\>\"", "|", "\"\<Normal\>\""}], ",", 
               "True", ",", "\[IndentingNewLine]", "\t", "_", ",", "False"}], 
              "\[IndentingNewLine]", "]"}]}], ",", "\[IndentingNewLine]", 
            RowBox[{"Sequence", "@@", 
             RowBox[{"Cases", "[", 
              RowBox[{"ass1", ",", "_Rule"}], "]"}]}]}], 
           "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", "_", ",",
           "None"}], "\[IndentingNewLine]", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Operator", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"NDiagonalize", "[", "\[IndentingNewLine]", 
          RowBox[{"mat", ",", "\[IndentingNewLine]", 
           RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"Assumptions", "\[Rule]", "ass2"}], ",", 
             "\[IndentingNewLine]", "opts"}], "\[IndentingNewLine]", "]"}]}], 
          "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", "basis", ",",
          "\[IndentingNewLine]", 
         RowBox[{"SimplifyRules", "[", 
          RowBox[{"opopts", ",", "opts"}], "]"}]}], "\[IndentingNewLine]", 
        "]"}]}], "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.586080623025322*^9, 3.586080693204924*^9}, {
  3.5860823454200897`*^9, 3.5860823814112043`*^9}, {3.586082428541574*^9, 
  3.586082730213779*^9}, {3.586082765132083*^9, 3.58608281869175*^9}, {
