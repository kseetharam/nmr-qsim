Cell[CellGroupData[{

Cell["Population and Coherence Operators", "Subsection",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 AspectRatioFixed->
  True,ExpressionUUID->"f482c4c4-788d-46b4-9f9c-287e1021767a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"PopulationOperator", "::", "usage"}], 
   "=", "\"\<PopulationOperator[r] is the population operator for the state \
with label r in the current basis.; PopulationOperator[r,basis] is the \
population operator for the state with label r in the defined basis.\>\""}], 
  ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.486465494219887*^9, 3.486465566635884*^9}, {
  3.486465714126111*^9, 3.486465714437365*^9}, {3.756316965775264*^9, 
  3.75631697516813*^9}},
 CellLabel->
  "In[1183]:=",ExpressionUUID->"45402709-eda3-4105-90fb-4c53f6c95d44"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"CoherenceOperator", "::", "usage"}], 
   "=", "\"\<CoherenceOperator[{r,s}] is the operator |r><s| for the pair of \
states with labels {r,s} in the current basis.;  \
CoherenceOperator[{r,s},basis] is the operator |r><s| for the pair of states \
with labels {r,s} in the defined basis.\>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
