Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"HoldPattern", "@", 
     RowBox[{"MatrixRepresentation", "[", 
      RowBox[{
       RowBox[{"Operator", "[", 
        RowBox[{"specs_", ",", "basis1_", ",", "opts1__Rule"}], "]"}], ",", 
       "basis2_", ",", "opts2___Rule"}], "]"}]}], "/;", 
    RowBox[{
     RowBox[{"UnsameQ", "[", 
      RowBox[{"basis1", ",", "basis2"}], "]"}], "&&", 
     RowBox[{"SameQ", "[", 
