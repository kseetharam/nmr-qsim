    RowBox[{"$VersionNumber", ">=", "14.3"}], ",", "\[IndentingNewLine]", 
    RowBox[{"UserLevelDependentDefinition", "[", 
     RowBox[{"Commutator", ",", "Infinity", ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Commutator", "[", 
        RowBox[{
         RowBox[{"op1_", "?", "OperatorQ"}], ",", 
         RowBox[{"op2_", "?", "OperatorQ"}]}], "]"}], ":=", 
       RowBox[{"Simplify", "[", 
        RowBox[{
         RowBox[{"op1", ".", "op2"}], "-", 
         RowBox[{"op2", ".", "op1"}]}], "]"}]}]}], "\[IndentingNewLine]", 
     "]"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Commutator", "[", 
      RowBox[{
       RowBox[{"op1_", "?", "OperatorQ"}], ",", 
       RowBox[{"op2_", "?", "OperatorQ"}]}], "]"}], ":=", 
     RowBox[{"Simplify", "[", 
