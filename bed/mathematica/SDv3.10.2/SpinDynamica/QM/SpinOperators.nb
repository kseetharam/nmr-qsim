      RowBox[{"Lam_", ",", "M_"}], "}"}], ",", "opts___Rule"}], "]"}], ":=", 
   RowBox[{"Simplify", "[", 
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"CG", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"Lam", ",", "M"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"l1", ",", "mu1"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"l2", ",", 
           RowBox[{"M", "-", "mu1"}]}], "}"}]}], "]"}], " ", 
       RowBox[{
        RowBox[{"opT", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"intID1", ",", 
            RowBox[{"{", 
             RowBox[{"l1", ",", "mu1"}], "}"}]}], "}"}], ",", 
          RowBox[{"Normalize", "\[Rule]", "False"}], ",", "opts"}], "]"}], ".", 
        RowBox[{"opT", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"intID2", ",", 
            RowBox[{"{", 
             RowBox[{"l2", ",", 
              RowBox[{"M", "-", "mu1"}]}], "}"}]}], "}"}], ",", 
          RowBox[{"Normalize", "\[Rule]", "False"}], ",", "opts"}], "]"}]}]}],
       ",", 
      RowBox[{"{", 
       RowBox[{"mu1", ",", 
        RowBox[{"-", "l1"}], ",", 
        RowBox[{"+", "l1"}], ",", "1"}], "}"}]}], "]"}], "]"}]}], 
  ";"}]], "Input",
