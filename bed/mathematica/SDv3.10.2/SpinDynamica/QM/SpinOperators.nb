Cell[CellGroupData[{

Cell["\<\
compose IST ops for a set of different spins (use all available ranks from 1 \
upwards for each spin)\
\>", "Subsubsection",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.639216930066469*^9, 
  3.639216939604437*^9}},ExpressionUUID->"7d9dea5a-8f31-4a52-ac67-\
8a8608bf6bfd"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"opT", "[", 
    RowBox[{
     RowBox[{"spins", ":", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Except", "[", "_List", "]"}], ".."}], "}"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"Lam_", ",", "M_"}], "}"}], ",", "opts___Rule"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Message", "[", 
       RowBox[{
        RowBox[{"opT", "::", "ranktoohigh"}], ",", " ", "Lam"}], "]"}], ";", 
      RowBox[{"NullOperator", "[", "]"}]}], ")"}], "/;", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Union", "[", "spins", "]"}], "\[Equal]", 
       RowBox[{"Sort", "@", "spins"}]}], ")"}], "&&", 
     RowBox[{"(", 
      RowBox[{"Lam", ">", 
       RowBox[{"2", "*", 
        RowBox[{"Plus", "@@", 
         RowBox[{"(", 
          RowBox[{"SpinQuantumNumber", "/@", "spins"}], ")"}]}]}]}], 
      ")"}]}]}]}], ";"}]], "Input",
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.467301380985623*^9, 3.467301382973514*^9}, {
   3.467560359649908*^9, 3.467560360855567*^9}, 3.4867109837842193`*^9, {
   3.639216435794561*^9, 3.639216465503833*^9}, 3.639216530153208*^9},
 CellLabel->
