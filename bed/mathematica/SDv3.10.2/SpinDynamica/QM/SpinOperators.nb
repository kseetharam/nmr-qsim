Cell[CellGroupData[{

Cell["AngularMomentumOperator, opI", "Subsection",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.502166455101253*^9, 3.502166464106722*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"9e1f5069-0c99-4da2-b40f-a24ded533a08"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"opI", "::", "usage"}], 
   "=", "\"\<opI[spin, \[Mu]] defines an angular momentum operator for the \
indicated spin. If the symbol spin is a List, a sum over the spins in the \
list is implied, and if the symbol spin is absent, a sum over all spins in \
the current spin system is taken. The label \[Mu] may be a phase \[Phi] \
(indicating the phase angle of the spin angular momentum in the xy-plane), or \
may specify the polar angles {\[Theta],\[Phi]} (indicating spin angular \
momentum in an arbitrary direction in 3D space). The label \[Mu] may also \
take the values \\\"x\\\", \\\"y\\\", \\\"z\\\", indicating spin angular \
momentum operators along one of the Cartesian axes. Shift operators are \
indicated by using labels \\\"+\\\",\\\"-\\\", while polarization operators \
for spins-1/2 are indicated by using labels \\\"\[Alpha]\\\", \
\\\"\[Beta]\\\". If the label \[Mu] is absent, a vector of the three \
Cartesian angular momentum components is generated. Hence  opI[i].opI[j] \
defines the scalar product of the angular momenta of spins i and j.\>\""}], 
  ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.456164621599744*^9, 3.456164763147931*^9}, {
  3.502165613905551*^9, 3.502166213256482*^9}, {3.502166251440702*^9, 
  3.502166274365844*^9}, {3.949063609165865*^9, 3.9490636105823*^9}},
 CellLabel->
  "In[1173]:=",ExpressionUUID->"baaf64bc-9f63-4b2f-8ca8-ca7a98ce9131"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"AngularMomentumOperator", "::", "usage"}], 
   "=", "\"\<AngularMomentumOperator is a synonym for opI\>\""}], 
  ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.5021663623030853`*^9, 3.502166380020104*^9}},
 CellLabel->
  "In[1174]:=",ExpressionUUID->"3af0992c-f277-47e2-ae41-7774d8bafd3b"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ValidAxisSpecificationQ", "::", "usage"}], 
   "=", "\"\<ValidAxisSpecificationQ[<axis>] returns True if <axis> has the \
valid syntax for specifying the axis of an angular momentum operator.\>\""}], 
  ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.674551844517115*^9, 3.6745519037263002`*^9}},
 CellLabel->
  "In[1175]:=",ExpressionUUID->"2b0c1fef-4aff-4cc5-b48b-b1cee158281a"]
}, Closed]],

