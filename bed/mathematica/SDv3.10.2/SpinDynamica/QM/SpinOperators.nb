Cell[CellGroupData[{

Cell["other cases", "Subsubsection",
 CellChangeTimes->{{3.949059934606908*^9, 
  3.9490599490147667`*^9}},ExpressionUUID->"4f1dce39-d5a2-4e98-bc3b-\
5353f0259ee8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Operator", "[", 
   RowBox[{
    RowBox[{"op_", "?", "OperatorQ"}], ",", "basis_", ",", "opts___Rule"}], 
   "]"}], ":=", "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"oplist", ",", "perm", ",", "dummy", ",", "opformats"}], "}"}], ",",
     "\[IndentingNewLine]", 
    RowBox[{"If", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"MatchQ", "[", 
       RowBox[{"op", ",", "_OperatorProduct"}], "]"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"oplist", "=", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"dummy", "[", "op", "]"}], "/.", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"dummy", "[", 
             RowBox[{"a_.", "*", 
              RowBox[{"_", "[", 
               RowBox[{"A___", ",", "optsQ___Rule"}], "]"}]}], "]"}], "\[RuleDelayed]",
             " ", 
            RowBox[{"{", "A", "}"}]}], "}"}]}], ")"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"opformats", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"dummy", "[", "#", "]"}], "/.", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"dummy", "[", 
               RowBox[{"_", "[", 
                RowBox[{"A___", ",", "optsA___Rule"}], "]"}], "]"}], "\[RuleDelayed]",
               " ", 
              RowBox[{"(", 
               RowBox[{"OperatorFormat", "/.", 
                RowBox[{"{", "optsA", "}"}]}], ")"}]}], "}"}]}], ")"}], "&"}],
          "/@", 
         RowBox[{"(", 
          RowBox[{"Operator", "/@", "oplist"}], ")"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"MemberQ", "[", 
          RowBox[{"opformats", ",", "Automatic"}], "]"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"Operator", "[", 
          RowBox[{
           RowBox[{"MatrixRepresentation", "[", 
            RowBox[{"op", ",", "basis"}], "]"}], ",", "basis", ",", 
           RowBox[{"Sequence", "@@", 
            RowBox[{"SimplifyRules", "[", 
             RowBox[{"{", 
              RowBox[{"opts", ",", 
               RowBox[{"OperatorFormat", "\[Rule]", " ", "Automatic"}]}], 
              "}"}], "]"}]}]}], "]"}], ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"perm", "=", " ", 
           RowBox[{
            RowBox[{"PermutationProduct", "[", 
             RowBox[{"Sequence", "@@", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{
                 RowBox[{"Cycles", "[", 
                  RowBox[{"If", "[", 
                   RowBox[{
                    RowBox[{
                    RowBox[{"Depth", "[", "#", "]"}], "\[Equal]", "2"}], ",", 
                    
                    RowBox[{"{", "#", "}"}], ",", "#"}], "]"}], "]"}], "&"}], 
                "/@", "opformats"}], ")"}]}], "]"}], "\[LeftDoubleBracket]", 
            "1", "\[RightDoubleBracket]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"Operator", "[", 
           RowBox[{
            RowBox[{"MatrixRepresentation", "[", 
             RowBox[{"op", ",", "basis"}], "]"}], ",", "basis", ",", 
            RowBox[{"Sequence", "@@", 
             RowBox[{"SimplifyRules", "[", 
              RowBox[{"{", 
               RowBox[{"opts", ",", 
                RowBox[{"OperatorFormat", "\[Rule]", "perm"}]}], "}"}], 
              "]"}]}]}], "]"}]}]}], "\[IndentingNewLine]", "]"}]}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"If", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"MatchQ", "[", 
         RowBox[{"op", ",", "_Operator"}], "]"}], ",", "\[IndentingNewLine]", 
        
        RowBox[{
         RowBox[{"opformats", "=", 
          RowBox[{
           RowBox[{"dummy", "[", "op", "]"}], "/.", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"dummy", "[", 
              RowBox[{"_", "[", 
               RowBox[{"A___", ",", "optsA___Rule"}], "]"}], "]"}], "\[RuleDelayed]",
              " ", 
             RowBox[{"(", 
              RowBox[{"OperatorFormat", "/.", 
               RowBox[{"{", "optsA", "}"}]}], ")"}]}], "}"}]}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"Operator", "[", 
          RowBox[{
           RowBox[{"MatrixRepresentation", "[", 
            RowBox[{"op", ",", "basis"}], "]"}], ",", "basis", ",", 
           RowBox[{"Sequence", "@@", 
            RowBox[{"SimplifyRules", "[", 
             RowBox[{"{", 
              RowBox[{"opts", ",", 
               RowBox[{"OperatorFormat", "\[Rule]", " ", "opformats"}], ",", 
               RowBox[{"OperatorFormat", "\[Rule]", " ", "Automatic"}]}], 
              "}"}], "]"}]}]}], "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"Operator", "[", 
         RowBox[{
          RowBox[{"MatrixRepresentation", "[", 
           RowBox[{"op", ",", "basis"}], "]"}], ",", "basis", ",", 
          RowBox[{"Sequence", "@@", 
           RowBox[{"SimplifyRules", "[", 
            RowBox[{"{", 
             RowBox[{"opts", ",", 
              RowBox[{"OperatorFormat", "\[Rule]", " ", "Automatic"}]}], 
             "}"}], "]"}]}]}], "]"}]}], "\[IndentingNewLine]", "]"}]}], 
     "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", "]"}]}]], "Input",\

 InitializationCell->True,
 CellChangeTimes->{{3.586166711603229*^9, 3.586166778065651*^9}, {
