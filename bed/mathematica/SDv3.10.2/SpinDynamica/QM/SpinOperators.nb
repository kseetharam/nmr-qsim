 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Operator", "[", 
     RowBox[{
      RowBox[{"opmat_", "?", "MatrixQ"}], ",", "basis_", ",", "opts___Rule"}],
      "]"}], "/;", 
