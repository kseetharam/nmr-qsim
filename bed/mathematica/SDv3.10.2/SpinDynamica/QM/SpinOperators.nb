Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Operator", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"X_", "?", "MatrixQ"}], ",", "evals_List", ",", 
       RowBox[{"Xinv_", "?", "MatrixQ"}]}], "}"}], ",", "basis_", ",", 
     "opts___Rule"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "orthogX", "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Operator", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"X", ",", "evals", ",", "Xinv"}], "}"}], ",", "basis", ",", 
         "\[IndentingNewLine]", 
         RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"OperatorType", "\[Rule]", 
            RowBox[{"Which", "[", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"And", "@@", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{"Chop", "@", 
                    RowBox[{"Expand", "[", 
                    RowBox[{
                    RowBox[{"Abs", "[", "#", "]"}], "-", "1"}], "]"}]}], "\[Equal]",
                     "0"}], ")"}], "&"}], "/@", "evals"}], ")"}]}], 
              ",", "\"\<Unitary\>\"", ",", "\[IndentingNewLine]", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"orthogX", "=", 
                 RowBox[{"OrthogonalQ", "[", "X", "]"}]}], ";", 
                "\[IndentingNewLine]", 
                RowBox[{"orthogX", " ", "&&", "\[IndentingNewLine]", 
                 RowBox[{"And", "@@", 
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{
                    RowBox[{"Element", "[", 
                    RowBox[{"#", ",", "Reals"}], "]"}], "&"}], "/@", 
                    "evals"}], ")"}]}]}]}], ")"}], ",", "\"\<Hermitian\>\"", ",",
               "\[IndentingNewLine]", "orthogX", ",", "\"\<Normal\>\"", ",", 
              "\[IndentingNewLine]", "True", ",", "None"}], "]"}]}], ",", 
           "\[IndentingNewLine]", "opts"}], "\[IndentingNewLine]", "]"}]}], 
        "\[IndentingNewLine]", "]"}], "/;", 
       RowBox[{"(", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"MatchQ", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"{", 
              RowBox[{"CheckOperatorType", ",", "OperatorType"}], "}"}], "/.", 
             RowBox[{"{", "opts", "}"}]}], "/.", 
            RowBox[{"Options", "[", "Operator", "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"True", ",", "Undefined"}], "}"}]}], "]"}], "&&", 
         "\[IndentingNewLine]", 
         RowBox[{"MatchQ", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"X", ",", "evals", ",", "Xinv"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"_", "?", "NumericMatrixQ"}], ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"_", "?", "NumericQ"}], ".."}], "}"}], ",", 
             RowBox[{"_", "?", "NumericMatrixQ"}]}], "}"}]}], "]"}]}], 
        "\[IndentingNewLine]", ")"}]}], "\[IndentingNewLine]", ")"}]}], 
    "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.583432407146059*^9, 3.583432543452914*^9}, {
