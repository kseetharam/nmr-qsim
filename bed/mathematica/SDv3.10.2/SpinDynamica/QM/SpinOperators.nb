Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"HoldPattern", "@", 
     RowBox[{"OperatorProduct", "[", 
      RowBox[{
       RowBox[{"ops", ":", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"_", "?", "OperatorQ"}], ".."}], ")"}]}], ",", 
       "opts___Rule"}], "]"}]}], "/;", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Checked", "/.", 
        RowBox[{"{", "opts", "}"}]}], "/.", 
       RowBox[{"Options", "[", "OperatorProduct", "]"}]}], ")"}], "&&", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"!", "Sorted"}], "/.", 
        RowBox[{"{", "opts", "}"}]}], "/.", 
       RowBox[{"Options", "[", "OperatorProduct", "]"}]}], ")"}]}]}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "sortedops", "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"sortedops", "=", 
        RowBox[{
         RowBox[{"{", "ops", "}"}], "//.", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"opsa___", ",", "op1_", ",", "op2_", ",", "opsb___"}], 
            "}"}], ":>", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"opsa", ",", "op2", ",", "op1", ",", "opsb"}], "}"}], "/;", 
            RowBox[{"swapoperatorsQ", "[", 
             RowBox[{"op1", ",", "op2"}], "]"}]}]}], ")"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"OperatorProduct", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Sequence", "@@", "sortedops"}], ",", "\[IndentingNewLine]", 
         
         RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"Sorted", "\[Rule]", "True"}], ",", "\[IndentingNewLine]", 
