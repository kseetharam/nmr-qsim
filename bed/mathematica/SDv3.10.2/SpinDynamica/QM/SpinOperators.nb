Cell["\<\
includes special simplifications in the common case of symbolic angles\
\>", "Text",
 CellChangeTimes->{{3.7532965395343537`*^9, 
  3.753296567231337*^9}},ExpressionUUID->"8b54e60e-7ef5-4b16-a0f9-\
8c2646f7e678"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"NormalizeEigenvector", "[", "evec_List", "]"}], "/;", 
    RowBox[{
     RowBox[{"Length", "[", 
      RowBox[{"UnassignedSymbols", "[", "evec", "]"}], "]"}], "\[NotEqual]", 
     "0"}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"tfevec", ",", "normsq", ",", "norm"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"tfevec", "=", 
        RowBox[{"TrigFactor", "[", "evec", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"normsq", "=", 
        RowBox[{"TrigFactor", "[", 
         RowBox[{"tfevec", ".", "tfevec"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"norm", "=", 
        RowBox[{"PowerExpand", "[", 
         RowBox[{"Sqrt", "[", "normsq", "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Simplify", "[", 
        RowBox[{"tfevec", "/", "norm"}], "]"}]}], "\[IndentingNewLine]", 
      ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.753296573223015*^9, 3.753296800797538*^9}},
 CellLabel->
  "In[1677]:=",ExpressionUUID->"2fa22251-7d55-4a0a-9f56-dce97da758b6"],

