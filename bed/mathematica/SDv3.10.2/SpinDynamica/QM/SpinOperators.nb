Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ProjectionOperator", "[", 
    RowBox[{"instates", ":", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"_", ",", "_"}], "}"}], ".."}], "}"}]}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"inspins", ",", "outspins", ",", "outstates"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"inspins", "=", 
        RowBox[{"First", "/@", "instates"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"outspins", "=", 
        RowBox[{"DeleteCases", "[", 
         RowBox[{
          RowBox[{"First", "/@", 
           RowBox[{"SpinSystem", "[", "]"}]}], ",", 
          RowBox[{"Alternatives", "@@", "inspins"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"outstates", "=", 
        RowBox[{"Flatten", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Outer", "[", 
           RowBox[{"List", ",", 
            RowBox[{"Sequence", "@@", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"Table", "[", 
                 RowBox[{
                  RowBox[{"{", 
                   RowBox[{"#", ",", "mI"}], "}"}], ",", 
                  RowBox[{"{", 
                   RowBox[{"mI", ",", 
                    RowBox[{"-", 
                    RowBox[{"SpinQuantumNumber", "[", "#", "]"}]}], ",", 
                    RowBox[{"+", 
                    RowBox[{"SpinQuantumNumber", "[", "#", "]"}]}]}], "}"}]}],
                  "]"}], "&"}], "/@", "outspins"}], ")"}]}], ",", 
            "\[IndentingNewLine]", "1"}], "]"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"Length", "[", "outspins", "]"}], "-", "1"}]}], "]"}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"Plus", "@@", 
        RowBox[{"Map", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"ProjectionOperator", "[", 
            RowBox[{"Sort", "[", 
             RowBox[{"Join", "[", 
              RowBox[{"#", ",", "instates"}], "]"}], "]"}], "]"}], "&"}], ",",
           "\[IndentingNewLine]", "outstates"}], "\[IndentingNewLine]", 
         "]"}]}]}], "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
