    RowBox[{"HoldPattern", "@", 
     RowBox[{"OperatorProduct", "[", 
      RowBox[{
       RowBox[{"args", ":", 
        RowBox[{
         RowBox[{"Except", "[", "_Rule", "]"}], ".."}]}], ",", 
       "opts___Rule"}], "]"}]}], "/;", 
    RowBox[{
     RowBox[{"!", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Checked", "/.", 
         RowBox[{"{", "opts", "}"}]}], "/.", 
        RowBox[{"Options", "[", "OperatorProduct", "]"}]}], ")"}]}], "&&", 
     RowBox[{"Or", "@@", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"!", 
          RowBox[{"MatchQ", "[", 
           RowBox[{"#", ",", 
