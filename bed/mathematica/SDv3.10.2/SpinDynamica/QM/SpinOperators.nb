Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"opT", "[", 
    RowBox[{"intID_", ",", 
     RowBox[{"\[Lambda]", ":", 
      RowBox[{"Except", "[", "_List", "]"}]}], ",", "opts___Rule"}], "]"}], ":=",
    "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "STOcomponents", "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"STOcomponents", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"opT", "[", 
           RowBox[{"intID", ",", 
            RowBox[{"{", 
             RowBox[{"\[Lambda]", ",", "\[Mu]"}], "}"}], ",", "opts"}], "]"}],
           ",", 
          RowBox[{"{", 
           RowBox[{"\[Mu]", ",", 
            RowBox[{"+", "\[Lambda]"}], ",", 
            RowBox[{"-", "\[Lambda]"}], ",", 
            RowBox[{"-", "1"}]}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"And", "@@", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"!", 
              RowBox[{"MatchQ", "[", 
               RowBox[{"#", ",", "_List"}], "]"}]}], "&"}], "/@", 
            "STOcomponents"}], ")"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"SphericalTensor", "[", 
          RowBox[{"\[Lambda]", ",", "STOcomponents"}], "]"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Message", "[", 
            RowBox[{"opT", "::", "componentnotunique"}], "]"}], ";", 
           "$Failed"}], ")"}]}], "\[IndentingNewLine]", "]"}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
