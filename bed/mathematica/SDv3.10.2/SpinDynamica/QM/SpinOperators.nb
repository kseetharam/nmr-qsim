Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"opT", "::", "high\[Lambda]"}], 
   "=", "\"\<Spherical tensor operators of high rank are calculated using the \
Wigner-Eckart theorem and provided in the form of Operator. Explicit \
expressions may be constructed by applying ExpressOperator. This message \
appears only once.\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.639207090259028*^9, 3.639207238766346*^9}, {
