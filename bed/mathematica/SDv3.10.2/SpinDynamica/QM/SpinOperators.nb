Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ConstructMatrixRepresentation", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"opj", ":", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"HoldPattern", "@", 
          RowBox[{"OperatorProduct", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{"opI", "|", "opR"}], ")"}], "[", 
              RowBox[{"j_", ",", "___"}], "]"}], ".."}], ",", "___Rule"}], 
           "]"}]}], "|", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"opI", "|", "opR"}], ")"}], "[", 
          RowBox[{"j_", ",", "___"}], "]"}]}], ")"}]}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"basis", ":", 
       RowBox[{"ZeemanBasis", "[", 
        RowBox[{
         RowBox[{"spins_", "?", "MatrixQ"}], ",", "basisopts___Rule"}], 
        "]"}]}], ",", "opts___Rule"}], "\[IndentingNewLine]", "]"}], "/;", 
    RowBox[{
     RowBox[{"Length", "[", "spins", "]"}], ">", "1"}]}], ":=", 
   RowBox[{"Apply", "[", "\[IndentingNewLine]", 
    RowBox[{"KroneckerProduct", ",", "\[IndentingNewLine]", 
     RowBox[{"Reverse", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"#", "\[Equal]", "j"}], ",", "\[IndentingNewLine]", 
          RowBox[{"SingleSpinZeemanBasisMatrixRepresentation", "[", 
           RowBox[{"opj", ",", 
            RowBox[{"ZeemanBasis", "[", 
             RowBox[{"Cases", "[", 
              RowBox[{"spins", ",", 
               RowBox[{"{", 
                RowBox[{"j", ",", "_"}], "}"}]}], "]"}], "]"}]}], "]"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"SingleSpinZeemanBasisMatrixRepresentation", "[", 
           RowBox[{
            RowBox[{"UnityOperator", "[", "#", "]"}], ",", 
            RowBox[{"ZeemanBasis", "[", 
             RowBox[{"Cases", "[", 
              RowBox[{"spins", ",", 
               RowBox[{"{", 
                RowBox[{"#", ",", "_"}], "}"}]}], "]"}], "]"}]}], "]"}]}], 
         "\[IndentingNewLine]", "]"}], "&"}], "/@", 
       RowBox[{"(", 
        RowBox[{"First", "/@", "spins"}], ")"}]}], "\[IndentingNewLine]", 
      "]"}]}], "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
 InitializationCell->True,
