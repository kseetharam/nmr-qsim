Cell[CellGroupData[{

Cell["\<\
specify operator from a set of interactions, ranks, and rank histories. \
\>", "Subsubsection",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->
  True,ExpressionUUID->"cf32e34f-22a3-4f32-8c24-89137d0d81c0"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"opT", "[", 
    RowBox[{
     RowBox[{"interactions", ":", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"ID1_", ",", "l1_"}], "}"}], ",", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"_", ",", "_"}], "}"}], "..."}]}], "}"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"rankhistory", ":", 
      RowBox[{"{", 
       RowBox[{"___", ",", "Lam_"}], "}"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"Lam_", ",", "M_"}], "}"}], ",", "opts___Rule"}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"IDs", ",", "ranks"}], "}"}], ",", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{"IDs", ",", "ranks"}], "}"}], "=", 
         RowBox[{"Transpose", "[", "interactions", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"opT", "[", 
           RowBox[{
            RowBox[{"First", "[", "#", "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"Lam", ",", "M"}], "}"}], ",", "opts"}], "]"}], "&"}], "@", 
         RowBox[{"(", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{
            RowBox[{"NestWhile", "[", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"Take", "[", 
                  RowBox[{"#", ",", "2"}], "]"}], ",", "\[IndentingNewLine]", 
                 
                 RowBox[{"Sequence", "@@", 
                  RowBox[{"Drop", "[", 
                   RowBox[{"#", ",", "2"}], "]"}]}]}], "\[IndentingNewLine]", 
                "}"}], "&"}], ",", "\[IndentingNewLine]", 
              RowBox[{"Flatten", "/@", 
               RowBox[{"Transpose", "[", 
                RowBox[{"{", 
                 RowBox[{"interactions", ",", "rankhistory"}], "}"}], 
                "\[IndentingNewLine]", "]"}]}], ",", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"Length", "[", "#", "]"}], ">", "2"}], ")"}], 
               "&"}]}], "\[IndentingNewLine]", "]"}], "//.", 
            RowBox[{"{", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{"int1_", ",", "lam1_", ",", "Lam1_"}], "}"}], ",", 
                 RowBox[{"{", 
                  RowBox[{"int2_", ",", "lam2_", ",", "Lam2_"}], "}"}]}], 
                "}"}], "\[RuleDelayed]", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"{", 
                    RowBox[{"int1", ",", "lam1"}], "}"}], ",", 
                   RowBox[{"{", 
                    RowBox[{"int2", ",", "lam2"}], "}"}]}], "}"}], ",", 
                 "Lam2"}], "}"}]}], ",", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{"int1_", ",", "lam1_"}], "}"}], ",", 
                 RowBox[{"{", 
                  RowBox[{"int2_", ",", "lam2_", ",", "Lam2_"}], "}"}], ",", 
                 "rest___"}], "}"}], "\[RuleDelayed]", "\[IndentingNewLine]", 
               
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"{", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"int1", ",", "lam1"}], "}"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"int2", ",", "lam2"}], "}"}]}], "}"}], ",", 
                   "Lam2"}], "}"}], ",", "rest"}], "}"}]}]}], 
             "\[IndentingNewLine]", "}"}]}], "//.", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"{", "args___", "}"}], "}"}], "\[RuleDelayed]", 
            RowBox[{"{", "args", "}"}]}]}], "\[IndentingNewLine]", ")"}]}]}], 
       "\[IndentingNewLine]", ")"}]}], "]"}], " ", "/;", 
    RowBox[{
     RowBox[{"Length", "[", "interactions", "]"}], "\[Equal]", 
     RowBox[{"Length", "[", "rankhistory", "]"}]}]}]}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
