Cell[CellGroupData[{

Cell["handle list of spins, or multiple lists of spins", "Subsection",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.630582017873025*^9, 3.6305820184552593`*^9}, {
  3.630582201003671*^9, 3.630582203983336*^9}, {3.630582550243239*^9, 
  3.6305825575036182`*^9}, {3.630583823688793*^9, 
  3.630583844782449*^9}},ExpressionUUID->"8b3790cc-814b-43dc-9343-\
393f080c7bab"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"CoherenceOrder", "[", 
    RowBox[{"spins_List", ",", 
     RowBox[{"op_", "?", "OperatorQ"}]}], "]"}], ":=", "\[IndentingNewLine]", 
   
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "matrep", ",", "nonzpos", ",", "Mvals", ",", "pvals", ",", "zbasis"}], 
      "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"zbasis", "=", 
        RowBox[{"ZeemanBasis", "[", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"matrep", "=", 
        RowBox[{"MatrixRepresentation", "[", 
         RowBox[{"op", ",", "zbasis"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"nonzpos", "=", 
        RowBox[{"Position", "[", 
         RowBox[{
          RowBox[{"Chop", "@", 
           RowBox[{"Expand", "@", 
            RowBox[{"N", "@", 
             RowBox[{"Normal", "@", "matrep"}]}]}]}], ",", 
          RowBox[{"Except", "[", "0", "]"}], ",", 
          RowBox[{"{", "2", "}"}], ",", 
          RowBox[{"Heads", "\[Rule]", "False"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Mvals", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"MagneticQuantumNumber", "[", 
           RowBox[{"#", ",", "spins"}], "]"}], "&"}], "/@", 
         RowBox[{"BasisKets", "[", "zbasis", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"pvals", "=", 
        RowBox[{"Union", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"Mvals", "\[LeftDoubleBracket]", 
              RowBox[{"First", "[", "#", "]"}], "\[RightDoubleBracket]"}], "-", 
             RowBox[{"Mvals", "\[LeftDoubleBracket]", 
              RowBox[{"Last", "[", "#", "]"}], "\[RightDoubleBracket]"}]}], 
            ")"}], "&"}], "/@", "nonzpos"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Which", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"MatchQ", "[", 
           RowBox[{"spins", ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"Except", "[", "List", "]"}], ".."}], "}"}]}], "]"}], "&&", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Length", "[", "pvals", "]"}], "\[Equal]", "1"}], ")"}]}],
          ",", "\[IndentingNewLine]", "\t", 
         RowBox[{"First", "[", "pvals", "]"}], ",", "\[IndentingNewLine]", 
         "True", ",", "\[IndentingNewLine]", "\t", "pvals"}], 
        "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", ")"}]}], 
    "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.502075301874644*^9, 3.502075483683388*^9}, {
   3.502076266868636*^9, 3.502076269665908*^9}, {3.502076588258809*^9, 
   3.502076631689501*^9}, {3.502077002407042*^9, 3.502077016753995*^9}, {
