              RowBox[{"Pick", "[", 
               RowBox[{"Ivals", ",", 
                RowBox[{"First", "/@", "spinsys"}], ",", 
                RowBox[{"Last", "[", "#", "]"}]}], "]"}]}], ")"}], "&"}]}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
