Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"NDiagonalize", "[", 
    RowBox[{
     RowBox[{"Operator", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"X_", "?", "MatrixQ"}], ",", "evals_List", ",", 
         RowBox[{"Xinv_", "?", "MatrixQ"}]}], "}"}], ",", "opbasis_", ",", 
       "opopts___Rule"}], "]"}], ",", "basis_", ",", "opts___Rule"}], "]"}], ":=",
    "\[IndentingNewLine]", 
   RowBox[{"Operator", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Chop", "@", 
        RowBox[{"Expand", "[", 
         RowBox[{
          RowBox[{"BasisTransformationMatrix", "[", 
           RowBox[{"basis", ",", "opbasis"}], "]"}], ".", "X"}], "]"}]}], ",",
        "\[IndentingNewLine]", "evals", ",", "\[IndentingNewLine]", 
       RowBox[{"Chop", "@", 
        RowBox[{"Expand", "[", 
         RowBox[{"Xinv", ".", 
          RowBox[{"BasisTransformationMatrix", "[", 
           RowBox[{"opbasis", ",", "basis"}], "]"}]}], "]"}]}]}], "}"}], ",", 
     "\[IndentingNewLine]", "basis", ",", "\[IndentingNewLine]", 
     RowBox[{"SimplifyRules", "[", 
      RowBox[{"opopts", ",", "opts"}], "]"}]}], "\[IndentingNewLine]", 
    "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.586080496491189*^9, 3.586080507239616*^9}, {
