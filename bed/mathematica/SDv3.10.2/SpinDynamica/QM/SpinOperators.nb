Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"HoldPattern", "@", 
     RowBox[{"MatrixRepresentation", "[", 
      RowBox[{
       RowBox[{"op_", "?", "OperatorQ"}], ",", "basis_", ",", "opts___Rule"}],
       "]"}]}], "/;", 
    RowBox[{
     RowBox[{"MatchQ", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Method", "/.", 
         RowBox[{"{", "opts", "}"}]}], "/.", 
        RowBox[{"Options", "[", "MatrixRepresentation", "]"}]}], 
       ",", "\"\<Direct\>\""}], "]"}], "&&", 
     RowBox[{"FreeQ", "[", 
      RowBox[{"op", ",", "_InterpolatingFunction"}], "]"}]}]}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"(", "\[IndentingNewLine]", 
    RowBox[{"SparseArray", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Outer", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"#1", ".", "op", ".", "#2"}], ")"}], "&"}], ",", 
        RowBox[{"BasisBras", "[", "basis", "]"}], ",", 
        RowBox[{"BasisKets", "[", "basis", "]"}]}], "]"}], "/.", 
      RowBox[{"{", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"HoldPattern", "[", 
          RowBox[{"OperatorProduct", "[", 
           RowBox[{"___", ",", "0", ",", "___"}], "]"}], "]"}], "\[RuleDelayed]",
          "0"}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"HoldPattern", "[", 
          RowBox[{"OperatorProduct", "[", 
           RowBox[{"a__", ",", "1", ",", "b___"}], "]"}], "]"}], "\[RuleDelayed]", 
         RowBox[{"OperatorProduct", "[", 
          RowBox[{"a", ",", "b"}], "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"HoldPattern", "[", 
          RowBox[{"OperatorProduct", "[", 
           RowBox[{"a___", ",", "1", ",", "b__"}], "]"}], "]"}], "\[RuleDelayed]", 
         RowBox[{"OperatorProduct", "[", 
          RowBox[{"a", ",", "b"}], "]"}]}]}], "\[IndentingNewLine]", "}"}]}], 
     "\[IndentingNewLine]", "]"}], ")"}]}], ";"}]], "Input",
 InitializationCell->True,
