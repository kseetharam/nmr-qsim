Cell["\<\
sign switch for odd \[Lambda] introduced to be consistent with C. W. Chung \
and S. Wimperis, \[OpenCurlyDoubleQuote]Measurement Of Spin-5/2 Relaxation In \
Biological And Macromolecular Systems Using Multiple-Quantum NMR Techniques,\
\[CloseCurlyDoubleQuote] Mol. Phys. 76, 47-81 (1992).\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.640696619836971*^9, 3.64069663563205*^9}, 
   3.640696744665086*^9},ExpressionUUID->"1aa95fd0-be27-43b9-98e3-\
6c2047119b07"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ReducedISTOMatrixElement", "[", 
    RowBox[{"Ij_", ",", "\[Lambda]_"}], "]"}], ":=", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"ReducedISTOMatrixElement", "[", 
      RowBox[{"Ij", ",", "\[Lambda]"}], "]"}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"-", "1"}], ")"}], "^", "\[Lambda]"}], "/", 
      RowBox[{"(", 
       RowBox[{"Sqrt", "@", 
        RowBox[{"Sum", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Abs", "[", 
            RowBox[{"CG", "[", 
             RowBox[{
              RowBox[{"{", "Ij", "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"\[Lambda]", ",", "0"}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"Ij", ",", "m"}], "}"}]}], "]"}], "]"}], "^", "2"}], ",", 
          RowBox[{"{", 
           RowBox[{"m", ",", 
            RowBox[{"-", "Ij"}], ",", 
            RowBox[{"+", "Ij"}], ",", "1"}], "}"}]}], "]"}]}], ")"}]}]}], 
    ")"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.639206575959935*^9, 3.6392065960549297`*^9}, {
