   RowBox[{"OperatorProjection", "::", "usage"}], "=", 
   "\[IndentingNewLine]", "\"\<OperatorProjection[op1,op2,Basis->basis] gives \
the projection of op1 onto op2, using the specified basis.\>\""}], 
  ";"}]], "Input",
