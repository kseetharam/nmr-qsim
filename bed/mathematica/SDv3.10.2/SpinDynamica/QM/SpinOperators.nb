       RowBox[{"\[Lambda]_", ",", "\[Mu]_"}], "}"}]}], "]"}], "[", 
    RowBox[{"{", 
     RowBox[{"m1_", ",", "m2_"}], "}"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"CG", "[", 
     RowBox[{
      RowBox[{"{", 
