       "\[IndentingNewLine]", ")"}], "/;", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"pairs", "=", 
         RowBox[{"Partition", "[", 
          RowBox[{"perm", ",", "2", ",", "1"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Ivals", "=", 
         RowBox[{"Last", "/@", "spinsys"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"mismatches", "=", 
         RowBox[{"Select", "[", 
          RowBox[{"pairs", ",", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"Pick", "[", 
               RowBox[{"Ivals", ",", 
                RowBox[{"First", "/@", "spinsys"}], ",", 
