  3.590574948531828*^9}},ExpressionUUID->"1ef98f9f-99c0-4fac-8b43-\
598493e8a217"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SpinPermutationOperator", "[", 
    RowBox[{"perm_List", ",", "spinsys_"}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "zbasis", ",", "rules", ",", "ket", ",", "zkets", ",", "permzkets"}], 
      "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"zbasis", "=", 
        RowBox[{"ZeemanBasis", "[", "spinsys", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"zkets", "=", 
        RowBox[{"BasisKets", "[", "zbasis", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"rules", "=", 
        RowBox[{"Inner", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"#1", ",", "M1_"}], "}"}], ":>", 
             RowBox[{"{", 
              RowBox[{"#2", ",", "M1"}], "}"}]}], ")"}], "&"}], ",", "perm", ",", 
          RowBox[{"RotateLeft", "[", "perm", "]"}], ",", "List"}], "]"}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"permzkets", "=", "\[IndentingNewLine]", 
        RowBox[{"zkets", "/.", 
         RowBox[{
          RowBox[{"HoldPattern", "@", 
           RowBox[{"Ket", "[", 
            RowBox[{
             RowBox[{"kets_", "?", "MatrixQ"}], ",", "spinsys", ",", 
             "opts___Rule"}], "]"}]}], "\[RuleDelayed]", 
          RowBox[{"Ket", "[", 
           RowBox[{
            RowBox[{"kets", "/.", "rules"}], ",", "spinsys", ",", 
            "\[IndentingNewLine]", 
            RowBox[{"SimplifyRules", "[", 
             RowBox[{
              RowBox[{"Validity", "\[Rule]", "False"}], ",", "opts"}], 
             "]"}]}], "\[IndentingNewLine]", "]"}]}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"SpinPermutationOperator", "[", 
         RowBox[{"perm", ",", "spinsys"}], "]"}], "=", "\[IndentingNewLine]", 
        
        RowBox[{"Operator", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"SparseArray", "@", 
           RowBox[{"Outer", "[", 
            RowBox[{"Dot", ",", 
             RowBox[{"Adjoint", "/@", "zkets"}], ",", "permzkets"}], "]"}]}], 
          ",", "\[IndentingNewLine]", "zbasis", ",", "\[IndentingNewLine]", 
          RowBox[{"OperatorType", "\[Rule]", "\"\<Unitary\>\""}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"CheckOperatorType", "\[Rule]", "False"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"OperatorFormat", "\[Rule]", "perm"}]}], 
         "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", ")"}]}], 
    "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 InitializationGroup->True,
