  3.691403545276457*^9}},ExpressionUUID->"a7a09fca-83fc-4f15-97de-\
d4ac19c081cb"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Operator", "[", 
     RowBox[{"specs_", ",", "basis_", ",", "opts___Rule"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"MatchQ", "[", 
        RowBox[{"specs", ",", 
         RowBox[{
          RowBox[{"_", "?", "NumericMatrixQ"}], "|", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"_", "?", "NumericMatrixQ"}], ",", "_List", ",", 
            RowBox[{"_", "?", "NumericMatrixQ"}]}], "}"}]}]}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"Operator", "[", 
        RowBox[{"specs", ",", "basis", ",", 
         RowBox[{"SimplifyRules", "[", 
          RowBox[{
           RowBox[{"CheckOperatorType", "\[Rule]", "True"}], ",", "opts"}], 
          "]"}]}], "]"}], ",", 
       RowBox[{"Operator", "[", 
        RowBox[{"specs", ",", "basis", ",", 
         RowBox[{"SimplifyRules", "[", 
          RowBox[{
           RowBox[{"CheckOperatorType", "\[Rule]", "True"}], ",", 
           RowBox[{"OperatorType", "\[Rule]", " ", "None"}]}], "]"}]}], 
        "]"}]}], "]"}], "/;", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"!", 
        RowBox[{"MemberQ", "[", 
         RowBox[{
          RowBox[{"First", "/@", 
           RowBox[{"(", 
            RowBox[{"Assumptions", "/.", 
             RowBox[{"{", "opts", "}"}]}], ")"}]}], ",", "OperatorType"}], 
         "]"}]}], ")"}], "&&", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"MatchQ", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{"CheckOperatorType", ",", "OperatorType"}], "}"}], "/.", 
            
            RowBox[{"{", "opts", "}"}]}], "/.", 
           RowBox[{"Options", "[", "Operator", "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"Automatic", ",", "Undefined"}], "}"}]}], "]"}], "&&", 
        RowBox[{"(", "\[IndentingNewLine]", 
         RowBox[{"(", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"BasisDimension", "[", "basis", "]"}], "\[LessEqual]", 
            "OperatorTypeCheckDisableThreshold"}], ")"}], ")"}], 
         "\[IndentingNewLine]", ")"}]}], "\[IndentingNewLine]", ")"}]}]}]}], 
   ";"}], " "}]], "Input",
 InitializationCell->True,
