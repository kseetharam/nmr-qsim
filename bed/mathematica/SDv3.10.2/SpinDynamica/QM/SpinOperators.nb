Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SpinProductRank", "::", "usage"}], 
   "=", "\"\<SpinProductRank[op] gives the spin product rank of an operator \
op. For example, \!\(\*SubscriptBox[\(I\), \(1  x\)]\).\!\(\*SubscriptBox[\(I\
\), \(2  y\)]\) has a spin product rank of 2.\>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.429871324201727*^9, 3.429871368663629*^9}, {
  3.468154963801524*^9, 3.468155039700362*^9}, {3.468155341962016*^9, 
