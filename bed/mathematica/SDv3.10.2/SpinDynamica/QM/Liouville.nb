Cell["calculate and memorize the individual spin transformations", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.5465244735735188`*^9, 
  3.546524488084092*^9}},ExpressionUUID->"1270e0a9-9af2-40bf-ba7b-\
491bd7667df2"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"OperatorBasisTransformationMatrix", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"opbasis2", ":", 
       RowBox[{"opbtype2_", "[", 
        RowBox[{"type2___", ",", 
         RowBox[{"{", 
          RowBox[{"{", 
           RowBox[{"j_", ",", "Ij_"}], "}"}], "}"}], ",", "opb2opts___Rule"}],
         "]"}]}], ",", 
      RowBox[{"opbasis1", ":", 
       RowBox[{"opbtype1_", "[", 
        RowBox[{"type1___", ",", 
         RowBox[{"{", 
          RowBox[{"{", 
           RowBox[{"j_", ",", "Ij_"}], "}"}], "}"}], ",", "opb1opts___Rule"}],
         "]"}]}], ",", "\[IndentingNewLine]", 
      RowBox[{"basis", ":", 
       RowBox[{"ZeemanBasis", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"{", 
           RowBox[{"j_", ",", "Ij_"}], "}"}], "}"}], ",", "opts___Rule"}], 
        "]"}]}]}], "\[IndentingNewLine]", "]"}], "/;", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"MatchQ", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Sorted", "/.", 
          RowBox[{"{", "opb2opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "opbtype2", "]"}]}], ",", 
        RowBox[{"\"\<OrderBySpin\>\"", "|", "\"\<Canonical\>\""}]}], "]"}], 
      ")"}], "&&", 
     RowBox[{"(", 
      RowBox[{"MatchQ", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Sorted", "/.", 
          RowBox[{"{", "opb1opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "opbtype1", "]"}]}], ",", 
        RowBox[{"\"\<OrderBySpin\>\"", "|", "\"\<Canonical\>\""}]}], "]"}], 
      ")"}]}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"k", ",", "reps1", ",", "reps2", ",", "OBTmat"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Verbose", "/.", 
           RowBox[{"{", "opts", "}"}]}], "/.", 
          RowBox[{
          "Options", "[", "OperatorBasisTransformationMatrix", "]"}]}], ",", 
         RowBox[{"Print", "[", 
          RowBox[{"\"\<using OrderBySpin (1):\>\"", ",", 
           RowBox[{"{", 
            RowBox[{"opbasis2", ",", "opbasis1"}], "}"}]}], "]"}]}], 
        "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"reps1", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"MatrixRepresentation", "[", 
           RowBox[{"#", ",", 
            RowBox[{"ZeemanBasis", "[", 
             RowBox[{"{", 
              RowBox[{"{", 
               RowBox[{"j", ",", "Ij"}], "}"}], "}"}], "]"}]}], "]"}], "&"}], 
         "/@", 
         RowBox[{"BasisOperators", "[", "opbasis1", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"reps2", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"MatrixRepresentation", "[", 
           RowBox[{"#", ",", 
            RowBox[{"ZeemanBasis", "[", 
             RowBox[{"{", 
              RowBox[{"{", 
               RowBox[{"j", ",", "Ij"}], "}"}], "}"}], "]"}]}], "]"}], "&"}], 
         "/@", 
         RowBox[{"BasisOperators", "[", "opbasis2", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"OBTmat", "=", 
        RowBox[{"SparseArray", "[", 
         RowBox[{"Chop", "@", 
          RowBox[{"Expand", "@", 
           RowBox[{"Outer", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"Tr", "[", 
               RowBox[{
                RowBox[{"Adjoint", "[", "#1", "]"}], ".", "#2"}], "]"}], 
              "&"}], ",", "reps2", ",", "reps1", ",", "1"}], "]"}]}]}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"PrependTo", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
         "DownValues", "[", "OperatorBasisTransformationMatrix", "]"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
          "OperatorBasisTransformationMatrix", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"opbtype2", "[", 
             RowBox[{"type2", ",", 
              RowBox[{"{", 
               RowBox[{"{", 
                RowBox[{"j", ",", "Ij"}], "}"}], "}"}], ",", "opb2opts"}], 
             "]"}], ",", "\[IndentingNewLine]", 
            RowBox[{"opbtype1", "[", 
             RowBox[{"type1", ",", 
              RowBox[{"{", 
               RowBox[{"{", 
                RowBox[{"j", ",", "Ij"}], "}"}], "}"}], ",", "opb1opts"}], 
             "]"}], ",", "\[IndentingNewLine]", 
            RowBox[{"ZeemanBasis", "[", 
             RowBox[{"{", 
              RowBox[{"{", 
               RowBox[{"j", ",", "Ij"}], "}"}], "}"}], "]"}], ",", 
            "___Rule"}], "]"}], "\[Rule]", "\[IndentingNewLine]", 
          "OBTmat"}]}], "\[IndentingNewLine]", "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"OperatorBasisTransformationMatrix", "[", 
        RowBox[{"opbasis2", ",", "opbasis1", ",", "basis"}], "]"}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.546524160140793*^9, 3.546524374926654*^9}, {
