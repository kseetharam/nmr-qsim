   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"spop", ",", "zbasis", ",", "zkbopbasis"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
