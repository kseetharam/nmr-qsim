Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SuperoperatorMatrixRepresentation", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"Exp", "[", 
       RowBox[{"CommutationSuperoperator", "[", 
        RowBox[{
         RowBox[{"HoldPattern", "@", 
          RowBox[{"Operator", "[", 
           RowBox[{
            RowBox[{"ifunc_InterpolatingFunction", "[", "t_", "]"}], ",", 
            "basis_", ",", "___"}], "]"}]}], ",", "___"}], "]"}], "]"}], "|", 
      
      RowBox[{"E", "^", 
       RowBox[{"(", 
        RowBox[{"CommutationSuperoperator", "[", 
         RowBox[{
          RowBox[{"HoldPattern", "@", 
           RowBox[{"Operator", "[", 
            RowBox[{
             RowBox[{"ifunc_InterpolatingFunction", "[", "t_", "]"}], ",", 
             "basis_", ",", "___"}], "]"}]}], ",", "___"}], "]"}], ")"}]}]}], 
     ",", "\[IndentingNewLine]", "opbasis_", ",", "basis_", ",", 
     "opts___Rule"}], "\[IndentingNewLine]", "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "spinsys", "}"}], ",", 
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Replace", "[", 
         RowBox[{"ifunc", ",", "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"mat_", "?", "MatrixQ"}], "\[RuleDelayed]", 
            RowBox[{"SparseArray", "[", 
             RowBox[{"KroneckerProduct", "[", 
              RowBox[{
               RowBox[{"MatrixExp", "[", "mat", "]"}], ",", 
               RowBox[{"Transpose", "@", 
                RowBox[{"MatrixExp", "[", 
                 RowBox[{"-", "mat"}], "]"}]}]}], "]"}], "]"}]}], "}"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"{", "3", "}"}]}], "\[IndentingNewLine]", "]"}], "[", "t", 
        "]"}], "\[IndentingNewLine]", ")"}], "/;", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"spinsys", "=", 
         RowBox[{"SpinSystem", "[", "opbasis", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"MatchQ", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Method", "/.", 
             RowBox[{"{", "opts", "}"}]}], "/.", 
            RowBox[{
            "Options", "[", "SuperoperatorMatrixRepresentation", "]"}]}], ",",
            "Automatic"}], "]"}], "&&", "\[IndentingNewLine]", 
         RowBox[{"MatchQ", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"opbasis", ",", "basis"}], "}"}], ",", 
           RowBox[{"{", 
