Cell[CellGroupData[{

Cell["Lindbladian", "Subsection",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.816773459168128*^9, 3.816773471113985*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"717b74e1-fc58-447f-a16b-c654aa44e755"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Lindbladian", "::", "usage"}], "=", 
   "\"\<Lindbladian[A,B] is the Lindbladian dissipation superoperator \
\!\(\*OverscriptBox[\(D\), \(^\)]\)[A,B] constructed from the operators A and \
B, with the properties \!\(\*OverscriptBox[\(D\), \(^\)]\)[A,B][op]= A\
\[CenterDot]op\[CenterDot]B-\!\(\*FractionBox[\(1\), \(2\)]\)(B\[CenterDot]A\
\[CenterDot]op+op\[CenterDot]B\[CenterDot]A). The syntax Lindbladian[A] is \
equivalent to Lindbladian[A,\!\(\*SuperscriptBox[\(A\), \(\[Dagger]\)]\)]. \
See Bengs and Levitt, doi.org/10.1016/j.jmr.2019.106645\>\""}], 
  ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{
  3.816773474986879*^9, {3.81677355175172*^9, 3.816773928044822*^9}, {
   3.816774001680271*^9, 3.816774017406115*^9}, {3.8167742830457883`*^9, 
   3.816774344881168*^9}, {3.816774524080725*^9, 3.816774543490486*^9}},
 CellLabel->
  "In[160]:=",ExpressionUUID->"7d72af6c-f653-4431-ad7a-555417a3f48a"]
}, Closed]],

