Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"CheckOperatorBasis", "[", 
    RowBox[{
     RowBox[{"opbasis_", "?", "BuiltInOperatorBasisQ"}], ",", "opts___Rule"}],
     "]"}], ":=", "True"}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.699895282533958*^9, 3.69989529738783*^9}},
 CellLabel->
  "In[227]:=",ExpressionUUID->"ea8183b4-2ad5-4ccb-a98c-e3c85ce4e69b"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"CheckOperatorBasis", "[", 
    RowBox[{
     RowBox[{"basisops", ":", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"_", "?", "OperatorQ"}], "..."}], "}"}]}], ",", 
     "opts___Rule"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"vecreps", ",", "umat", ",", "topleft"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"If", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "basisops", "]"}], "!=", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"Times", "@@", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"2", "*", 
                   RowBox[{"SpinQuantumNumber", "[", "#", "]"}]}], "+", "1"}],
                  ")"}], "&"}], "/@", 
               RowBox[{"(", 
                RowBox[{"First", "/@", 
                 RowBox[{"SpinSystem", "[", "]"}]}], ")"}]}], ")"}]}], ")"}], 
           "^", "2"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"Message", "[", 
          RowBox[{"CheckOperatorBasis", "::", "incomplete"}], "]"}]}], 
        "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"umat", "=", 
          RowBox[{"Outer", "[", 
           RowBox[{"LiouvilleBracket", ",", "basisops", ",", "basisops"}], 
           "]"}]}], ";"}], "*)"}], "\[IndentingNewLine]", 
       RowBox[{"vecreps", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"OperatorVectorRepresentation", "[", 
           RowBox[{"#", ",", 
            RowBox[{"ZeemanKetBraOperatorBasis", "[", "]"}]}], "]"}], "&"}], "/@", 
         RowBox[{"N", "@", "basisops"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"umat", "=", 
        RowBox[{"SparseArray", "@", 
         RowBox[{"Chop", "@", 
          RowBox[{"Expand", "@", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"Dot", "[", 
               RowBox[{
                RowBox[{"Conjugate", "@", "vecreps"}], ",", "#"}], "]"}], 
              "&"}], "/@", "vecreps"}], ")"}]}]}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"topleft", "=", 
        RowBox[{"umat", "\[LeftDoubleBracket]", 
         RowBox[{"1", ",", "1"}], "\[RightDoubleBracket]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Which", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"OrthonormalQ", "[", "umat", "]"}], ",", 
         "\[IndentingNewLine]", "\t", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Message", "[", 
            RowBox[{"CheckOperatorBasis", "::", "orthonormal"}], "]"}], ";", 
           "True"}], ")"}], ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"DiagonalQ", "[", "umat", "]"}], "&&", 
          RowBox[{"(", 
           RowBox[{"And", "@@", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"#", "==", "topleft"}], ")"}], "&"}], "/@", 
              RowBox[{"Diagonal", "[", "umat", "]"}]}], ")"}]}], ")"}]}], ",",
          "    ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Message", "[", 
            RowBox[{
             RowBox[{"CheckOperatorBasis", "::", "orthogonalsamenorm"}], ",", 
             "topleft"}], "]"}], ";", "False"}], ")"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"DiagonalQ", "[", "umat", "]"}], ",", "\[IndentingNewLine]", 
         "\t", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Message", "[", 
            RowBox[{
             RowBox[{"CheckOperatorBasis", "::", "orthogonaldiffnorm"}], ",", 
             
             RowBox[{"Diagonal", "[", "umat", "]"}]}], "]"}], ";", "False"}], 
          ")"}], ",", "\[IndentingNewLine]", "True", ",", 
         "\[IndentingNewLine]", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Message", "[", 
            RowBox[{"CheckOperatorBasis", "::", "notorthogonal"}], "]"}], ";",
            "False"}], ")"}]}], "]"}]}], "\[IndentingNewLine]", ")"}]}], 
    "]"}]}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.430567581108365*^9, 3.430567588815233*^9}, {
   3.430567660266232*^9, 3.430567713048575*^9}, {3.434516920456045*^9, 
   3.434516921318618*^9}, 3.4561623912752843`*^9, {3.4621855262930403`*^9, 
