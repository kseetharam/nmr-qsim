Cell[CellGroupData[{

Cell["SingleSpinCartesianBasisOperators", "Subsubsection",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.462190634011159*^9, 3.462190638948386*^9}, 
   3.543499328381192*^9, {3.639153589098634*^9, 
   3.6391535915746*^9}},ExpressionUUID->"b6bfbcff-b231-45d2-b9da-\
35de46f59e1e"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SingleSpinCartesianBasisOperators", "[", 
    RowBox[{"{", 
     RowBox[{"j_", ",", 
      RowBox[{"1", "/", "2"}]}], "}"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"Sqrt", "[", "2", "]"}], "*", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "/", "2"}], ")"}], 
       RowBox[{"UnityOperator", "[", "]"}]}], ",", 
      RowBox[{"opI", "[", 
       RowBox[{"j", ",", "\"\<x\>\""}], "]"}], ",", 
      RowBox[{"opI", "[", 
       RowBox[{"j", ",", "\"\<y\>\""}], "]"}], ",", 
      RowBox[{"opI", "[", 
       RowBox[{"j", ",", "\"\<z\>\""}], "]"}]}], "}"}]}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.6391537999682713`*^9, 3.639153856722848*^9}, {
  3.639154449036543*^9, 3.639154452235663*^9}},
 CellLabel->
  "In[274]:=",ExpressionUUID->"0bf5a6fe-c8b6-4977-9811-d093a326fca4"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"SingleSpinCartesianBasisOperators", "[", 
     RowBox[{"{", 
      RowBox[{"j_", ",", "Ij_"}], "}"}], "]"}], "/;", 
    RowBox[{"Ij", ">", 
     RowBox[{"1", "/", "2"}]}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"SingleSpinCartesianBasisOperators", "[", 
     RowBox[{"{", 
      RowBox[{"j", ",", "Ij"}], "}"}], "]"}], "=", "\[IndentingNewLine]", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "shzbops", ",", "ops", ",", "ZQnumber", ",", "dim", ",", "pmpos", ",", 
        "pppos"}], "}"}], ",", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"Ij", ">", 
           RowBox[{"3", "/", "2"}]}], ",", 
          RowBox[{
          "PrintTemporary", "[", 
           "\"\<Calculating a set of Cartesian basis operators can be slow \
for spins > 3/2. Working...\>\"", "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
        
        RowBox[{"shzbops", "=", 
         RowBox[{"SingleSpinShiftAndZBasisOperators", "[", 
          RowBox[{"{", 
           RowBox[{"j", ",", "Ij"}], "}"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"ZQnumber", "=", 
         RowBox[{
          RowBox[{"2", "*", "Ij"}], "+", "1"}]}], ";", "\[IndentingNewLine]", 
        
        RowBox[{"dim", "=", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"2", "Ij"}], "+", "1"}], ")"}], 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"2", "Ij"}], "+", "1"}], ")"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"pmpos", "=", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"dim", "-", "ZQnumber"}], ")"}], "/", "2"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"pppos", "=", 
         RowBox[{"dim", "-", "pmpos", "+", "1"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Flatten", "@", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"shzbops", "\[LeftDoubleBracket]", 
             RowBox[{
              RowBox[{"pmpos", "+", "1"}], ";;", 
              RowBox[{"pppos", "-", "1"}]}], "\[RightDoubleBracket]"}], ",", 
            RowBox[{"Transpose", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{
                 RowBox[{"1", "/", 
                  RowBox[{"Sqrt", "[", "2", "]"}]}], "*", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"shzbops", "\[LeftDoubleBracket]", 
                    RowBox[{"pppos", ";;"}], "\[RightDoubleBracket]"}], "+", 
                   RowBox[{"Reverse", "[", 
                    RowBox[{"shzbops", "\[LeftDoubleBracket]", 
                    RowBox[{"1", ";;", "pmpos"}], "\[RightDoubleBracket]"}], 
                    "]"}]}], ")"}]}], ",", "\[IndentingNewLine]", 
                RowBox[{
                 RowBox[{"1", "/", 
                  RowBox[{"(", 
                   RowBox[{"I", " ", 
                    RowBox[{"Sqrt", "[", "2", "]"}]}], ")"}]}], "*", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"shzbops", "\[LeftDoubleBracket]", 
                    RowBox[{"pppos", ";;"}], "\[RightDoubleBracket]"}], "-", 
                   RowBox[{"Reverse", "[", 
                    RowBox[{"shzbops", "\[LeftDoubleBracket]", 
                    RowBox[{"1", ";;", "pmpos"}], "\[RightDoubleBracket]"}], 
                    "]"}]}], ")"}]}]}], "}"}], "\[IndentingNewLine]", "/.", 
              RowBox[{"{", "\[IndentingNewLine]", 
               RowBox[{
                RowBox[{
                 RowBox[{"opI", "[", 
                  RowBox[{"j$_", ",", "\"\<+\>\""}], "]"}], "\[RuleDelayed]", 
                 
                 RowBox[{
                  RowBox[{"opI", "[", 
                   RowBox[{"j$", ",", "\"\<x\>\""}], "]"}], "+", 
                  RowBox[{"I", " ", 
                   RowBox[{"opI", "[", 
                    RowBox[{"j$", ",", "\"\<y\>\""}], "]"}]}]}]}], ",", 
                "\[IndentingNewLine]", 
                RowBox[{
                 RowBox[{"opI", "[", 
                  RowBox[{"j$_", ",", "\"\<-\>\""}], "]"}], "\[RuleDelayed]", 
                 
                 RowBox[{
                  RowBox[{"opI", "[", 
                   RowBox[{"j$", ",", "\"\<x\>\""}], "]"}], "-", 
                  RowBox[{"I", " ", 
                   RowBox[{"opI", "[", 
                    RowBox[{"j$", ",", "\"\<y\>\""}], "]"}]}]}]}]}], 
               "\[IndentingNewLine]", "}"}]}], "]"}]}], "}"}]}], "//", 
         "Simplify"}]}], "\[IndentingNewLine]", ")"}]}], "]"}]}]}], 
  ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.639120042471846*^9, 3.639120079251799*^9}, {
   3.639120738571924*^9, 3.6391208410776052`*^9}, {3.639120930859823*^9, 
