\>", "Text",
 CellChangeTimes->{{3.921229914713335*^9, 3.921230033074643*^9}, {
  3.921230123993619*^9, 
  3.921230125065233*^9}},ExpressionUUID->"867a4052-ab2f-4b3f-8f63-\
4dd8a7ca183c"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"UndefineOperatorBasis", "[", "opbasis_", "]"}], "/;", 
    RowBox[{"!", 
     RowBox[{"DefinedOperatorBasisQ", "[", "opbasis", "]"}]}]}], ":=", 
   RowBox[{"Message", "[", 
    RowBox[{
     RowBox[{"UndefineOperatorBasis", "::", "notdef"}], ",", "opbasis"}], 
    "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.6568700642578573`*^9, 3.656870105052923*^9}, {
  3.6568703521847887`*^9, 3.656870369649864*^9}},
 CellLabel->
  "In[206]:=",ExpressionUUID->"f8f5a62e-e1c7-451f-b818-ff33dde782e5"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"UndefineOperatorBasis", "[", "opbasis_", "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"obtmdefs", ",", "iobdefs", ",", "chkobdefs"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"BasisOperators", "[", "opbasis", "]"}], "=."}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"opbasis", "/:", 
        RowBox[{"SpinSystem", "[", "opbasis", "]"}], "=."}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"obtmdefs", "=", 
        RowBox[{"Select", "[", 
         RowBox[{
          RowBox[{
          "DownValues", "[", "OperatorBasisTransformationMatrix", "]"}], ",", 
          
          RowBox[{
           RowBox[{"FreeQ", "[", 
            RowBox[{"#", ",", "opbasis"}], "]"}], "&"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", "\t", 
       RowBox[{"Clear", "[", "OperatorBasisTransformationMatrix", "]"}], ";", 
       "\[IndentingNewLine]", "\t", 
       RowBox[{
        RowBox[{"DownValues", "[", "OperatorBasisTransformationMatrix", "]"}],
         "=", "obtmdefs"}], ";", "\[IndentingNewLine]", 
       RowBox[{"iobdefs", "=", 
        RowBox[{"Select", "[", 
         RowBox[{
          RowBox[{"DownValues", "[", "IntermediateOperatorBasis", "]"}], ",", 
          
          RowBox[{
           RowBox[{"FreeQ", "[", 
            RowBox[{"#", ",", "opbasis"}], "]"}], "&"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", "\t", 
       RowBox[{"Clear", "[", "IntermediateOperatorBasis", "]"}], ";", 
       "\[IndentingNewLine]", "\t", 
       RowBox[{
        RowBox[{"DownValues", "[", "IntermediateOperatorBasis", "]"}], "=", 
        "iobdefs"}], ";", "\[IndentingNewLine]", 
       RowBox[{"chkobdefs", "=", 
        RowBox[{"Select", "[", 
         RowBox[{
          RowBox[{"DownValues", "[", "CheckOperatorBasis", "]"}], ",", 
          RowBox[{
           RowBox[{"FreeQ", "[", 
            RowBox[{"#", ",", "opbasis"}], "]"}], "&"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", "\t", 
       RowBox[{"Clear", "[", "CheckOperatorBasis", "]"}], ";", 
       "\[IndentingNewLine]", "\t", 
       RowBox[{
        RowBox[{"DownValues", "[", "CheckOperatorBasis", "]"}], "=", 
        "chkobdefs"}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"DefinedOperatorBasisQ", "[", "opbasis", "]"}], "=", 
        "False"}], ";", "\[IndentingNewLine]", 
       RowBox[{"SetOptions", "[", "\[IndentingNewLine]", 
        RowBox[{"UnassignedSymbols", ",", "\[IndentingNewLine]", 
         RowBox[{"PermittedSymbols", "->", 
          RowBox[{"Cases", "[", 
           RowBox[{
            RowBox[{"PermittedSymbols", "/.", 
             RowBox[{"Options", "[", "UnassignedSymbols", "]"}]}], ",", 
            RowBox[{"Except", "[", "opbasis", "]"}]}], "]"}]}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Message", "[", 
        RowBox[{
         RowBox[{"UndefineOperatorBasis", "::", "undefined"}], ",", 
         "opbasis"}], "]"}], ";"}], "\[IndentingNewLine]", ")"}]}], "]"}]}], 
  ";"}]], "Input",
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.439434533395159*^9, 3.4394346152362823`*^9}, 
   3.439553945705853*^9, {3.46806900148256*^9, 3.468069014547549*^9}, {
   3.468069103168381*^9, 3.468069108150302*^9}, {3.6998935369637117`*^9, 
