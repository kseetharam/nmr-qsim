6fa3d73c0044"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Superoperator", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"X_", "?", "MatrixQ"}], ",", "evals_List", ",", 
       RowBox[{"Xinv_", "?", "MatrixQ"}]}], "}"}], ",", "opbasis_", ",", 
     "basis_", ",", "opts___Rule"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "orthogX", "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Superoperator", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"X", ",", "evals", ",", "Xinv"}], "}"}], ",", "opbasis", 
         ",", "basis", ",", "\[IndentingNewLine]", 
         RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"SuperoperatorType", "\[Rule]", 
            RowBox[{"Which", "[", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"And", "@@", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{"Chop", "@", 
                    RowBox[{"Expand", "[", 
                    RowBox[{
                    RowBox[{"Abs", "[", "#", "]"}], "-", "1"}], "]"}]}], 
                    "\[Equal]", "0"}], ")"}], "&"}], "/@", "evals"}], ")"}]}],
               ",", "\"\<Unitary\>\"", ",", "\[IndentingNewLine]", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"orthogX", "=", 
                 RowBox[{"OrthogonalQ", "[", "X", "]"}]}], ";", 
                "\[IndentingNewLine]", 
                RowBox[{"orthogX", " ", "&&", "\[IndentingNewLine]", 
                 RowBox[{"And", "@@", 
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{
                    RowBox[{"Element", "[", 
                    RowBox[{"#", ",", "Reals"}], "]"}], "&"}], "/@", 
                    "evals"}], ")"}]}]}]}], ")"}], ",", "\"\<Hermitian\>\"", 
              ",", "\[IndentingNewLine]", 
              RowBox[{"orthogX", " ", "&&", "\[IndentingNewLine]", 
               RowBox[{"And", "@@", 
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"Element", "[", 
                    RowBox[{
                    RowBox[{"Chop", "@", 
                    RowBox[{"Expand", "@", 
                    RowBox[{"N", "[", 
                    RowBox[{"I", " ", "#"}], "]"}]}]}], ",", "Reals"}], "]"}],
                    "&"}], "/@", "evals"}], ")"}]}]}], ",", 
              "\"\<AntiHermitian\>\"", ",", "\[IndentingNewLine]", "True", 
              ",", "None"}], "]"}]}], ",", "\[IndentingNewLine]", "opts"}], 
          "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", "]"}], "/;", 
       
       RowBox[{"(", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"MatchQ", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"{", 
              RowBox[{"CheckSuperoperatorType", ",", "SuperoperatorType"}], 
              "}"}], "/.", 
             RowBox[{"{", "opts", "}"}]}], "/.", 
            RowBox[{"Options", "[", "Superoperator", "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"True", ",", "Undefined"}], "}"}]}], "]"}], "&&", 
         "\[IndentingNewLine]", 
         RowBox[{"MatchQ", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"X", ",", "evals", ",", "Xinv"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"_", "?", "NumericMatrixQ"}], ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"_", "?", "NumericQ"}], ".."}], "}"}], ",", 
             RowBox[{"_", "?", "NumericMatrixQ"}]}], "}"}]}], "]"}]}], 
        "\[IndentingNewLine]", ")"}]}], "\[IndentingNewLine]", ")"}]}], 
    "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.583432407146059*^9, 3.583432543452914*^9}, {
  3.58615764580089*^9, 3.586157650688512*^9}, {3.586157827858062*^9, 
  3.586157923065819*^9}, {3.586157962270501*^9, 3.586158027225636*^9}, {
