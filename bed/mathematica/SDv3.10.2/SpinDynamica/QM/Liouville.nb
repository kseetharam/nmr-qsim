              "]"}]}], "\[IndentingNewLine]", "]"}]}]}], 
        "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Delete", "[", "temp", "]"}], ";", "\[IndentingNewLine]", 
