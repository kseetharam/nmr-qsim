Cell[CellGroupData[{

Cell["SingleSpinShiftAndZBasisOperators", "Subsubsection",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.462190634011159*^9, 3.462190638948386*^9}, 
   3.543499328381192*^9},ExpressionUUID->"12fd0037-47ed-4577-b7ff-\
d37d55499de2"],

Cell["\<\
sets up orthogonal operators for an individual spin of arbitrary quantum \
number. Needed in the calculation of the complete multiple-spin basis. This \
routine gets quite slow for spins>3/2. \
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.543499252034922*^9, 3.543499316568716*^9}, {
  3.639122594788381*^9, 
  3.639122595675678*^9}},ExpressionUUID->"3660d990-a7e7-4c52-97a7-\
c6ea86b8bce2"],

Cell["\<\
faster code was implemented in v2.12.3b1. However the basis construction is \
still very slow for spin-7/2 or higher.\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.639122601886063*^9, 3.63912262094414*^9}, {
  3.63912268124967*^9, 3.639122681708716*^9}, {3.639208392125268*^9, 
  3.639208416717216*^9}},ExpressionUUID->"22b9e5d5-4927-4640-81ba-\
de545c205985"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SingleSpinShiftAndZBasisOperators", "[", 
    RowBox[{"{", 
     RowBox[{"j_", ",", "Ij_"}], "}"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "d$", ",", "Iplus", ",", "Iz", ",", "Id", ",", "\[Phi]", ",", "SZops", 
       ",", "SZzreps", ",", "SZpreps", ",", "SZreps", ",", "\[Phi]vec", ",", 
       "len", ",", "newset"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"d$", "[", 
        RowBox[{
         RowBox[{"k_.", "*", "p_Plus"}], ",", "B_"}], "]"}], ":=", 
       RowBox[{
        RowBox[{
         RowBox[{"k", "*", 
          RowBox[{"d$", "[", 
           RowBox[{"#", ",", "B"}], "]"}]}], "&"}], "/@", "p"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"d$", "[", 
        RowBox[{"A_", ",", 
         RowBox[{"k_.", "*", "p_Plus"}]}], "]"}], ":=", 
       RowBox[{
        RowBox[{
         RowBox[{"k", "*", 
          RowBox[{"d$", "[", 
           RowBox[{"A", ",", "#"}], "]"}]}], "&"}], "/@", "p"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"d$", "[", 
        RowBox[{
         RowBox[{"k1_.", 
          RowBox[{"\[Phi]", "[", "m_", "]"}]}], ",", 
         RowBox[{"k2_.", 
          RowBox[{"\[Phi]", "[", "n_", "]"}]}]}], "]"}], ":=", 
       RowBox[{"k1", "*", "k2", "*", 
        RowBox[{
         RowBox[{"Conjugate", "[", 
          RowBox[{
          "SZreps", "\[LeftDoubleBracket]", "m", "\[RightDoubleBracket]"}], 
          "]"}], ".", 
         RowBox[{
         "SZreps", "\[LeftDoubleBracket]", "n", 
          "\[RightDoubleBracket]"}]}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
