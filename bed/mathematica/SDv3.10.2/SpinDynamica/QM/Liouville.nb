     ",", "\[IndentingNewLine]", "opbasis2", ",", "\[IndentingNewLine]", 
     "basis2", ",", "\[IndentingNewLine]", 
     RowBox[{"SimplifyRules", "[", 
      RowBox[{"sopopts", ",", "opts"}], "]"}]}], "\[IndentingNewLine]", 
    "]"}]}], ";"}]], "Input",
 InitializationCell->True,
