Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"CombineSuperoperatorMatrixRepresentations", "[", 
     RowBox[{
      RowBox[{"ifunc1_InterpolatingFunction", "[", "t_", "]"}], ",", 
      "ifunc2_InterpolatingFunction"}], "]"}], "/;", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Depth", "[", "ifunc1", "]"}], "\[GreaterEqual]", "3"}], ")"}],
      "&&", "\[IndentingNewLine]", 
     RowBox[{"MatchQ", "[", 
      RowBox[{
       RowBox[{"ifunc1", "[", 
        RowBox[{"ifunc1", "\[LeftDoubleBracket]", 
         RowBox[{"1", ",", "1", ",", "1"}], "\[RightDoubleBracket]"}], "]"}], 
       ",", 
       RowBox[{"_", "?", "MatrixQ"}]}], "]"}], "&&", "\[IndentingNewLine]", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Depth", "[", "ifunc2", "]"}], "\[GreaterEqual]", "3"}], ")"}],
      "&&", "\[IndentingNewLine]", 
     RowBox[{"MatchQ", "[", 
      RowBox[{
       RowBox[{"ifunc2", "[", 
        RowBox[{"ifunc2", "\[LeftDoubleBracket]", 
         RowBox[{"1", ",", "1", ",", "1"}], "\[RightDoubleBracket]"}], "]"}], 
       ",", 
       RowBox[{"_", "?", "MatrixQ"}]}], "]"}]}]}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "interptimes", "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"interptimes", "=", 
        RowBox[{"Sort", "@", 
         RowBox[{"Union", "[", 
          RowBox[{
           RowBox[{"ifunc1", "\[LeftDoubleBracket]", 
            RowBox[{"3", ",", "1"}], "\[RightDoubleBracket]"}], ",", 
           RowBox[{"ifunc1", "\[LeftDoubleBracket]", 
            RowBox[{"3", ",", "2"}], "\[RightDoubleBracket]"}]}], "]"}]}]}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"Interpolation", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"ifunc1", "[", "#", "]"}], "+", 
            RowBox[{"ifunc2", "[", "#", "]"}]}], ")"}], "&"}], "/@", 
         "interptimes"}], "]"}]}], "\[IndentingNewLine]", ")"}]}], "]"}]}], 
  ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{
  3.621161231681098*^9, {3.62116126441649*^9, 3.62116145577761*^9}, 
   3.621161500668488*^9, {3.62116160430916*^9, 3.621161722810411*^9}, 
   3.621244000796517*^9},
 CellLabel->
