Cell[CellGroupData[{

Cell["define by specifying basis operators", "Subsubsection",
 CellChangeTimes->{{3.699431757238006*^9, 3.699431768701005*^9}, {
  3.699431922640235*^9, 3.699431929758881*^9}, {3.699457777617359*^9, 
  3.699457783029633*^9}},ExpressionUUID->"131c12d4-7e03-47c2-b3c6-\
9401665b7ca8"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"DefineOperatorBasis", "[", 
    RowBox[{"newopbasis_", ",", 
     RowBox[{"basisops", ":", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"_", "?", "OperatorQ"}], ".."}], "}"}]}], ",", 
     "opts___Rule"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"check", ",", "basischeck"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Message", "[", 
        RowBox[{"DefineOperatorBasis", "::", "maybeslow"}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"check", "=", 
        RowBox[{
         RowBox[{"CheckOperatorBasis", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "DefineOperatorBasis", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"BasisOperators", "[", "newopbasis", "]"}], "=", "basisops"}],
        ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"check", "&&", 
            RowBox[{"CheckOperatorBasis", "[", "basisops", "]"}]}], ")"}], "||", 
          RowBox[{"!", "check"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"(", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{
            RowBox[{"DefinedOperatorBasisQ", "[", "newopbasis", "]"}], "=", 
            "True"}], ";", "\[IndentingNewLine]", 
           RowBox[{"SetOptions", "[", "\[IndentingNewLine]", 
            RowBox[{"UnassignedSymbols", ",", "\[IndentingNewLine]", 
             RowBox[{"PermittedSymbols", "->", 
              RowBox[{"Append", "[", 
               RowBox[{
                RowBox[{"PermittedSymbols", "/.", 
                 RowBox[{"Options", "[", "UnassignedSymbols", "]"}]}], ",", 
                "newopbasis"}], "]"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
           
           RowBox[{
            RowBox[{"SpinSystem", "[", "newopbasis", "]"}], "^=", 
            RowBox[{"SpinSystem", "[", "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"Message", "[", 
            RowBox[{
             RowBox[{"DefineOperatorBasis", "::", "defined"}], ",", 
             "newopbasis"}], "]"}], ";", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"!", "check"}], ",", 
             RowBox[{"Message", "[", 
              RowBox[{
               RowBox[{"DefineOperatorBasis", "::", "nocheckwarning"}], ",", 
               "newopbasis"}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
           "newopbasis"}], "\[IndentingNewLine]", ")"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Message", "[", 
            RowBox[{
             RowBox[{"DefineOperatorBasis", "::", "notdef"}], ",", 
             "newopbasis"}], "]"}], ";", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"BasisOperators", "[", "newopbasis", "]"}], "=."}]}], 
          "\[IndentingNewLine]", ")"}]}], "\[IndentingNewLine]", "]"}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.699455678021784*^9, 3.6994557753291197`*^9}, {
   3.699455824711293*^9, 3.699455847050506*^9}, {3.699455877622148*^9, 
   3.699455883746778*^9}, {3.699456047503438*^9, 3.699456087691831*^9}, {
   3.699456162671975*^9, 3.699456163044957*^9}, {3.699456238904225*^9, 
   3.699456245174143*^9}, {3.699457531178266*^9, 3.699457534302911*^9}, {
