Cell[CellGroupData[{

Cell["DefineOperatorBasis", "Subsection",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.549961879086213*^9, 3.549961891996063*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"272aef9f-351b-43e7-94ab-16769be1ff92"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"DefineOperatorBasis", "::", "usage"}], "=", 
   "\"\<DefineOperatorBasis[newopbasis,{op1,op2,..},opts] defines an operator \
basis newopbasis which may be used for superoperator matrix representations. \
The option CheckOperatorBasis->True may be used to check its suitability. \n\
The syntax DefineOperatorBasis[newopbasis,opbasis,ordering] defines an \
operator basis newopbasis based on an existing operator basis opbasis by \
reordering the basis operators. The List ordering specifies how the basis \
operators are reordered in the new basis. For example, if ordering is given \
by {2,1,3,4,5...}, then newopbasis  has the same basis operators as opbasis, \
but with the first two operators exchanged. \nThe syntax \
DefineOperatorBasis[newopbasis,opbasis,superop] defines an operator basis \
newopbasis based on an existing operator basis opbasis by applying the \
superoperator superop to each of the basis operators. \nThe syntax \
DefineOperatorBasis[newopbasis,opbasis,superop,ordering] defines an operator \
basis newopbasis by applying the superoperator superop to each of the basis \
operators of opbasis, ordered according to the list ordering. \nThe \
definition of a new operator basis using an arbitrary set of basis operators \
can be computationally intensive; the options described above, which build \
upon a pre-existing operator basis by reordering the operators and/or \
applying a superoperator to each of them, are computationally more efficient. \
\n\>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{
  3.448354744448742*^9, {3.699431130356435*^9, 3.699431564902205*^9}, {
   3.699459323083325*^9, 3.699459337206688*^9}, {3.699459376561305*^9, 
   3.699459489643423*^9}},
 CellLabel->
  "In[127]:=",ExpressionUUID->"c55c18ce-3498-41fd-99a1-73bb57dbb823"]
}, Closed]],

