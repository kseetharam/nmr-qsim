Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"HoldPattern", "@", 
    RowBox[{"SuperoperatorMatrixRepresentation", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"CommutationSuperoperator", "[", 
       RowBox[{
        RowBox[{"Operator", "[", 
         RowBox[{
          RowBox[{"mat_", "?", "MatrixQ"}], ",", "basis_", ",", "___"}], 
         "]"}], ",", "___"}], "]"}], ",", "\[IndentingNewLine]", "opbasis_", 
      ",", "basis_", ",", "opts___Rule"}], "\[IndentingNewLine]", "]"}]}], ":=",
    "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"spinsys", ",", "Emat"}], "}"}], ",", 
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Emat", "=", 
         RowBox[{"MatrixRepresentation", "[", 
          RowBox[{
           RowBox[{"UnityOperator", "[", "]"}], ",", "basis", ",", "opts"}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"SparseArray", "[", 
         RowBox[{
          RowBox[{"KroneckerProduct", "[", 
           RowBox[{"mat", ",", "Emat"}], "]"}], "-", 
          RowBox[{"Transpose", "@", 
           RowBox[{"KroneckerProduct", "[", 
            RowBox[{"Emat", ",", "mat"}], "]"}]}]}], "]"}]}], 
       "\[IndentingNewLine]", ")"}], "/;", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"spinsys", "=", 
         RowBox[{"SpinSystem", "[", "opbasis", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"MatchQ", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Method", "/.", 
             RowBox[{"{", "opts", "}"}]}], "/.", 
            RowBox[{
            "Options", "[", "SuperoperatorMatrixRepresentation", "]"}]}], ",",
            "Automatic"}], "]"}], "&&", "\[IndentingNewLine]", 
         RowBox[{"MatchQ", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"opbasis", ",", "basis"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"ZeemanKetBraOperatorBasis", "[", 
              RowBox[{"spinsys", ",", 
               RowBox[{"Sorted", "\[Rule]", "\"\<Canonical\>\""}]}], "]"}], 
             ",", 
             RowBox[{"ZeemanBasis", "[", "spinsys", "]"}]}], "}"}]}], 
          "]"}]}]}], "\[IndentingNewLine]", ")"}]}]}], "]"}]}], 
  ";"}]], "Input",
