Cell[CellGroupData[{

Cell["\<\
CommutationSuperoperator of a diagonalized operator,  that is known or \
assumed to be Hermitian\
\>", "Subsubsection",
 InitializationCell->True,
 CellChangeTimes->{{3.586193070859205*^9, 3.586193084970389*^9}, {
  3.586193118562601*^9, 3.586193148029195*^9}, {3.586193793280416*^9, 
  3.586193804238991*^9}, {3.58619486626667*^9, 3.586194872273711*^9}, {
  3.586333101404947*^9, 3.586333118650494*^9}, {3.586333371976274*^9, 
  3.586333378381918*^9}},ExpressionUUID->"13b150bb-e8c4-42a4-812f-\
e0c9884cf8f3"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"NDiagonalize", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"CommutationSuperoperator", "[", 
      RowBox[{
       RowBox[{"op", ":", 
        RowBox[{"Operator", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Xop_", "?", "NumericMatrixQ"}], ",", "opevals_List", ",", 
            RowBox[{"Xopinv_", "?", "NumericMatrixQ"}]}], "}"}], ",", 
          "basis_", ",", "___Rule"}], "]"}]}], ",", "\[IndentingNewLine]", 
       "sopopts___Rule"}], "]"}], ",", "\[IndentingNewLine]", "opbasis_", ",",
      "basis_", ",", "opts___Rule"}], "\[IndentingNewLine]", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "zkbop", ",", "zb", ",", "ass", ",", "opevecs", ",", "sopevecs"}], 
      "}"}], ",", 
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"opevecs", "=", 
         RowBox[{"Orthogonalize", "@", 
          RowBox[{"Transpose", "[", "Xop", "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"sopevecs", "=", 
         RowBox[{"KroneckerProduct", "[", 
          RowBox[{"opevecs", ",", 
           RowBox[{"ComplexExpand", "[", 
            RowBox[{"Conjugate", "/@", "opevecs"}], "]"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Superoperator", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"{", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"SparseArray", "@", 
             RowBox[{"Chop", "@", 
              RowBox[{"Expand", "@", 
               RowBox[{"Transpose", "[", "sopevecs", "]"}]}]}]}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"Chop", "@", 
             RowBox[{"Flatten", "@", 
              RowBox[{"Outer", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"#1", "-", 
                   RowBox[{"Conjugate", "[", "#2", "]"}]}], ")"}], "&"}], ",",
                 "opevals", ",", "opevals"}], "]"}]}]}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"SparseArray", "@", 
             RowBox[{"Chop", "@", 
              RowBox[{"Expand", "@", 
               RowBox[{"Conjugate", "[", "sopevecs", "]"}]}]}]}]}], 
           "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
          "opbasis", ",", "basis", ",", "opts"}], "\[IndentingNewLine]", 
         "]"}]}], "\[IndentingNewLine]", ")"}], "/;", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"zkbop", "=", 
         RowBox[{"ZeemanKetBraOperatorBasis", "[", 
          RowBox[{"Sorted", "\[Rule]", "\"\<Canonical\>\""}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"zb", "=", 
         RowBox[{"ZeemanBasis", "[", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"MatchQ", "[", 
          RowBox[{"opbasis", ",", "zkbop"}], "]"}], "&&", 
         "\[IndentingNewLine]", 
         RowBox[{"MatchQ", "[", 
          RowBox[{"basis", ",", "zb"}], "]"}], "&&", "\[IndentingNewLine]", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"MatchQ", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"OperatorType", "/.", 
               RowBox[{"{", "sopopts", "}"}]}], "/.", 
              RowBox[{"Options", "[", "Operator", "]"}]}], ",", 
             "\"\<Hermitian\>\""}], "]"}], "||", "\[IndentingNewLine]", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"ass", "=", 
              RowBox[{
               RowBox[{"Assumptions", "/.", 
                RowBox[{"{", "sopopts", "}"}]}], "/.", 
               RowBox[{"Options", "[", "NDiagonalize", "]"}]}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"MatchQ", "[", 
               RowBox[{"ass", ",", 
                RowBox[{"{", 
                 RowBox[{"_Rule", "..."}], "}"}]}], "]"}], "&&", 
              "\[IndentingNewLine]", 
              RowBox[{"MatchQ", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"OperatorType", "/.", "ass"}], "/.", 
                 RowBox[{"Options", "[", "NDiagonalize", "]"}]}], ",", 
                "\"\<Hermitian\>\""}], "]"}]}]}], ")"}]}], 
          "\[IndentingNewLine]", ")"}]}]}], "\[IndentingNewLine]", ")"}]}]}], 
    "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.586193825446396*^9, 3.586193951919151*^9}, {
   3.586194182657648*^9, 3.586194356574205*^9}, {3.586194948084222*^9, 
