Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"OperatorBasisTransformationMatrix", "[", 
    RowBox[{
    "opbasis2_", ",", "opbasis1_", ",", "basis_", ",", "opts___Rule"}], "]"}],
    ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "iopbasis", "}"}], ",", 
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Verbose", "/.", 
            RowBox[{"{", "opts", "}"}]}], "/.", 
           RowBox[{
           "Options", "[", "OperatorBasisTransformationMatrix", "]"}]}], ",", 
          
          RowBox[{"Print", "[", 
           RowBox[{"\"\<going through iopb (1):\>\"", ",", "iopbasis", ",", 
            RowBox[{"{", 
             RowBox[{"opbasis2", ",", "opbasis1"}], "}"}]}], "]"}]}], 
         "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"PrependTo", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
          "DownValues", "[", "OperatorBasisTransformationMatrix", "]"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"OperatorBasisTransformationMatrix", "[", 
            RowBox[{
            "opbasis2", ",", "opbasis1", ",", "basis", ",", "___Rule"}], 
            "]"}], "\[Rule]", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"OperatorBasisTransformationMatrix", "[", 
             RowBox[{"opbasis2", ",", "iopbasis", ",", "basis", ",", "opts"}],
              "]"}], ".", "\[IndentingNewLine]", 
            RowBox[{"OperatorBasisTransformationMatrix", "[", 
             RowBox[{"iopbasis", ",", "opbasis1", ",", "basis", ",", "opts"}],
              "]"}]}]}]}], "\[IndentingNewLine]", "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"OperatorBasisTransformationMatrix", "[", 
         RowBox[{"opbasis2", ",", "opbasis1", ",", "basis"}], "]"}]}], 
       "\[IndentingNewLine]", ")"}], "/;", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"iopbasis", "=", 
         RowBox[{"IntermediateOperatorBasis", "[", "opbasis1", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"MatchQ", "[", 
           RowBox[{"opbasis2", ",", "iopbasis"}], "]"}]}], "&&", 
         RowBox[{"!", 
          RowBox[{"MatchQ", "[", 
           RowBox[{"opbasis1", ",", "iopbasis"}], "]"}]}]}]}], 
       "\[IndentingNewLine]", ")"}]}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
