Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"OperatorVectorRepresentation", "[", 
    RowBox[{"op_", ",", "opbasis_", ",", "basis_", ",", "opts___Rule"}], 
    "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"iopbasis", ",", "spinsys", ",", "zb"}], "}"}], ",", 
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"iopbasis", "=", 
         RowBox[{"ZeemanKetBraOperatorBasis", "[", 
          RowBox[{"spinsys", ",", 
           RowBox[{"Sorted", "\[Rule]", "\"\<Canonical\>\""}]}], "]"}]}], ";",
         "\[IndentingNewLine]", 
        RowBox[{"zb", "=", 
         RowBox[{"ZeemanBasis", "[", "spinsys", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"SparseArray", "[", 
         RowBox[{"Simplify", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"OperatorBasisTransformationMatrix", "[", 
            RowBox[{"opbasis", ",", "iopbasis", ",", "zb"}], "]"}], ".", 
           "\[IndentingNewLine]", 
           RowBox[{"OperatorVectorRepresentation", "[", 
            RowBox[{"op", ",", "iopbasis", ",", "zb", ",", 
             RowBox[{"Method", "\[Rule]", "Automatic"}], ",", "opts"}], 
            "]"}]}], "\[IndentingNewLine]", "]"}], "]"}]}], 
       "\[IndentingNewLine]", ")"}], "/;", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"spinsys", "=", 
         RowBox[{"SpinSystem", "[", "opbasis", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"MatchQ", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Method", "/.", 
             RowBox[{"{", "opts", "}"}]}], "/.", 
            RowBox[{"Options", "[", "OperatorVectorRepresentation", "]"}]}], 
           ",", "Automatic"}], "]"}], "&&", "\[IndentingNewLine]", 
         RowBox[{"!", 
          RowBox[{"MatchQ", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"opbasis", ",", "basis"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"ZeemanKetBraOperatorBasis", "[", 
               RowBox[{"spinsys", ",", 
                RowBox[{"Sorted", "\[Rule]", "\"\<Canonical\>\""}]}], "]"}], 
              ",", 
              RowBox[{"ZeemanBasis", "[", "spinsys", "]"}]}], "}"}]}], 
           "]"}]}]}]}], "\[IndentingNewLine]", ")"}]}]}], "]"}]}], 
  ";"}]], "Input",
