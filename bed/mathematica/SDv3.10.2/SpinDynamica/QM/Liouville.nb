Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"HoldPattern", "@", 
     RowBox[{"MatrixRepresentation", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"op", ":", 
        RowBox[{"Operator", "[", 
         RowBox[{
          RowBox[{"ifunc_InterpolatingFunction", "[", "t_", "]"}], ",", 
          RowBox[{"vecopbasis", ":", 
           RowBox[{"Except", "[", "_Rule", "]"}]}], ",", 
          RowBox[{"vecbasis", ":", 
           RowBox[{"Except", "[", "_Rule", "]"}]}], ",", "___Rule"}], "]"}]}],
        ",", "\[IndentingNewLine]", 
       RowBox[{"basis", ":", 
        RowBox[{"Except", "[", "_Rule", "]"}]}], ",", "___Rule"}], "]"}]}], "/;", 
    RowBox[{
     RowBox[{"MatchQ", "[", 
      RowBox[{"basis", ",", 
       RowBox[{"ZeemanBasis", "[", "]"}]}], "]"}], "&&", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Depth", "[", "ifunc", "]"}], "\[GreaterEqual]", "3"}], 
        ")"}], "&&", "\[IndentingNewLine]", 
       RowBox[{"MatchQ", "[", 
        RowBox[{
         RowBox[{"ifunc", "[", 
          RowBox[{"ifunc", "\[LeftDoubleBracket]", 
           RowBox[{"1", ",", "1", ",", "1"}], "\[RightDoubleBracket]"}], 
          "]"}], ",", 
         RowBox[{"_", "?", "VectorQ"}]}], "]"}]}], ")"}]}]}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "zbasis", "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"zbasis", "=", 
        RowBox[{"ZeemanBasis", "[", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"MatrixRepresentation", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Operator", "[", 
          RowBox[{"op", ",", 
           RowBox[{"ZeemanKetBraOperatorBasis", "[", 
            RowBox[{"Sorted", "\[Rule]", "\"\<Canonical\>\""}], "]"}], ",", 
           "zbasis", ",", 
           RowBox[{"CheckOperatorType", "\[Rule]", "False"}]}], "]"}], ",", 
         "\[IndentingNewLine]", "zbasis"}], "\[IndentingNewLine]", "]"}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
