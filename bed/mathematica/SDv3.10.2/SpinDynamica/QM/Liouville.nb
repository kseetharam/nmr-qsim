fb00de2473ce"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"OperatorBasisTransformationMatrix", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"opbasis2", ":", 
       RowBox[{"type2_", "[", 
        RowBox[{
         RowBox[{"stuff2", ":", 
          RowBox[{
           RowBox[{"Except", "[", "_Rule", "]"}], ".."}]}], ",", 
         "opb2opts___Rule"}], "]"}]}], ",", 
      RowBox[{"zkbop", ":", 
       RowBox[{"ZeemanKetBraOperatorBasis", "[", 
        RowBox[{
         RowBox[{"stuff1", ":", 
          RowBox[{
           RowBox[{"Except", "[", "_Rule", "]"}], ".."}]}], ",", 
         "opb1opts___Rule"}], "]"}]}], ",", "\[IndentingNewLine]", "basis_", 
      ",", "opts___Rule"}], "\[IndentingNewLine]", "]"}], "/;", 
    RowBox[{"(", 
     RowBox[{"MatchQ", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Sorted", "/.", 
         RowBox[{"{", "opb1opts", "}"}]}], "/.", 
        RowBox[{"Options", "[", "type2", "]"}]}], ",", "\"\<Canonical\>\""}], 
      "]"}], ")"}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"PrintTemporary", "[", 
      RowBox[{
      "\"\<setting up OperatorBasisTransformationMatrix from \>\"", ",", 
       "zkbop", ",", "\"\< to \>\"", ",", "opbasis2"}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Verbose", "/.", 
         RowBox[{"{", "opts", "}"}]}], "/.", 
        RowBox[{"Options", "[", "OperatorBasisTransformationMatrix", "]"}]}], 
       ",", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<setting up using canonical ordering ..\>\"", ",", 
         RowBox[{"{", 
          RowBox[{"opbasis2", ",", "zkbop"}], "}"}]}], "]"}]}], 
      "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"PrependTo", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"DownValues", "[", "OperatorBasisTransformationMatrix", "]"}], 
       ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"OperatorBasisTransformationMatrix", "[", 
         RowBox[{"opbasis2", ",", "zkbop", ",", "basis", ",", "___Rule"}], 
         "]"}], "\[Rule]", "\[IndentingNewLine]", 
        RowBox[{"SparseArray", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"Conjugate", "@", 
            RowBox[{"Flatten", "@", 
             RowBox[{"MatrixRepresentation", "[", 
              RowBox[{"#", ",", 
               RowBox[{"ZeemanBasis", "[", "stuff1", "]"}]}], "]"}]}]}], 
           "&"}], "/@", "\[IndentingNewLine]", 
          RowBox[{"BasisOperators", "[", "opbasis2", "]"}]}], 
         "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"OperatorBasisTransformationMatrix", "[", 
      RowBox[{"opbasis2", ",", "zkbop", ",", "basis"}], "]"}]}], 
    "\[IndentingNewLine]", ")"}]}], ";"}]], "Input",
 InitializationCell->True,
