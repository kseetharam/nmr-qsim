Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"CartesianProductOperatorBasis", "::", "usage"}], "=", 
   "\"\<CartesianProductOperatorBasis[] generates a set of Cartesian product \
operators for the current spin system (which must have been set first using \
the SetSpinSystem command of the SpinOperators package). Currently, this \
basis may only be used if all nuclei are spins-1/2. The option Sorted->True \
sorts the operators according to SpinProductRank and CoherenceOrder.\>\""}], 
  ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.459515345530847*^9, 3.459515371589775*^9}, {
