  RowBox[{
   RowBox[{
    RowBox[{"OperatorBasisTransformationMatrix", "[", 
     RowBox[{
     "opbasis1_", ",", "opbasis2_", ",", "basis_", ",", "opts___Rule"}], 
     "]"}], "/;", 
    RowBox[{"!", 
     RowBox[{"OperatorBasesOrderedQ", "[", 
      RowBox[{"{", 
       RowBox[{"opbasis1", ",", "opbasis2"}], "}"}], "]"}]}]}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"(", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Verbose", "/.", 
         RowBox[{"{", "opts", "}"}]}], "/.", 
        RowBox[{"Options", "[", "OperatorBasisTransformationMatrix", "]"}]}], 
       ",", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<transposing order:\>\"", ",", 
         RowBox[{"{", 
          RowBox[{"opbasis2", ",", "opbasis1"}], "}"}]}], "]"}]}], 
      "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Adjoint", "[", 
      RowBox[{"OperatorBasisTransformationMatrix", "[", 
       RowBox[{"opbasis2", ",", "opbasis1", ",", "basis", ",", "opts"}], 
       "]"}], "]"}]}], "\[IndentingNewLine]", ")"}]}], ";"}]], "Input",
