                 RowBox[{"-", "I"}], " ", "opevals"}], ",", "Xopinv"}], "}"}],
               ",", "basis", ",", "\[IndentingNewLine]", 
              RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
