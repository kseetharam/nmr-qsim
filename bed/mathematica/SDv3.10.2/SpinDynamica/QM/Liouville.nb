Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"OperatorBasisTransformationMatrix", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"opbasis2", ":", 
       RowBox[{"type2_", "[", 
        RowBox[{
         RowBox[{"stuff2", ":", 
          RowBox[{
           RowBox[{"Except", "[", "_Rule", "]"}], ".."}]}], ",", 
         "opb2opts___Rule"}], "]"}]}], ",", 
      RowBox[{"opbasis1", ":", 
       RowBox[{"type1_", "[", 
        RowBox[{
         RowBox[{"stuff1", ":", 
          RowBox[{
           RowBox[{"Except", "[", "_Rule", "]"}], ".."}]}], ",", 
         "opb1opts___Rule"}], "]"}]}], ",", "\[IndentingNewLine]", "basis_", 
      ",", "opts___Rule"}], "\[IndentingNewLine]", "]"}], "/;", 
    RowBox[{
     RowBox[{"MemberQ", "[", 
      RowBox[{
       RowBox[{"AllowedSortValues", "[", "opbasis2", "]"}], ",", 
       "\"\<OrderBySpin\>\""}], "]"}], "&&", 
     RowBox[{"MemberQ", "[", 
      RowBox[{
       RowBox[{"AllowedSortValues", "[", "opbasis1", "]"}], ",", 
       "\"\<OrderBySpin\>\""}], "]"}], "&&", 
     RowBox[{"(", 
      RowBox[{"!", 
       RowBox[{"MatchQ", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Sorted", "/.", 
           RowBox[{"{", "opb1opts", "}"}]}], "/.", 
          RowBox[{"Options", "[", "type1", "]"}]}], ",", 
         "\"\<OrderBySpin\>\""}], "]"}]}], ")"}], "&&", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Length", "[", 
        RowBox[{"SpinSystem", "[", "opbasis1", "]"}], "]"}], ">", "1"}], 
      ")"}]}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "iopbasis", ",", "orderopbasis1", ",", "orderiopbasis", ",", "perm"}], 
      "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Verbose", "/.", 
           RowBox[{"{", "opts", "}"}]}], "/.", 
          RowBox[{
          "Options", "[", "OperatorBasisTransformationMatrix", "]"}]}], ",", 
         RowBox[{"Print", "[", 
          RowBox[{"\"\<setting up OrderBySpin (2):\>\"", ",", 
           RowBox[{"{", 
            RowBox[{"opbasis2", ",", "opbasis1"}], "}"}]}], "]"}]}], 
        "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"iopbasis", "=", "\[IndentingNewLine]", 
        RowBox[{"type1", "[", 
         RowBox[{"stuff1", ",", "\[IndentingNewLine]", 
          RowBox[{"SimplifyRules", "[", 
           RowBox[{
            RowBox[{"Sorted", "\[Rule]", "\"\<OrderBySpin\>\""}], ",", 
