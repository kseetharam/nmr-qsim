 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"NDiagonalize", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"CommutationSuperoperator", "[", 
       RowBox[{
        RowBox[{"op", ":", 
         RowBox[{"Operator", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Xop_", "?", "NumericMatrixQ"}], ",", "opevals_List", 
             ",", 
             RowBox[{"Xopinv_", "?", "NumericMatrixQ"}]}], "}"}], ",", 
           "basis_", ",", "opopts___Rule"}], "]"}]}], ",", 
        "\[IndentingNewLine]", "sopopts___Rule"}], "]"}], ",", 
      "\[IndentingNewLine]", "opbasis_", ",", "basis_", ",", "opts___Rule"}], 
     "\[IndentingNewLine]", "]"}], "/;", 
    RowBox[{"MatchQ", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"OperatorType", "/.", 
        RowBox[{"{", "sopopts", "}"}]}], "/.", 
       RowBox[{"Options", "[", "Operator", "]"}]}], ",", 
      "\"\<AntiHermitian\>\""}], "]"}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{"MapAt", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"Times", "[", 
          RowBox[{"I", ",", "#"}], "]"}], "&"}], ",", "\[IndentingNewLine]", 
        RowBox[{"NDiagonalize", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"CommutationSuperoperator", "[", "\[IndentingNewLine]", 
