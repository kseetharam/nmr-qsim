Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"CombineSuperoperatorMatrixRepresentations", "[", 
     RowBox[{
      RowBox[{"ifunc_InterpolatingFunction", "[", "t_", "]"}], ",", 
      RowBox[{"mat_", "?", "MatrixQ"}]}], "]"}], "/;", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Depth", "[", "ifunc", "]"}], "\[GreaterEqual]", "3"}], ")"}], 
     "&&", "\[IndentingNewLine]", 
     RowBox[{"MatchQ", "[", 
      RowBox[{
       RowBox[{"ifunc", "[", 
        RowBox[{"ifunc", "\[LeftDoubleBracket]", 
         RowBox[{"1", ",", "1", ",", "1"}], "\[RightDoubleBracket]"}], "]"}], 
       ",", 
       RowBox[{"_", "?", "MatrixQ"}]}], "]"}]}]}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Replace", "[", 
     RowBox[{"ifunc", ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"m_", "?", "MatrixQ"}], "\[RuleDelayed]", 
        RowBox[{"m", "+", "mat"}]}], "}"}], ",", 
      RowBox[{"{", "3", "}"}]}], "]"}], "[", "t", "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{
  3.621161231681098*^9, {3.62116126441649*^9, 3.621161368191345*^9}, 
   3.621161498395927*^9, {3.621162466016517*^9, 3.6211624669937067`*^9}, 
   3.621243989819203*^9},
 CellLabel->
