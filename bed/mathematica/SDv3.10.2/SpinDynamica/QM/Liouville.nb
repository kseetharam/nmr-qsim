             ",", 
             RowBox[{"ZeemanBasis", "[", "spinsys", "]"}]}], "}"}]}], "]"}], "&&", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Depth", "[", "ifunc", "]"}], "\[GreaterEqual]", "3"}], 
          ")"}], "&&", "\[IndentingNewLine]", 
         RowBox[{"MatchQ", "[", 
          RowBox[{
           RowBox[{"ifunc", "[", 
            RowBox[{"ifunc", "\[LeftDoubleBracket]", 
             RowBox[{"1", ",", "1", ",", "1"}], "\[RightDoubleBracket]"}], 
            "]"}], ",", 
           RowBox[{"_", "?", "MatrixQ"}]}], "]"}]}]}], "\[IndentingNewLine]", 
       ")"}]}]}], "]"}]}], ";"}]], "Input",
