Cell[CellGroupData[{

Cell["\<\
case where the starting basis is the canonical ZeemanKetBraOperatorBasis, and \
the target basis is also in canonical order\
\>", "Subsection",
 CellChangeTimes->{{3.699624780254404*^9, 3.699624834164208*^9}, {
  3.699626011037663*^9, 3.699626011451573*^9}, {3.699626069086454*^9, 
