Cell[CellGroupData[{

Cell["check SuperoperatorType for diagonalization form", "Subsubsection",
 InitializationCell->True,
 CellChangeTimes->{{3.5861636308554487`*^9, 3.586163640398192*^9}, {
   3.58616368165716*^9, 3.5861636981218443`*^9}, 
