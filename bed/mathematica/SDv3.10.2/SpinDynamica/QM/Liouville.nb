Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"OperatorBasesMatchQ", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"opbasis2", ":", 
       RowBox[{"type_", "[", 
        RowBox[{
         RowBox[{"stuff", ":", 
          RowBox[{
           RowBox[{"Except", "[", "_Rule", "]"}], ".."}]}], ",", 
         "opb2opts___Rule"}], "]"}]}], ",", "\[IndentingNewLine]", 
