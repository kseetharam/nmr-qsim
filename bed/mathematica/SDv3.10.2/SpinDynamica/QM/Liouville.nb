Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"BasisOperators", "[", "\[IndentingNewLine]", 
     RowBox[{"SingletTripletOperatorBasis", "[", 
      RowBox[{"1", ",", 
       RowBox[{"spins", ":", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"_", ",", "_"}], "}"}], ".."}], "}"}]}], ",", 
       "opts___Rule"}], "]"}], "\[IndentingNewLine]", "]"}], "/;", 
    RowBox[{"MatchQ", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Sorted", "/.", 
        RowBox[{"{", "opts", "}"}]}], "/.", 
       RowBox[{"Options", "[", "SingletTripletOperatorBasis", "]"}]}], ",", 
      "CoherenceOrder"}], "]"}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "j", ",", "k", ",", "ket\[Alpha]\[Alpha]", ",", "ket\[Alpha]\[Beta]", 
       ",", "ket\[Beta]\[Alpha]", ",", "ket\[Beta]\[Beta]", ",", "ketS0", ",",
        "ketT1", ",", "ketT0", ",", "ketTm1", ",", "braS0", ",", "braT1", ",",
        "braT0", ",", "braTm1"}], "}"}], ",", 
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{"j", ",", "k"}], "}"}], "=", 
         RowBox[{"First", "/@", "spins"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "ket\[Alpha]\[Alpha]", ",", "ket\[Alpha]\[Beta]", ",", 
           "ket\[Beta]\[Alpha]", ",", "ket\[Beta]\[Beta]"}], "}"}], "=", 
         RowBox[{"Flatten", "@", 
          RowBox[{"Outer", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Ket", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"{", 
