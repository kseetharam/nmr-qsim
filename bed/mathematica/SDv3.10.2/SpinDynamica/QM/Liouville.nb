Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SuperoperatorMatrixRepresentation", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"head", ":", 
          RowBox[{"(", 
           RowBox[{
           "LeftMultiplicationSuperoperator", "|", 
            "RightMultiplicationSuperoperator"}], ")"}]}], ")"}], "[", 
        RowBox[{
         RowBox[{"HoldPattern", "@", 
          RowBox[{"Operator", "[", 
           RowBox[{
            RowBox[{"mat_", "?", "MatrixQ"}], ",", "zbasis_", ",", "___"}], 
           "]"}]}], ",", "___"}], "]"}], "]"}], "|", 
      RowBox[{"E", "^", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"head", ":", 
           RowBox[{"(", 
            RowBox[{
            "LeftMultiplicationSuperoperator", "|", 
             "RightMultiplicationSuperoperator"}], ")"}]}], ")"}], "[", 
         RowBox[{
          RowBox[{"HoldPattern", "@", 
           RowBox[{"Operator", "[", 
            RowBox[{
             RowBox[{"mat_", "?", "MatrixQ"}], ",", "zbasis_", ",", "___"}], 
            "]"}]}], ",", "___"}], "]"}], ")"}]}]}], ",", 
     "\[IndentingNewLine]", "opbasis_", ",", "zbasis_", ",", "opts___Rule"}], 
    "\[IndentingNewLine]", "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"spinsys", ",", "Emat"}], "}"}], ",", 
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Emat", "=", 
         RowBox[{"MatrixRepresentation", "[", 
          RowBox[{
           RowBox[{"UnityOperator", "[", "]"}], ",", "zbasis", ",", "opts"}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"MatchQ", "[", 
           RowBox[{"head", ",", "LeftMultiplicationSuperoperator"}], "]"}], 
          ",", 
          RowBox[{"SparseArray", "[", 
           RowBox[{"KroneckerProduct", "[", 
            RowBox[{
             RowBox[{"MatrixExp", "[", "mat", "]"}], ",", "Emat"}], "]"}], 
           "]"}], ",", 
          RowBox[{"SparseArray", "[", 
           RowBox[{"Transpose", "@", 
            RowBox[{"KroneckerProduct", "[", 
             RowBox[{
              RowBox[{"MatrixExp", "[", "Emat", "]"}], ",", "mat"}], "]"}]}], 
           "]"}]}], "]"}]}], "\[IndentingNewLine]", ")"}], "/;", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"spinsys", "=", 
         RowBox[{"SpinSystem", "[", "opbasis", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"MatchQ", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Method", "/.", 
             RowBox[{"{", "opts", "}"}]}], "/.", 
            RowBox[{
            "Options", "[", "SuperoperatorMatrixRepresentation", "]"}]}], ",",
            "Automatic"}], "]"}], "&&", "\[IndentingNewLine]", 
         RowBox[{"MatchQ", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"opbasis", ",", "zbasis"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"ZeemanKetBraOperatorBasis", "[", 
              RowBox[{"spinsys", ",", 
               RowBox[{"Sorted", "\[Rule]", "\"\<Canonical\>\""}]}], "]"}], 
             ",", 
             RowBox[{"ZeemanBasis", "[", "spinsys", "]"}]}], "}"}]}], 
          "]"}]}]}], "\[IndentingNewLine]", ")"}]}]}], "]"}]}], 
  ";"}]], "Input",
