         "opb1opts___Rule"}], "]"}]}]}], "\[IndentingNewLine]", "]"}], "/;", 
    RowBox[{
     RowBox[{"MatchQ", "[", 
      RowBox[{
       RowBox[{"Options", "[", "type", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"_Rule", "..."}], "}"}]}], "]"}], "&&", "\[IndentingNewLine]", 
     RowBox[{"MatchQ", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"First", "/@", 
          RowBox[{"Options", "[", "type", "]"}]}], ")"}], "/.", 
        RowBox[{"{", "opb2opts", "}"}]}], ",", " ", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"First", "/@", 
          RowBox[{"Options", "[", "type", "]"}]}], ")"}], "/.", 
        RowBox[{"{", "opb1opts", "}"}]}]}], "]"}]}]}], ":=", "True"}], 
