  RowBox[{
   RowBox[{"RightMultiplicationSuperoperator", "[", 
    RowBox[{"op_Operator", ",", "opts___Rule"}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"ass", ",", "optype", ",", "assoptype"}], "}"}], ",", 
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{"RightMultiplicationSuperoperator", "[", 
        RowBox[{"op", ",", "\[IndentingNewLine]", 
         RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"Assumptions", "\[Rule]", "None"}], ",", 
           "\[IndentingNewLine]", "opts"}], "\[IndentingNewLine]", "]"}]}], 
        "\[IndentingNewLine]", "]"}], "\[IndentingNewLine]", ")"}], "/;", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"ass", "=", 
         RowBox[{"Assumptions", "/.", 
          RowBox[{"{", "opts", "}"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"optype", "=", 
         RowBox[{
          RowBox[{"OperatorType", "/.", 
           RowBox[{"{", "opts", "}"}]}], "/.", 
          RowBox[{
          "Options", "[", "RightMultiplicationSuperoperator", "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"MatchQ", "[", 
          RowBox[{"ass", ",", 
           RowBox[{"{", 
            RowBox[{"_Rule", ".."}], "}"}]}], "]"}], "&&", 
         "\[IndentingNewLine]", 
         RowBox[{"!", 
          RowBox[{"MatchQ", "[", 
           RowBox[{"optype", ",", "Undefined"}], "]"}]}], "&&", 
         RowBox[{"(", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"assoptype", "=", 
            RowBox[{
             RowBox[{"OperatorType", "/.", "ass"}], "/.", 
             RowBox[{
             "Options", "[", "RightMultiplicationSuperoperator", "]"}]}]}], 
           ";", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"MatchQ", "[", 
             RowBox[{"assoptype", ",", "optype"}], "]"}], "||", 
            "\[IndentingNewLine]", 
