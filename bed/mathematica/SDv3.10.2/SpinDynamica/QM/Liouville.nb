     RowBox[{"opbasis2", ":", 
      RowBox[{"type_", "[", "___", "]"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"opbasis1", ":", 
      RowBox[{"type_", "[", "___", "]"}]}], ",", "\[IndentingNewLine]", 
     "basis_", ",", "opts___Rule"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"(", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Verbose", "/.", 
         RowBox[{"{", "opts", "}"}]}], "/.", 
        RowBox[{"Options", "[", "OperatorBasisTransformationMatrix", "]"}]}], 
       ",", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<using reordering of basis operators:\>\"", ",", 
         RowBox[{"{", 
          RowBox[{"opbasis2", ",", "opbasis1"}], "}"}]}], "]"}]}], 
      "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"PrependTo", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"DownValues", "[", "OperatorBasisTransformationMatrix", "]"}], 
       ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"OperatorBasisTransformationMatrix", "[", 
         RowBox[{"opbasis2", ",", "opbasis1", ",", "basis", ",", "___Rule"}], 
         "]"}], "\[Rule]", "\[IndentingNewLine]", 
        RowBox[{"SparseArray", "@", 
         RowBox[{"ReplacePart", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"DiagonalMatrix", "[", 
            RowBox[{"Table", "[", 
             RowBox[{"0", ",", 
              RowBox[{"{", 
               RowBox[{"OperatorBasisDimension", "[", "opbasis1", "]"}], 
               "}"}]}], "]"}], "]"}], ",", "\[IndentingNewLine]", 
           RowBox[{"Inner", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"#1", ",", "#2"}], "}"}], "\[Rule]", "1"}], ")"}], 
              "&"}], ",", "\[IndentingNewLine]", 
             RowBox[{"Ordering", "@", 
              RowBox[{"BasisOperators", "[", "opbasis2", "]"}]}], ",", 
             "\[IndentingNewLine]", 
             RowBox[{"Ordering", "@", 
              RowBox[{"BasisOperators", "[", "opbasis1", "]"}]}], ",", 
             "\[IndentingNewLine]", "List"}], "\[IndentingNewLine]", "]"}]}], 
          "\[IndentingNewLine]", "]"}]}]}]}], "\[IndentingNewLine]", "]"}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"OperatorBasisTransformationMatrix", "[", 
      RowBox[{"opbasis2", ",", "opbasis1", ",", "basis"}], "]"}]}], 
    "\[IndentingNewLine]", ")"}]}], ";"}]], "Input",
