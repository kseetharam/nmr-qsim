Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"DefaultOperatorBasis", "[", 
    RowBox[{"spinsys_", "?", "MatrixQ"}], "]"}], ":=", "\[IndentingNewLine]", 
   
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Max", "[", 
       RowBox[{"Last", "/@", "spinsys"}], "]"}], ">", 
      RowBox[{"3", "/", "2"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"ZeemanKetBraOperatorBasis", "[", 
      RowBox[{"spinsys", ",", 
       RowBox[{"Sorted", "\[Rule]", "\"\<Canonical\>\""}]}], "]"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"ShiftAndZOperatorBasis", "[", 
      RowBox[{"spinsys", ",", 
       RowBox[{"Sorted", "\[Rule]", "CoherenceOrder"}]}], "]"}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
 InitializationCell->True,
