a0721463a672"],

Cell["\<\
Use Liouville bracket and the relevant MatrixRepresentations of the \
operators. This should always work but can be slow. \
\>", "Text",
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.43523990199058*^9, 3.435239923027184*^9}, {
  3.435242362797196*^9, 
  3.435242373074333*^9}},ExpressionUUID->"a4ca7cbd-658d-4754-b7b7-\
c19b2ab25f1a"],

Cell["\<\
memorize the MatrixRepresentations of all BasisOperators since they will \
probably be needed again\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.5465340810987186`*^9, 3.546534105979957*^9}, {
  3.5465346795239058`*^9, 
  3.546534679914092*^9}},ExpressionUUID->"6f8ae18c-5acc-4a7f-8fe3-\
cca5e0a970d7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SuperoperatorMatrixRepresentation", "[", 
   RowBox[{"sop_", ",", "opbasis_", ",", "basis_", ",", "opts___Rule"}], 
   "]"}], ":=", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "n", "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"n", "=", 
        RowBox[{"OperatorBasisDimension", "[", "opbasis", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"FreeQ", "[", 
            RowBox[{"#", ",", "$Failed"}], "]"}], ",", 
           RowBox[{"SparseArray", "[", "#", "]"}], ",", "$Failed"}], "]"}], 
         "&"}], "@", "\[IndentingNewLine]", 
        RowBox[{"Table", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"FixedPoint", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"ExpToTrig", "[", 
              RowBox[{"PowerExpand", "[", 
               RowBox[{"Simplify", "[", "#", "]"}], "]"}], "]"}], "&"}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"LiouvilleBracket", "[", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{
               RowBox[{"BasisOperatorMatrixRepresentations", "[", 
                RowBox[{"opbasis", ",", "basis"}], "]"}], 
               "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}], ",", 
              "\[IndentingNewLine]", 
              RowBox[{"MatrixRepresentation", "[", 
               RowBox[{
                RowBox[{"sop", "[", 
                 RowBox[{
                  RowBox[{"BasisOperators", "[", "opbasis", "]"}], 
                  "\[LeftDoubleBracket]", "j", "\[RightDoubleBracket]"}], 
                 "]"}], ",", "basis"}], "]"}]}], "\[IndentingNewLine]", 
             "]"}]}], "\[IndentingNewLine]", "]"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", "n"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"j", ",", "1", ",", "n"}], "}"}]}], "\[IndentingNewLine]", 
         "]"}]}]}], "\[IndentingNewLine]", ")"}]}], "]"}], "/;", 
   RowBox[{"MatchQ", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Method", "/.", 
       RowBox[{"{", "opts", "}"}]}], "/.", 
      RowBox[{"Options", "[", "SuperoperatorMatrixRepresentation", "]"}]}], 
     ",", "\"\<Direct\>\""}], "]"}]}]}]], "Input",
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.430456036023714*^9, 3.43045611027256*^9}, {
   3.430565075055227*^9, 3.430565077965583*^9}, {3.430566896470188*^9, 
