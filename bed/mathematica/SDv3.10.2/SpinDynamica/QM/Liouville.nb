Cell[CellGroupData[{

Cell["LiouvilleBracket", "Section",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{
  3.605545643975979*^9, {3.682608729600243*^9, 3.682608750011409*^9}, {
   3.682608922627829*^9, 3.682608926620495*^9}, {3.682608991087707*^9, 
   3.682608997095499*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"fed9a1f9-fc91-421a-8eb8-d4d2f2f1a967"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"LiouvilleBracket", "::", "usage"}], "=", "\[IndentingNewLine]", 
   "\"\<LiouvilleBracket[A,B,opbasis,basis,options] calculates the bracket \
Tr(\!\(\*SuperscriptBox[\(A\), \(\[Dagger]\)]\).B) using the specified \
Hilbert basis. The operator basis opbasis and Hilbert basis basis are used: \
If these are missing, the current OperatorBasis[] and Basis[] are used. \nThe \
option Normalize\[Rule]True normalizes both operators before taking the \
bracket. The default is Normalize->False.\n\
LiouvilleBracket[A,sop,B,opbasis,basis,options] calculates the bracket \
Tr(\!\(\*SuperscriptBox[\(A\), \(\[Dagger]\)]\).sop[B]) where sop is a \
superoperator. The operator basis opbasis and Hilbert basis basis are used: \
If these are missing, the current OperatorBasis[] and Basis[] are used. The \
option Normalize->True normalizes both operators before taking the bracket. \
The default is Normalize->False.\n\>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.430894718371416*^9, 3.430894745387373*^9}, {
  3.449235021671195*^9, 3.449235029419876*^9}, {3.472112647166668*^9, 
  3.472112652652694*^9}, {3.472112696494695*^9, 3.47211270138532*^9}, {
  3.533043810096947*^9, 3.533043852487866*^9}, {3.682607836052731*^9, 
  3.682607837835514*^9}, {3.682607923668349*^9, 3.682607945131767*^9}, {
  3.682608974447358*^9, 3.6826089754952173`*^9}, {3.699434680685896*^9, 
  3.699434691124462*^9}},
 CellLabel->
  "In[146]:=",ExpressionUUID->"fd743d87-71ef-4733-8523-d24f519bcdcd"]
}, Closed]],

Cell[CellGroupData[{

Cell["OperatorAmplitude", "Section",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.501995058791401*^9, 3.5019950653257504`*^9}, 
   3.502322836563464*^9},
 AspectRatioFixed->
  True,ExpressionUUID->"a1b95aed-c89b-454d-92ee-1f3787f74cf2"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"OperatorAmplitude", "::", "usage"}], "=", "\[IndentingNewLine]", 
   "\"\<OperatorAmplitude[op1\[Rule]op2] provides the answer to a question of \
the form: \\\"How much of operator op2 is contained in operator op1?\\\".\n\
Formally, OperatorAmplitude[op1\[Rule]op2] returns the amplitude a, such that \
op1\[NonBreakingSpace]=\[NonBreakingSpace]a\[Cross]op2\[NonBreakingSpace]+\
\[NonBreakingSpace](operators orthogonal to op2).\nThe amplitude is given by \
the following expression: \
a\[NonBreakingSpace]=\[NonBreakingSpace](op2|op1)/(op2|op2) where (A|B)=Tr{\!\
\(\*SuperscriptBox[\(A\), \(\[Dagger]\)]\)B} is a Liouville bracket.\nThe \
syntax OperatorAmplitude[op2,op1] is equivalent to OperatorAmplitude[op1\
\[Rule]op2].\>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.430894718371416*^9, 3.430894745387373*^9}, {
  3.449235021671195*^9, 3.449235029419876*^9}, {3.472112647166668*^9, 
  3.472112652652694*^9}, {3.472112696494695*^9, 3.47211270138532*^9}, {
  3.501995069112587*^9, 3.501995290225147*^9}, {3.501995383402261*^9, 
  3.501995461658272*^9}, {3.501996544469832*^9, 3.501996555575652*^9}, {
  3.502012009191866*^9, 3.502012084917433*^9}, {3.502322838607835*^9, 
  3.502322840424123*^9}, {3.533176513272941*^9, 3.53317653980025*^9}, {
  3.674623574576624*^9, 3.674623921973181*^9}, {3.674623985884865*^9, 
  3.674624147969195*^9}, {3.674624182959946*^9, 3.674624187679563*^9}},
 CellLabel->
  "In[147]:=",ExpressionUUID->"11b03dc5-a773-423d-8c72-3af98db6c873"]
}, Closed]],

