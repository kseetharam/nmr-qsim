Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SphericalTensorIndices", "[", 
    RowBox[{"op_", "?", "OperatorQ"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "opvecrep", ",", "stob", ",", "stob\[Lambda]\[Mu]vals", ",", 
       "\[Lambda]\[Mu]vals"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"stob", "=", 
        RowBox[{"SphericalTensorOperatorBasis", "[", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"stob\[Lambda]\[Mu]vals", "=", 
        RowBox[{"SphericalTensorIndices", "[", "stob", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"opvecrep", "=", 
        RowBox[{"OperatorVectorRepresentation", "[", 
         RowBox[{"op", ",", "stob"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Length", "[", "#", "]"}], "\[Equal]", "1"}], ",", 
           RowBox[{"First", "[", "#", "]"}], ",", "#"}], "]"}], "&"}], "@", 
        "\[IndentingNewLine]", 
        RowBox[{"Union", "@", 
         RowBox[{"Pick", "[", 
          RowBox[{"stob\[Lambda]\[Mu]vals", ",", "opvecrep", ",", 
           RowBox[{"_", "?", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"Chop", "@", 
                RowBox[{"Expand", "[", "#", "]"}]}], "\[NotEqual]", "0"}], 
              "&"}], ")"}]}]}], "]"}]}]}]}], "\[IndentingNewLine]", ")"}]}], 
    "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.639287281767623*^9, 3.639287605218351*^9}, {
