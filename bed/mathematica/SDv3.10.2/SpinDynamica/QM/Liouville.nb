Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"OperatorBasisTransformationMatrix", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"opbasis2", ":", 
       RowBox[{"type2_", "[", 
        RowBox[{
         RowBox[{"stuff2", ":", 
          RowBox[{
           RowBox[{"Except", "[", "_Rule", "]"}], ".."}]}], ",", 
         "opb2opts___Rule"}], "]"}]}], ",", 
      RowBox[{"opbasis1", ":", 
       RowBox[{"type1_", "[", 
        RowBox[{
         RowBox[{"stuff1", ":", 
          RowBox[{
           RowBox[{"Except", "[", "_Rule", "]"}], ".."}]}], ",", 
         "opb1opts___Rule"}], "]"}]}], ",", "\[IndentingNewLine]", "basis_", 
      ",", "opts___Rule"}], "\[IndentingNewLine]", "]"}], "/;", 
    RowBox[{
     RowBox[{"MemberQ", "[", 
      RowBox[{
       RowBox[{"AllowedSortValues", "[", "opbasis2", "]"}], ",", 
       "\"\<OrderBySpin\>\""}], "]"}], "&&", "\[IndentingNewLine]", 
     RowBox[{"MemberQ", "[", 
      RowBox[{
       RowBox[{"AllowedSortValues", "[", "opbasis1", "]"}], ",", 
       "\"\<OrderBySpin\>\""}], "]"}], "&&", 
     RowBox[{"(", 
      RowBox[{"!", 
       RowBox[{"MatchQ", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Sorted", "/.", 
           RowBox[{"{", "opb2opts", "}"}]}], "/.", 
          RowBox[{"Options", "[", "type2", "]"}]}], ",", 
         "\"\<OrderBySpin\>\""}], "]"}]}], ")"}], "&&", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Length", "[", 
        RowBox[{"SpinSystem", "[", "opbasis2", "]"}], "]"}], ">", "1"}], 
      ")"}]}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "iopbasis", ",", "orderopbasis2", ",", "orderiopbasis", ",", "perm"}], 
      "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Verbose", "/.", 
           RowBox[{"{", "opts", "}"}]}], "/.", 
          RowBox[{
          "Options", "[", "OperatorBasisTransformationMatrix", "]"}]}], ",", 
         RowBox[{"Print", "[", 
          RowBox[{"\"\<setting up OrderBySpin (1):\>\"", ",", 
           RowBox[{"{", 
            RowBox[{"opbasis2", ",", "opbasis1"}], "}"}]}], "]"}]}], 
        "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"iopbasis", "=", "\[IndentingNewLine]", 
        RowBox[{"type2", "[", 
         RowBox[{"stuff2", ",", "\[IndentingNewLine]", 
          RowBox[{"SimplifyRules", "[", 
           RowBox[{
            RowBox[{"Sorted", "\[Rule]", "\"\<OrderBySpin\>\""}], ",", 
            "opb2opts"}], "]"}]}], "\[IndentingNewLine]", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"orderopbasis2", "=", 
        RowBox[{"Ordering", "[", 
         RowBox[{"BasisOperators", "[", "opbasis2", "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"orderiopbasis", "=", 
        RowBox[{"Ordering", "[", 
         RowBox[{"BasisOperators", "[", "iopbasis", "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"perm", "=", 
        RowBox[{"orderiopbasis", "\[LeftDoubleBracket]", 
         RowBox[{"InversePermutation", "[", "orderopbasis2", "]"}], 
         "\[RightDoubleBracket]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"PrependTo", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
         "DownValues", "[", "OperatorBasisTransformationMatrix", "]"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"OperatorBasisTransformationMatrix", "[", 
           RowBox[{
           "opbasis2", ",", "opbasis1", ",", "basis", ",", "___Rule"}], "]"}],
           "\[Rule]", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"OperatorBasisTransformationMatrix", "[", 
            RowBox[{"iopbasis", ",", "opbasis1", ",", "basis", ",", "opts"}], 
            "]"}], "\[LeftDoubleBracket]", "perm", 
           "\[RightDoubleBracket]"}]}]}], "\[IndentingNewLine]", "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"OperatorBasisTransformationMatrix", "[", 
        RowBox[{"opbasis2", ",", "opbasis1", ",", "basis"}], "]"}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
