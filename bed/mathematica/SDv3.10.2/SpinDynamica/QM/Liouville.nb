Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SphericalComponentFiltrationSuperoperator", "[", 
    RowBox[{"{", 
     RowBox[{"\[Lambda]_", ",", "\[Mu]2_", ",", "\[Mu]1_"}], "}"}], "]"}], ":=",
    "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "nspin", ",", "\[CapitalLambda]", ",", "ops2", ",", "ops1", ",", 
       "oppairs"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"nspin", "=", 
        RowBox[{"Length", "[", 
         RowBox[{"SpinSystem", "[", "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"\[CapitalLambda]", "=", 
        RowBox[{"Cases", "[", 
         RowBox[{
          RowBox[{"Subsets", "[", 
           RowBox[{
            RowBox[{"First", "/@", 
             RowBox[{"SpinSystem", "[", "]"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"\[Lambda]", ",", "nspin"}], "}"}]}], "]"}], ",", 
          RowBox[{"Except", "[", 
           RowBox[{"{", "}"}], "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Off", "[", 
        RowBox[{"opT", "::", "multiple"}], "]"}], ";", "\[IndentingNewLine]", 
       
       RowBox[{"ops2", "=", 
        RowBox[{"Union", "@", 
         RowBox[{"Flatten", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"opT", "[", 
             RowBox[{"#", ",", 
              RowBox[{"{", 
               RowBox[{"\[Lambda]", ",", "\[Mu]2"}], "}"}], ",", 
              RowBox[{"Normalize", "\[Rule]", "True"}]}], "]"}], "&"}], "/@", 
           "\[CapitalLambda]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"ops1", "=", 
        RowBox[{"Union", "@", 
         RowBox[{"Flatten", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"opT", "[", 
             RowBox[{"#", ",", 
              RowBox[{"{", 
               RowBox[{"\[Lambda]", ",", "\[Mu]1"}], "}"}], ",", 
              RowBox[{"Normalize", "\[Rule]", "True"}]}], "]"}], "&"}], "/@", 
           "\[CapitalLambda]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"oppairs", "=", 
        RowBox[{"Transpose", "[", 
         RowBox[{"{", 
          RowBox[{"ops2", ",", "ops1"}], "}"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"On", "[", 
        RowBox[{"opT", "::", "multiple"}], "]"}], ";", "\[IndentingNewLine]", 
       
       RowBox[{"If", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"MatchQ", "[", 
           RowBox[{"ops2", ",", 
            RowBox[{"{", "}"}]}], "]"}], "||", 
          RowBox[{"MatchQ", "[", 
           RowBox[{"ops1", ",", 
            RowBox[{"{", "}"}]}], "]"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"NullSuperoperator", "[", "]"}], ",", "\[IndentingNewLine]", 
         
         RowBox[{"Plus", "@@", "\[IndentingNewLine]", 
          RowBox[{"MapThread", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{
             RowBox[{"ShiftSuperoperator", "[", 
              RowBox[{"#1", ",", "#2"}], "]"}], "&"}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"{", 
             RowBox[{"ops2", ",", "ops1"}], "}"}]}], "\[IndentingNewLine]", 
           "]"}]}]}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
      ")"}]}], "]"}]}], ";"}]], "Input",
 PageWidth:>WindowWidth,
