Cell[CellGroupData[{

Cell["\<\
transform into \
ZeemanKetBraOperatorBasis[Sorted\[Rule]\[CloseCurlyDoubleQuote]Canonical\
\[CloseCurlyDoubleQuote]] and ZeemanBasis[]\
\>", "Subsubsection",
 InitializationCell->True,
 CellChangeTimes->{{3.586193070859205*^9, 3.586193084970389*^9}, {
   3.586193118562601*^9, 3.586193148029195*^9}, {3.586193317993219*^9, 
   3.586193320584287*^9}, 3.586193356273401*^9, {3.586194083280962*^9, 
   3.58619408751025*^9}},ExpressionUUID->"cfe48c32-aa3c-49bd-8266-\
becb45bc6450"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"NDiagonalize", "[", 
    RowBox[{
    "csop_CommutationSuperoperator", ",", "opbasis_", ",", "basis_", ",", 
     "opts___Rule"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "X\[CapitalLambda]Xinv", ",", "X", ",", "evals", ",", "Xinv", ",", 
       "zkbop", ",", "zb"}], "}"}], ",", 
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"X\[CapitalLambda]Xinv", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"!", 
              RowBox[{"FreeQ", "[", 
               RowBox[{"#", ",", "$Failed"}], "]"}]}], ",", "$Failed", ",", 
             RowBox[{"First", "[", "#", "]"}]}], "]"}], "&"}], "@", 
          "\[IndentingNewLine]", 
          RowBox[{"NDiagonalize", "[", 
           RowBox[{"csop", ",", "zkbop", ",", "zb", ",", "opts"}], "]"}]}]}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"!", 
           RowBox[{"FreeQ", "[", 
            RowBox[{"X\[CapitalLambda]Xinv", ",", "$Failed"}], "]"}]}], ",", 
          "\[IndentingNewLine]", "$Failed", ",", "\[IndentingNewLine]", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"{", 
              RowBox[{"X", ",", "evals", ",", "Xinv"}], "}"}], "=", 
             "X\[CapitalLambda]Xinv"}], ";", "\[IndentingNewLine]", 
            RowBox[{"Superoperator", "[", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{"SparseArray", "@", 
                 RowBox[{"Chop", "@", 
                  RowBox[{"Expand", "[", 
                   RowBox[{
                    RowBox[{"OperatorBasisTransformationMatrix", "[", 
                    RowBox[{"opbasis", ",", "zkbop"}], "]"}], ".", "X"}], 
                   "]"}]}]}], ",", "\[IndentingNewLine]", "evals", ",", 
                "\[IndentingNewLine]", 
                RowBox[{"SparseArray", "@", 
                 RowBox[{"Chop", "@", 
                  RowBox[{"Expand", "[", 
                   RowBox[{"Xinv", ".", 
                    RowBox[{"OperatorBasisTransformationMatrix", "[", 
                    RowBox[{"zkbop", ",", "opbasis"}], "]"}]}], "]"}]}]}]}], 
               "}"}], ",", "\[IndentingNewLine]", "opbasis", ",", "zb", ",", 
              "opts"}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]",
            ")"}]}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
       ")"}], "/;", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"zkbop", "=", 
         RowBox[{"ZeemanKetBraOperatorBasis", "[", 
          RowBox[{"Sorted", "\[Rule]", "\"\<Canonical\>\""}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"zb", "=", 
         RowBox[{"ZeemanBasis", "[", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"!", 
           RowBox[{"MatchQ", "[", 
            RowBox[{"opbasis", ",", "zkbop"}], "]"}]}], ")"}], "||", 
         RowBox[{"(", 
          RowBox[{"!", 
           RowBox[{"MatchQ", "[", 
            RowBox[{"basis", ",", "zb"}], "]"}]}], ")"}]}]}], 
       "\[IndentingNewLine]", ")"}]}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
