   3.8379460432705173`*^9, 3.837946181620122*^9}, {3.837946218654379*^9, 
   3.837946362990079*^9}, {3.837946451207546*^9, 3.837946489183086*^9}, {
   3.83794652258879*^9, 
   3.837946526750829*^9}},ExpressionUUID->"0e1e1b2a-507d-4c8d-8a87-\
e166c42a12da"]
}, Closed]],

