  3.586346819231881*^9}},ExpressionUUID->"b5254597-100b-423f-88a6-\
3226059ac608"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"RightMultiplicationSuperoperator", "[", 
    RowBox[{"op_Operator", ",", "opts___Rule"}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"ass", ",", "optype", ",", "assoptype"}], "}"}], ",", 
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Message", "[", 
         RowBox[{
          RowBox[{"RightMultiplicationSuperoperator", "::", "badass"}], ",", 
          "assoptype", ",", "optype"}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"RightMultiplicationSuperoperator", "[", 
         RowBox[{"op", ",", "\[IndentingNewLine]", 
          RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"Assumptions", "\[Rule]", "None"}], ",", 
            "\[IndentingNewLine]", "opts"}], "\[IndentingNewLine]", "]"}]}], 
         "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", ")"}], "/;", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"ass", "=", 
         RowBox[{"Assumptions", "/.", 
          RowBox[{"{", "opts", "}"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"optype", "=", 
         RowBox[{
          RowBox[{"OperatorType", "/.", 
           RowBox[{"{", "opts", "}"}]}], "/.", 
          RowBox[{
          "Options", "[", "RightMultiplicationSuperoperator", "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"MatchQ", "[", 
          RowBox[{"ass", ",", 
           RowBox[{"{", 
            RowBox[{"_Rule", ".."}], "}"}]}], "]"}], "&&", 
         "\[IndentingNewLine]", 
         RowBox[{"!", 
          RowBox[{"MatchQ", "[", 
           RowBox[{"optype", ",", "Undefined"}], "]"}]}], "&&", 
         RowBox[{"(", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"assoptype", "=", 
            RowBox[{
             RowBox[{"OperatorType", "/.", "ass"}], "/.", 
             RowBox[{
             "Options", "[", "RightMultiplicationSuperoperator", "]"}]}]}], 
           ";", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"!", 
             RowBox[{"MatchQ", "[", 
              RowBox[{"assoptype", ",", "optype"}], "]"}]}], "&&", 
            "\[IndentingNewLine]", 
            RowBox[{"!", 
             RowBox[{"MatchQ", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"optype", ",", "assoptype"}], "}"}], ",", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{
                 "\"\<Hermitian\>\"", "|", "\"\<AntiHermitian\>\"", "|", 
                  "\"\<Unitary\>\""}], ",", "\"\<Normal\>\""}], "}"}]}], 
              "]"}]}]}]}], "\[IndentingNewLine]", ")"}]}]}], 
       "\[IndentingNewLine]", ")"}]}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.586346832228771*^9, 3.58634695183791*^9}, {
