Cell["\<\
If NDiagonalize is used with Assumptions\[Rule]Automatic, the \
SuperoperatorType is used to determine the assumptions for \
OrthogonalEigenvectors. \
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.586082960337178*^9, 3.586082993483173*^9}, {
  3.586090567954957*^9, 
  3.586090569016633*^9}},ExpressionUUID->"630cc393-b060-4417-a5fb-\
4e2fde8715ed"],

Cell["\<\
If NDiagonalize is used with Assumptions\[Rule]{a\[Rule]b..}, or Assumptions\
\[Rule]None or False, these rules supersede any based on the \
SuperoperatorType.\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.586082960337178*^9, 3.586082993483173*^9}, {
   3.58608341045536*^9, 3.586083433732214*^9}, {3.586083500890614*^9, 
