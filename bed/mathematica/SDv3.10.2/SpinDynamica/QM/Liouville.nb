        RowBox[{"Emat", "=", 
         RowBox[{"MatrixRepresentation", "[", 
          RowBox[{
           RowBox[{"UnityOperator", "[", "]"}], ",", "basis", ",", "opts"}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Replace", "[", 
          RowBox[{"ifunc", ",", "\[IndentingNewLine]", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"mat_", "?", "MatrixQ"}], "\[RuleDelayed]", 
             RowBox[{
              RowBox[{"KroneckerProduct", "[", 
               RowBox[{"mat", ",", "Emat"}], "]"}], "-", 
              RowBox[{"Transpose", "@", 
               RowBox[{"KroneckerProduct", "[", 
                RowBox[{"Emat", ",", "mat"}], "]"}]}]}]}], "}"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"{", "3", "}"}]}], "\[IndentingNewLine]", "]"}], "[", "t", 
