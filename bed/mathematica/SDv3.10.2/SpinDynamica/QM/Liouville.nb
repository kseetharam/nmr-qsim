   3.586083904669049*^9}, {3.58608460907589*^9, 3.586084617680365*^9}, {
   3.586084736209659*^9, 3.586084755345783*^9}, {3.586084803159905*^9, 
   3.586084804820221*^9}, {3.586090580929549*^9, 3.586090679662564*^9}, 
   3.640411430291793*^9, {3.816842857799325*^9, 3.816842876164626*^9}, {
   3.8378369842279053`*^9, 3.837836984511805*^9}, {3.837944898094672*^9, 
   3.8379449025355864`*^9}, {3.837945480333064*^9, 3.837945567195373*^9}, {
