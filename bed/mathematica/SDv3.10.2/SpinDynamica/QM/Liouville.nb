   3.699455175741175*^9, 3.699455223145372*^9}, {3.699458493118952*^9, 
   3.699458494091868*^9}, 3.7093969306199493`*^9, 3.709397254454746*^9},
 CellLabel->
  "In[191]:=",ExpressionUUID->"d4029c59-371f-4704-967c-2c25bc6af83e"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"DefineOperatorBasis", "[", 
    RowBox[{"newopbasis_", ",", 
     RowBox[{"opbasis_", "?", "DefinedOperatorBasisQ"}], ",", 
     RowBox[{"sop_", "?", "SuperoperatorQ"}], ",", 
     RowBox[{"ordering", ":", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Except", "[", 
         RowBox[{"_", "?", "OperatorQ"}], "]"}], ".."}], "}"}]}], ",", 
     "opts___Rule"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"spinsys", ",", "basis", ",", "permmat", ",", "NL"}], "}"}], 
     ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"spinsys", "=", 
        RowBox[{"SpinSystem", "[", "opbasis", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"basis", "=", 
        RowBox[{"ZeemanBasis", "[", "spinsys", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"NL", "=", 
        RowBox[{"OperatorBasisDimension", "[", "opbasis", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"BasisOperators", "[", "newopbasis", "]"}], "=", 
        RowBox[{
         RowBox[{
          RowBox[{"ExpressOperator", "[", 
           RowBox[{
            RowBox[{"sop", "[", "#", "]"}], ",", "opbasis"}], "]"}], "&"}], "/@", 
         RowBox[{
          RowBox[{"BasisOperators", "[", "opbasis", "]"}], 
          "\[LeftDoubleBracket]", "ordering", "\[RightDoubleBracket]"}]}]}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"permmat", "=", 
        RowBox[{"SparseArray", "@", 
         RowBox[{"ReplacePart", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"DiagonalMatrix", "[", 
            RowBox[{"Table", "[", 
             RowBox[{"0", ",", 
              RowBox[{"{", "NL", "}"}]}], "]"}], "]"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"Inner", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"#1", ",", "#2"}], "}"}], "\[Rule]", "1"}], ")"}], 
              "&"}], ",", "ordering", ",", 
             RowBox[{"Range", "[", 
              RowBox[{"1", ",", "NL"}], "]"}], ",", "List"}], "]"}]}], 
          "\[IndentingNewLine]", "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"OperatorBasisTransformationMatrix", "[", 
         RowBox[{"newopbasis", ",", "opbasis", ",", "basis"}], "]"}], "=", 
        "\[IndentingNewLine]", 
        RowBox[{"permmat", ".", 
         RowBox[{"Adjoint", "@", 
          RowBox[{"SuperoperatorMatrixRepresentation", "[", 
           RowBox[{"sop", ",", "opbasis", ",", "basis"}], "]"}]}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"IntermediateOperatorBasis", "[", "newopbasis", "]"}], "=", 
        "opbasis"}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"CheckOperatorBasis", "[", "newopbasis", "]"}], "=", 
        RowBox[{
         RowBox[{"CheckOperatorBasis", "[", "opbasis", "]"}], "&&", 
         RowBox[{"UnitaryMatrixQ", "@", 
          RowBox[{"SuperoperatorMatrixRepresentation", "[", 
           RowBox[{"sop", ",", "opbasis"}], "]"}]}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"SetOptions", "[", "\[IndentingNewLine]", 
        RowBox[{"UnassignedSymbols", ",", "\[IndentingNewLine]", 
         RowBox[{"PermittedSymbols", "->", 
          RowBox[{"AppendTo", "[", 
           RowBox[{
            RowBox[{"PermittedSymbols", "/.", 
             RowBox[{"Options", "[", "UnassignedSymbols", "]"}]}], ",", 
            "newopbasis"}], "]"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"DefinedOperatorBasisQ", "[", "newopbasis", "]"}], "=", 
        "True"}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"SpinSystem", "[", "newopbasis", "]"}], "^=", 
