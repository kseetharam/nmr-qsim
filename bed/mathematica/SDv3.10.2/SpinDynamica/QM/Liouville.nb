  RowBox[{
   RowBox[{"UnitySuperoperator", "/:", 
    RowBox[{
     RowBox[{"HoldPattern", "@", 
      RowBox[{"Plus", "[", 
       RowBox[{"n1___", ",", 
        RowBox[{"UnitySuperoperator", "[", "___", "]"}], ",", "n2___"}], 
       "]"}]}], "/;", "\[IndentingNewLine]", 
     RowBox[{"!", 
      RowBox[{"And", "@@", 
