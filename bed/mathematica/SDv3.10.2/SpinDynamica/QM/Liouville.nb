Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"NDiagonalize", "[", 
    RowBox[{
     RowBox[{"Superoperator", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"X_", "?", "MatrixQ"}], ",", "evals_List", ",", 
         RowBox[{"Xinv_", "?", "MatrixQ"}]}], "}"}], ",", "opbasis1_", ",", 
       "basis1_", ",", "sopopts___Rule"}], "]"}], ",", "opbasis2_", ",", 
     "basis2_", ",", "opts___Rule"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Superoperator", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Chop", "@", 
        RowBox[{"Expand", "[", 
         RowBox[{
          RowBox[{"OperatorBasisTransformationMatrix", "[", 
           RowBox[{"opbasis2", ",", "opbasis1"}], "]"}], ".", "X"}], "]"}]}], 
       ",", "\[IndentingNewLine]", "evals", ",", "\[IndentingNewLine]", 
