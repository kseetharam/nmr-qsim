Cell["handling of dot products", "Subsubsection",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.4545739764606113`*^9, 
  3.454573978922975*^9}},ExpressionUUID->"50b30d0a-ceac-489e-9380-\
d1a2dd9f96c4"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"HoldPattern", "@", 
    RowBox[{"SuperoperatorMatrixRepresentation", "[", 
     RowBox[{
      RowBox[{"Dot", "[", 
       RowBox[{"sops", ":", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"_", "?", "SuperoperatorQ"}], ".."}], ")"}]}], "]"}], ",", 
      "opbasis_", ",", "basis_", ",", "opts___Rule"}], "]"}]}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "matreps", "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"matreps", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"SuperoperatorMatrixRepresentation", "[", 
           RowBox[{"#", ",", "opbasis", ",", "basis", ",", "opts"}], "]"}], 
          "&"}], "/@", 
         RowBox[{"{", "sops", "}"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "matreps", "]"}], "\[Equal]", "1"}], ",", 
         RowBox[{"First", "@", "matreps"}], ",", 
         RowBox[{"Fold", "[", 
          RowBox[{"Dot", ",", 
           RowBox[{"First", "@", "matreps"}], ",", 
           RowBox[{"Drop", "[", 
            RowBox[{"matreps", ",", "1"}], "]"}]}], "]"}]}], 
        "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", ")"}]}], 
    "]"}]}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
