Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Superoperator", "[", 
    RowBox[{
     RowBox[{"sopmat_", "?", "MatrixQ"}], ",", "opbasis_", ",", "basis_", ",",
      "opts___Rule"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Superoperator", "[", "\[IndentingNewLine]", 
     RowBox[{
     "sopmat", ",", "opbasis", ",", "basis", ",", "\[IndentingNewLine]", 
      RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"SuperoperatorType", "\[Rule]", 
         RowBox[{"Which", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"HermitianQ", "[", "sopmat", "]"}], ",", 
           "\"\<Hermitian\>\"", ",", "\[IndentingNewLine]", 
           RowBox[{"AntiHermitianQ", "[", "sopmat", "]"}], ",", 
           "\"\<AntiHermitian\>\"", ",", "\[IndentingNewLine]", 
           RowBox[{"UnitaryQ", "[", 
            RowBox[{"N", "@", "sopmat"}], "]"}], ",", "\"\<Unitary\>\"", ",", 
           "\[IndentingNewLine]", 
           RowBox[{"NormalQ", "[", 
            RowBox[{"N", "@", "sopmat"}], "]"}], ",", "\"\<Normal\>\"", ",", 
           "\[IndentingNewLine]", "True", ",", "None"}], "]"}]}], ",", 
        "\[IndentingNewLine]", "opts"}], "\[IndentingNewLine]", "]"}]}], 
     "\[IndentingNewLine]", "]"}], "/;", 
    RowBox[{"(", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"MatchQ", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{"CheckSuperoperatorType", ",", "SuperoperatorType"}], 
           "}"}], "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "Superoperator", "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"True", ",", "Undefined"}], "}"}]}], "]"}], "&&", 
      "\[IndentingNewLine]", 
      RowBox[{"NumericMatrixQ", "[", "sopmat", "]"}]}], "\[IndentingNewLine]",
      ")"}]}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.583432407146059*^9, 3.583432543452914*^9}, {
