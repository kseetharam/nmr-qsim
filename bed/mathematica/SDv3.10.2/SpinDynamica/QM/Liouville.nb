Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"OperatorVectorRepresentation", "[", 
    RowBox[{"op_", ",", "opbasis_", ",", "basis_", ",", "opts___Rule"}], 
    "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "spinsys", "}"}], ",", 
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{"SparseArray", "@", 
        RowBox[{"Flatten", "@", 
         RowBox[{"MatrixRepresentation", "[", 
          RowBox[{"op", ",", "basis"}], "]"}]}]}], "\[IndentingNewLine]", 
       ")"}], "/;", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"spinsys", "=", 
         RowBox[{"SpinSystem", "[", "opbasis", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"MatchQ", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Method", "/.", 
             RowBox[{"{", "opts", "}"}]}], "/.", 
            RowBox[{"Options", "[", "OperatorVectorRepresentation", "]"}]}], 
           ",", "Automatic"}], "]"}], "&&", "\[IndentingNewLine]", 
         RowBox[{"MatchQ", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"opbasis", ",", "basis"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"ZeemanKetBraOperatorBasis", "[", 
              RowBox[{"spinsys", ",", 
               RowBox[{"Sorted", "\[Rule]", "\"\<Canonical\>\""}]}], "]"}], 
             ",", 
             RowBox[{"ZeemanBasis", "[", "spinsys", "]"}]}], "}"}]}], 
          "]"}]}]}], "\[IndentingNewLine]", ")"}]}]}], "]"}]}], 
