Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"HoldPattern", "@", 
    RowBox[{"SuperoperatorMatrixRepresentation", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"sop", ":", 
       RowBox[{"RotationSuperoperator", "[", "args___", "]"}]}], ",", 
      "\[IndentingNewLine]", "opbasis_", ",", "basis_", ",", "opts___Rule"}], 
     "\[IndentingNewLine]", "]"}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"spinsys", ",", "Rmat"}], "}"}], ",", 
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Rmat", "=", 
         RowBox[{"MatrixRepresentation", "[", 
          RowBox[{
           RowBox[{"RotationOperator", "[", "args", "]"}], ",", "basis", ",", 
           "opts"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"SparseArray", "@", 
         RowBox[{"ComplexExpand", "@", 
          RowBox[{"Normal", "[", 
           RowBox[{"KroneckerProduct", "[", 
            RowBox[{"Rmat", ",", 
             RowBox[{"Conjugate", "@", "Rmat"}]}], "]"}], "]"}]}]}]}], 
       "\[IndentingNewLine]", ")"}], "/;", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"spinsys", "=", 
         RowBox[{"SpinSystem", "[", "opbasis", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"MatchQ", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Method", "/.", 
             RowBox[{"{", "opts", "}"}]}], "/.", 
            RowBox[{
            "Options", "[", "SuperoperatorMatrixRepresentation", "]"}]}], ",",
            "Automatic"}], "]"}], "&&", "\[IndentingNewLine]", 
         RowBox[{"MatchQ", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"opbasis", ",", "basis"}], "}"}], ",", 
           RowBox[{"{", 
