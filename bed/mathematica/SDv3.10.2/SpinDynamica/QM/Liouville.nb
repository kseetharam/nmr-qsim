     RowBox[{"newopbasis_", ",", 
      RowBox[{"opbasis_", "?", "DefinedOperatorBasisQ"}], ",", 
      RowBox[{"sop_", "?", "SuperoperatorQ"}], ",", 
      RowBox[{"ordering", ":", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Except", "[", 
          RowBox[{"_", "?", "OperatorQ"}], "]"}], ".."}], "}"}]}], ",", 
      "opts___Rule"}], "]"}], "/;", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"CheckOperatorBasis", "/.", 
        RowBox[{"{", "opts", "}"}]}], "/.", 
       RowBox[{"Options", "[", "DefineOperatorBasis", "]"}]}], ")"}], "&&", 
     "\[IndentingNewLine]", 
