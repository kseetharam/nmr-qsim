Cell["\<\
this should never used but the code here may be used for a check\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.638887780992434*^9, 3.638887808916068*^9}, {
  3.699625888478282*^9, 
  3.699625892626937*^9}},ExpressionUUID->"8bff8f67-8590-426c-b4e1-\
671ef4966982"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"OperatorBasisTransformationMatrix", "[", 
    RowBox[{
    "opbasis2_", ",", "opbasis1_", ",", "basis_", ",", "opts___Rule"}], "]"}],
    ":=", "\[IndentingNewLine]", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"PrintTemporary", "[", 
      RowBox[{
      "\"\<setting up OperatorBasisTransformationMatrix from \>\"", ",", 
       "opbasis1", ",", "\"\< to \>\"", ",", "opbasis2"}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Verbose", "/.", 
         RowBox[{"{", "opts", "}"}]}], "/.", 
        RowBox[{"Options", "[", "OperatorBasisTransformationMatrix", "]"}]}], 
       ",", 
       RowBox[{"Print", "[", 
        RowBox[{
        "\"\<setting up opbtm using direct procedure:\>\"", " ", ",", 
         RowBox[{"{", 
          RowBox[{"opbasis2", ",", "opbasis1"}], "}"}]}], "]"}]}], 
      "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"PrependTo", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"DownValues", "[", "OperatorBasisTransformationMatrix", "]"}], 
       ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"OperatorBasisTransformationMatrix", "[", 
         RowBox[{"opbasis2", ",", "opbasis1", ",", "basis", ",", "___Rule"}], 
         "]"}], "\[Rule]", "\[IndentingNewLine]", 
        RowBox[{"Module", "[", 
         RowBox[{
          RowBox[{"{", "spinsys", "}"}], ",", 
          RowBox[{"(", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"spinsys", "=", 
             RowBox[{"SpinSystem", "[", "opbasis2", "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"SparseArray", "@", 
             RowBox[{"Outer", "[", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{
                RowBox[{"LiouvilleBracket", "[", 
                 RowBox[{"#1", ",", "#2"}], "]"}], "&"}], ",", 
               "\[IndentingNewLine]", 
               RowBox[{
                RowBox[{
                 RowBox[{"MatrixRepresentation", "[", 
                  RowBox[{"#", ",", 
                   RowBox[{"ZeemanBasis", "[", "spinsys", "]"}]}], "]"}], 
                 "&"}], "/@", 
                RowBox[{"BasisOperators", "[", "opbasis2", "]"}]}], ",", 
               "\[IndentingNewLine]", 
               RowBox[{
                RowBox[{
                 RowBox[{"MatrixRepresentation", "[", 
                  RowBox[{"#", ",", 
                   RowBox[{"ZeemanBasis", "[", "spinsys", "]"}]}], "]"}], 
                 "&"}], "/@", 
                RowBox[{"BasisOperators", "[", "opbasis1", "]"}]}], ",", 
               "\[IndentingNewLine]", "1"}], "\[IndentingNewLine]", "]"}]}]}],
            "\[IndentingNewLine]", ")"}]}], "]"}]}]}], "\[IndentingNewLine]", 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"OperatorBasisTransformationMatrix", "[", 
      RowBox[{"opbasis2", ",", "opbasis1", ",", "basis"}], "]"}]}], 
    "\[IndentingNewLine]", ")"}]}], ";"}]], "Input",
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.431060507531653*^9, 3.431060524344806*^9}, {
