Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SuperoperatorMatrixRepresentation", "::", "usage"}], "=", 
   "\"\<SuperoperatorMatrixRepresentation[superop,opbasis] derives the matrix \
representation of a superoperator in a given operator basis. The option \
Method\[Rule]Automatic (default) uses an intermediate basis in which \
factorization of the basis operators into ket-bra products is used to speed \
up the computation. Method\[Rule]\\\"Direct\\\" uses explicit matrix \
representations of the basis operators in the chosen basis.\>\""}], 
  ";"}]], "Input",
 PageWidth:>WindowWidth,
