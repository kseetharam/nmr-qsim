Cell[CellGroupData[{

Cell["check SuperoperatorType for matrix form", "Subsubsection",
 InitializationCell->True,
 CellChangeTimes->{{3.5861636308554487`*^9, 3.586163640398192*^9}, {
  3.58616368165716*^9, 3.586163683120761*^9}, {3.586164065803493*^9, 
