Cell[CellGroupData[{

Cell["CoherenceOrderFiltrationSuperoperator", "Subsection",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.450614075954517*^9, 3.450614082159617*^9}, 
   3.4506141488329387`*^9},
 AspectRatioFixed->
  True,ExpressionUUID->"9e1c2b4e-d3cb-4fb6-9946-4f08a08fb078"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"CoherenceOrderFiltrationSuperoperator", "::", "usage"}], "=", 
   "\"\<CoherenceOrderFiltrationSuperoperator[{order1, order2...}] is the \
superoperator for filtration through a set of coherence orders (all orders in \
the set {order1, order2...} being allowed, with other orders disallowed). \n\
CoherenceOrderFiltrationSuperoperator[spins,{order1, order2...}] is the \
superoperator for filtration through a set of coherence orders of spins (all \
orders of spins not included in {order1, order2...} are suppressed, while all \
orders for spins not included in spins are allowed).\n\
CoherenceOrderFiltrationSuperoperator[{spins1,{order1, \
order2...},{spins2,{order3, order4...}..}] filters successively through \
{order1, order2...} for spins1, orders {order3, order4...} for spins2, etc. \n\
Examples: After SetSpinSystem[4], CoherenceOrderFiltrationSuperoperator[0]or \
CoherenceOrderFiltrationSuperoperator[{0}] suppresses all coherences which \
are not zero-quantum for all four spins. \
CoherenceOrderFiltrationSuperoperator[{1,2},0] suppresses all coherences \
which are not zero-quantum for spins {1,2}, but permits all coherences for \
spins {3,4}. CoherenceOrderFiltrationSuperoperator[{{1,2},0},{{3,4},0}] \
suppresses all terms that are not zero-quantum for both sets of spins {1,2} \
and {3,4}. \n\>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.450614085287265*^9, 3.450614109002995*^9}, {
   3.450614150522191*^9, 3.450614177232225*^9}, 3.472112577824038*^9, {
   3.587293784995238*^9, 3.587293823212933*^9}, {3.722559374624462*^9, 
   3.722559552789167*^9}, {3.722559613944544*^9, 3.722559794241913*^9}, {
   3.722559828040889*^9, 3.722559970559312*^9}, {3.72256006268791*^9, 
   3.722560266661717*^9}, {3.722560359378787*^9, 3.722560374203562*^9}, {
   3.722561240220998*^9, 3.722561254765221*^9}},
 CellLabel->
  "In[163]:=",ExpressionUUID->"c63fe332-b1c6-4994-b32c-6e6c6d9e6d4e"]
}, Closed]],

Cell[CellGroupData[{

Cell["RotationSuperoperator", "Subsection",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.450614075954517*^9, 3.450614082159617*^9}, 
   3.4506141488329387`*^9, {3.450614512363935*^9, 3.450614513504929*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"e63cf1a7-edd0-4cd3-92b6-f9f35765779a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"RotationSuperoperator", "::", "usage"}], "=", 
   "\"\<RotationSuperoperator[spins,angle] is the superoperator for rotating \
a single spin or a set of spins through the specified angle. If spins is \
absent, all spins in the current SpinSystem are rotated. The following \
formats for angle may be used: 1. {\[Beta],\[Phi]} indicates a rotation \
through \[Beta] about an axis in the xy plane with the phase \[Phi]. The \
phase value may either be numeric, or be specified using the text codes \\\"x\
\\\", \\\"y\\\", \\\"-x\\\" for the quadrature phases. A code \\\"z\\\" \
indicates a rotation about the z-axis. 2. The format \
{\[Xi],{\[Theta],\[Phi]}} indicates a rotation through the angle \[Xi] about \
an axis with polar angles \[Theta] and \[Phi]. 3. The format \
{\[Alpha],\[Beta],\[Gamma]} indicates a rotation through the specified Euler \
angles, using the zyz convention.\>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.450614085287265*^9, 3.450614109002995*^9}, {
  3.450614150522191*^9, 3.450614177232225*^9}, {3.450614518943392*^9, 
  3.450614616202996*^9}, {3.4562008848391123`*^9, 3.456200967571823*^9}, {
  3.46036613598059*^9, 3.460366425441249*^9}},
 CellLabel->
  "In[164]:=",ExpressionUUID->"62109f1c-093d-411d-b4b5-2dcad0cd3afd"]
}, Closed]],

