e3ebb62c6d6f"],

Cell["\<\
In v2.12.3b6, the assumption of orthogonal eigenvectors was disabled for type \
\[OpenCurlyDoubleQuote]Normal\[CloseCurlyDoubleQuote]. This was incorrect and \
lead to incorrect results for thermalized relaxation superoperators.\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.640411389234887*^9, 3.640411413791872*^9}, {
  3.640411469644186*^9, 3.640411486991731*^9}, {3.640411517159263*^9, 
  3.64041153201632*^9}, {3.640490245510507*^9, 
  3.6404902749942636`*^9}},ExpressionUUID->"be7f3713-4efa-4476-93d4-\
cf155d8fa1ba"],

Cell["\<\
In v3.6.1, if diagonalization fails, the OperatorBasis is switched to \
ZeemanKetBraOperatorBasis and a new attempt is made. If that also fails, the \
superoperator is left undiagonalized.  \
\>", "Text",
 CellChangeTimes->{{3.837945409719298*^9, 
  3.837945464174941*^9}},ExpressionUUID->"d9379af0-3d03-481b-94eb-\
729f09b22534"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"NDiagonalize", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Superoperator", "[", 
      RowBox[{
       RowBox[{"mat_", "?", "MatrixQ"}], ",", "opbasis_", ",", "basis2_", ",",
        "sopopts___Rule"}], "]"}], ",", "\[IndentingNewLine]", "opbasis_", 
     ",", "basis1_", ",", "opts___Rule"}], "\[IndentingNewLine]", "]"}], ":=",
    "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "ass1", ",", "ass2", ",", "zkbopbasis", ",", "ndiagoutput", ",", 
       "diagform", ",", "diagopbasis"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"ass1", "=", 
        RowBox[{
         RowBox[{"Assumptions", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "NDiagonalize", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"ass2", "=", 
        RowBox[{"Switch", "[", "\[IndentingNewLine]", 
         RowBox[{"ass1", ",", "\[IndentingNewLine]", 
          RowBox[{"None", "|", "False"}], ",", "False", ",", 
          "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{"_Rule", "..."}], "}"}], ",", "ass1", ",", 
          "\[IndentingNewLine]", 
          RowBox[{"Automatic", "|", "True"}], ",", "\[IndentingNewLine]", 
          RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{
            "OrthogonalEigenvectors", "\[Rule]", "\[IndentingNewLine]", 
             RowBox[{"Switch", "[", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{
                RowBox[{"SuperoperatorType", "/.", 
                 RowBox[{"{", "sopopts", "}"}]}], "/.", 
                RowBox[{"Options", "[", "Superoperator", "]"}]}], ",", 
               "\[IndentingNewLine]", "\t", 
               RowBox[{
               "\"\<Hermitian\>\"", "|", "\"\<Unitary\>\"", "|", 
                "\"\<AntiHermitian\>\""}], ",", "True", ",", 
               "\[IndentingNewLine]", "\t", "_", ",", "False"}], 
              "\[IndentingNewLine]", "]"}]}], ",", "\[IndentingNewLine]", 
            RowBox[{"Sequence", "@@", 
             RowBox[{"Cases", "[", 
              RowBox[{"ass1", ",", "_Rule"}], "]"}]}]}], 
           "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", "_", ",",
           "None"}], "\[IndentingNewLine]", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"zkbopbasis", "=", 
        RowBox[{"ZeemanKetBraOperatorBasis", "[", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"ndiagoutput", "=", 
        RowBox[{"NDiagonalize", "[", 
         RowBox[{
          RowBox[{"N", "@", "mat"}], ",", 
          RowBox[{"SimplifyRules", "[", 
           RowBox[{
            RowBox[{"Assumptions", "\[Rule]", "ass2"}], ",", "opts"}], 
           "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Which", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"MatchQ", "[", 
           RowBox[{"ndiagoutput", ",", "$Failed"}], "]"}]}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"diagform", "=", "ndiagoutput"}], ";", 
           RowBox[{"diagopbasis", "=", "opbasis"}]}], ")"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"MatchQ", "[", 
           RowBox[{"ndiagoutput", ",", "$Failed"}], "]"}], "&&", 
          RowBox[{"!", 
           RowBox[{"MatchQ", "[", 
            RowBox[{"opbasis", ",", "zkbopbasis"}], "]"}]}]}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"diagform", "=", 
            RowBox[{"NDiagonalize", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"OperatorBasisTransformationMatrix", "[", 
                RowBox[{"zkbopbasis", ",", "opbasis"}], "]"}], ".", 
               RowBox[{"N", "[", "mat", "]"}], ".", 
               RowBox[{"OperatorBasisTransformationMatrix", "[", 
                RowBox[{"opbasis", ",", "zkbopbasis"}], "]"}]}], ",", 
              RowBox[{"SimplifyRules", "[", 
               RowBox[{
                RowBox[{"Assumptions", "\[Rule]", "ass2"}], ",", "opts"}], 
               "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"diagopbasis", "=", "zkbopbasis"}]}], ")"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"MatchQ", "[", 
           RowBox[{"ndiagoutput", ",", "$Failed"}], "]"}], "&&", 
          RowBox[{"MatchQ", "[", 
           RowBox[{"opbasis", ",", "zkbopbasis"}], "]"}]}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"diagform", "=", "$Failed"}], ";", 
           RowBox[{"diagopbasis", "=", "opbasis"}]}], ")"}]}], 
        "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"MatchQ", "[", 
          RowBox[{"diagform", ",", "$Failed"}], "]"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Message", "[", 
            RowBox[{
             RowBox[{"NDiagonalize", "::", "sopdiagfailed"}], ",", 
             "diagopbasis"}], "]"}], ";", "$Failed"}], ")"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"Superoperator", "[", "\[IndentingNewLine]", 
          RowBox[{
          "diagform", ",", "\[IndentingNewLine]", "diagopbasis", ",", 
           "\[IndentingNewLine]", "basis1", ",", "\[IndentingNewLine]", 
           RowBox[{"SimplifyRules", "[", 
            RowBox[{"sopopts", ",", "opts"}], "]"}]}], "\[IndentingNewLine]", 
          "]"}]}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
      ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.586080623025322*^9, 3.586080693204924*^9}, {
   3.5860823454200897`*^9, 3.5860823814112043`*^9}, {3.586082428541574*^9, 
   3.586082730213779*^9}, {3.586082765132083*^9, 3.58608281869175*^9}, {
   3.586082896649729*^9, 3.586082926435439*^9}, {3.586083007680859*^9, 
