Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"OperatorBasisTransformationMatrix", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"opbasis2", ":", 
       RowBox[{"opbtype2_", "[", 
        RowBox[{"type2___", ",", 
         RowBox[{"spins_", "?", "MatrixQ"}], ",", "opb2opts___Rule"}], 
        "]"}]}], ",", 
      RowBox[{"opbasis1", ":", 
       RowBox[{"opbtype1_", "[", 
        RowBox[{"type1___", ",", 
         RowBox[{"spins_", "?", "MatrixQ"}], ",", "opb1opts___Rule"}], 
        "]"}]}], ",", "\[IndentingNewLine]", "basis_", ",", "opts___Rule"}], 
     "\[IndentingNewLine]", "]"}], "/;", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"MatchQ", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Sorted", "/.", 
          RowBox[{"{", "opb2opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "opbtype2", "]"}]}], ",", 
        "\"\<OrderBySpin\>\""}], "]"}], ")"}], "&&", 
     RowBox[{"(", 
      RowBox[{"MatchQ", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Sorted", "/.", 
          RowBox[{"{", "opb1opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "opbtype1", "]"}]}], ",", 
        "\"\<OrderBySpin\>\""}], "]"}], ")"}], "&&", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Length", "[", "spins", "]"}], ">", "1"}], ")"}]}]}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"temp", ",", "spin", ",", "opbtm"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"temp", "=", 
        RowBox[{"PrintTemporary", "[", 
         RowBox[{
         "\"\<setting up OperatorBasisTransformationMatrix from \>\"", ",", 
          "opbasis1", ",", "\"\< to \>\"", ",", "opbasis2"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Verbose", "/.", 
           RowBox[{"{", "opts", "}"}]}], "/.", 
          RowBox[{
          "Options", "[", "OperatorBasisTransformationMatrix", "]"}]}], ",", 
         RowBox[{"Print", "[", 
          RowBox[{"\"\<using OrderBySpin (2):\>\"", ",", 
           RowBox[{"{", 
            RowBox[{"opbasis2", ",", "opbasis1"}], "}"}]}], "]"}]}], 
        "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"PrependTo", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
         "DownValues", "[", "OperatorBasisTransformationMatrix", "]"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"OperatorBasisTransformationMatrix", "[", 
           RowBox[{
           "opbasis2", ",", "opbasis1", ",", "basis", ",", "___Rule"}], "]"}],
           "\[Rule]", "\[IndentingNewLine]", 
          RowBox[{"KroneckerProduct", "[", "\[IndentingNewLine]", 
           RowBox[{"Sequence", "@@", 
            RowBox[{"Map", "[", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"Function", "[", 
               RowBox[{"spin", ",", "\[IndentingNewLine]", 
                RowBox[{
                "OperatorBasisTransformationMatrix", "[", 
                 "\[IndentingNewLine]", 
                 RowBox[{
                  RowBox[{"opbtype2", "[", 
                   RowBox[{"type2", ",", 
                    RowBox[{"{", "spin", "}"}], ",", 
                    RowBox[{"Sorted", "\[Rule]", "\"\<OrderBySpin\>\""}]}], 
                   "]"}], ",", "\[IndentingNewLine]", 
                  RowBox[{"opbtype1", "[", 
                   RowBox[{"type1", ",", 
                    RowBox[{"{", "spin", "}"}], ",", 
                    RowBox[{"Sorted", "\[Rule]", "\"\<OrderBySpin\>\""}]}], 
                   "]"}], ",", "\[IndentingNewLine]", 
