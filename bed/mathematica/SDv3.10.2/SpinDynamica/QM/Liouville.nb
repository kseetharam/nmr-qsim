Cell[CellGroupData[{

Cell["Superoperator", "Subsection",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.448291327652368*^9, 3.448291329025457*^9}, 
   3.504109824945512*^9, {3.531926985057364*^9, 3.531926985926383*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"ae95a85d-4205-4fad-a402-a7ecb29ac4a0"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Superoperator", "::", "usage"}], "=", 
   "\"\<Superoperator[matrep,opbasis,basis,opts] defines a spin superoperator \
that has the matrix representation matrep in the specified operator basis \
opbasis and state basis basis. The current operator basis and state basis are \
assumed if opbasis or basis is missing. The options may include \
SuperoperatorType, which may be used to define whether the operator is \
unitary, hermitian, etc. Superoperator may also be called with the format \
Superoperator[sop,opbasis,basis,opts], where sop is a superoperator \
expression. The routine will then calculate the matrix representation and \
assign the SuperoperatorType automatically.\nSuperoperator may also have the \
form Superoperator[{X,evals,Xinv},opbasis,basis,opts] where X is a matrix \
whose columns are the eigenvectors of the matrix representation of the \
superoperator in the operator basis opbasis, evals are the eigenvalues, and \
Xinv is the inverse of X. This form is generated by applying NDiagonalize to \
a superoperator.\n\>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.448291333690934*^9, 3.448291357780293*^9}, {
   3.50410982710646*^9, 3.504109860910949*^9}, {3.504110177020758*^9, 
   3.504110189617758*^9}, {3.531829191563922*^9, 3.5318291919915*^9}, {
   3.531829256245398*^9, 3.531829349850441*^9}, 3.531926989317468*^9, {
   3.53192702098775*^9, 3.531927151006223*^9}, {3.586089543771623*^9, 
   3.5860895939143677`*^9}},
 CellLabel->
  "In[148]:=",ExpressionUUID->"b9ab0711-8dec-4db5-8fc7-19a8dbf4156a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SuperoperatorType", "::", "usage"}], "=", 
   "\"\<SuperoperatorType is an option for Superoperator, with possible \
values {None, Automatic, \\\"Hermitian\\\", \\\"Unitary\\\",\\\"Normal\\\"}\>\
\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.531829197100492*^9, 3.5318292531763887`*^9}, {
  3.53192699331525*^9, 3.531927012747682*^9}},
