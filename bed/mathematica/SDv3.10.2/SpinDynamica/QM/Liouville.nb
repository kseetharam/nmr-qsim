Cell[CellGroupData[{

Cell["ShiftAndZOperatorBasis", "Subsection",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 AspectRatioFixed->
  True,ExpressionUUID->"8c825e3e-708d-4da4-9f2e-7c6d9bd30fcd"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ShiftAndZOperatorBasis", "::", "usage"}], "=", 
   "\"\<ShiftAndZOperatorBasis[] generates an orthonormal set of products of \
shift operators and z operators for the current spin system. The option \
Sorted->True may be used to sort according to coherence order. This basis is \
defined for any combination of spin quantum numbers. The option \
Sorted\[Rule]CoherenceOrder may be used to arrange the operators according to \
coherence order.\>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.462273166895113*^9, 3.462273196309677*^9}, {
  3.468155093786396*^9, 3.468155097810239*^9}, {3.546421684090328*^9, 
  3.5464217564911146`*^9}, {3.546535241669148*^9, 3.54653524219265*^9}},
 CellLabel->
  "In[138]:=",ExpressionUUID->"cc30f1c3-64c8-4ed9-ae6e-b60971d17f00"]
}, Closed]],

Cell[CellGroupData[{

Cell["SingletTripletOperatorBasis", "Subsection",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{3.4296978569276342`*^9},
 AspectRatioFixed->
  True,ExpressionUUID->"f701b516-f8b0-47ca-978b-be201877069e"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SingletTripletOperatorBasis", "::", "usage"}], "=", 
   "\"\<SingletTripletOperatorBasis[options] generates the direct product \
between the set of singlet-triplet bras and kets for a 2-spin-1/2 system. By \
default, the option Sorted\[Rule]True is used which arranges the basis \
operators in order of descending coherence order. Coherence order sorting may \
be disabled by specifying Sorted\[Rule]False or \
Sorted\[Rule]\\\"Canonical\\\".\nSingletTripletOperatorBasis[2,options] \
generates the modified singlet-triplet operator basis as used in G. Pileio \
and M. H. Levitt, J. Chem. Phys. 130, 214501-214514 (2009). This basis is \
automatically organized according to coherence order.\>\""}], ";"}]], "Input",\

 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.456736679916744*^9, 3.45673674802743*^9}, {
   3.456737301181441*^9, 3.456737311611559*^9}, 3.462273205219442*^9, {
   3.753336253424742*^9, 3.753336347525502*^9}, {3.753336384024395*^9, 
   3.75333641256366*^9}},
 CellLabel->
  "In[139]:=",ExpressionUUID->"dad18d23-aba3-4aa0-98ec-329cc87b867c"]
}, Closed]],

Cell[CellGroupData[{

Cell["ZeemanKetBraOperatorBasis", "Subsection",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{3.433524791179223*^9},
 AspectRatioFixed->
  True,ExpressionUUID->"daacff1e-fecc-4ba3-95a9-09eafdcbcfa8"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ZeemanKetBraOperatorBasis", "::", "usage"}], "=", 
   "\"\<ZeemanKetBraOperatorBasis[] generates an operator basis consisting of \
ket.bra products where each ket and bra is a direct product of the Zeeman \
kets and bras for the individual spins in the defined spin system. This \
operator basis may be used for any spin quantum number. For the case of \
spins-1/2, ZeemanKetBraOperatorBasis is equivalent to \
ShiftAndPolarizationOperatorBasis. The option Sorted->True may be used to \
sort according to coherence order. The option Sorted\[Rule]\\\"Canonical\\\" \
generates canonical ordering with the set of Ket-Bra products arranged so \
that all quantum numbers for the Bras are ordered first, before the Ket \
quantum numbers are incremented. The option Sorted\[Rule]\\\"OrderBySpin\\\" \
arranges the Ket-Bra products so that all combinations of Ket-Bra quantum \
numbers for the first spin are completed before the quantum numbers for the \
second spin are incremented. \n\>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.433524656785557*^9, 3.433524821087268*^9}, {
  3.468155132077271*^9, 3.468155135493196*^9}, {3.546420537026317*^9, 
  3.546420682440168*^9}, {3.5464215691043*^9, 3.546421583047607*^9}},
 CellLabel->
  "In[140]:=",ExpressionUUID->"1cd42991-335c-4dd8-b480-f2eb5c7e8c8a"]
}, Closed]],

Cell[CellGroupData[{

Cell["SphericalTensorOperatorBasis", "Subsection",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{
  3.433524791179223*^9, {3.434516366486778*^9, 3.434516373371316*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"9bb61919-cd5f-4537-970d-9f4918264498"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SphericalTensorOperatorBasis", "::", "usage"}], "=", 
   "\"\<SphericalTensorOperatorBasis[] generates an operator basis consisting \
of the complete set of irreducible spherical tensor operators for the defined \
spin system. The option Sorted->True or \
Sorted->{SphericalRank,CoherenceOrder} may be used to sort the basis, first \
according to spherical rank and then with respect to coherence order. The \
option Sorted->{CoherenceOrder,SphericalRank} sorts first with respect to \
coherence order, and then with respect to SphericalRank.\>\""}], 
  ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.433524656785557*^9, 3.433524821087268*^9}, {
  3.434516377306247*^9, 3.434516410185973*^9}, {3.468155144198454*^9, 
  3.468155253199935*^9}},
 CellLabel->
  "In[141]:=",ExpressionUUID->"37629684-89f9-4e21-8bf3-a18f4b29982f"]
}, Closed]]
}, Closed]],

