Cell[CellGroupData[{

Cell["ShiftAndPolarizationOperatorBasis", "Subsection",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 AspectRatioFixed->
  True,ExpressionUUID->"e85ddb60-6497-4454-a57c-a8d340d22367"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ShiftAndPolarizationOperatorBasis", "::", "usage"}], "=", 
   "\"\<ShiftAndPolarizationOperatorBasis[] generates a set of shift and \
polarization operators for the current spin system (which must have been set \
first using the SetSpinSystem command of the SpinOperators package). The \
operators are arranged in the same order as used in the Gamma package. The \
option Sorted\[Rule]True may be used to arrange the operators according to \
increasing coherence order. This basis may only be used if all nuclei are \
spins-1/2.\>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.468155062418538*^9, 3.468155063537328*^9}, {
  3.546535192130265*^9, 3.546535193938882*^9}},
 CellLabel->
  "In[136]:=",ExpressionUUID->"8d23864e-f895-4c17-98ae-07569e59c89f"]
}, Closed]],

Cell[CellGroupData[{

Cell["CartesianProductOperatorBasis", "Subsection",
 PageWidth:>WindowWidth,
 Evaluatable->False,
