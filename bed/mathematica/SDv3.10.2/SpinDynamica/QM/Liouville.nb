Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SuperoperatorMatrixRepresentation", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"HoldPattern", "@", 
      RowBox[{"CoherenceOrderFiltrationSuperoperator", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"spins", ":", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Except", "[", "_List", "]"}], ".."}], "}"}]}], ",", 
          RowBox[{"orders", ":", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Except", "[", "_List", "]"}], ".."}], "}"}]}]}], "}"}], 
        ",", "cofsopts___Rule"}], "]"}]}], ",", "\[IndentingNewLine]", 
     "opbasis_", ",", "basis_", ",", "opts___Rule"}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"n", ",", "pos", ",", "spinsys"}], "}"}], ",", 
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"n", "=", 
         RowBox[{"OperatorBasisDimension", "[", 
          RowBox[{"ZeemanKetBraOperatorBasis", "[", 
           RowBox[{"Sorted", "\[Rule]", "\"\<Canonical\>\""}], "]"}], "]"}]}],
         ";", "\[IndentingNewLine]", 
        RowBox[{"pos", "=", 
         RowBox[{"Flatten", "@", 
          RowBox[{"Position", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"CoherenceOrder", "[", 
               RowBox[{"spins", ",", "#"}], "]"}], "&"}], "/@", 
             RowBox[{"BasisOperators", "[", 
              RowBox[{"ZeemanKetBraOperatorBasis", "[", 
               RowBox[{"Sorted", "\[Rule]", "\"\<Canonical\>\""}], "]"}], 
              "]"}]}], ",", 
            RowBox[{"Alternatives", "@@", "orders"}]}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"SparseArray", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"#", ",", "#"}], "}"}], "\[Rule]", "1"}], ")"}], "&"}],
            "/@", "pos"}], ",", 
          RowBox[{"{", 
           RowBox[{"n", ",", "n"}], "}"}]}], "]"}]}], "\[IndentingNewLine]", 
       ")"}], "/;", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"spinsys", "=", 
         RowBox[{"SpinSystem", "[", "opbasis", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"MatchQ", "[", 
         RowBox[{"opbasis", ",", 
          RowBox[{"ZeemanKetBraOperatorBasis", "[", 
           RowBox[{"spinsys", ",", 
            RowBox[{"Sorted", "\[Rule]", "\"\<Canonical\>\""}]}], "]"}]}], 
         "]"}]}], "\[IndentingNewLine]", ")"}]}]}], "\[IndentingNewLine]", 
    "]"}]}], ";"}]], "Input",
