Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SuperoperatorMatrixRepresentation", "[", 
    RowBox[{"sop_", ",", "opbasis_", ",", "basis_", ",", "opts___Rule"}], 
    "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"iopbasis", ",", "spinsys"}], "}"}], ",", 
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"iopbasis", "=", 
         RowBox[{"ZeemanKetBraOperatorBasis", "[", 
          RowBox[{"Sorted", "\[Rule]", "\"\<Canonical\>\""}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
        "MultiplyMatricesAndMatrixInterpolationFunctions", "[", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"OperatorBasisTransformationMatrix", "[", 
           RowBox[{"opbasis", ",", "iopbasis", ",", "basis"}], "]"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"SuperoperatorMatrixRepresentation", "[", 
           RowBox[{"sop", ",", "iopbasis", ",", "basis", ",", 
            RowBox[{"Method", "\[Rule]", "Automatic"}], ",", "opts"}], "]"}], 
          ",", "\[IndentingNewLine]", 
          RowBox[{"OperatorBasisTransformationMatrix", "[", 
           RowBox[{"iopbasis", ",", "opbasis", ",", "basis"}], "]"}]}], 
         "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", ")"}], "/;", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"spinsys", "=", 
         RowBox[{"SpinSystem", "[", "opbasis", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"MatchQ", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Method", "/.", 
             RowBox[{"{", "opts", "}"}]}], "/.", 
            RowBox[{
            "Options", "[", "SuperoperatorMatrixRepresentation", "]"}]}], ",",
            "Automatic"}], "]"}], "&&", "\[IndentingNewLine]", 
         RowBox[{"!", 
