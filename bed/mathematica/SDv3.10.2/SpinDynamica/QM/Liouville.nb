   3.709276585838269*^9}, {3.709276637536909*^9, 3.709276661006999*^9}, {
   3.7092769922045794`*^9, 3.7092769923847227`*^9}, {3.709284239941059*^9, 
   3.709284263576981*^9}, {3.709284350214435*^9, 3.709284354403436*^9}, {
   3.709393875017393*^9, 3.70939388575995*^9}, 3.709397373547167*^9, {
   3.709397453890108*^9, 3.709397483751692*^9}, {3.70939751981434*^9, 
   3.709397551385014*^9}, 3.709397600370755*^9, {3.921229451179406*^9, 
   3.921229460410421*^9}, 3.921402843561359*^9, {3.921402875481893*^9, 
