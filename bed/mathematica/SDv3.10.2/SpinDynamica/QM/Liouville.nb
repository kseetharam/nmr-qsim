   RowBox[{"DefaultOperatorBasis", "[", "Undefined", "]"}], ":=", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"Message", "[", 
      RowBox[{"OperatorBasis", "::", "undefspinsys"}], "]"}], ";", 
