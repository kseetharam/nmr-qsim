  3.623335597505698*^9}},ExpressionUUID->"8dec1eb6-0ec8-41c0-ab87-\
be83b135cfe5"],

Cell["\<\
 take the OperatorVectorRepresentation in ZeemanKetBraOperatorBasis[Sorted \
\[Rule] \"Canonical\"] and partition it into sublists to get the \
MatrixRepresentation\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.623334705971511*^9, 
  3.62333472558913*^9}},ExpressionUUID->"a7e56ce5-0a06-401f-9a4c-\
6c9080ccd6ba"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"HoldPattern", "@", 
    RowBox[{"MatrixRepresentation", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"op", ":", 
       RowBox[{"Operator", "[", 
        RowBox[{
         RowBox[{"vec_", "?", "VectorQ"}], ",", "___"}], "]"}]}], ",", 
      RowBox[{"basis", ":", 
       RowBox[{"Except", "[", "_Rule", "]"}]}], ",", "___Rule"}], "]"}]}], "/;", 
   RowBox[{"MatchQ", "[", 
    RowBox[{"basis", ",", 
     RowBox[{"ZeemanBasis", "[", "]"}]}], "]"}]}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{"Partition", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"OperatorVectorRepresentation", "[", "\[IndentingNewLine]", 
     RowBox[{"op", ",", 
      RowBox[{"ZeemanKetBraOperatorBasis", "[", 
       RowBox[{"Sorted", "\[Rule]", "\"\<Canonical\>\""}], "]"}], ",", 
      "basis"}], "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
    RowBox[{"BasisDimension", "[", "basis", "]"}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 InitializationCell->True,
 CellLabel->
  "In[405]:=",ExpressionUUID->"c738f160-299a-48d2-aa87-1672361772f8"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"HoldPattern", "@", 
     RowBox[{"MatrixRepresentation", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"op", ":", 
        RowBox[{"Operator", "[", 
         RowBox[{
          RowBox[{"ifunc_InterpolatingFunction", "[", "t_", "]"}], ",", 
          RowBox[{"vecopbasis", ":", 
           RowBox[{"Except", "[", "_Rule", "]"}]}], ",", 
          RowBox[{"vecbasis", ":", 
           RowBox[{"Except", "[", "_Rule", "]"}]}], ",", "___Rule"}], "]"}]}],
        ",", "\[IndentingNewLine]", 
       RowBox[{"basis", ":", 
        RowBox[{"Except", "[", "_Rule", "]"}]}], ",", "___Rule"}], "]"}]}], "/;", 
    RowBox[{
     RowBox[{"MatchQ", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"vecopbasis", ",", "basis"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"ZeemanKetBraOperatorBasis", "[", 
          RowBox[{"Sorted", "\[Rule]", "\"\<Canonical\>\""}], "]"}], ",", 
         RowBox[{"ZeemanBasis", "[", "]"}]}], "}"}]}], "]"}], "&&", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Depth", "[", "ifunc", "]"}], "\[GreaterEqual]", "3"}], 
        ")"}], "&&", "\[IndentingNewLine]", 
       RowBox[{"MatchQ", "[", 
        RowBox[{
         RowBox[{"ifunc", "[", 
          RowBox[{"ifunc", "\[LeftDoubleBracket]", 
           RowBox[{"1", ",", "1", ",", "1"}], "\[RightDoubleBracket]"}], 
          "]"}], ",", 
         RowBox[{"_", "?", "VectorQ"}]}], "]"}]}], ")"}]}]}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Partition", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"Replace", "[", 
       RowBox[{"ifunc", ",", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"v_", "?", "VectorQ"}], "\[RuleDelayed]", 
          RowBox[{"Partition", "[", 
           RowBox[{"v", ",", 
            RowBox[{"BasisDimension", "[", "basis", "]"}]}], "]"}]}], "}"}], 
        ",", 
        RowBox[{"{", "3", "}"}]}], "\[IndentingNewLine]", "]"}], "[", "t", 
      "]"}], ",", "\[IndentingNewLine]", 
     RowBox[{"BasisDimension", "[", "basis", "]"}]}], "\[IndentingNewLine]", 
    "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.623334758746505*^9, 3.623334780644711*^9}, {
  3.623334850768051*^9, 3.623334980121045*^9}, {3.623335015352548*^9, 
