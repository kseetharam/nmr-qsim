Cell[BoxData[
 RowBox[{
  RowBox[{"CouplingHistories", "[", 
   RowBox[{"scheme_", "?", "MatrixQ"}], "]"}], ":=", "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"ranks", ",", "n", ",", "\[Lambda]table"}], "}"}], ",", 
    RowBox[{"(", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"ranks", "=", 
       RowBox[{"Last", "/@", "scheme"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"n", "=", 
       RowBox[{"Length", "@", "ranks"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"\[Lambda]table", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"ToExpression", "[", 
          RowBox[{"\"\<\[Lambda]\>\"", "<>", 
           RowBox[{"ToString", "[", "i", "]"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", 
           RowBox[{"Length", "[", "ranks", "]"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"Flatten", "[", 
         RowBox[{"#", ",", 
          RowBox[{"n", "-", "1"}]}], "]"}], "&"}], "@", "\[IndentingNewLine]", 
       RowBox[{"Table", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Evaluate", "@", "\[Lambda]table"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"Evaluate", "@", 
          RowBox[{"Apply", "[", 
           RowBox[{"Sequence", ",", "\[IndentingNewLine]", 
            RowBox[{"MapThread", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                 RowBox[{
                 "#1", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}],
                  ",", 
                 RowBox[{"Abs", "[", 
                  RowBox[{
                   RowBox[{
                   "#1", "\[LeftDoubleBracket]", "1", 
                    "\[RightDoubleBracket]"}], "-", "#2"}], "]"}], ",", 
                 RowBox[{"Abs", "[", 
                  RowBox[{
                   RowBox[{
                   "#1", "\[LeftDoubleBracket]", "1", 
                    "\[RightDoubleBracket]"}], "+", "#2"}], "]"}]}], "}"}], 
               "&"}], ",", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"Partition", "[", 
                 RowBox[{
                  RowBox[{"Prepend", "[", 
                   RowBox[{"\[Lambda]table", ",", "0"}], "]"}], ",", "2", ",",
                   "1"}], "]"}], ",", "ranks"}], "}"}]}], "]"}]}], 
           "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", "]"}]}]}],
      "\[IndentingNewLine]", ")"}]}], "]"}]}]], "Input",
 InitializationCell->True,
 InitializationGroup->True,
