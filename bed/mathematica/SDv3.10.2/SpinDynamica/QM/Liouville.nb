Cell[CellGroupData[{

Cell["\<\
OperatorBasesOrderedQ determines whether two operator bases are ordered\
\>", "Subsubsection",
 InitializationCell->True,
 CellChangeTimes->{{3.638884998796598*^9, 3.63888502986525*^9}, {
  3.699637595338702*^9, 
  3.699637599231407*^9}},ExpressionUUID->"4f5eefdd-9b85-4dc5-a53d-\
b75d91a5992a"],

Cell["\<\
A pair of bases is ordered if the second basis of the pair is the defined \
IntermediateOperatorBasis for the basis. In most cases this is the \
ZeemanKetBraOperatorBasis with canonical ordering.\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.638885034197332*^9, 3.638885060152164*^9}, {
  3.638885197535298*^9, 3.638885215770627*^9}, {3.699637057140057*^9, 
  3.699637141880084*^9}},ExpressionUUID->"8b1927ae-1fe1-45a9-93d2-\
8b684fcc5008"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"OperatorBasesOrderedQ", "[", 
     RowBox[{"{", 
      RowBox[{"opbasis2_", ",", "opbasis1_"}], "}"}], "]"}], "/;", 
    RowBox[{"OperatorBasesMatchQ", "[", 
     RowBox[{"{", 
