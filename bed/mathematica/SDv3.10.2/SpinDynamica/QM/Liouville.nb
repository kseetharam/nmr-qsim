Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Superoperator", "[", 
     RowBox[{
      RowBox[{"sopmat_", "?", "MatrixQ"}], ",", "opbasis_", ",", "basis_", 
      ",", "opts___Rule"}], "]"}], "/;", 
    RowBox[{"TrueQ", "[", 
     RowBox[{
      RowBox[{"CheckMatrixDimensions", "/.", 
       RowBox[{"{", "opts", "}"}]}], "/.", 
      RowBox[{"Options", "[", "Superoperator", "]"}]}], "]"}]}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "n", "}"}], ",", 
