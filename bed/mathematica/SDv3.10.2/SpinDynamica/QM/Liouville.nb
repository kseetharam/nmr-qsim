Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SpinPermutationSuperoperator", "::", "usage"}], "=", 
   "\"\<SpinPermutationSuperoperator[{j,k}] is the superoperator for exchange \
of spin j with spin k. SpinPermutationSuperoperator[{j,k,l,m..}] is the \
superoperator for a cyclic permutation of the specified spins, with \
j\[Rule]k,k\[Rule]l,l\[Rule]m, etc. \
SpinPermutationSuperoperator[{..{j2,k2..},{j1,k1..}}] is the operator for \
successive spin exchange operations, with the {j1,k1..} permutation preceding \
the {j2,k2..} permutation, and so on (i.e. right to left order of \
application).\>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.450614085287265*^9, 3.450614109002995*^9}, {
