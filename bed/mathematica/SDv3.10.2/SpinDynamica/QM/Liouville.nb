      RowBox[{"CommutationSuperoperator", "[", 
       RowBox[{
        RowBox[{"Operator", "[", 
         RowBox[{
          RowBox[{"ifunc_InterpolatingFunction", "[", "t_", "]"}], ",", 
          "basis_", ",", "___"}], "]"}], ",", "___"}], "]"}], ",", 
      "\[IndentingNewLine]", "opbasis_", ",", "basis_", ",", "opts___Rule"}], 
     "\[IndentingNewLine]", "]"}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
