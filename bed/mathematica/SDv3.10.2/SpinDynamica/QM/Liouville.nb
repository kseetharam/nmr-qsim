Cell["\<\
operator supplied as matrix in Zeeman basis \[Rule] construct \
SuperoperatorMatrixRepresentation using Kronecker products\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.502604135742118*^9, 3.502604146148756*^9}, 
