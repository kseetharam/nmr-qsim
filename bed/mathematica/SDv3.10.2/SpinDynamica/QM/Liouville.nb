Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Superoperator", "[", 
    RowBox[{"specs_", ",", "opbasis_", ",", "basis_", ",", "opts___Rule"}], 
    "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Superoperator", "[", "\[IndentingNewLine]", 
     RowBox[{
     "specs", ",", "opbasis", ",", "basis", ",", "\[IndentingNewLine]", 
      RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"CheckSuperoperatorType", "\[Rule]", "True"}], ",", 
        "\[IndentingNewLine]", "opts"}], "\[IndentingNewLine]", "]"}]}], 
     "\[IndentingNewLine]", "]"}], "/;", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"MatchQ", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{"CheckSuperoperatorType", ",", "SuperoperatorType"}], 
           "}"}], "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "Superoperator", "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"Automatic", ",", "Undefined"}], "}"}]}], "]"}], "&&", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"MatchQ", "[", 
         RowBox[{"specs", ",", 
          RowBox[{
          "_CommutationSuperoperator", "|", 
           "_LeftMultiplicationSuperoperator", "|", 
           "_RightMultiplicationSuperoperator"}]}], "]"}], "||", 
        "\[IndentingNewLine]", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"OperatorBasisDimension", "[", "opbasis", "]"}], 
            "\[LessEqual]", "SuperoperatorTypeCheckDisableThreshold"}], ")"}],
           "&&", "\[IndentingNewLine]", 
          RowBox[{"MatchQ", "[", 
           RowBox[{"specs", ",", 
            RowBox[{
             RowBox[{"_", "?", "NumericMatrixQ"}], "|", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"_", "?", "NumericMatrixQ"}], ",", "_List", ",", 
               RowBox[{"_", "?", "NumericMatrixQ"}]}], "}"}]}]}], "]"}]}], 
         ")"}]}], "\[IndentingNewLine]", ")"}]}], "\[IndentingNewLine]", 
     ")"}]}]}], ";"}]], "Input",
 InitializationCell->True,
