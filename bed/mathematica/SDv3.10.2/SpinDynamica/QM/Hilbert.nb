Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"DefineBasis", "[", 
     RowBox[{"basis_", ",", "kets_List", ",", "opts___Rule"}], "]"}], "/;", 
    RowBox[{"MatchQ", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"BasisLabels", "/.", 
        RowBox[{"{", "opts", "}"}]}], "/.", 
       RowBox[{"Options", "[", "DefineBasis", "]"}]}], ",", "Automatic"}], 
     "]"}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"DefineBasis", "[", 
    RowBox[{"basis", ",", "kets", ",", 
     RowBox[{"BasisLabels", "->", 
      RowBox[{"Range", "[", 
       RowBox[{"1", ",", 
        RowBox[{"Length", "[", "kets", "]"}]}], "]"}]}], ",", "opts"}], 
    "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.4863868708781*^9, 3.486386961220276*^9}},
 CellLabel->"In[95]:=",ExpressionUUID->"8bedf25c-5b68-4c69-8215-88c798b76cdc"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"DefineBasis", "[", 
     RowBox[{"basis_", ",", "kets_List", ",", "opts___Rule"}], "]"}], "/;", 
    RowBox[{
     RowBox[{"Length", "[", 
      RowBox[{
       RowBox[{"BasisLabels", "/.", 
        RowBox[{"{", "opts", "}"}]}], "/.", 
       RowBox[{"Options", "[", "DefineBasis", "]"}]}], "]"}], "\[NotEqual]", 
     RowBox[{"Length", "[", "kets", "]"}]}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"Message", "[", 
      RowBox[{"DefineBasis", "::", "inapplabels"}], "]"}], ";", "$Failed"}], 
