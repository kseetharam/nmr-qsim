c29c8b7d6724"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ProductKet", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"ket1_Ket", ",", "ket2_Ket"}], "}"}], ",", "spinsys_"}], "]"}], 
   ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "ssys1", ",", "ssys2", ",", "comspins", ",", "Mvals", ",", "ssys12", ",",
        "invalspins"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"ssys1", "=", 
        RowBox[{
        "ket1", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"ssys2", "=", 
        RowBox[{
        "ket2", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"comspins", "=", 
        RowBox[{"Intersection", "[", 
         RowBox[{
          RowBox[{"First", "/@", "ssys1"}], ",", 
          RowBox[{"First", "/@", "ssys2"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Mvals", "=", 
        RowBox[{"Join", "[", 
         RowBox[{
          RowBox[{
          "ket1", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], ",", 
          RowBox[{
          "ket2", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"ssys12", "=", 
        RowBox[{"Join", "[", 
         RowBox[{
          RowBox[{
          "ket1", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}], ",", 
          RowBox[{
          "ket2", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"invalspins", "=", 
        RowBox[{"Complement", "[", 
         RowBox[{
          RowBox[{"First", "/@", "ssys12"}], ",", 
          RowBox[{"First", "/@", "spinsys"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Which", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"MatchQ", "[", 
           RowBox[{"comspins", ",", 
            RowBox[{"{", "}"}]}], "]"}]}], ",", "\[IndentingNewLine]", "\t", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Message", "[", 
            RowBox[{
             RowBox[{"ProductKet", "::", "comspins"}], ",", "comspins"}], 
            "]"}], ";", "$Failed"}], ")"}], ",", "\[IndentingNewLine]", 
         RowBox[{"!", 
          RowBox[{"MatchQ", "[", 
           RowBox[{"invalspins", ",", 
            RowBox[{"{", "}"}]}], "]"}]}], ",", "\[IndentingNewLine]", "\t", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Message", "[", 
            RowBox[{
             RowBox[{"ProductKet", "::", "invalspins"}], ",", "invalspins", ",",
              "spinsys"}], "]"}], ";", "$Failed"}], ")"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"MatchQ", "[", 
          RowBox[{"ssys12", ",", "spinsys"}], "]"}], ",", 
         "\[IndentingNewLine]", "\t", 
         RowBox[{"Ket", "[", 
          RowBox[{"Mvals", ",", "ssys12"}], "]"}], ",", "\[IndentingNewLine]",
          "True", ",", "\[IndentingNewLine]", "\t", 
         RowBox[{"Ket", "[", 
          RowBox[{
           RowBox[{"SortBy", "[", 
            RowBox[{"Mvals", ",", 
             RowBox[{
              RowBox[{"Position", "[", 
               RowBox[{
                RowBox[{"First", "/@", "spinsys"}], ",", 
                RowBox[{"First", "[", "#", "]"}]}], "]"}], "&"}]}], "]"}], ",", 
           RowBox[{"SortBy", "[", 
            RowBox[{"ssys12", ",", 
             RowBox[{
              RowBox[{"Position", "[", 
               RowBox[{
                RowBox[{"First", "/@", "spinsys"}], ",", 
                RowBox[{"First", "[", "#", "]"}]}], "]"}], "&"}]}], "]"}]}], 
          "]"}]}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
      ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.623432545897689*^9, 3.623432602560408*^9}, {
   3.623432635081326*^9, 3.623432659094321*^9}, {3.623432721067717*^9, 
