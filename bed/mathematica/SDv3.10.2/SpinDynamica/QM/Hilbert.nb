      RowBox[{"couplingmatrix", "[", 
       RowBox[{"I1_", ",", "I2_"}], "]"}], ":=", 
      RowBox[{
       RowBox[{"couplingmatrix", "[", 
        RowBox[{"I1", ",", "I2"}], "]"}], "=", 
       RowBox[{"(", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"I3vals", "=", 
          RowBox[{"Range", "[", 
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{"I1", "-", "I2"}], "]"}], ",", 
            RowBox[{"I1", "+", "I2"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
         
         RowBox[{"setI1", "=", 
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{"I1", ",", "#"}], "}"}], "&"}], "/@", 
           RowBox[{"Range", "[", 
            RowBox[{
             RowBox[{"-", "I1"}], ",", "I1"}], "]"}]}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"setI2", "=", 
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{"I2", ",", "#"}], "}"}], "&"}], "/@", 
           RowBox[{"Range", "[", 
            RowBox[{
             RowBox[{"-", "I2"}], ",", "I2"}], "]"}]}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"setI3", "=", 
          RowBox[{"Flatten", "[", 
           RowBox[{
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"L", ",", "#"}], "}"}], "&"}], "/@", 
               RowBox[{"Range", "[", 
                RowBox[{
                 RowBox[{"-", "L"}], ",", "L"}], "]"}]}], ",", 
              RowBox[{"{", 
               RowBox[{"L", ",", "I3vals"}], "}"}]}], "]"}], ",", "1"}], 
           "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"setI1I2", "=", 
          RowBox[{"Flatten", "[", 
           RowBox[{
            RowBox[{"Outer", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"{", 
                RowBox[{"#1", ",", "#2"}], "}"}], "&"}], ",", "setI1", ",", 
              "setI2", ",", "1"}], "]"}], ",", "1"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"I3vals", ",", 
           RowBox[{"SparseArray", "[", 
            RowBox[{"Outer", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"Quiet", "@", 
                RowBox[{"ClebschGordan", "[", 
                 RowBox[{
                  RowBox[{
                  "#2", "\[LeftDoubleBracket]", "1", 
                   "\[RightDoubleBracket]"}], ",", 
                  RowBox[{
                  "#2", "\[LeftDoubleBracket]", "2", 
                   "\[RightDoubleBracket]"}], ",", "#1"}], "]"}]}], "&"}], ",",
               "setI3", ",", "setI1I2", ",", "1"}], "]"}], "]"}]}], "}"}]}], 
        "\[IndentingNewLine]", ")"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"couplemomenta", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"I1_List", ",", "BT_"}], "}"}], ",", "I2_"}], "]"}], ":=", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"coupledmatrix", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"couplingmatrix", "[", 
            RowBox[{"#", ",", "I2"}], "]"}], "&"}], "/@", "I1"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"newmomenta", "=", 
         RowBox[{"coupledmatrix", "\[LeftDoubleBracket]", 
          RowBox[{"All", ",", "1"}], "\[RightDoubleBracket]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"UI1I2", "=", 
         RowBox[{"ArrayFlatten", "[", 
          RowBox[{"ReleaseHold", "[", 
           RowBox[{"DiagonalMatrix", "[", 
            RowBox[{"Hold", "/@", 
             RowBox[{"(", 
              RowBox[{"coupledmatrix", "\[LeftDoubleBracket]", 
               RowBox[{"All", ",", "2"}], "\[RightDoubleBracket]"}], ")"}]}], 
            "]"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Flatten", "[", "newmomenta", "]"}], ",", 
          RowBox[{"Dot", "[", 
           RowBox[{"UI1I2", ",", 
            RowBox[{"KroneckerProduct", "[", 
             RowBox[{"BT", ",", 
              RowBox[{"IdentityMatrix", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"2", "I2"}], "+", "1"}], ",", "SparseArray"}], 
               "]"}]}], "]"}]}], "]"}]}], "}"}]}], "\[IndentingNewLine]", 
       ")"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"ip", "=", 
      RowBox[{"InversePermutation", "@", 
       RowBox[{"Ordering", "[", 
        RowBox[{"BasisKets", "[", 
         RowBox[{"ZeemanBasis", "[", "spinsys", "]"}], "]"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"UZBtoI", "=", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Fold", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"couplemomenta", "[", 
             RowBox[{"#1", ",", "#2"}], "]"}], "&"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"First", "[", "momenta", "]"}], "}"}], ",", 
             RowBox[{"IdentityMatrix", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"2", "*", 
                 RowBox[{"First", "[", "momenta", "]"}]}], "+", "1"}], ",", 
               "SparseArray"}], "]"}]}], "}"}], ",", 
           RowBox[{"Rest", "[", "momenta", "]"}]}], "]"}], "\[LeftDoubleBracket]",
          "2", "\[RightDoubleBracket]"}], ")"}], "\[LeftDoubleBracket]", 
       RowBox[{"ip", ",", "ip"}], "\[RightDoubleBracket]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Clear", "[", "couplingmatrix", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"UZBtoI", ".", 
      RowBox[{"BasisKets", "[", 
       RowBox[{"ZeemanBasis", "[", "spinsys", "]"}], "]"}]}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
