49b70389e6da"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ProductKet", "::", "usage"}], 
   "=", "\"\<ProductKet[ket1, ket2, ...] returns the direct product of the \
argument kets. Each of the argument kets must involve a different set of \
spins. If possible, the spins in the output ket are arranged according to \
their order in the current SpinSystem[]. \>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.448291333690934*^9, 3.448291357780293*^9}, {
