Cell[CellGroupData[{

Cell["\[Alpha]\[Beta] output notation for spins-1/2", "Subsubsection",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{
  3.57034315872335*^9},ExpressionUUID->"ff8a6e74-da93-436a-86b8-0bbf80ef544d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Format", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"HoldPattern", "[", 
     RowBox[{"Ket", "[", 
      RowBox[{
       RowBox[{"jmpairs_", "?", "MatrixQ"}], ",", 
       RowBox[{"spinsystem_", "?", "MatrixQ"}], ",", "opts___Rule"}], "]"}], 
     "]"}], "/;", 
    RowBox[{"(", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"First", "/@", "jmpairs"}], "==", 
        RowBox[{"First", "/@", "spinsystem"}]}], ")"}], "&&", 
      "\[IndentingNewLine]", 
      RowBox[{"MatchQ", "[", 
       RowBox[{
        RowBox[{"Last", "/@", "spinsystem"}], ",", 
        RowBox[{"{", 
         RowBox[{"Repeated", "[", 
          RowBox[{"1", "/", "2"}], "]"}], "}"}]}], "]"}]}], 
     "\[IndentingNewLine]", ")"}]}], "\[IndentingNewLine]", "]"}], "^:=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "mvals", "}"}], ",", 
    RowBox[{"(", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"If", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"Sort", "[", 
           RowBox[{"First", "/@", "spinsystem"}], "]"}], "\[Equal]", 
          RowBox[{"Sort", "[", 
           RowBox[{"First", "/@", 
            RowBox[{"SpinSystem", "[", "]"}]}], "]"}]}], "&&", 
         "\[IndentingNewLine]", 
         RowBox[{"spinsystem", "!=", 
          RowBox[{"SpinSystem", "[", "]"}]}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"Message", "[", 
         RowBox[{"Ket", "::", "outputspinorder"}], "]"}]}], 
       "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"mvals", "=", 
       RowBox[{"Last", "/@", "jmpairs"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"\"\<\[LeftBracketingBar]\>\"", "<>", 
       RowBox[{"StringJoin", "@@", 
        RowBox[{"(", 
         RowBox[{"mvals", "/.", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"-", "1"}], "/", "2"}], "->", "\"\<\[Beta]\>\""}], ",", 
            
            RowBox[{
             RowBox[{"1", "/", "2"}], "->", "\"\<\[Alpha]\>\""}]}], "}"}]}], 
         ")"}]}], "<>", "\"\<\[RightAngleBracket]\>\""}]}], 
     "\[IndentingNewLine]", ")"}]}], "]"}]}]], "Input",
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{
  3.433527309134687*^9, {3.433529673039196*^9, 3.433529679168274*^9}, {
