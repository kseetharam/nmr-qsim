Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"HoldPattern", "@", 
    RowBox[{"SpinSystem", "[", 
     RowBox[{"Plus", "[", 
      RowBox[{"a_", ",", "b__"}], "]"}], "]"}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "spinsystems", "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"spinsystems", "=", 
        RowBox[{"SpinSystem", "/@", 
         RowBox[{"{", 
          RowBox[{"a", ",", "b"}], "}"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"MatchQ", "[", 
          RowBox[{"spinsystems", ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"spinsystem_", "?", "MatrixQ"}], ".."}], "}"}]}], "]"}], 
         ",", "\[IndentingNewLine]", 
         RowBox[{"First", "@", "spinsystems"}], ",", "\[IndentingNewLine]", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Message", "[", 
            RowBox[{"SpinSystem", "::", "inconsist"}], "]"}], ";", 
           "$Failed"}], ")"}]}], "\[IndentingNewLine]", "]"}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
