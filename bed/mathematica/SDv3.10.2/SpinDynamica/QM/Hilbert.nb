    RowBox[{"basiskets_List", ",", "opts___Rule"}], "]"}], ":=", 
   RowBox[{"CheckBasis", "[", 
    RowBox[{"basiskets", ",", 
     RowBox[{"Adjoint", "/@", "basiskets"}], ",", "opts"}], "]"}]}], 
  ";"}]], "Input",
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.439287678184429*^9, 3.439287723227458*^9}},
 CellLabel->"In[81]:=",ExpressionUUID->"db57fe79-4101-4e28-991d-1d243a233ec6"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"CheckBasis", "[", 
    RowBox[{"basiskets_List", ",", "basisbras_List", ",", "opts___Rule"}], 
    "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"vecs", ",", "mat", ",", "topleft"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"vecs", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"VectorRepresentation", "[", 
           RowBox[{"#", ",", 
            RowBox[{"ZeemanBasis", "[", 
             RowBox[{"SpinSystem", "[", "]"}], "]"}]}], "]"}], "&"}], "/@", 
         "basiskets"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "basiskets", "]"}], "\[NotEqual]", 
          RowBox[{"(", 
           RowBox[{"Times", "@@", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"2", "*", 
                  RowBox[{"SpinQuantumNumber", "[", "#", "]"}]}], "+", "1"}], 
                ")"}], "&"}], "/@", 
              RowBox[{"(", 
               RowBox[{"First", "/@", 
                RowBox[{"SpinSystem", "[", "]"}]}], ")"}]}], ")"}]}], ")"}]}],
          ",", "\[IndentingNewLine]", 
         RowBox[{"Message", "[", 
          RowBox[{"CheckBasis", "::", "incomplete"}], "]"}]}], 
        "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"mat", "=", 
        RowBox[{"Chop", "@", 
         RowBox[{"N", "@", 
          RowBox[{"Outer", "[", 
           RowBox[{"Dot", ",", 
            RowBox[{"Conjugate", "[", "vecs", "]"}], ",", "vecs", ",", "1"}], 
           "]"}]}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"topleft", "=", 
        RowBox[{"mat", "\[LeftDoubleBracket]", 
         RowBox[{"1", ",", "1"}], "\[RightDoubleBracket]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Which", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"OrthonormalQ", "[", "mat", "]"}], ",", 
         "\[IndentingNewLine]", "\t", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Message", "[", 
            RowBox[{"CheckBasis", "::", "orthonormal"}], "]"}], ";", "True"}],
           ")"}], ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"DiagonalQ", "[", "mat", "]"}], "&&", 
          RowBox[{"(", 
           RowBox[{"And", "@@", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"#", "==", "topleft"}], ")"}], "&"}], "/@", 
              RowBox[{"Diagonal", "[", "mat", "]"}]}], ")"}]}], ")"}]}], ",", 
         "    ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Message", "[", 
            RowBox[{
             RowBox[{"CheckBasis", "::", "orthogonalsamenorm"}], ",", 
             "topleft"}], "]"}], ";", "False"}], ")"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"DiagonalQ", "[", "mat", "]"}], ",", "\[IndentingNewLine]", 
         "\t", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Message", "[", 
            RowBox[{
             RowBox[{"CheckBasis", "::", "orthogonaldiffnorm"}], ",", 
             RowBox[{"Diagonal", "[", "mat", "]"}]}], "]"}], ";", "False"}], 
          ")"}], ",", "\[IndentingNewLine]", "True", ",", 
         "\[IndentingNewLine]", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Message", "[", 
            RowBox[{"CheckBasis", "::", "notorthogonal"}], "]"}], ";", 
           "False"}], ")"}]}], "]"}]}], "\[IndentingNewLine]", ")"}]}], 
    "]"}]}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.430567581108365*^9, 3.430567588815233*^9}, {
   3.430567660266232*^9, 3.430567713048575*^9}, {3.434516920456045*^9, 
