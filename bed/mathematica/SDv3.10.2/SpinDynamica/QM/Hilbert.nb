Cell[CellGroupData[{

Cell["SetSpinSystem", "Subsection",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 AspectRatioFixed->
  True,ExpressionUUID->"03f3aa24-7f55-478e-bab5-b99e5247d6c1"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SetSpinSystem", "::", "usage"}], 
   "=", "\"\<SetSpinSystem[{{j,Ij},{k,Ik}..}] sets a spin system with labels \
j and k and spin quantum numbers Ij and Ik. For example, \
SetSpinSystem[{{1,1/2},{2,1}}] defines two spins, with labels 1 and 2 and \
spin quantum numbers 1/2 and 1 respectively. Shortcuts are available, for \
example: SetSpinSystem[3] sets up a set of 3 spins-1/2 with default labels 1, \
2 and 3.\>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.438873111535149*^9, 3.438873248583531*^9}, {
  3.682593958485556*^9, 3.682593972689973*^9}},
 CellLabel->"In[6]:=",ExpressionUUID->"b3b25869-658c-49fb-be72-cdd18246aae6"]
}, Closed]],

Cell[CellGroupData[{

Cell["SpinQuantumNumber", "Subsection",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 AspectRatioFixed->
  True,ExpressionUUID->"af4f0b1f-19a2-4ac2-bda2-30a5dadcf3ba"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SpinQuantumNumber", "::", "usage"}], " ", 
   "=", "\"\<SpinQuantumNumber[label] determines the angular momentum quantum \
number of the spin with the given label, in the current spin system.\>\""}], 
  ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.547025367811775*^9, 3.547025377782058*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"a2147afe-c269-438d-8926-01b7e6f33e58"]
}, Closed]],

