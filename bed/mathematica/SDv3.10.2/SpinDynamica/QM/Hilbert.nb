Cell[CellGroupData[{

Cell["MagneticQuantumNumber", "Subsection",
 InitializationCell->True,
 CellChangeTimes->{
  3.590234124973562*^9},ExpressionUUID->"bd58839a-8458-400b-9773-\
0249c0803c45"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"MagneticQuantumNumber", "::", "usage"}], 
   "=", "\"\<MagneticQuantumNumber[arg,spins] returns the magnetic quantum \
number (M-value) for the specified set of spins, for the object arg, which \
may be a Ket or a Bra. If spins is omitted, all spins are taken. \nIf the arg \
object contains several kets or bras, with different magnetic quantum \
numbers, a list of the M values is returned. \nThe syntax \
MagneticQuantumNumber[ket,{spins1, spins2..}] returns the sets of magnetic \
quantum numbers for each specified set of spins, and returns a list of the \
results.\>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.448291333690934*^9, 3.448291357780293*^9}, {
   3.448347658322262*^9, 3.448347678207681*^9}, {3.589974193838787*^9, 
