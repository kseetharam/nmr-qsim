   RowBox[{
    RowBox[{"Bra", "[", 
     RowBox[{"id_String", ",", 
      RowBox[{"spinsys_", "?", "MatrixQ"}], ",", "opts___Rule"}], "]"}], "/;",
     "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"!", 
       RowBox[{"TrueQ", "[", 
        RowBox[{
         RowBox[{"Validity", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "Bra", "]"}]}], "]"}]}], ")"}], "&&", 
     "\[IndentingNewLine]", 
     RowBox[{"StringMatchQ", "[", 
      RowBox[{"id", ",", 
       RowBox[{"Repeated", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"\"\<\[Alpha]\>\"", "|", "\"\<\[Beta]\>\""}], ")"}], ",", 
         RowBox[{"{", 
          RowBox[{"Length", "[", "spinsys", "]"}], "}"}]}], "]"}]}], "]"}], "&&",
      "\[IndentingNewLine]", 
