Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ProductBasis", "[", 
     RowBox[{"bases_List", ",", 
      RowBox[{"spinsys_", "?", "MatrixQ"}], ",", "opts___Rule"}], "]"}], "/;",
     "\[IndentingNewLine]", 
    RowBox[{"(", 
     RowBox[{"!", 
      RowBox[{"TrueQ", "[", 
       RowBox[{
        RowBox[{"Validity", "/.", 
         RowBox[{"{", "opts", "}"}]}], "/.", 
        RowBox[{"Options", "[", "ProductBasis", "]"}]}], "]"}]}], ")"}]}], ":=",
    "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"spinsystems", ",", "spins", ",", "comspins", ",", "totspins"}],
       "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"spinsystems", "=", 
        RowBox[{"SpinSystem", "/@", "bases"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"spins", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"First", "[", 
           RowBox[{"Transpose", "[", "#", "]"}], "]"}], "&"}], "/@", 
         "spinsystems"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"comspins", "=", 
        RowBox[{"Intersection", "@@", "spins"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"totspins", "=", 
        RowBox[{"Union", "@@", "spins"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Which", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"MatchQ", "[", 
           RowBox[{"comspins", ",", 
            RowBox[{"{", "}"}]}], "]"}]}], ",", "\[IndentingNewLine]", "\t", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Message", "[", 
            RowBox[{
             RowBox[{"ProductBasis", "::", "sharedspins"}], ",", "comspins"}],
             "]"}], ";", "$Failed"}], ")"}], ",", "\[IndentingNewLine]", 
         RowBox[{"!", 
          RowBox[{"And", "@@", 
           RowBox[{"(", 
            RowBox[{"DefinedBasisQ", "/@", "bases"}], ")"}]}]}], ",", 
         "\[IndentingNewLine]", "\t", 
         RowBox[{"(", 
          RowBox[{
