Cell["\<\
rearrange Mvals and spinsystem according to ordering in requested SpinSystem\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.625911791656616*^9, 3.625911826150445*^9}, {
   3.625918964329218*^9, 3.625918972225142*^9}, 3.632939777470308*^9, {
