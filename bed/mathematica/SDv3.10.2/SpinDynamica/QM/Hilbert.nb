 CellLabel->"In[93]:=",ExpressionUUID->"fdc04dd4-1681-43b3-9402-b42e811730d3"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"DefineBasis", "[", 
     RowBox[{"basis_", ",", "existingbasis_", ",", "opts___Rule"}], "]"}], "/;", 
    RowBox[{
     RowBox[{"MatchQ", "[", 
      RowBox[{"existingbasis", ",", 
       RowBox[{"Except", "[", "_List", "]"}]}], "]"}], "&&", 
     RowBox[{"!", 
      RowBox[{"DefinedBasisQ", "[", "existingbasis", "]"}]}]}]}], ":=", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"Message", "[", 
      RowBox[{
       RowBox[{"DefineBasis", "::", "undefbasis"}], ",", "basis", ",", 
       "existingbasis"}], "]"}], ";", "$Failed"}], ")"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.674991160650182*^9, 3.674991233316341*^9}, {
