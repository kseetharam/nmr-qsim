Cell[CellGroupData[{

Cell["BasisLabels", "Subsection",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.486386306202651*^9, 3.486386308457654*^9}, {
  3.486386614342316*^9, 3.486386614963355*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"9df41f75-9277-41ec-b226-68aeebd6f949"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"BasisLabels", "::", "usage"}], 
    "=", "\"\<BasisLabels is an option for the Hilbert space bases. If \
BasisLabels\[Rule]Automatic (default), the Kets and Bras may be referred to \
using integers running from 1 to the basis dimension. The option BasisLabels\
\[Rule]{a,b,c..} allows the integers or strings {a,b,c..} to be used to refer \
to the Kets and Bras. The operation BasisLabels[basis] may also be used to \
obtain the set of state labels defined for a particular basis.\>\""}], ";"}], 
  "   "}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.486386313532861*^9, 3.486386452254155*^9}, {
  3.486386618171278*^9, 3.486386671012261*^9}},
 CellLabel->"In[11]:=",ExpressionUUID->"295a98bb-318f-4443-a459-30de6d4f5b40"]
}, Closed]],

