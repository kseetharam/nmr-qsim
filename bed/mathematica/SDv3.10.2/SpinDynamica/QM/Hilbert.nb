     RowBox[{"ProductBasis", "[", 
      RowBox[{"bases", ",", "spinsys", ",", "___Rule"}], "]"}], "]"}], "=", 
    "\[IndentingNewLine]", 
    RowBox[{"Simplify", "@", 
