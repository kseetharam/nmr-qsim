          RowBox[{"SpinSystem", "/.", 
           RowBox[{"{", "opts", "}"}]}], "/.", 
          RowBox[{"Options", "[", "ProductBasis", "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"MatchQ", "[", 
         RowBox[{"spinsys", ",", 
          RowBox[{"_", "?", "MatrixQ"}]}], "]"}]}], "\[IndentingNewLine]", 
