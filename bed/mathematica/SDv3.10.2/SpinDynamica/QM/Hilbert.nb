 CellLabel->"In[24]:=",ExpressionUUID->"f530534b-1eae-41b3-b9e3-10b4d0a18f33"]
}, Closed]],

Cell[CellGroupData[{

Cell["Eigenbasis", "Subsection",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.42968234673812*^9, 3.429682350151795*^9}, {
  3.502016119081449*^9, 3.502016122695365*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"bc26d777-6b80-4474-8bc5-95c1b468e3a8"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Eigenbasis", "::", "usage"}], " ", "=", 
   " ", "\"\<Eigenbasis[op] defines a basis of eigenkets for the operator op. \
The option TargetBasis may be used to control the ordering of the eigenkets, \
so that they have the best possible match to the kets of the TargetBasis. \
Execute ?TargetBasis for details.\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.547025529277066*^9, 3.547025539852783*^9}, {
  3.756305052696478*^9, 3.7563051579440813`*^9}, {3.7563051983106623`*^9, 
  3.756305220298723*^9}, {3.756305323656301*^9, 3.756305341669031*^9}},
 CellLabel->"In[25]:=",ExpressionUUID->"9768ce95-2a8c-4117-bc8e-6dcf13f78bc0"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"TargetBasis", "::", "usage"}], 
   "=", "\"\<TargetBasis is an option for Eigenbasis, allowing control over \
the order of eigenkets generated by Eigenbasis. In general, \
Eigenbasis[op,TargetBasis\[Rule]basis] generates the eigenbasis of the \
operator op, but with the kets of the eigenbasis ordered in such a way as to \
match most closely the kets of the TargetBasis.\n\>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.448291333690934*^9, 3.448291357780293*^9}, {
   3.50410982710646*^9, 3.504109860910949*^9}, {3.504110177020758*^9, 
   3.504110189617758*^9}, {3.531829191563922*^9, 3.5318291919915*^9}, {
   3.531829256245398*^9, 3.531829349850441*^9}, 3.5319270345165243`*^9, {
   3.531927158408794*^9, 3.5319271595917683`*^9}, 3.547025716497306*^9, {
   3.586080111366419*^9, 3.58608019735291*^9}, {3.586083819447632*^9, 
   3.586083823366138*^9}, {3.586084049255663*^9, 3.586084154661208*^9}, {
   3.586089010983004*^9, 3.586089011938239*^9}, {3.756030129808923*^9, 
   3.756030139895711*^9}, {3.756304862325273*^9, 3.756304895756662*^9}, {
   3.756304945130779*^9, 3.756305026100646*^9}, {3.756305233994988*^9, 
   3.756305253120253*^9}},
 CellLabel->"In[26]:=",ExpressionUUID->"b78f5992-0564-441e-aec2-c3fbbbe9501c"]
}, Closed]],

Cell[CellGroupData[{

Cell["ProductBasis", "Subsection",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.42968234673812*^9, 3.429682350151795*^9}, {
  3.502016119081449*^9, 3.502016122695365*^9}, {3.623913665335273*^9, 
  3.623913668325341*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"656d8810-841d-47dc-912e-b03ca7920126"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ProductBasis", "::", "usage"}], " ", "=", 
   " ", "\"\<ProductBasis[basis1,basis2..] defines a basis of product kets \
constructed from the kets of the argument bases. The kets of the product \
basis is ordered so that the kets of basis1 form the innermost loop.\n The \
SpinSystem option may be used to set the spin system of the ProductBasis. The \
default is SpinSystem\[Rule]Automatic which uses the current SpinSystem[] if \
possible, and otherwise uses a SpinSystem derived from the spin systems of \
the component bases. \>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.547025529277066*^9, 3.547025539852783*^9}, {
   3.623913671463773*^9, 3.623913743165023*^9}, {3.623917461758579*^9, 
   3.623917494042832*^9}, {3.804141667765543*^9, 3.804141788399252*^9}, 
   3.804143291135151*^9, {3.804145903944784*^9, 
   3.804145905614011*^9}},ExpressionUUID->"9769dfdf-b465-418f-800b-\
0a20e8192f72"]
}, Closed]]
}, Closed]],

