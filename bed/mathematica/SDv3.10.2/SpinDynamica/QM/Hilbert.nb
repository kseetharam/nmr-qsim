Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ProductBasis", "[", 
     RowBox[{"bases_List", ",", "opts___Rule"}], "]"}], "/;", 
    RowBox[{"MatchQ", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"SpinSystem", "/.", 
        RowBox[{"{", "opts", "}"}]}], "/.", 
       RowBox[{"Options", "[", "ProductBasis", "]"}]}], ",", "Automatic"}], 
     "]"}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"currspinsys", ",", "joinedspinsys", ",", "spinsys"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"currspinsys", "=", 
        RowBox[{"SpinSystem", "[", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"joinedspinsys", "=", 
        RowBox[{"Join", "@@", 
         RowBox[{"(", 
          RowBox[{"SpinSystem", "/@", "bases"}], ")"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"spinsys", "=", "\[IndentingNewLine]", 
        RowBox[{"Which", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"currspinsys", "==", "joinedspinsys"}], ",", 
          "\[IndentingNewLine]", "\t", "currspinsys", ",", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"Sort", "[", 
            RowBox[{"First", "/@", "currspinsys"}], "]"}], "==", 
           RowBox[{"Sort", "[", 
            RowBox[{"First", "/@", "joinedspinsys"}], "]"}]}], ",", 
          "\[IndentingNewLine]", "\t", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Message", "[", 
             RowBox[{"ProductBasis", "::", "usecurrspinsys"}], "]"}], ";", 
            "currspinsys"}], ")"}], ",", "\[IndentingNewLine]", "True", ",", 
          "\[IndentingNewLine]", "\t", "joinedspinsys"}], 
         "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"ProductBasis", "[", 
        RowBox[{"bases", ",", "\[IndentingNewLine]", 
         RowBox[{"SimplifyRules", "[", 
          RowBox[{
           RowBox[{"SpinSystem", "\[Rule]", "spinsys"}], ",", "opts"}], 
          "]"}]}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
      ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
