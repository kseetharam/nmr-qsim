Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ProductBasis", "[", 
    RowBox[{"bases_List", ",", "opts___Rule"}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"spinsys", ",", "joinedspinsys"}], "}"}], ",", 
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"joinedspinsys", "=", 
         RowBox[{"Join", "@@", 
          RowBox[{"(", 
           RowBox[{"SpinSystem", "/@", "bases"}], ")"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"!", 
           RowBox[{"SameQ", "[", 
            RowBox[{
             RowBox[{"Sort", "[", 
              RowBox[{"First", "/@", "spinsys"}], "]"}], ",", 
