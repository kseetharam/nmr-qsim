Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Bra", "::", "usage"}], "=", 
   "\[IndentingNewLine]", "\"\<Bra[specification,spinsystem] defines a Bra in \
the specified spinsystem.\nIf spinsystem is omitted, the current SpinSystem[] \
is used. Otherwise, spinsystem has the syntax {{j,Ij},{k,Ik}..} where {j,k..} \
are spin labels and {Ij,Ik..} are spin quantum numbers. \nspecification may \
be:\n* a single symbol, which indicates a state label in the current Basis[]. \
For example, if the default ZeemanBasis[] is used, the value of specification \
may be an integer {1,2..}, numbering the bras in the current basis;\n* a \
string of the form \\\"\[Alpha]\[Alpha]..\[Beta]\\\" indicating magnetic \
quantum numbers \[PlusMinus]1/2, in the case of spins-1/2;\n* a list of the \
form {{j,Mj},{k,Mk}..} where {j,k..} are spin labels and {Mj,Mk..} are \
magnetic quantum numbers. The spin labels must correspond to those specified \
in the spinsystem argument.\n\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.674285083180787*^9, 3.67428560022798*^9}},
 CellLabel->"In[30]:=",ExpressionUUID->"ecb02c63-a21d-442e-867f-3b3f63a74de0"]
