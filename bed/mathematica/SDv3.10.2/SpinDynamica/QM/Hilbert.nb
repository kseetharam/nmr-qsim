Cell[CellGroupData[{

Cell["ZeemanBasis", "Subsubsection",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 AspectRatioFixed->
  True,ExpressionUUID->"a58413b0-3130-43e1-9ca8-6804853aae4a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ZeemanBasis", "::", "usage"}], " ", "=", 
   " ", "\"\<ZeemanBasis[{{1,1/2},{2,1/2},{3,1}}] defines a Zeeman product \
basis for spins with indices 1, 2 and 3 and spins 1/2, 1/2, 1 respectively. \
The list of spins must be ordered. ZeemanBasis[] defines a Zeeman product \
basis for the current spin system.\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.547025474335778*^9, 3.5470254876691837`*^9}},
 CellLabel->"In[21]:=",ExpressionUUID->"3ee6aa57-04ce-4a4f-824a-9ce59df61d7e"]
}, Closed]],

Cell[CellGroupData[{

Cell["SingletTripletBasis", "Subsubsection",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 AspectRatioFixed->
  True,ExpressionUUID->"23c66396-d020-42c6-86ab-9a0092bddf77"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SingletTripletBasis", "::", "usage"}], " ", "=", 
   " ", "\"\<SingletTripletBasis[{1,2}] defines a singlet-triplet basis for \
spins with indices 1 and 2. This is currently available only for 2-spin-1/2 \
systems.\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.54702549531077*^9, 3.547025503512613*^9}},
 CellLabel->"In[22]:=",ExpressionUUID->"fcec8e17-0959-4dda-98f5-7dcd92c8850c"]
}, Closed]],

Cell[CellGroupData[{

Cell["AngularMomentumBasis", "Subsubsection",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.770635466811578*^9, 3.770635469002675*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"11b1a1b8-519a-440f-8498-ebffe365e3c1"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"AngularMomentumBasis", "::", "usage"}], " ", "=", 
   " ", "\"\<AngularMomentumBasis[{{1,1/2},{2,1/2},{3,1}, ...}] couples the \
angular momentum of all present spins to generate the eigenbasis of the \
total- and z-angular momentum operator. The list of spins must be ordered. \
AngularMomentumBasis[] defines the coupled basis for the current spin system.\
\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.547025474335778*^9, 3.5470254876691837`*^9}, {
  3.770635478346826*^9, 3.770635575248198*^9}},
 CellLabel->"In[23]:=",ExpressionUUID->"3b4a6497-4763-42a8-91ea-a47c042a9724"]
}, Closed]]
}, Closed]],

Cell[CellGroupData[{

Cell["TransformedBasis", "Subsection",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.42968234673812*^9, 3.429682350151795*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"092e7c3c-13d4-45c1-af49-85831bbf052a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"TransformedBasis", "::", "usage"}], " ", 
   "=", "\"\<TransformedBasis[op,basis] defines a basis in which the kets are \
composed by applying the operator op to the kets of basis. \
TransformedBasis[op] generates a transformation of the current basis.\>\""}], 
  ";"}]], "Input",
 InitializationCell->True,
