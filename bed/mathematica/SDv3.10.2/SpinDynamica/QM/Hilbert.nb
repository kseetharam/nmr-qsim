Cell["\<\
this happens if the set of spin labels used for the kets is the same as in \
spinsystem, but in the wrong order.  \
\>", "Text",
 CellChangeTimes->{{3.695467516269975*^9, 
  3.695467574755065*^9}},ExpressionUUID->"b504bbff-e859-43e5-9f41-\
eea5ac903e94"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Ket", "[", 
    RowBox[{
     RowBox[{"jmpairs_", "?", "MatrixQ"}], ",", 
     RowBox[{"spinsystem_", "?", "MatrixQ"}], ",", "opts___Rule"}], "]"}], ":=",
    "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"spinlabels", ",", "ketspinlabels", ",", "perm"}], "}"}], ",", 
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"perm", "=", 
         RowBox[{"SparseArray", "[", "\[IndentingNewLine]", 
          RowBox[{"Inner", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"List", "[", 
                RowBox[{"#1", ",", "#2"}], "]"}], "\[Rule]", "1"}], ")"}], 
             "&"}], ",", 
            RowBox[{"Ordering", "[", "spinlabels", "]"}], ",", 
            RowBox[{"Ordering", "[", "ketspinlabels", "]"}], ",", "List"}], 
           "]"}], "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
        
        RowBox[{"Ket", "[", 
         RowBox[{
          RowBox[{"perm", ".", "jmpairs"}], ",", "spinsystem", ",", "opts"}], 
         "]"}]}], "\[IndentingNewLine]", ")"}], "/;", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"!", 
          RowBox[{"TrueQ", "[", 
           RowBox[{
            RowBox[{"Validity", "/.", 
             RowBox[{"{", "opts", "}"}]}], "/.", 
            RowBox[{"Options", "[", "Ket", "]"}]}], "]"}]}], ")"}], "&&", 
        RowBox[{"(", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"spinlabels", "=", 
           RowBox[{"First", "/@", "spinsystem"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"ketspinlabels", "=", 
           RowBox[{"First", "/@", "jmpairs"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"spinlabels", "\[NotEqual]", "ketspinlabels"}], ")"}], "&&",
            "\[IndentingNewLine]", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"Sort", "[", "spinlabels", "]"}], "\[Equal]", 
             RowBox[{"Sort", "[", "ketspinlabels", "]"}]}], ")"}]}]}], 
         "\[IndentingNewLine]", ")"}]}], "\[IndentingNewLine]", ")"}]}]}], 
    "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.547013754085935*^9, 3.54701385891964*^9}, {
