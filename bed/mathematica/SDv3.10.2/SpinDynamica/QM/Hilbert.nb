  RowBox[{
   RowBox[{"SetSpinSystem", "[", 
    RowBox[{"spinsys_", "?", "MatrixQ"}], "]"}], ":=", "\[IndentingNewLine]", 
   
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"labels", ",", "Ivals", ",", "invalIvals"}], "}"}], ",", 
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Message", "[", 
         RowBox[{
          RowBox[{"SetSpinSystem", "::", "invalI"}], ",", "invalIvals"}], 
         "]"}], ";", "$Failed"}], "\[IndentingNewLine]", ")"}], "/;", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{"labels", ",", "Ivals"}], "}"}], "=", 
         RowBox[{"Transpose", "[", "spinsys", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"invalIvals", "=", 
         RowBox[{"Select", "[", 
          RowBox[{"Ivals", ",", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"!", 
               RowBox[{"IntegerQ", "[", 
                RowBox[{"2", "#"}], "]"}]}], "||", 
              RowBox[{"Negative", "[", "#", "]"}]}], ")"}], "&"}]}], "]"}]}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Length", "[", "invalIvals", "]"}], "\[NotEqual]", "0"}]}], 
       "\[IndentingNewLine]", ")"}]}]}], "]"}]}], ";"}]], "Input",
