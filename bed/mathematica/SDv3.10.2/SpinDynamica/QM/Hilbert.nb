Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Bra", "[", 
    RowBox[{
     RowBox[{"bras_", "?", "MatrixQ"}], ",", 
     RowBox[{"spinsystem_", "?", "MatrixQ"}], ",", "opts___Rule"}], "]"}], ":=",
    "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"spinlabels", ",", "braspinlabels", ",", "perm"}], "}"}], ",", 
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"perm", "=", 
         RowBox[{"SparseArray", "[", "\[IndentingNewLine]", 
          RowBox[{"Inner", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"List", "[", 
                RowBox[{"#1", ",", "#2"}], "]"}], "\[Rule]", "1"}], ")"}], 
             "&"}], ",", 
            RowBox[{"Ordering", "[", "spinlabels", "]"}], ",", 
            RowBox[{"Ordering", "[", "braspinlabels", "]"}], ",", "List"}], 
           "]"}], "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
        
        RowBox[{"Bra", "[", 
         RowBox[{
          RowBox[{"perm", ".", "bras"}], ",", "spinsystem", ",", "opts"}], 
         "]"}]}], "\[IndentingNewLine]", ")"}], "/;", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"!", 
          RowBox[{"TrueQ", "[", 
           RowBox[{
            RowBox[{"Validity", "/.", 
             RowBox[{"{", "opts", "}"}]}], "/.", 
            RowBox[{"Options", "[", "Bra", "]"}]}], "]"}]}], ")"}], "&&", 
        RowBox[{"(", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"spinlabels", "=", 
           RowBox[{"First", "/@", "spinsystem"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"braspinlabels", "=", 
           RowBox[{"First", "/@", "bras"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"spinlabels", "\[NotEqual]", "braspinlabels"}], ")"}], "&&",
            "\[IndentingNewLine]", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"Sort", "[", "spinlabels", "]"}], "\[Equal]", 
             RowBox[{"Sort", "[", "braspinlabels", "]"}]}], ")"}]}]}], 
         "\[IndentingNewLine]", ")"}]}], "\[IndentingNewLine]", ")"}]}]}], 
    "]"}]}], ";"}]], "Input",
 InitializationCell->True,
