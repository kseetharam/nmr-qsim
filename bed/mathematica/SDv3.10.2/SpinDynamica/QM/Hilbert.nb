Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"DefineBasis", "[", 
    RowBox[{"basis_", ",", 
     RowBox[{"existingbasis_", "?", "DefinedBasisQ"}], ",", "opts___Rule"}], 
    "]"}], ":=", 
   RowBox[{"DefineBasis", "[", 
    RowBox[{"basis", ",", 
     RowBox[{"BasisKets", "[", "existingbasis", "]"}], ",", "opts"}], "]"}]}],
   ";"}]], "Input",
