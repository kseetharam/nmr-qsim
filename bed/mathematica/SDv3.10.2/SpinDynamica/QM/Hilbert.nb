    RowBox[{
     RowBox[{"(", 
      RowBox[{"!", 
       RowBox[{"TrueQ", "[", 
        RowBox[{
         RowBox[{"Validity", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "Ket", "]"}]}], "]"}]}], ")"}], "&&", 
     "\[IndentingNewLine]", 
     RowBox[{"StringMatchQ", "[", 
      RowBox[{"id", ",", 
       RowBox[{"Repeated", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"\"\<\[Alpha]\>\"", "|", "\"\<\[Beta]\>\""}], ")"}], ",", 
         RowBox[{"{", 
          RowBox[{"Length", "[", "spinsys", "]"}], "}"}]}], "]"}]}], "]"}], "&&",
      "\[IndentingNewLine]", 
     RowBox[{"MatchQ", "[", 
      RowBox[{
       RowBox[{"Last", "/@", "spinsys"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"1", "/", "2"}], ".."}], "}"}]}], "]"}]}]}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Ket", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"MapThread", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"#1", ",", 
          RowBox[{"Switch", "[", 
           RowBox[{"#2", ",", "\"\<\[Alpha]\>\"", ",", 
            RowBox[{"1", "/", "2"}], ",", "\"\<\[Beta]\>\"", ",", 
            RowBox[{
             RowBox[{"-", "1"}], "/", "2"}]}], "]"}]}], "}"}], "&"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"First", "/@", "spinsys"}], ",", 
         RowBox[{"Characters", "[", "id", "]"}]}], "}"}]}], "]"}], ",", 
     "\[IndentingNewLine]", "spinsys", ",", "\[IndentingNewLine]", 
     RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Validity", "\[Rule]", "True"}], ",", "\[IndentingNewLine]", 
       "opts"}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
    "]"}]}], ";"}]], "Input",
