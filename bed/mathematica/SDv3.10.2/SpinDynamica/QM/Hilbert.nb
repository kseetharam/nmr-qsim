Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"UndefineBasis", "[", "basis_", "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "btmdefs", "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Quiet", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"BasisKets", "[", "basis", "]"}], "=."}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"BasisBras", "[", "basis", "]"}], "=."}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"BasisDimension", "[", "basis", "]"}], "=."}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"BasisLabels", "[", "basis", "]"}], "=."}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"btmdefs", "=", 
          RowBox[{"Select", "[", 
           RowBox[{
            RowBox[{"DownValues", "[", "BasisTransformationMatrix", "]"}], ",", 
            RowBox[{
             RowBox[{"FreeQ", "[", 
              RowBox[{"#", ",", "basis"}], "]"}], "&"}]}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"Clear", "[", "BasisTransformationMatrix", "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"DownValues", "[", "BasisTransformationMatrix", "]"}], "=", 
          "btmdefs"}], ";", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"DefinedBasisQ", "[", "basis", "]"}], "=", "False"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"CheckedBasisQ", "[", "basis", "]"}], "=", "False"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"SetOptions", "[", 
          RowBox[{"UnassignedSymbols", ",", "\[IndentingNewLine]", "\t", 
           RowBox[{"PermittedSymbols", "->", 
            RowBox[{"Cases", "[", 
             RowBox[{
              RowBox[{"PermittedSymbols", "/.", 
               RowBox[{"Options", "[", "UnassignedSymbols", "]"}]}], ",", 
