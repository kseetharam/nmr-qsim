 RowBox[{
  RowBox[{
   RowBox[{"Options", "[", "DefineBasis", "]"}], "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"CheckBasis", "->", "True"}], ",", " ", 
     RowBox[{"BasisLabels", "\[Rule]", "Automatic"}]}], "}"}]}], 
  ";"}]], "Input",
