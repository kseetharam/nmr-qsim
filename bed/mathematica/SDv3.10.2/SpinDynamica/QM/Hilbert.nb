Cell[CellGroupData[{

Cell["DefineBasis", "Subsection",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.4388524571721783`*^9, 3.438852465651808*^9}, 
   3.4483571957211647`*^9, {3.683189603033992*^9, 3.683189612189409*^9}, 
   3.68318965988424*^9},
 AspectRatioFixed->
  True,ExpressionUUID->"2131595a-3fc2-42b3-9804-dd454ba5d9aa"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"DefineBasis", "::", "usage"}], 
   "=", "\"\<DefineBasis[newbasis,{ket1,ket2,..},opts] defines a state basis \
which may be used for operator matrix representations. The option CheckBasis\
\[Rule]True may be used to check its suitability. \nThe syntax \
DefineBasis[newbasis,existingbasis], where basis is the name of an already \
defined basis, sets the basis kets of newbasis to be equal to the basis kets \
of existingbasis.\n\>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.438852469414063*^9, 3.43885250300457*^9}, {
   3.473172448897842*^9, 3.473172451434535*^9}, 3.547024928259735*^9, {
   3.561355398347836*^9, 3.5613554162341423`*^9}, {3.674990946132768*^9, 
   3.674991007906126*^9}, 3.674991041380299*^9},
 CellLabel->"In[13]:=",ExpressionUUID->"5fd77777-0837-48b5-a7e7-a2d7c014c270"]
}, Closed]],

