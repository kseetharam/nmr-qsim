            RowBox[{"prevspinsys", ",", "spinsys"}], "]"}]}]}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"SetBasis", "[", 
          RowBox[{"ZeemanBasis", "[", "spinsys", "]"}], "]"}]}], 
