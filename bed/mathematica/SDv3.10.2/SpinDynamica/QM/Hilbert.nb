Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"BasisKets", "[", 
    RowBox[{"ZeemanBasis", "[", 
     RowBox[{
      RowBox[{"spinsys_", "?", "MatrixQ"}], ",", "opts___Rule"}], "]"}], 
    "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "states", "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"states", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"First", "[", "#", "]"}], ",", "m"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"m", ",", 
              RowBox[{"Last", "[", "#", "]"}], ",", 
              RowBox[{"-", 
               RowBox[{"Last", "[", "#", "]"}]}], ",", 
              RowBox[{"-", "1"}]}], "}"}]}], "]"}], "&"}], "/@", 
         "spinsys"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"Ket", "[", 
          RowBox[{
           RowBox[{"Reverse", "[", "#", "]"}], ",", "spinsys", ",", 
           RowBox[{"Check", "\[Rule]", "False"}]}], "]"}], "&"}], "/@", 
        RowBox[{"Flatten", "[", 
         RowBox[{
          RowBox[{"Outer", "[", 
           RowBox[{"List", ",", 
            RowBox[{"Sequence", "@@", 
             RowBox[{"Reverse", "[", "states", "]"}]}], ",", "1"}], "]"}], ",", 
          RowBox[{
           RowBox[{"Length", "[", "spinsys", "]"}], "-", "1"}]}], "]"}]}]}], 
