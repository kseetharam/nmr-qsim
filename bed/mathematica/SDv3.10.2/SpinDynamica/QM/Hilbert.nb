Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"DefineBasis", "[", 
    RowBox[{"basis_", ",", "kets_List", ",", "opts___Rule"}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"check", ",", "basislabels", ",", "unasssymbs"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"check", "=", 
        RowBox[{
         RowBox[{"CheckBasis", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "DefineBasis", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"basislabels", "=", 
        RowBox[{
         RowBox[{"BasisLabels", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "DefineBasis", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"unasssymbs", "=", 
        RowBox[{"UnassignedSymbols", "[", "kets", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "unasssymbs", "]"}], "\[NotEqual]", "0"}], ",",
          "\[IndentingNewLine]", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Message", "[", 
            RowBox[{
             RowBox[{"DefineBasis", "::", "unasssymb"}], ",", "unasssymbs"}], 
            "]"}], ";", "\[IndentingNewLine]", 
           RowBox[{"check", "=", "False"}]}], ")"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"BasisKets", "[", "basis", "]"}], "=", "kets"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"BasisBras", "[", "basis", "]"}], "=", 
        RowBox[{"Adjoint", "/@", "kets"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"BasisDimension", "[", "basis", "]"}], "=", 
        RowBox[{"Length", "[", "kets", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"BasisLabels", "[", "basis", "]"}], "=", "basislabels"}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"Which", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"check", "&&", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"CheckedBasisQ", "[", "basis", "]"}], "||", 
            RowBox[{"CheckBasis", "[", "basis", "]"}]}], ")"}]}], ",", 
         "\[IndentingNewLine]", "\t", 
         RowBox[{"(", "\[IndentingNewLine]", "\t", 
          RowBox[{
           RowBox[{
            RowBox[{"DefinedBasisQ", "[", "basis", "]"}], "=", "True"}], ";", 
           "\[IndentingNewLine]", "\t", 
           RowBox[{
            RowBox[{"CheckedBasisQ", "[", "basis", "]"}], "=", "True"}], ";", 
           "\[IndentingNewLine]", "\t", 
           RowBox[{"SetOptions", "[", 
            RowBox[{"UnassignedSymbols", ",", "\[IndentingNewLine]", "\t", 
             RowBox[{"PermittedSymbols", "->", 
              RowBox[{"Append", "[", 
               RowBox[{
                RowBox[{"PermittedSymbols", "/.", 
                 RowBox[{"Options", "[", "UnassignedSymbols", "]"}]}], ",", 
                "basis"}], "]"}]}]}], "]"}], ";", "\[IndentingNewLine]", "\t", 
           RowBox[{
            RowBox[{"SpinSystem", "[", "basis", "]"}], "^=", 
            RowBox[{"SpinSystem", "[", "]"}]}], ";", "\[IndentingNewLine]", 
           "\t", 
           RowBox[{"Message", "[", 
            RowBox[{
             RowBox[{"DefineBasis", "::", "defined"}], ",", "basis"}], "]"}], 
           ";"}], "\[IndentingNewLine]", "\t", ")"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"check", "&&", 
          RowBox[{"!", 
           RowBox[{"CheckedBasisQ", "[", "basis", "]"}]}], "&&", 
          RowBox[{"!", 
           RowBox[{"CheckBasis", "[", "basis", "]"}]}]}], ",", 
         "\[IndentingNewLine]", "\t", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Message", "[", 
            RowBox[{
             RowBox[{"DefineBasis", "::", "notdefined"}], ",", "basis"}], 
            "]"}], ";", "\[IndentingNewLine]", "\t", 
           RowBox[{"UndefineBasis", "[", "basis", "]"}], ";", 
           "\[IndentingNewLine]", "\t", 
           RowBox[{
            RowBox[{"DefinedBasisQ", "[", "basis", "]"}], "=", "False"}], ";",
            "\[IndentingNewLine]", "\t", "$Failed"}], "\[IndentingNewLine]", 
          "\t", ")"}], ",", "\[IndentingNewLine]", "True", ",", 
         "\[IndentingNewLine]", "\t", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Message", "[", 
            RowBox[{
             RowBox[{"DefineBasis", "::", "nocheck"}], ",", "basis"}], "]"}], 
           ";", "\[IndentingNewLine]", "\t", 
           RowBox[{"Message", "[", 
            RowBox[{
             RowBox[{"DefineBasis", "::", "defined"}], ",", "basis"}], "]"}], 
           ";", "\[IndentingNewLine]", "\t", 
           RowBox[{
            RowBox[{"DefinedBasisQ", "[", "basis", "]"}], "=", "True"}], ";", 
           "\[IndentingNewLine]", "\t", 
           RowBox[{
            RowBox[{"CheckedBasisQ", "[", "basis", "]"}], "=", "False"}], ";",
            "\[IndentingNewLine]", "\t", 
           RowBox[{
            RowBox[{"SpinSystem", "[", "basis", "]"}], "^=", 
            RowBox[{"SpinSystem", "[", "]"}]}], ";"}], "\[IndentingNewLine]", 
          "\t", ")"}]}], "\[IndentingNewLine]", "]"}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.43885283050099*^9, 3.4388528821828737`*^9}, {
   3.4388530399474373`*^9, 3.438853075966858*^9}, {3.4388720778121853`*^9, 
