     RowBox[{"{", 
      RowBox[{
      "sdopsites", ",", "xopbsites", ",", "sdops", ",", "uniqueops", ",", 
       "ops", ",", "uniqueoppos", ",", "uniqueopvecreps", ",", "opbasis"}], 
      "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"sdopsites", ",", "sdops"}], "}"}], "=", 
        RowBox[{"Transpose", "@", 
         RowBox[{"First", "@", "sdop"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"xopbsites", "=", 
        RowBox[{"Sites", "[", "xopb", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"opbasis", "=", 
        RowBox[{"OperatorBasis", "[", "xopb", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"uniqueops", "=", 
        RowBox[{"First", "/@", 
         RowBox[{"Tally", "[", 
          RowBox[{"Append", "[", 
           RowBox[{"sdops", ",", 
