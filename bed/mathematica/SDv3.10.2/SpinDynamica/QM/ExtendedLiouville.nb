Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"KineticExchangeMatrix", "[", 
    RowBox[{"sites_List", ",", 
     RowBox[{"rulekvallist", ":", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"_Rule", ",", "_"}], "}"}], "..."}], "}"}]}], ",", 
     "opts___Rule"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"rules", ",", "kvals", ",", "symmrulekvallist"}], "}"}], ",", 
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{"KineticExchangeMatrix", "[", 
        RowBox[{"sites", ",", "symmrulekvallist", ",", "opts"}], "]"}], 
       "\[IndentingNewLine]", ")"}], "/;", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{"rules", ",", "kvals"}], "}"}], "=", 
         RowBox[{"Transpose", "@", "rulekvallist"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"symmrulekvallist", "=", 
         RowBox[{"First", "/@", 
          RowBox[{"GatherBy", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"Join", "[", 
             RowBox[{"rulekvallist", ",", 
              RowBox[{"Transpose", "[", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"Reverse", "/@", "rules"}], ",", "kvals"}], "}"}], 
               "]"}]}], "]"}], ",", "First"}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"!", 
         RowBox[{"MatchQ", "[", 
          RowBox[{
           RowBox[{"Sort", "[", 
            RowBox[{"First", "/@", "symmrulekvallist"}], "]"}], ",", 
           RowBox[{"Sort", "[", 
            RowBox[{"First", "/@", "rulekvallist"}], "]"}]}], "]"}]}]}], 
       "\[IndentingNewLine]", ")"}]}]}], "]"}]}], ";"}]], "Input",
