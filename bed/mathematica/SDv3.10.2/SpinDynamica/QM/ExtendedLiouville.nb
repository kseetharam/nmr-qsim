              "\[IndentingNewLine]", 
              RowBox[{"NullOperator", "[", "]"}]}], "\[IndentingNewLine]", 
             "]"}]}], "\[IndentingNewLine]", "]"}], "/@", "xopbsites"}], 
         "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"uniqueoppos", "=", 
        RowBox[{"Flatten", "[", 
         RowBox[{
          RowBox[{
