Cell[CellGroupData[{

Cell["KineticExchangeMatrix", "Section",
 InitializationCell->True,
 CellChangeTimes->{{3.696760539870386*^9, 
  3.6967605528186617`*^9}},ExpressionUUID->"3a3b12cd-45b9-472e-a14a-\
04aa52c1bc43"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"KineticExchangeMatrix", "::", "usage"}], "=", 
   "\[IndentingNewLine]", 
   "\"\<KineticExchangeMatrix[{i,j..},K,options] defines a kinetic exchange \
matrix for dynamic exchange between the sites {i,j..}. The argument K may be \
be one of the following: (1) A square matrix of dimension equal to the number \
of exchanging sites, with elements given by the kinetic rate constants; (2) A \
list of the form {{i\[Rule]j,kji},{l\[Rule]m,kml}..} in which the rate \
constant kji for the conversion of site i into site j is specified \
explicitly, and similarly for the other rate constants. If the list contains \
an element of the form {i\[Rule]j,kji}, but no element for the opposite \
transformation {j\[Rule]i,kij}, the routine assumes kij=kji, i.e. symmetrical \
rate constants between sites i and j. Asymmetrical rate constants between i \
and j are defined by including elements of both forms {i\[Rule]j,kji} and {j\
\[Rule]i,kij}. \nIf the sites {i,j..} are omitted, the sites are taken from \
the current Sites[].\\nThe options may include \
ImposeDetailedBalance\[Rule]True may be used to impose detailed balance \
automatically by adjustment of the diagonal elements. The default is \
ImposeDetailedBalance\[Rule]True.\nThe output of KineticExchangeMatrix has \
the form KineticExchangeMatrix[{i,j..},matrix,options] where matrix is the \
resulting kinetic exchange matrix (as a SparseArray object). \nThe raw \
kinetic matrix may be extracted by applying Expand to the result.\>\""}], 
  ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.696760145210371*^9, 3.6967605624694633`*^9}, {
   3.6967606124540462`*^9, 3.696760613376444*^9}, {3.713340617433261*^9, 
   3.713340620095624*^9}, {3.714372581183305*^9, 3.714372587580288*^9}, {
   3.7143806203836823`*^9, 3.714380686435903*^9}, {3.714386804859247*^9, 
   3.714386871650673*^9}, 3.714401597609281*^9, {3.714401713078907*^9, 
   3.714402076731064*^9}, {3.71465019511032*^9, 3.714650300448206*^9}, 
   3.714650338974455*^9},ExpressionUUID->"13759527-3e96-416b-bed5-\
945a8be69ef9"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ImposeDetailedBalance", "::", "usage"}], "=", 
   "\"\<ImposeDetailedBalance is an option value for KineticExchangeMatrix. \
If ImposeDetailedBalance\[Rule]True, detailed kinetic balance is \
automatically imposed by adjusting the diagonal elements of the kinetic \
exchange matrix.\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.696760576409285*^9, 
  3.69676068649081*^9}},ExpressionUUID->"983ceb7d-edf4-4758-8be4-\
8e854a6f04d8"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"DetailedBalance", "::", "usage"}], "=", 
   "\"\<DetailedBalance is an option value for KineticExchangeMatrix. It is \
set to True when the KineticExchangeMatrix possesses detailed balance.\>\""}],
   ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.696760576409285*^9, 3.69676068649081*^9}, {
  3.7143789862639923`*^9, 
  3.7143790253504667`*^9}},ExpressionUUID->"614680e4-ec92-43f9-8192-\
f99826de2079"]
}, Closed]],

