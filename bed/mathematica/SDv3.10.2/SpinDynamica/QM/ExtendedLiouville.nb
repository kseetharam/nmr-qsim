Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SiteDependentOperator", "::", "usage"}], "=", 
   "\[IndentingNewLine]", 
   "\"\<SiteDependentOperator[{{i,opi},{j,opj}..}] defines an operator which \
depends on the site indices {i,j..}. The set of sites {i,j..} must be a \
subset of Sites[]. The syntax SiteDependentOperator[{i,opi}] defines an \
operator which applies to just one of the sites. The syntax \
SiteDependentOperator[op] assumes that the operator applies to all sites. \
\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.696759610347431*^9, 3.696759641360589*^9}, {
  3.696759678767851*^9, 3.6967598417831163`*^9}, {3.713365483967828*^9, 
  3.713365496157132*^9}, {3.713596925675501*^9, 3.7135971068937187`*^9}, {
  3.713602364650424*^9, 
  3.7136023868174562`*^9}},ExpressionUUID->"bfc7e0fa-2c03-41e8-9b16-\
791d73aa91ff"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ExtendedOperatorVectorRepresentation", "::", "usage"}], "=", 
   "\"\<ExtendedOperatorVectorRepresentation[<sdop>,<xopb>] derives the \
vector representation of a SiteDependentOperator <sdop> in the \
ExtendedOperatorBasis <xopb>. If <xopb> is omitted, the current \
ExtendedOperatorBasis is used.\n\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.696759610347431*^9, 3.696759641360589*^9}, {
  3.696759678767851*^9, 3.6967598417831163`*^9}, {3.713365483967828*^9, 
  3.713365496157132*^9}, {3.713367219185351*^9, 3.713367299407853*^9}, {
  3.713367348747473*^9, 
  3.713367371278051*^9}},ExpressionUUID->"f4ce9aef-3fa0-4539-a463-\
df3b1a7e3f73"]
}, Closed]],

