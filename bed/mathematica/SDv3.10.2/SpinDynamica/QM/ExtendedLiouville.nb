coding ensures that unique superoperator matrix representations are \
calculated only once\
\>", "Text",
 CellChangeTimes->{{3.714053213739338*^9, 3.714053236043517*^9}, {
  3.7140534818481913`*^9, 3.714053487156118*^9}, {3.714053744478599*^9, 
  3.714053745733827*^9}},ExpressionUUID->"9212af6a-d0a7-48df-b370-\
6a57067c9a5e"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ExtendedSuperoperatorMatrixRepresentation", "[", 
    RowBox[{
    "sdsop_SiteDependentSuperoperator", ",", "xopb_ExtendedOperatorBasis", 
     ",", "opts___Rule"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "sdsopsites", ",", "xopbsites", ",", "sdsops", ",", "uniquesops", ",", 
       "sops", ",", "uniquesoppos", ",", "uniquesopmatreps", ",", 
       "sopmatreps", ",", "opbasis", ",", "nsite", ",", "nL"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"sdsopsites", ",", "sdsops"}], "}"}], "=", 
        RowBox[{"Transpose", "@", 
         RowBox[{"First", "@", "sdsop"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"xopbsites", "=", 
        RowBox[{"Sites", "[", "xopb", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"opbasis", "=", 
        RowBox[{"OperatorBasis", "[", "xopb", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"nsite", "=", 
        RowBox[{"Length", "@", "xopbsites"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"nL", "=", 
        RowBox[{"OperatorBasisDimension", "[", "opbasis", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"uniquesops", "=", 
        RowBox[{"First", "/@", 
         RowBox[{"Tally", "[", 
          RowBox[{"Append", "[", 
           RowBox[{"sdsops", ",", 
            RowBox[{"NullSuperoperator", "[", "]"}]}], "]"}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"sops", "=", 
        RowBox[{"Flatten", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Function", "[", 
           RowBox[{"site", ",", "\[IndentingNewLine]", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"MemberQ", "[", 
               RowBox[{"sdsopsites", ",", "site"}], "]"}], ",", 
              "\[IndentingNewLine]", 
              RowBox[{"Pick", "[", 
               RowBox[{"sdsops", ",", "sdsopsites", ",", "site"}], "]"}], ",",
               "\[IndentingNewLine]", 
              RowBox[{"NullSuperoperator", "[", "]"}]}], 
             "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", "]"}], "/@",
           "xopbsites"}], "\[IndentingNewLine]", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"uniquesoppos", "=", 
        RowBox[{"Flatten", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Position", "[", 
            RowBox[{"uniquesops", ",", "#"}], "]"}], "&"}], "/@", "sops"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"uniquesopmatreps", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"SuperoperatorMatrixRepresentation", "[", 
           RowBox[{"#", ",", "opbasis"}], "]"}], "&"}], "/@", 
         "uniquesops"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"sopmatreps", "=", 
        RowBox[{
        "uniquesopmatreps", "\[LeftDoubleBracket]", "uniquesoppos", 
         "\[RightDoubleBracket]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Join", "@@", 
        RowBox[{"Table", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"ArrayPad", "[", 
           RowBox[{
            RowBox[{
            "sopmatreps", "\[LeftDoubleBracket]", "i", 
             "\[RightDoubleBracket]"}], ",", 
            RowBox[{"{", 
             RowBox[{"0", ",", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"i", "-", "1"}], ")"}], "*", "nL"}], ",", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"nsite", "-", "i"}], ")"}], "*", "nL"}]}], "}"}]}], 
             "}"}]}], "]"}], ",", "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", "nsite"}], "}"}]}], 
         "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", ")"}]}], 
    "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.7133677000417*^9, 3.713367839557425*^9}, {
   3.713598441988331*^9, 3.713598498889618*^9}, {3.713598529864072*^9, 
