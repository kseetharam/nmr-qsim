Cell[CellGroupData[{

Cell["\<\
SpinSystem and Sites are defined, but inconsistent with the current \
ExtendedOperatorBasis\
\>", "Subsubsection",
 CellChangeTimes->{{3.7133602827929153`*^9, 3.713360315518165*^9}, {
  3.713360403572756*^9, 3.713360418232863*^9}, {3.71336213803375*^9, 
