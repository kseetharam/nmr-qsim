  3.713362317695921*^9}},ExpressionUUID->"07b82152-5497-4a4e-b913-\
7d8dff0d6921"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ExtendedOperatorBasis", "[", "opts___Rule", "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"xopb", ",", "opb", ",", "spinsys", ",", "sites"}], "}"}], ",", 
     
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Message", "[", 
         RowBox[{"ExtendedOperatorBasis", "::", "inappspinsys"}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"SetExtendedOperatorBasis", "[", "opts", "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"ExtendedOperatorBasis", "[", "opts", "]"}], ";"}], 
       "\[IndentingNewLine]", ")"}], "/;", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"xopb", "=", 
         RowBox[{"ExtendedOperatorBasis", "/.", 
          RowBox[{"Options", "[", "ExtendedOperatorBasis", "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"spinsys", "=", 
         RowBox[{"SpinSystem", "[", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"sites", "=", 
         RowBox[{"Sites", "[", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"MatchQ", "[", 
           RowBox[{"spinsys", ",", 
            RowBox[{"SpinSystem", "[", "xopb", "]"}]}], "]"}]}], "||", 
         RowBox[{"!", 
          RowBox[{"MatchQ", "[", 
           RowBox[{"sites", ",", 
            RowBox[{"Sites", "[", "xopb", "]"}]}], "]"}]}]}]}], 
       "\[IndentingNewLine]", ")"}]}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.7133597290984793`*^9, 3.713359890677438*^9}, {
  3.7133599234594603`*^9, 3.7133600562975397`*^9}, {3.713360094438141*^9, 
