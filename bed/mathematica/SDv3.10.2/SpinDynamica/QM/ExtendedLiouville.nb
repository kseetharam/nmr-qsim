Cell[CellGroupData[{

Cell["convert rule/k form to matrix form", "Section",
 CellChangeTimes->{{3.714375133510252*^9, 3.714375136874604*^9}, {
  3.714376071525765*^9, 
  3.714376086788589*^9}},ExpressionUUID->"44580c89-1238-4e8d-be00-\
6402bc10f9bb"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"KineticExchangeMatrix", "[", 
    RowBox[{"sites_List", ",", 
     RowBox[{"rulekvallist", ":", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"_Rule", ",", "_"}], "}"}], "..."}], "}"}]}], ",", 
     "opts___Rule"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"rules", ",", "kvals", ",", "Kmat", ",", "n", ",", "matpos"}], 
      "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"n", "=", 
        RowBox[{"Length", "[", "sites", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"rules", ",", "kvals"}], "}"}], "=", 
        RowBox[{"Transpose", "@", "rulekvallist"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"matpos", "=", 
        RowBox[{
         RowBox[{"Function", "[", 
          RowBox[{"rule", ",", 
           RowBox[{"Reverse", "@", 
            RowBox[{"Flatten", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"Position", "[", 
                RowBox[{"sites", ",", "#"}], "]"}], "&"}], "/@", 
              RowBox[{"(", 
               RowBox[{"List", "@@", "rule"}], ")"}]}], "]"}]}]}], "]"}], "/@",
          "rules"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"KineticExchangeMatrix", "[", "\[IndentingNewLine]", 
        RowBox[{"sites", ",", "\[IndentingNewLine]", 
         RowBox[{"ReplacePart", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"SparseArray", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"{", 
               RowBox[{"_", ",", "_"}], "}"}], "\[Rule]", "0"}], ",", 
             RowBox[{"{", 
              RowBox[{"n", ",", "n"}], "}"}]}], "]"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"Apply", "[", 
            RowBox[{"Rule", ",", 
             RowBox[{"Transpose", "[", 
              RowBox[{"{", 
               RowBox[{"matpos", ",", "kvals"}], "}"}], "]"}], ",", "1"}], 
            "]"}]}], "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]",
          "opts"}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
      ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.7143761233977747`*^9, 3.714376191656074*^9}, {
  3.7143763834507713`*^9, 3.714376394573679*^9}, {3.714376482769376*^9, 
