Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"KineticExchangeMatrix", "[", 
     RowBox[{"sites_List", ",", 
      RowBox[{"Kmat", ":", 
       RowBox[{"(", 
        RowBox[{"_SparseArray", "|", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Except", "[", "_Rule", "]"}], "..."}], "}"}], "..."}], 
          "}"}]}], ")"}]}], ",", "opts___Rule"}], "]"}], "/;", 
    RowBox[{"MatchQ", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"ImposeDetailedBalance", ",", "DetailedBalance"}], "}"}], "/.", 
        RowBox[{"{", "opts", "}"}]}], "/.", 
       RowBox[{"Options", "[", "KineticExchangeMatrix", "]"}]}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"True", ",", "False"}], "}"}]}], "]"}]}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{"KineticExchangeMatrix", "[", 
       RowBox[{"sites", ",", "\[IndentingNewLine]", 
        RowBox[{"SparseArray", "@", 
         RowBox[{"Transpose", "@", 
          RowBox[{"Table", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"Which", "[", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{
               RowBox[{"Plus", "@@", 
                RowBox[{"Kmat", "\[LeftDoubleBracket]", 
                 RowBox[{"All", ",", "col"}], "\[RightDoubleBracket]"}]}], 
               "\[Equal]", "0"}], ",", "\[IndentingNewLine]", "\t", 
              RowBox[{"Kmat", "\[LeftDoubleBracket]", 
               RowBox[{"All", ",", "col"}], "\[RightDoubleBracket]"}], ",", 
              "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"Kmat", "\[LeftDoubleBracket]", 
                RowBox[{"col", ",", "col"}], "\[RightDoubleBracket]"}], 
               "\[Equal]", "0"}], ",", "\[IndentingNewLine]", "\t", 
              RowBox[{"ReplacePart", "[", 
               RowBox[{
                RowBox[{"Kmat", "\[LeftDoubleBracket]", 
                 RowBox[{"All", ",", "col"}], "\[RightDoubleBracket]"}], ",", 
                
                RowBox[{"col", "\[Rule]", 
                 RowBox[{"-", 
                  RowBox[{"Plus", "@@", 
                   RowBox[{"Kmat", "\[LeftDoubleBracket]", 
                    RowBox[{"All", ",", "col"}], 
                    "\[RightDoubleBracket]"}]}]}]}]}], "]"}], ",", 
              "\[IndentingNewLine]", "True", ",", "\[IndentingNewLine]", "\t", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"Message", "[", 
                 RowBox[{"KineticExchangeMatrix", "::", "detbalerr"}], "]"}], 
                ";", "$Failed"}], ")"}]}], "\[IndentingNewLine]", "]"}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"{", 
             RowBox[{"col", ",", "1", ",", 
              RowBox[{"Length", "[", "sites", "]"}]}], "}"}]}], 
           "\[IndentingNewLine]", "]"}]}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"DetailedBalance", "\[Rule]", "True"}], ",", 
          "\[IndentingNewLine]", "opts"}], "\[IndentingNewLine]", "]"}]}], 
       "\[IndentingNewLine]", "]"}], "\[IndentingNewLine]", ")"}]}], "]"}]}], 
  ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.714374894570382*^9, 3.714374935673368*^9}, {
