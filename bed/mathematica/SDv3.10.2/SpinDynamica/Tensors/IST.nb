Cell[CellGroupData[{

Cell["SphericalToCartesian", "Subsection",
 CellChangeTimes->{{3.9329623988758087`*^9, 
  3.9329624193587914`*^9}},ExpressionUUID->"fb2c9d81-28d6-43ae-bdaf-\
91bfbf0ea429"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SphericalToCartesian", "::", "usage"}], "=", 
   "\"\<SphericalToCartesian[spheric] converts a spherical tensor object with \
integer rank \[Lambda] \[LessEqual] 2 into rank-2 cartesian tensor form. The \
output of SphericalToCartesian is a 3\[Times]3 matrix.\n\>\""}], 
  ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.694846871950903*^9, 3.694847057407888*^9}, {
  3.694864279865396*^9, 3.694864299928835*^9}, {3.694935676805183*^9, 
  3.694936078329644*^9}, {3.6949368641825953`*^9, 3.694936921838055*^9}, {
  3.694936952149021*^9, 3.694937009962043*^9}, {3.694937048166938*^9, 
  3.694937100324933*^9}, {3.7048004692595463`*^9, 3.7048004849127674`*^9}, {
  3.704800576638641*^9, 3.7048005796694956`*^9}, {3.71199951998263*^9, 
  3.711999524786352*^9}, {3.711999889469221*^9, 3.7119999899427633`*^9}, {
