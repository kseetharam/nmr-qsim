Cell[CellGroupData[{

Cell["\<\
check symmetry of elements (* disabled for rank-1. See note *)\
\>", "Subsubsection",
 CellChangeTimes->{{3.69487682762547*^9, 3.694876831315098*^9}, {
  3.6948783979359903`*^9, 
  3.694878405066288*^9}},ExpressionUUID->"644a08f8-b2eb-49a8-8d26-\
f4c6705822e2"],

Cell["\<\
The symmetry relation below comes from P.P. Man, Cartesian and Spherical \
Tensors in NMR Hamiltonians, Concepts Magn. Reson. 42 (2013) 197\[Dash]244. \
doi:10.1002/cmr.a.21289, 
equation 285. \
\>", "Text",
 CellChangeTimes->{{3.694876783030108*^9, 
  3.694876817771783*^9}},ExpressionUUID->"dd46f8fa-d118-4872-9869-\
1231282a995c"],

Cell["\<\
The symmetry check has been disabled for rank-1, since the standard rank-1 \
spherical representation of vectors does not follow the same rule. I do not \
understand the reason for this contradiction. \
\>", "Text",
 CellChangeTimes->{{3.694878278153974*^9, 3.69487832944377*^9}, {
  3.694878393547284*^9, 3.694878395391267*^9}, {3.694936223636234*^9, 
  3.694936224626318*^9}},ExpressionUUID->"f57e2034-d9c8-4019-a8de-\
fef5f4698306"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"SphericalTensor", "[", 
     RowBox[{
      RowBox[{"\[Lambda]_Integer", "|", 
       RowBox[{"{", 
        RowBox[{"\[Lambda]_Integer", ",", "_"}], "}"}]}], ",", 
      "elements_List", ",", "more___", ",", "opts___Rule"}], "]"}], "/;", 
    RowBox[{
     RowBox[{"IntegerQ", "[", 
      RowBox[{"2", "\[Lambda]"}], "]"}], "&&", 
     RowBox[{"(", 
      RowBox[{"\[Lambda]", "\[NotEqual]", "1"}], ")"}], "&&", 
     RowBox[{"(", 
      RowBox[{"elements", "\[NotEqual]", 
       RowBox[{"Reverse", "@", 
        RowBox[{"Conjugate", "@", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Table", "[", 
            RowBox[{
             SuperscriptBox[
              RowBox[{"(", 
               RowBox[{"-", "1"}], ")"}], 
              RowBox[{"\[Lambda]", "-", "m"}]], ",", 
             RowBox[{"{", 
              RowBox[{"m", ",", "\[Lambda]", ",", 
               RowBox[{"-", "\[Lambda]"}], ",", 
               RowBox[{"-", "1"}]}], "}"}]}], "]"}], "*", "elements"}], 
          ")"}]}]}]}], ")"}]}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"Message", "[", 
      RowBox[{"SphericalTensor", "::", "badsymm"}], "]"}], ";", "$Failed"}], 
    ")"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.694862863381682*^9, 3.694862973430074*^9}, {
   3.694863011085185*^9, 3.694863123248958*^9}, 3.694864551920632*^9, {
   3.694865202304017*^9, 3.6948652118199267`*^9}, {3.694876719313078*^9, 
   3.694876760822912*^9}, {3.694878340941185*^9, 3.6948783475448*^9}, {
   3.694936214873671*^9, 
   3.694936215458468*^9}},ExpressionUUID->"19cc43e6-fee2-4f62-9ade-\
696520da8866"]
}, Closed]]
}, Closed]],

