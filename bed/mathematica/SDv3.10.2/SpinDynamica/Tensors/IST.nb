Cell[CellGroupData[{

Cell["SphericalTensor and TransformSphericalTensor", "Subsection",
 CellChangeTimes->{{3.9329623988758087`*^9, 
  3.9329624051947937`*^9}},ExpressionUUID->"1c8deb6e-20b3-4da3-8d14-\
8a8e4839f403"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SphericalTensor", "::", "usage"}], "=", 
   "\"\<SphericalTensor[\[Lambda],elements] is an irreducible spherical \
tensor of rank \[Lambda] with 2\[Lambda]+1 elements given by the list \
elements, arranged with the m-value in descending order from m=+\[Lambda] to \
m=-\[Lambda]. The element with index m may be accessed using the syntax \
SphericalTensor[\[Lambda],elements][m] or \
SphericalTensor[{\[Lambda],m},elements]. A SphericalTensor may be transformed \
between reference frames using the routine TransformSphericalTensor.\>\""}], 
  ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.694846871950903*^9, 3.694847057407888*^9}, {
  3.694864279865396*^9, 3.694864299928835*^9}, {3.694935676805183*^9, 
  3.694936078329644*^9}, {3.6949368641825953`*^9, 3.694936921838055*^9}, {
  3.694936952149021*^9, 3.694937009962043*^9}, {3.694937048166938*^9, 
  3.694937100324933*^9}, {3.827070606782473*^9, 
  3.8270706532322817`*^9}},ExpressionUUID->"0b682b60-16cb-45a2-b402-\
235ea2658322"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"TransformSphericalTensor", "::", "usage"}], "=", 
   "\[IndentingNewLine]", 
   "\"\<TransformSphericalTensor[sphericaltensor,eulerangles] transforms the \
spherical tensor, written in a reference frame 1 to a new reference frame 2, \
where frame 1 may be rotated into frame 2 by the Euler angles eulerangles. \
For example, if SphericalTensor[\[Lambda],elements] specifies a spherical \
tensor in its principal axis frame, then \
TransformSphericalTensor[SphericalTensor[\[Lambda],elements],{\[Alpha]PL,\
\[Beta]PL,\[Gamma]PL}] specifies the same spherical tensor in the lab frame, \
where {\[Alpha]PL,\[Beta]PL,\[Gamma]PL} represents the Euler angles which \
align the principal axis frame P with the lab frame L. The Euler angles may \
in turn be derived through AxesToEuler[Paxes,Laxes], where Paxes and Laxes \
are sets of 3-dimensional axes, generated by AxisSystem. The Euler angles \
eulerangles may also be specified as a chain of transformations, for example \
{{\[Alpha]PF,\[Beta]PF,\[Gamma]PF},{\[Alpha]FL,\[Beta]FL,\[Gamma]FL}}..}. \n\
\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.827070092770856*^9, 3.827070238929891*^9}, {
  3.827070431627577*^9, 
  3.827070596995986*^9}},ExpressionUUID->"50b2f02e-cdb8-4ff4-a8b4-\
bb9a50049dcf"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"CartesianTensor", "::", "usage"}], "=", "\"\<?\>\""}], 
  ";"}]], "Input",
