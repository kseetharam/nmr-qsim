Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"CartesianToSpherical", "[", 
    RowBox[{"1", ",", 
     RowBox[{"vec_", "?", "VectorQ"}], ",", "opts___Rule"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"x", ",", "y", ",", "z"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x", ",", "y", ",", "z"}], "}"}], "=", "vec"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"SphericalTensor", "[", 
       RowBox[{"1", ",", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"-", 
            RowBox[{"(", 
             RowBox[{"1", "/", 
              RowBox[{"Sqrt", "[", "2", "]"}]}], ")"}]}], 
           RowBox[{"(", 
            RowBox[{"x", "+", 
             RowBox[{"I", " ", "y"}]}], ")"}]}], ",", "\[IndentingNewLine]", 
          "z", ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"+", 
            RowBox[{"(", 
             RowBox[{"1", "/", 
              RowBox[{"Sqrt", "[", "2", "]"}]}], ")"}]}], 
           RowBox[{"(", 
            RowBox[{"x", "-", 
             RowBox[{"I", " ", "y"}]}], ")"}]}]}], "\[IndentingNewLine]", 
         "}"}], ",", "\[IndentingNewLine]", "opts"}], "\[IndentingNewLine]", 
       "]"}]}]}], "]"}]}], ";"}]], "Input",
