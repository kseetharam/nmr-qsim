42edb18cfc4a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SphericalTensor", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Lambda]_", "?", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"IntegerQ", "[", 
           RowBox[{"2", "#"}], "]"}], "&"}], ")"}]}], ",", "m_"}], "}"}], ",",
      "elements_List", ",", "opts___Rule"}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"MemberQ", "[", 
      RowBox[{
       RowBox[{"Range", "[", 
        RowBox[{
         RowBox[{"-", "\[Lambda]"}], ",", 
         RowBox[{"+", "\[Lambda]"}], ",", 
         RowBox[{"+", "1"}]}], "]"}], ",", "m"}], "]"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"elements", "\[LeftDoubleBracket]", 
      RowBox[{
       RowBox[{"+", "\[Lambda]"}], "-", "m", "+", "1"}], 
      "\[RightDoubleBracket]"}], ",", "\[IndentingNewLine]", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Message", "[", 
        RowBox[{
         RowBox[{"SphericalTensor", "::", "badm"}], ",", "m", ",", 
         "\[Lambda]"}], "]"}], ";", "$Failed"}], ")"}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.6948631927191052`*^9, 3.694863225962493*^9}, {
