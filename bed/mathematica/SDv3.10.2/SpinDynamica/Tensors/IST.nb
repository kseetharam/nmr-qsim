Cell[CellGroupData[{

Cell["CartesianToSpherical", "Subsection",
 CellChangeTimes->{{3.9329623988758087`*^9, 
  3.9329624318992147`*^9}},ExpressionUUID->"7aeff68a-b913-483a-a26c-\
9cbcb251de99"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"CartesianToSpherical", "::", "usage"}], "=", 
   "\"\<CartesianToSpherical[\[Lambda],cart] converts a scalar, cartesian \
vector or 3\[Times]3 matrix into spherical tensor form. For rank \[Lambda]=0, \
the argument cart may be a number (scalar), or a 3\[Times]3 matrix. For rank \
\[Lambda]=1, the argument cart may be a 3-element Cartesian vector, or a 3\
\[Times]3 matrix. For rank \[Lambda]=2, the argument cart must be a \
3\[Times]3 matrix.\nThe output of CartesianToSpherical is a SphericalTensor \
object. \nThe syntax CartesianToSpherical[{\[Lambda]1,\[Lambda]2},cart] \
generates a list of SphericalTensor objects. \nThe syntax \
CartesianToSpherical[cart] generates a list of all SphericalTensor objects \
compatible with the argument cart. \n\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.694846871950903*^9, 3.694847057407888*^9}, {
  3.694864279865396*^9, 3.694864299928835*^9}, {3.694864661148262*^9, 
  3.694865048490993*^9}},ExpressionUUID->"fc33e156-84b1-41d4-ae71-\
6f857c606e46"]
}, Closed]]
}, Closed]],

