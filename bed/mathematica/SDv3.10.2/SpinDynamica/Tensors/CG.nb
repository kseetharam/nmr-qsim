Cell[CellGroupData[{

Cell["specific cases which are slow when using ClebschGordan", "Subsubsection",
 CellChangeTimes->{{3.7446042093641787`*^9, 3.7446042423606253`*^9}, {
  3.7446044544918127`*^9, 
  3.744604465375651*^9}},ExpressionUUID->"8897927c-fdd0-423c-a0a5-\
5052c0d96844"],

Cell["\<\
This problem was identified in Mathematica 11.3 where the lines below can \
take 1.5 seconds to evaluate.\
\>", "Text",
 CellChangeTimes->{{3.74460453677789*^9, 
  3.7446045628522778`*^9}},ExpressionUUID->"177b543b-75f4-4a2f-a544-\
2916af29beaf"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"CG", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"2", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"1", ",", 
       RowBox[{"-", "1"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"1", ",", "1"}], "}"}]}], "]"}], "=", 
   RowBox[{"1", "/", 
    RowBox[{"Sqrt", "[", "6", "]"}]}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.744604485171117*^9, 
  3.744604492773848*^9}},ExpressionUUID->"9eba083c-739e-4bd6-999c-\
984926d2f57c"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"CG", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"2", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"1", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"1", ",", 
       RowBox[{"-", "1"}]}], "}"}]}], "]"}], "=", 
   RowBox[{"1", "/", 
    RowBox[{"Sqrt", "[", "6", "]"}]}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.744604485171117*^9, 
  3.7446045015265007`*^9}},ExpressionUUID->"9e862881-dc57-4e4c-a651-\
feafe267aa8a"]
}, Open  ]],

Cell[CellGroupData[{

Cell["general case", "Subsubsection",
 CellChangeTimes->{{3.7446042093641787`*^9, 
  3.7446042423606253`*^9}},ExpressionUUID->"a24522a9-4823-474a-a409-\
21e540a3e91b"],

Cell["\<\
The routine now remembers any computed definitions, so that any slow \
executions are problematic only once.\
\>", "Text",
 CellChangeTimes->{{3.744604577697319*^9, 3.7446045954011517`*^9}, {
  3.744604640939055*^9, 
  3.744604653743431*^9}},ExpressionUUID->"082fd572-874c-49fa-a064-\
23d70e499624"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"CG", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"j3_", ",", " ", "m3_"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"j1_", ",", " ", "m1_"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"j2_", ",", " ", "m2_"}], "}"}]}], "]"}], " ", ":=", " ", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"CG", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"j3", ",", " ", "m3"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"j1", ",", " ", "m1"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"j2", ",", " ", "m2"}], "}"}]}], "]"}], "=", "\n", "  ", 
    RowBox[{"ClebschGordan", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"j1", ",", " ", "m1"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"j2", ",", " ", "m2"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"j3", ",", " ", "m3"}], "}"}]}], "]"}]}]}], ";"}]], "Input",
 PageWidth->WindowWidth,
