Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"CG", "::", "usage"}], " ", "=", " ", 
   "\"\<CG[{j3,m3},{j1,m1},{j2,m2}] generates a Clebsch-Gordan coefficient, \
ordered as in VMK. CG[{j3},{j1,m1},{j2,m2}] generates \
CG[{j3,m1+m2},{j1,m1},{j2,m2}]. If m3 != m1+m2, the result 0 is \
returned.\>\""}], ";"}]], "Input",
 PageWidth->WindowWidth,
 InitializationCell->True,
 CellChangeTimes->{{3.409833733282138*^9, 3.4098337358765182`*^9}, {
   3.564599182087885*^9, 3.56459928717844*^9}, 3.683134536766574*^9, 
   3.683134605884015*^9, {3.683191926020918*^9, 3.683191926173251*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"d49e442d-6beb-441b-9836-ce78cd2d0c34"]
}, Closed]],

