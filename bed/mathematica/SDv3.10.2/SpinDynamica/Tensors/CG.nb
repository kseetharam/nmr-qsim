Cell["Clebsch-Gordan coefficients, using the convention in VMK", "Text",
 CellChangeTimes->{{3.683191859143014*^9, 
  3.683191923508997*^9}},ExpressionUUID->"e760493a-ad9e-4483-bc04-\
cf69e1dd1ea6"],

Cell["\<\
The evaluation of some common combinations by ClebschGordan has become very \
slow in Mathematica 11 relative to earlier versions, for unknown reasons. \
These combinations have now been programmed explicitly.\
\>", "Text",
 CellChangeTimes->{{3.744604124228567*^9, 
  3.744604183096498*^9}},ExpressionUUID->"03e1fa6c-65c7-4ea0-af98-\
023ddbb8298e"],

