Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"NuclearSpinQuantumNumber", "::", "usage"}], " ", "=", " ", 
   "\"\<NuclearSpinQuantumNumber[isotope] gives the ground-state nuclear spin \
quantum number of the given isotope, specified using either its mass number, \
or as an abbreviation, for example \\\"13C\\\".\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.574845208885941*^9, 3.574845249654599*^9}, {
