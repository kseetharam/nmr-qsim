Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"LarmorFrequency", "::", "usage"}], " ", "=", " ", 
   "\"\<LarmorFrequency[isotope,\!\(\*SubscriptBox[\(B\), \(0\)]\)] gives the \
Larmor frequency of the specified isotope in the field \!\(\*SubscriptBox[\(B\
\), \(0\)]\) [specified in Tesla], in units of \
rad\[NonBreakingSpace]\!\(\*SuperscriptBox[\(s\), \(-1\)]\). The isotope is \
specified either by its mass number, or as an abbreviation, for example \
\\\"13C\\\".\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.574845208885941*^9, 3.5748453012209806`*^9}, {
   3.574845507793983*^9, 3.574845512876615*^9}, 
