Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"MagnetogyricRatio", "::", "usage"}], " ", "=", " ", 
   "\"\<MagnetogyricRatio[isotope] gives the magnetogyric ratio of the \
specified isotope, in units of rad\[NonBreakingSpace]\!\(\*SuperscriptBox[\(s\
\), \(-1\)]\)\[NonBreakingSpace]\!\(\*SuperscriptBox[\(T\), \(-1\)]\). The \
isotope is specified either by its mass number, or as an abbreviation, for \
example \\\"13C\\\".\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.574845208885941*^9, 3.574845249654599*^9}, {
   3.5748454715280247`*^9, 3.5748454973209248`*^9}, 
