Cell[CellGroupData[{

Cell["DirectDipolarCoupling", "Subsection",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 CellChangeTimes->{3.574846275007186*^9},
 AspectRatioFixed->
  True,ExpressionUUID->"84b43691-05dc-4170-8095-66a14716c49a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"DirectDipolarCoupling", "::", "usage"}], " ", "=", " ", 
   "\"\<DirectDipolarCoupling[{isotope1,isotope2},r] gives the dipolar \
coupling (in rad\[NonBreakingSpace]\!\(\*SuperscriptBox[\(s\), \(-1\)]\)) \
between the nuclei of two isotopes separated by r (in meters). \
DirectDipolarCoupling[isotope1,r] assumes two identical isotopes. Each \
isotope is specified either by its mass number, or as an abbreviation, for \
example \\\"13C\\\".\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.574845315587294*^9, 3.574845371672052*^9}, {
   3.5748455257542*^9, 3.574845529134532*^9}, 
   3.574846275007721*^9},ExpressionUUID->"72a03325-0413-4885-87e2-\
409411cc1f3a"]
}, Closed]]
}, Closed]],

