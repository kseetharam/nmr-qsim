Cell["PhenomenologicalRelaxationSuperoperator", "Section",
 InitializationCell->True,
 CellChangeTimes->{{3.464960392986411*^9, 3.4649603952229023`*^9}, 
   3.4649606985178003`*^9, 3.5031057515835857`*^9, {3.5068630444608307`*^9, 
