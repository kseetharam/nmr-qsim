Cell[CellGroupData[{

Cell["construct relaxation superoperator", "Subsubsection",
 InitializationCell->True,
 CellChangeTimes->{{3.683204437400052*^9, 3.6832044696045437`*^9}, {
  3.683204504326599*^9, 3.68320450836325*^9}, {3.68320475928788*^9, 
  3.683204773003031*^9}},ExpressionUUID->"0ccb3e74-535d-41b0-b670-\
748221ef48d1"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"PhenomenologicalRelaxationSuperoperator", "[", 
    RowBox[{
     RowBox[{"jT1T2list", ":", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"_", ",", "_", ",", "_"}], "}"}], ".."}], "}"}]}], ",", 
     "opts___Rule"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "bops", ",", "counts", ",", "spins", ",", "spinsmissing", ",", 
       "jT1T2list$", ",", "R1", ",", "R2", ",", "diagels"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"bops", "=", 
        RowBox[{"BasisOperators", "[", 
         RowBox[{"ShiftAndZOperatorBasis", "[", "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"spins", "=", 
        RowBox[{"First", "/@", 
         RowBox[{"SpinSystem", "[", "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"spinsmissing", "=", 
        RowBox[{"Complement", "[", 
         RowBox[{"spins", ",", 
          RowBox[{"jT1T2list", "\[LeftDoubleBracket]", 
           RowBox[{"All", ",", "1"}], "\[RightDoubleBracket]"}]}], "]"}]}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"jT1T2list$", "=", 
        RowBox[{"Join", "[", 
         RowBox[{"jT1T2list", ",", 
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{"#", ",", "\[Infinity]", ",", "\[Infinity]"}], "}"}], 
            "&"}], "/@", "spinsmissing"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"counts", "=", 
        RowBox[{
         RowBox[{"Function", "[", 
          RowBox[{"op", ",", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{
             RowBox[{"{", 
              RowBox[{"#", ",", 
               RowBox[{"{", 
                RowBox[{"\"\<z\>\"", ",", 
                 RowBox[{"Count", "[", 
                  RowBox[{
                   RowBox[{"{", "op", "}"}], ",", 
                   RowBox[{"HoldPattern", "@", 
                    RowBox[{"opI", "[", 
                    RowBox[{"#", ",", "\"\<z\>\"", ",", "___"}], "]"}]}], ",",
                    "Infinity"}], "]"}]}], "}"}], ",", 
               RowBox[{"{", 
                RowBox[{"\"\<+\>\"", ",", 
                 RowBox[{"Count", "[", 
                  RowBox[{
                   RowBox[{"{", "op", "}"}], ",", 
                   RowBox[{"HoldPattern", "@", 
                    RowBox[{"opI", "[", 
                    RowBox[{"#", ",", "\"\<+\>\"", ",", "___"}], "]"}]}], ",",
                    "Infinity"}], "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
               
               RowBox[{"{", 
                RowBox[{"\"\<-\>\"", ",", 
                 RowBox[{"Count", "[", 
                  RowBox[{
                   RowBox[{"{", "op", "}"}], ",", 
                   RowBox[{"HoldPattern", "@", 
                    RowBox[{"opI", "[", 
                    RowBox[{"#", ",", "\"\<-\>\"", ",", "___"}], "]"}]}], ",",
                    "Infinity"}], "]"}]}], "}"}]}], "}"}], "&"}], "/@", 
            "\[IndentingNewLine]", "spins"}]}], "\[IndentingNewLine]", "]"}], 
         "/@", "bops"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"R1", "[", "j_", "]"}], ":=", 
        RowBox[{"1", "/", 
         RowBox[{
          RowBox[{"Cases", "[", 
           RowBox[{"jT1T2list$", ",", 
            RowBox[{"{", 
             RowBox[{"j", ",", "_", ",", "_"}], "}"}]}], "]"}], 
          "\[LeftDoubleBracket]", 
          RowBox[{"1", ",", "2"}], "\[RightDoubleBracket]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"R2", "[", "j_", "]"}], ":=", 
        RowBox[{"1", "/", 
         RowBox[{
          RowBox[{"Cases", "[", 
           RowBox[{"jT1T2list$", ",", 
            RowBox[{"{", 
             RowBox[{"j", ",", "_", ",", "_"}], "}"}]}], "]"}], 
          "\[LeftDoubleBracket]", 
          RowBox[{"1", ",", "3"}], "\[RightDoubleBracket]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"diagels", "=", 
        RowBox[{"-", 
         RowBox[{"Apply", "[", "\[IndentingNewLine]", 
          RowBox[{"Plus", ",", "\[IndentingNewLine]", 
           RowBox[{"counts", "/.", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"j_", ",", 
               RowBox[{"{", 
                RowBox[{"\"\<z\>\"", ",", "nz_"}], "}"}], ",", 
               RowBox[{"{", 
                RowBox[{"\"\<+\>\"", ",", "np_"}], "}"}], ",", 
               RowBox[{"{", 
                RowBox[{"\"\<-\>\"", ",", "nm_"}], "}"}]}], "}"}], 
             "\[RuleDelayed]", 
             RowBox[{
              RowBox[{"nz", "*", 
               RowBox[{"R1", "[", "j", "]"}]}], "+", 
              RowBox[{"np", "*", 
               RowBox[{"R2", "[", "j", "]"}]}], "+", 
              RowBox[{"nm", "*", 
               RowBox[{"R2", "[", "j", "]"}]}]}]}]}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"{", "1", "}"}]}], "\[IndentingNewLine]", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Superoperator", "[", 
        RowBox[{
         RowBox[{"SparseArray", "[", 
          RowBox[{"DiagonalMatrix", "[", "diagels", "]"}], "]"}], ",", 
         RowBox[{"ShiftAndZOperatorBasis", "[", "]"}]}], "]"}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.683204785842185*^9, 3.683204826112575*^9}, {
   3.683204967004055*^9, 3.683204987106071*^9}, {3.6832059909401484`*^9, 
   3.6832060213634243`*^9}, {3.683206110896839*^9, 3.683206157987269*^9}, {
