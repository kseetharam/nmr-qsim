  3.843298301830595*^9}},ExpressionUUID->"156cbcb0-18c2-4c4a-85b7-\
181618af6981"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SymmetryAdaptedBasisTFM", "[", 
   RowBox[{
    RowBox[{"SymmetryAdaptedBasis", "[", 
     RowBox[{"spinsys_", ",", 
      RowBox[{"SpinPermutationGroupOperators", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"\"\<CyclicGroup\>\"", ",", "n_"}], "}"}], ",", "group_"}],
          "}"}], ",", "_"}], "]"}], ",", "opts___Rule"}], "]"}], ",", 
    "basis1_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
     "spins", ",", "\[IndentingNewLine]", "K1", ",", "K2", ",", "K3", ",", 
      "K4", ",", "CSCO", ",", "G", ",", "dimG", ",", "\[IndentingNewLine]", 
      "ev", ",", "vecs", ",", "Gmats", ",", "X", ",", "Xinv", ",", "\[Xi]vec",
       ",", "\[IndentingNewLine]", "G\[CapitalGamma]\[Gamma]mats", ",", 
      "\[CapitalGamma]\[Gamma]subspaces", ",", "\[CapitalGamma]\[Gamma]order",
       ",", "\[IndentingNewLine]", "vecs\[CapitalGamma]\[Gamma]sorted", ",", 
      "X\[CapitalGamma]\[Gamma]sorted", ",", 
      "X\[CapitalGamma]\[Gamma]invsorted", ",", 
      "\[Xi]vec\[CapitalGamma]\[Gamma]sorted", ",", 
      "G\[CapitalGamma]\[Gamma]sortedmats", ",", "\[IndentingNewLine]", 
      "\[CapitalGamma]\[Gamma]cuts", ",", "\[CapitalGamma]\[Gamma]bounds", 
      ",", "\[CapitalGamma]\[Gamma]spaces", ",", "\[IndentingNewLine]", 
      "SpacePartition", ",", "IsotopicSpaces", ",", "truepos", ",", 
      "dim\[CapitalGamma]s", ",", "\[IndentingNewLine]", 
      "phasetransformations", ",", "phasetransformation", ",", 
      "\[IndentingNewLine]", "V", ",", "K2\[CapitalGamma]", ",", 
      "K3\[CapitalGamma]", ",", "dimvec"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"spins", "=", 
      RowBox[{"First", "[", 
       RowBox[{"Transpose", "[", "spinsys", "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"K1", "=", 
      RowBox[{"SpinPermutationOperator", "[", 
       RowBox[{"spins", ",", "spinsys"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"K2", "=", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"opI", "[", 
           RowBox[{
           "spins", "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}], 
           "]"}], ")"}], ".", 
         RowBox[{"(", 
          RowBox[{"opI", "[", 
           RowBox[{
           "spins", "\[LeftDoubleBracket]", "j", "\[RightDoubleBracket]"}], 
           "]"}], ")"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", "n"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", "1", ",", "n"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"K3", "=", 
      RowBox[{"opI", "[", "\"\<z\>\"", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"G", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"SpinPermutationOperator", "[", 
          RowBox[{
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"MatchQ", "[", 
              RowBox[{"#", ",", 
               RowBox[{"{", 
                RowBox[{"{", "__", "}"}], "}"}]}], "]"}], ",", 
             RowBox[{
             "#", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], ",",
              "#"}], "]"}], ",", "spinsys"}], "]"}], ")"}], "&"}], "/@", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Sort", "[", 
          RowBox[{
           RowBox[{"GroupElements", "[", 
            RowBox[{"CyclicGroup", "[", "n", "]"}], "]"}], "[", 
           RowBox[{"[", 
            RowBox[{"All", ",", "1"}], "]"}], "]"}], "]"}], "/.", 
         RowBox[{"Thread", "[", 
          RowBox[{
           RowBox[{"Range", "[", "n", "]"}], "\[Rule]", " ", "spins"}], 
          "]"}]}], ")"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"CSCO", "=", 
      RowBox[{"{", 
       RowBox[{"K1", ",", "K2", ",", "K3"}], "}"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"dimG", "=", 
      RowBox[{"Length", "[", "G", "]"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"ev", ",", "vecs"}], "}"}], "=", 
      RowBox[{"Chop", "@", 
       RowBox[{"Eigensystem", "[", 
        RowBox[{"MatrixRepresentation", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"RandomInteger", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"-", "100"}], ",", "100"}], "}"}], ",", 
             RowBox[{"Length", "[", "CSCO", "]"}]}], "]"}], ".", "CSCO"}], 
          ",", "basis1"}], "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"vecs", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"#", "/", 
         RowBox[{"FullSimplify", "[", 
          RowBox[{"Sqrt", "[", 
           RowBox[{"#", ".", 
            RowBox[{"Conjugate", "[", "#", "]"}]}], "]"}], "]"}]}], "&"}], "/@",
        "vecs"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Gmats", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"MatrixRepresentation", "[", 
         RowBox[{"#", ",", "basis1"}], "]"}], "&"}], "/@", "G"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"X", "=", 
      RowBox[{
       RowBox[{"Transpose", "[", "vecs", "]"}], "//", "SparseArray"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Xinv", "=", 
      RowBox[{"ConjugateTranspose", "[", "X", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"\[Xi]vec", "=", 
      RowBox[{"Normal", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"Xinv", ".", 
           RowBox[{"(", 
            RowBox[{"MatrixRepresentation", "[", 
             RowBox[{
              RowBox[{"CSCO", "[", 
               RowBox[{"[", "1", "]"}], "]"}], ",", "basis1"}], "]"}], ")"}], 
           ".", "X"}], "//", "N"}], "//", "Chop"}], "//", "Diagonal"}], 
       "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"G\[CapitalGamma]\[Gamma]mats", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"Simplify", "[", 
         RowBox[{"Chop", "[", 
          RowBox[{"Xinv", ".", "#", ".", "X"}], "]"}], "]"}], "&"}], "/@", 
       "Gmats"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"\[CapitalGamma]\[Gamma]subspaces", "=", 
      RowBox[{"SortBy", "[", 
       RowBox[{
        RowBox[{"ConnectedComponents", "[", 
         RowBox[{"Rule", "@@@", 
          RowBox[{
           RowBox[{"Chop", "[", 
            RowBox[{"Total", "[", 
             RowBox[{
              RowBox[{"RandomReal", "[", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"-", "100"}], ",", "100"}], "}"}], ",", "dimG"}], 
               "]"}], "*", "G\[CapitalGamma]\[Gamma]mats"}], "]"}], "]"}], 
           "[", "\"\<NonzeroPositions\>\"", "]"}]}], "]"}], ",", "Length"}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"\[CapitalGamma]\[Gamma]order", "=", 
      RowBox[{"Flatten", "[", "\[CapitalGamma]\[Gamma]subspaces", "]"}]}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"vecs\[CapitalGamma]\[Gamma]sorted", "=", 
      RowBox[{"vecs", "[", 
       RowBox[{"[", "\[CapitalGamma]\[Gamma]order", "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"X\[CapitalGamma]\[Gamma]sorted", "=", 
      RowBox[{
       RowBox[{"Transpose", "[", "vecs\[CapitalGamma]\[Gamma]sorted", "]"}], "//",
        "SparseArray"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"X\[CapitalGamma]\[Gamma]invsorted", "=", 
      RowBox[{
      "ConjugateTranspose", "[", "vecs\[CapitalGamma]\[Gamma]sorted", "]"}]}],
      ";", "\[IndentingNewLine]", 
     RowBox[{"\[Xi]vec\[CapitalGamma]\[Gamma]sorted", "=", 
