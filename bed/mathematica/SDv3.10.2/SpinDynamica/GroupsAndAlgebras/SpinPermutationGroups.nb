Cell[BoxData[
 RowBox[{
  RowBox[{"SpinPermutationGroup", "[", 
   RowBox[{"spins___List", ",", "gargs_", ",", "opts___Rule", ",", 
    RowBox[{"{", 
     RowBox[{"\"\<1\>\"", ",", "\"\<0\>\""}], "}"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "permgroup", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"permgroup", "=", 
      RowBox[{"Quiet", "[", 
       RowBox[{"FiniteGroupData", "[", 
        RowBox[{"gargs", ",", "\"\<PermutationRepresentation\>\""}], "]"}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"!", 
        RowBox[{"MatrixQ", "[", "permgroup", "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Message", "[", 
         RowBox[{"SpinPermutationGroup", "::", "WrongInput"}], "]"}], ";", 
        RowBox[{"Abort", "[", "]"}], ";"}], ",", "\[IndentingNewLine]", 
       RowBox[{"SpinPermutationGroup", "[", 
        RowBox[{"spins", ",", 
         RowBox[{"{", 
          RowBox[{"permgroup", ",", 
           RowBox[{"Length", "[", 
            RowBox[{"First", "[", "permgroup", "]"}], "]"}]}], "}"}], ",", 
         RowBox[{"SpinPermutationGroup", "\[Rule]", " ", "gargs"}], ",", 
         "opts", ",", 
         RowBox[{"{", 
          RowBox[{"\"\<1\>\"", ",", "\"\<1\>\""}], "}"}]}], "]"}]}], 
      "]"}]}]}], "\[IndentingNewLine]", "]"}]}]], "Input",
 InitializationCell->True,
