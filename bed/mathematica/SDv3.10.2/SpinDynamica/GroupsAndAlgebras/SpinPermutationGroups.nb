Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"SymmetryAdaptedBasis", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"grlabel_String", ",", "order_Integer"}], "}"}], ",", 
     "opts___Rule"}], "]"}], ":=", 
   RowBox[{"If", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"MatchQ", "[", 
      RowBox[{"grlabel", ",", "\"\<CyclicGroup\>\""}], "]"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"SymmetryAdaptedBasis", "[", 
      RowBox[{
       RowBox[{"SpinSystem", "[", "]"}], ",", 
       RowBox[{"SpinPermutationGroupOperators", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"grlabel", ",", "order"}], "}"}], ",", 
           RowBox[{"SpinPermutationOperator", "/@", 
            RowBox[{
             RowBox[{"GroupElements", "[", 
              RowBox[{"CyclicGroup", "[", "order", "]"}], "]"}], 
             "\[LeftDoubleBracket]", 
             RowBox[{"All", ",", "1"}], "\[RightDoubleBracket]"}]}]}], "}"}], 
         ",", 
         RowBox[{
          RowBox[{"SpinSystem", "[", "]"}], "\[LeftDoubleBracket]", 
          RowBox[{"All", ",", "1"}], "\[RightDoubleBracket]"}]}], "]"}], ",", 
       "opts"}], "]"}], ",", "\[IndentingNewLine]", 
     RowBox[{"SymmetryAdaptedBasis", "[", 
      RowBox[{
       RowBox[{"SpinSystem", "[", "]"}], ",", 
       RowBox[{"SpinPermutationGroup", "[", 
        RowBox[{"{", 
         RowBox[{"grlabel", ",", "order"}], "}"}], "]"}], ",", "opts"}], 
      "]"}]}], "\[IndentingNewLine]", "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"SymmetryAdaptedBasis", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"grlabel_String", ",", "order_Integer"}], "}"}], ",", 
       "gops_"}], "}"}], ",", "opts___Rule"}], "]"}], ":=", 
   RowBox[{"SymmetryAdaptedBasis", "[", 
    RowBox[{
     RowBox[{"SpinSystem", "[", "]"}], ",", 
     RowBox[{"SpinPermutationGroupOperators", "[", 
      RowBox[{
       RowBox[{"{", 
