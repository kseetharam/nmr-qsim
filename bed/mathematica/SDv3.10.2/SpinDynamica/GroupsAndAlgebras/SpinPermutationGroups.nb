Cell[BoxData[
 RowBox[{
  RowBox[{"SymmetryAdaptedBasisTFM", "[", 
   RowBox[{
    RowBox[{"SymmetryAdaptedBasis", "[", 
     RowBox[{"spinsys_", ",", 
      RowBox[{"SpinPermutationGroupOperators", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"grname_", ",", "n_"}], "}"}], ",", "gops_"}], "}"}], ",", 
        "_"}], "]"}], ",", "opts___Rule"}], "]"}], ",", "basis1_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
     "spins", ",", "nspins", ",", "dimG", ",", "\[IndentingNewLine]", 
      "PSGZKB", ",", "SG", ",", "SX", ",", "\[IndentingNewLine]", "K1", ",", 
      "K2", ",", "KC1", ",", "KC2", ",", "\[IndentingNewLine]", "nspace1", 
      ",", "nspace2", ",", "nspace", ",", "\[IndentingNewLine]", "nops", ",", 
      "nopsZKB", ",", "nopssym", ",", "\[IndentingNewLine]", "ev", ",", 
      "vecs", ",", "X", ",", "\[IndentingNewLine]", "Gmats", ",", 
      "Gmats\[Xi]", ",", "subspaces", ",", "\[IndentingNewLine]", "\[Xi]vecs",
       ",", "\[Xi]groupings", ",", "\[Xi]remaining", ",", "\[Xi]group", ",", 
      "\[Xi]perm", ",", "\[Xi]dim", ",", "\[IndentingNewLine]", 
      "Gmats\[Xi]perm", ",", "phaseU", ",", "normphaseU"}], 
     "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"spins", "=", 
      RowBox[{"First", "[", 
       RowBox[{"Transpose", "[", "spinsys", "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"nspins", "=", 
      RowBox[{"Length", "[", "spins", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"dimG", "=", 
      RowBox[{"Length", "[", "gops", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Gmats", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"MatrixRepresentation", "[", 
         RowBox[{"#", ",", "basis1"}], "]"}], "&"}], "/@", "gops"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"SG", "=", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"LeftMultiplicationSuperoperator", "[", "#", "]"}], ")"}], 
         ".", 
         RowBox[{"(", 
          RowBox[{"RightMultiplicationSuperoperator", "[", 
           RowBox[{"Adjoint", "[", "#", "]"}], "]"}], ")"}]}], "&"}], "/@", 
       "gops"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"PSGZKB", "=", 
      RowBox[{"SuperoperatorMatrixRepresentation", "[", 
       RowBox[{
        RowBox[{"Total", "[", "SG", "]"}], ",", 
        RowBox[{"ZeemanKetBraOperatorBasis", "[", "spinsys", "]"}]}], "]"}]}],
      ";", "\[IndentingNewLine]", 
     RowBox[{"SX", "=", 
      RowBox[{"OperatorBasisTransformationMatrix", "[", 
       RowBox[{
        RowBox[{"OperatorBasis", "[", "]"}], ",", 
        RowBox[{"ZeemanKetBraOperatorBasis", "[", "spinsys", "]"}]}], "]"}]}],
      ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"K1", "=", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"BasisOperators", "[", 
         RowBox[{"OperatorBasis", "[", "]"}], "]"}], ")"}], ".", 
       RowBox[{"(", 
        RowBox[{"SX", ".", "PSGZKB", ".", 
         RowBox[{"OperatorVectorRepresentation", "[", 
          RowBox[{
           RowBox[{"opI", "[", 
            RowBox[{"spins", ",", "\"\<z\>\""}], "]"}], ",", 
           RowBox[{"ZeemanKetBraOperatorBasis", "[", "spinsys", "]"}]}], 
          "]"}]}], ")"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"K2", "=", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"BasisOperators", "[", 
         RowBox[{"OperatorBasis", "[", "]"}], "]"}], ")"}], ".", 
       RowBox[{"(", 
        RowBox[{"SX", ".", "PSGZKB", ".", 
         RowBox[{"OperatorVectorRepresentation", "[", 
          RowBox[{
           RowBox[{"Sum", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{"opI", "[", "i", "]"}], ")"}], ".", 
              RowBox[{"(", 
               RowBox[{"opI", "[", "j", "]"}], ")"}]}], ",", 
             RowBox[{"{", 
              RowBox[{"i", ",", "1", ",", "nspins"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"j", ",", "1", ",", "nspins"}], "}"}]}], "]"}], ",", 
           RowBox[{"ZeemanKetBraOperatorBasis", "[", "spinsys", "]"}]}], 
          "]"}]}], ")"}]}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"KC1", "=", 
      RowBox[{
       RowBox[{"SX", ".", 
        RowBox[{"SuperoperatorMatrixRepresentation", "[", 
         RowBox[{
          RowBox[{"CommutationSuperoperator", "[", "K1", "]"}], ",", 
          RowBox[{"ZeemanKetBraOperatorBasis", "[", "spinsys", "]"}]}], "]"}],
         ".", 
        RowBox[{"ConjugateTranspose", "[", "SX", "]"}]}], "//", 
       "Simplify"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"KC2", "=", 
      RowBox[{
       RowBox[{"SX", ".", 
        RowBox[{"SuperoperatorMatrixRepresentation", "[", 
         RowBox[{
          RowBox[{"CommutationSuperoperator", "[", "K2", "]"}], ",", 
          RowBox[{"ZeemanKetBraOperatorBasis", "[", "spinsys", "]"}]}], "]"}],
         ".", 
        RowBox[{"ConjugateTranspose", "[", "SX", "]"}]}], "//", 
       "Simplify"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"nspace1", "=", 
      RowBox[{"SparseArray", "/@", 
