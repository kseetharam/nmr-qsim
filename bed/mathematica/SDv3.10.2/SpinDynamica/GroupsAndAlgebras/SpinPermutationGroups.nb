Cell[CellGroupData[{

Cell["enforce consistent  phase for isotopic spaces", "Subsection",ExpressionUUID->"7f07e441-f45c-4068-b453-fa8dc4302ecb"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ConsistentIsotopicPhase", "[", 
    RowBox[{"Gmats_", ",", "IsotopicSpaces_", ",", "1", ",", "dimG_"}], "]"}],
    ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"ReferenceSpace", ",", "ReferenceRep"}], "}"}], ",", "\n", 
     RowBox[{"IdentityMatrix", "[", 
      RowBox[{
       RowBox[{"Length", "[", "IsotopicSpaces", "]"}], ",", "SparseArray"}], 
      "]"}]}], "\n", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ConsistentIsotopicPhase", "[", 
    RowBox[{
    "Gmats_", ",", "IsotopicSpaces_", ",", "dim\[CapitalGamma]_", ",", 
     "dimG_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"ReferenceSpace", ",", "ReferenceRep", ",", "Scollection"}], 
      "}"}], ",", "\n", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Length", "[", "IsotopicSpaces", "]"}], "==", "1"}], ",", 
       "\n", 
       RowBox[{"IdentityMatrix", "[", 
        RowBox[{"dim\[CapitalGamma]", ",", "SparseArray"}], "]"}], ",", "\n", 
       
       RowBox[{
        RowBox[{"ReferenceSpace", "=", 
         RowBox[{"IsotopicSpaces", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ";", "\n", 
        RowBox[{"ReferenceRep", "=", 
         RowBox[{
          RowBox[{"Normal", "[", 
           RowBox[{"Gmats", "[", 
            RowBox[{"[", 
             RowBox[{"All", ",", "ReferenceSpace", ",", "ReferenceSpace"}], 
             "]"}], "]"}], "]"}], "//", "Simplify"}]}], ";", "\n", 
        RowBox[{"Scollection", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"ConsistentIsotopicPhaseU", "[", 
            RowBox[{"ReferenceRep", ",", 
             RowBox[{"Gmats", "[", 
              RowBox[{"[", 
               RowBox[{"All", ",", "#", ",", "#"}], "]"}], "]"}], ",", 
             "dim\[CapitalGamma]", ",", "dimG"}], "]"}], "&"}], "/@", 
          RowBox[{"Rest", "[", "IsotopicSpaces", "]"}]}]}], ";", "\n", 
        RowBox[{"ArrayFlatten", "[", 
         RowBox[{"ReleaseHold", "@", 
          RowBox[{"DiagonalMatrix", "[", 
           RowBox[{"Hold", "/@", 
            RowBox[{"Join", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"IdentityMatrix", "[", 
                RowBox[{"dim\[CapitalGamma]", ",", "SparseArray"}], "]"}], 
               "}"}], ",", "Scollection"}], "]"}]}], "]"}]}], "]"}]}]}], "\n",
       "]"}]}], "\n", "]"}]}], ";"}]}], "Code",
 CellChangeTimes->{{3.897388545982647*^9, 
  3.897388590680492*^9}},ExpressionUUID->"a583e3d4-7c47-4fc4-a76b-\
149282b83a2e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ConsistentIsotopicPhaseU", "[", 
   RowBox[{
   "\[Phi]_", ",", "\[Theta]_", ",", "dim\[CapitalGamma]_", ",", "dimG_"}], 
   "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"S", ",", "i$", ",", "k"}], "}"}], ",", "\n", 
    RowBox[{
     RowBox[{"i$", "=", "1"}], ";", "\n", 
     RowBox[{"S", "=", 
      RowBox[{"ConstantArray", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", 
         RowBox[{"dim\[CapitalGamma]", ",", "dim\[CapitalGamma]"}], "}"}], 
        ",", "SparseArray"}], "]"}]}], ";", "\n", 
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{"MatchQ", "[", 
        RowBox[{
         RowBox[{"S", "[", "\"\<NonzeroPositions\>\"", "]"}], ",", 
         RowBox[{"{", "}"}]}], "]"}], ",", "\n", 
       RowBox[{
        RowBox[{"S", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"dim\[CapitalGamma]", "/", "dimG"}], " ", 
              RowBox[{
               RowBox[{"\[Phi]", "[", 
                RowBox[{"[", 
                 RowBox[{"All", ",", "1", ",", "a"}], "]"}], "]"}], ".", 
               RowBox[{"Conjugate", "[", 
                RowBox[{"\[Theta]", "[", 
                 RowBox[{"[", 
                  RowBox[{"All", ",", "i$", ",", "b"}], "]"}], "]"}], 
                "]"}]}]}], ",", 
             RowBox[{"{", 
              RowBox[{"a", ",", "1", ",", "dim\[CapitalGamma]"}], "}"}], ",", 
             
             RowBox[{"{", 
              RowBox[{"b", ",", "1", ",", "dim\[CapitalGamma]"}], "}"}]}], 
            "]"}], "//", "Chop"}], "//", "SparseArray"}]}], ";", "\n", 
        RowBox[{"i$", "=", 
         RowBox[{"i$", "+", "1"}]}], ";"}]}], "\n", "]"}], ";", "\n", 
     RowBox[{"S", "=", 
      RowBox[{"Conjugate", "[", "S", "]"}]}]}]}], "\n", "]"}]}]], "Code",Expre\
ssionUUID->"dee45350-83dd-4e4d-ab8c-99f6a21f0067"]
