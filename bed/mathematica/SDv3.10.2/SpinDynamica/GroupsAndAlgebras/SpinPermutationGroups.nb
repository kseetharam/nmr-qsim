     RowBox[{"nspace2", "=", 
      RowBox[{"SparseArray", "/@", 
       RowBox[{"NullSpace", "[", "KC2", "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"nspace", "=", 
      RowBox[{"VectorSpaceIntersection", "[", 
       RowBox[{"nspace1", ",", "nspace2"}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"nops", "=", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"BasisOperators", "[", 
           RowBox[{"OperatorBasis", "[", "]"}], "]"}], ")"}], ".", "#"}], 
        "&"}], "/@", "nspace"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"nopsZKB", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"OperatorVectorRepresentation", "[", 
         RowBox[{"#", ",", 
          RowBox[{"ZeemanKetBraOperatorBasis", "[", "spinsys", "]"}]}], "]"}],
         "&"}], "/@", "nops"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"nopssym", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"ArrayReshape", "[", 
         RowBox[{"#", ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"BasisDimension", "[", 
             RowBox[{"ZeemanBasis", "[", "spinsys", "]"}], "]"}], ",", 
            RowBox[{"BasisDimension", "[", 
             RowBox[{"ZeemanBasis", "[", "spinsys", "]"}], "]"}]}], "}"}]}], 
         "]"}], "&"}], "/@", 
       RowBox[{"Orthogonalize", "[", 
        RowBox[{"N", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"PSGZKB", ".", "#"}], "&"}], "/@", "nopsZKB"}], "]"}], 
        "]"}]}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"ev", ",", "vecs"}], "}"}], "=", 
      RowBox[{
       RowBox[{"Eigensystem", "[", 
        RowBox[{"Total", "[", 
         RowBox[{
          RowBox[{"RandomReal", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "100"}], ",", "100"}], "}"}], ",", 
            RowBox[{"Length", "[", "nopssym", "]"}]}], "]"}], "nopssym"}], 
         "]"}], "]"}], "//", "Chop"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"vecs", "=", 
      RowBox[{"Orthogonalize", "[", "vecs", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"X", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"Transpose", "[", "vecs", "]"}], "//", "Chop"}], "//", 
       "SparseArray"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Gmats\[Xi]", "=", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"ConjugateTranspose", "[", "X", "]"}], ".", "#", ".", "X"}],
          "&"}], "/@", "Gmats"}], "//", "Chop"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"subspaces", "=", 
      RowBox[{"ConnectedComponents", "[", 
       RowBox[{"Rule", "@@@", 
        RowBox[{
         RowBox[{"SparseArray", "[", 
          RowBox[{"Chop", "[", 
           RowBox[{
            RowBox[{"RandomReal", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", "dimG"}], "]"}], 
            ".", "Gmats\[Xi]"}], "]"}], "]"}], "[", 
         "\"\<NonzeroPositions\>\"", "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"\[Xi]vecs", "=", 
      RowBox[{
       RowBox[{"Chop", "@", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"Tr", "[", 
             RowBox[{"gel", "\[LeftDoubleBracket]", 
              RowBox[{"#", ",", "#"}], "\[RightDoubleBracket]"}], "]"}], 
            "&"}], "/@", "subspaces"}], ",", 
          RowBox[{"{", 
           RowBox[{"gel", ",", "Gmats\[Xi]"}], "}"}]}], "]"}]}], "//", 
       "Transpose"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"\[Xi]groupings", "=", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"\[Xi]remaining", "=", 
      RowBox[{"Range", "[", 
       RowBox[{"Length", "[", "subspaces", "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{"\[Xi]remaining", "\[NotEqual]", 
        RowBox[{"{", "}"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"\[Xi]group", "=", 
         RowBox[{"\[Xi]remaining", "\[LeftDoubleBracket]", 
          RowBox[{"Flatten", "[", 
           RowBox[{"Position", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"MatchQ", "[", 
                RowBox[{
                 RowBox[{"{", "0", "}"}], ",", 
                 RowBox[{"Union", "[", 
                  RowBox[{"Chop", "[", 
                   RowBox[{
                    RowBox[{"\[Xi]vecs", "\[LeftDoubleBracket]", 
                    RowBox[{"First", "[", "\[Xi]remaining", "]"}], 
                    "\[RightDoubleBracket]"}], "-", "#"}], "]"}], "]"}]}], 
                "]"}], "&"}], "/@", 
              RowBox[{
              "\[Xi]vecs", "\[LeftDoubleBracket]", "\[Xi]remaining", 
               "\[RightDoubleBracket]"}]}], ",", "True"}], "]"}], "]"}], 
          "\[RightDoubleBracket]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"AppendTo", "[", 
         RowBox[{"\[Xi]groupings", ",", 
          RowBox[{
          "subspaces", "\[LeftDoubleBracket]", "\[Xi]group", 
           "\[RightDoubleBracket]"}]}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"\[Xi]remaining", "=", 
         RowBox[{"Complement", "[", 
          RowBox[{"\[Xi]remaining", ",", "\[Xi]group"}], "]"}]}], ";"}]}], 
      "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"\[Xi]perm", "=", 
      RowBox[{"Flatten", "[", "\[Xi]groupings", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"\[Xi]dim", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"Length", "[", 
         RowBox[{"First", "[", "#", "]"}], "]"}], "&"}], "/@", 
       "\[Xi]groupings"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Gmats\[Xi]perm", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"#", "\[LeftDoubleBracket]", 
         RowBox[{"\[Xi]perm", ",", "\[Xi]perm"}], "\[RightDoubleBracket]"}], 
        "&"}], "/@", "Gmats\[Xi]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"phaseU", "=", 
      RowBox[{"ArrayFlatten", "[", 
       RowBox[{"ReleaseHold", "@", 
        RowBox[{"DiagonalMatrix", "[", 
         RowBox[{"Hold", "/@", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"SparseArray", "@", 
              RowBox[{"ConsistentIsotopicPhase", "[", 
               RowBox[{"Gmats\[Xi]", ",", 
                RowBox[{
                "\[Xi]groupings", "\[LeftDoubleBracket]", "#", 
                 "\[RightDoubleBracket]"}], ",", 
                RowBox[{
                "\[Xi]dim", "\[LeftDoubleBracket]", "#", 
                 "\[RightDoubleBracket]"}], ",", "dimG"}], "]"}]}], "&"}], "/@", 
            RowBox[{"Range", "[", 
             RowBox[{"1", ",", 
              RowBox[{"Length", "[", "\[Xi]groupings", "]"}]}], "]"}]}], 
           ")"}]}], "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"normphaseU", "=", 
      RowBox[{"SparseArray", "@", 
       RowBox[{"DiagonalMatrix", "[", 
        RowBox[{"1", "/", 
         RowBox[{"Normal", "@", 
          RowBox[{"Sqrt", "[", 
           RowBox[{"Diagonal", "[", 
            RowBox[{
             RowBox[{"ConjugateTranspose", "[", "phaseU", "]"}], ".", 
             "phaseU"}], "]"}], "]"}]}]}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"phaseU", "=", 
      RowBox[{"phaseU", ".", "normphaseU"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"Conjugate", "[", 
        RowBox[{
         RowBox[{"Transpose", "[", 
          RowBox[{"(", 
           RowBox[{"X", ".", 
            RowBox[{"ConjugateTranspose", "[", 
             RowBox[{"phaseU", "\[LeftDoubleBracket]", 
              RowBox[{
               RowBox[{"InversePermutation", "[", "\[Xi]perm", "]"}], ",", 
               RowBox[{"InversePermutation", "[", "\[Xi]perm", "]"}]}], 
              "\[RightDoubleBracket]"}], "]"}]}], ")"}], "]"}], 
         "\[LeftDoubleBracket]", "\[Xi]perm", "\[RightDoubleBracket]"}], 
        "]"}], "//", "SparseArray"}], "//", "Chop"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
