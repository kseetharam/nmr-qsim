     RowBox[{
      RowBox[{
       RowBox[{"Length", "[", "spinsys", "]"}], "!=", "order"}], ",", 
      RowBox[{
       RowBox[{"Message", "[", 
        RowBox[{"SymmetryAdaptedBasis", "::", "order"}], "]"}], ";", 
       RowBox[{"Abort", "[", "]"}], ";"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Length", "[", 
        RowBox[{"DeleteDuplicates", "[", 
