Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SpinPermutationGroup", "::", "usage"}], "=", 
   "\"\<SpinPermutationGroup may be used to generate a set of operators that \
represents the specified group in terms of SpinPermutationOperators. The \
syntax for SpinPermutationGroup follows: \
SpinPermutationGroup[{\\\"GroupName\\\",GroupOrder}], where \\\"GroupName\\\" \
refers to the name of the group as a string and GroupOrder refers to the \
order of the group as an integer. For example, \
SpinPermutationGroup[{\\\"SymmetricGroup\\\",3}]. A list of supported groups \
may be found by executing the command \\\"FiniteGroupData[]\\\".\>\""}], 
  ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.547025606968602*^9, 3.547025615213552*^9}, {
   3.682594281787702*^9, 3.682594297089982*^9}, 3.7195728001256537`*^9, {
