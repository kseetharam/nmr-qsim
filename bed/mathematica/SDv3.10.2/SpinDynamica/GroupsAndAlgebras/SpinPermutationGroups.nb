Cell[BoxData[
 RowBox[{
  RowBox[{"SymmetryAdaptedBasisTFM", "[", 
   RowBox[{
    RowBox[{"SymmetryAdaptedBasis", "[", 
     RowBox[{"spinsys_", ",", 
      RowBox[{"SpinPermutationGroupOperators", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"\"\<SymmetricGroup\>\"", ",", "n_"}], "}"}], ",", 
          "group_"}], "}"}], ",", "spinlist_"}], "]"}], ",", "opts___Rule"}], 
     "]"}], ",", "basis1_"}], "]"}], ":=", "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
     "spins", ",", "\[IndentingNewLine]", "K1", ",", "K2", ",", "K3", ",", 
      "K4", ",", "CSCO", ",", "G", ",", "dimG", ",", "\[IndentingNewLine]", 
      "ev", ",", "vecs", ",", "Gmats", ",", "X", ",", "Xinv", ",", "\[Xi]vec",
       ",", "\[IndentingNewLine]", "G\[CapitalGamma]\[Gamma]mats", ",", 
      "\[CapitalGamma]\[Gamma]subspaces", ",", "\[CapitalGamma]\[Gamma]order",
       ",", "\[IndentingNewLine]", "vecs\[CapitalGamma]\[Gamma]sorted", ",", 
      "X\[CapitalGamma]\[Gamma]sorted", ",", 
      "X\[CapitalGamma]\[Gamma]invsorted", ",", 
      "\[Xi]vec\[CapitalGamma]\[Gamma]sorted", ",", "\[IndentingNewLine]", 
      "\[CapitalGamma]\[Gamma]cuts", ",", "\[CapitalGamma]\[Gamma]bounds", 
      ",", "\[CapitalGamma]\[Gamma]spaces", ",", "\[IndentingNewLine]", 
      "SpacePartition", ",", "IsotopicSpaces", ",", "truepos", ",", 
      "dim\[CapitalGamma]s", ",", "\[IndentingNewLine]", 
      "phasetransformations", ",", "phasetransformation", ",", 
      "\[IndentingNewLine]", "V", ",", "K3\[CapitalGamma]", ",", 
      "K4\[CapitalGamma]", ",", "dimvec"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"spins", "=", 
      RowBox[{"First", "[", 
       RowBox[{"Transpose", "[", "spinsys", "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"K1", "=", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{"SpinPermutationOperator", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{
            "spins", "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}], 
            ",", 
            RowBox[{
            "spins", "\[LeftDoubleBracket]", "j", "\[RightDoubleBracket]"}]}],
            "}"}], ",", "spinsys"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", 
          RowBox[{"n", "-", "1"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", 
          RowBox[{"i", "+", "1"}], ",", "n"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"K2", "=", 
      RowBox[{"SpinPermutationOperator", "[", 
       RowBox[{"spins", ",", "spinsys"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"K3", "=", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"opI", "[", 
           RowBox[{
           "spins", "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}], 
           "]"}], ")"}], ".", 
         RowBox[{"(", 
          RowBox[{"opI", "[", 
           RowBox[{
           "spins", "\[LeftDoubleBracket]", "j", "\[RightDoubleBracket]"}], 
           "]"}], ")"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", "n"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", "1", ",", "n"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"K4", "=", 
      RowBox[{"opI", "[", 
       RowBox[{"spins", ",", "\"\<z\>\""}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"G", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"SpinPermutationOperator", "[", 
          RowBox[{
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"MatchQ", "[", 
              RowBox[{"#", ",", 
               RowBox[{"{", 
                RowBox[{"{", "__", "}"}], "}"}]}], "]"}], ",", 
             RowBox[{
             "#", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], ",",
              "#"}], "]"}], ",", "spinsys"}], "]"}], ")"}], "&"}], "/@", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Sort", "[", 
          RowBox[{
           RowBox[{"GroupElements", "[", 
            RowBox[{"SymmetricGroup", "[", "n", "]"}], "]"}], "[", 
           RowBox[{"[", 
            RowBox[{"All", ",", "1"}], "]"}], "]"}], "]"}], "/.", 
         RowBox[{"Thread", "[", 
          RowBox[{
           RowBox[{"Range", "[", "n", "]"}], "\[Rule]", " ", "spins"}], 
          "]"}]}], ")"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"CSCO", "=", 
      RowBox[{"{", 
       RowBox[{"K1", ",", "K2", ",", "K3", ",", "K4"}], "}"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"dimG", "=", 
      RowBox[{"Length", "[", "G", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"ev", ",", "vecs"}], "}"}], "=", 
      RowBox[{"Chop", "@", 
       RowBox[{"Eigensystem", "[", 
        RowBox[{"MatrixRepresentation", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"RandomInteger", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"-", "100"}], ",", "100"}], "}"}], ",", 
             RowBox[{"Length", "[", "CSCO", "]"}]}], "]"}], ".", "CSCO"}], 
          ",", "basis1"}], "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"vecs", "=", 
      RowBox[{
       RowBox[{"vecs", "//", "Normal"}], "//", "FullSimplify"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"vecs", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"FullSimplify", "[", 
         RowBox[{"#", "/", 
          RowBox[{"Sqrt", "[", 
           RowBox[{"#", ".", 
            RowBox[{"Conjugate", "[", "#", "]"}]}], "]"}]}], "]"}], "&"}], "/@",
        "vecs"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Gmats", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"MatrixRepresentation", "[", 
         RowBox[{"#", ",", "basis1"}], "]"}], "&"}], "/@", "G"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"X", "=", 
      RowBox[{
       RowBox[{"Transpose", "[", "vecs", "]"}], "//", "SparseArray"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Xinv", "=", 
      RowBox[{"ConjugateTranspose", "[", "X", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"\[Xi]vec", "=", 
      RowBox[{"Normal", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"Xinv", ".", 
           RowBox[{"(", 
            RowBox[{"MatrixRepresentation", "[", 
             RowBox[{
              RowBox[{"CSCO", "[", 
               RowBox[{"[", "1", "]"}], "]"}], ",", "basis1"}], "]"}], ")"}], 
           ".", "X"}], "//", "N"}], "//", "Chop"}], "//", "Diagonal"}], 
       "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"G\[CapitalGamma]\[Gamma]mats", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"Simplify", "[", 
