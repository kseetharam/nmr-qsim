Cell[BoxData[{
 RowBox[{
  RowBox[{"Commutant", "[", 
   RowBox[{"args_", ",", "opts___Rule", ",", 
    RowBox[{"{", 
     RowBox[{"\"\<1\>\"", ",", "\"\<0\>\""}], "}"}]}], "]"}], ":=", 
  RowBox[{"Which", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"MatchQ", "[", 
     RowBox[{"args", ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"_", "?", "OperatorQ"}], ".."}], "}"}]}], "]"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"Commutant", "[", 
     RowBox[{"args", ",", "opts", ",", 
      RowBox[{"{", 
       RowBox[{"\"\<2\>\"", ",", "\"\<1\>\""}], "}"}]}], "]"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"MatchQ", "[", 
     RowBox[{"args", ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"_", "?", "OperatorQ"}], ".."}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
