Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Bicommutant", "::", "usage"}], "=", 
   "\"\<Bicommutant calculates the Bicommutant of a set of operators {Q}. The \
syntax for Bicommutant is as follows: (1) Bicommutant[{\!\(\*SubscriptBox[\(Q\
\), \(1\)]\),\!\(\*SubscriptBox[\(Q\), \(2\)]\),...,\!\(\*SubscriptBox[\(Q\), \
\(N\)]\)}], where \!\(\*SubscriptBox[\(Q\), \
\(1\)]\),\!\(\*SubscriptBox[\(Q\), \(2\)]\), etc. are spin operators. The \
Bicommutant is formally equivalent to the commutant of the commutant of Q, in \
example BC({Q})= C(C({Q})). In practice the Bicommutant is thus calculated as \
follows: Commutant[Commutant[{\!\(\*SubscriptBox[\(Q\), \
\(1\)]\),\!\(\*SubscriptBox[\(Q\), \(2\)]\),...,\!\(\*SubscriptBox[\(Q\), \(N\
\)]\)}]].\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.547025606968602*^9, 3.547025615213552*^9}, {
   3.682594281787702*^9, 3.682594297089982*^9}, 3.7195728001256537`*^9, {
