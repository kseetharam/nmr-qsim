Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Commutant", "::", "WrongInput"}], "=", " ", 
   "\"\<Commutant expects one of the following two inputs:\n\n1)a set of \
operators, for example {opI[\\\"z\\\"],opI[1].opI[2]}\n\n2)a tuple of a set \
of operators, for example \
{{opI[\\\"x\\\"]},{opI[\\\"x\\\"],opI[\\\"y\\\"]opI[\\\"z\\\"]}}\n\nIn case \
1) Commutant calculates the commutant of {\!\(\*SubscriptBox[\(Q\), \
\(1\)]\),..., \!\(\*SubscriptBox[\(Q\), \(n\)]\)} relative to the total \
operators space.\nIn case 2) Commutant calculates the commutant of \
{\!\(\*SubscriptBox[\(Q\), \(1\)]\),..., \!\(\*SubscriptBox[\(Q\), \(n\)]\)} \
relative to the truncated operators basis {\!\(\*SubscriptBox[\(B\), \
\(1\)]\),..., \!\(\*SubscriptBox[\(B\), \(N\)]\)} under the assumption that {\
\!\(\*SubscriptBox[\(Q\), \(1\)]\),..., \!\(\*SubscriptBox[\(Q\), \(n\)]\)} \
\[Subset] {\!\(\*SubscriptBox[\(B\), \(1\)]\),..., \!\(\*SubscriptBox[\(B\), \
\(N\)]\)}. \n\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.713866770255113*^9, 3.713866820477725*^9}, {
