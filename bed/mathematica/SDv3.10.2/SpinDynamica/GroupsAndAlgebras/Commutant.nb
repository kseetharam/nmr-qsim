   3.816351844413917*^9}, {3.816351925644654*^9, 3.816351926236689*^9}, {
   3.81635195992327*^9, 3.8163521760244284`*^9}, {3.816352243300144*^9, 
   3.816352335939567*^9}, {3.816355421449041*^9, 3.8163559714781637`*^9}, {
