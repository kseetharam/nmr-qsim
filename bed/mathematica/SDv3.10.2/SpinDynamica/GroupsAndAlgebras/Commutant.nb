Cell[CellGroupData[{

Cell["aux: VectorSpace intersection (Zassenhaus algorithm)", "Subsection",ExpressionUUID->"0f07bca5-d7b2-4d6d-8842-8c3ee3ddf0fa"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"VectorSpaceIntersection", "[", 
    RowBox[{
     RowBox[{"{", "}"}], ",", "W_"}], "]"}], ":=", 
   RowBox[{"{", "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"VectorSpaceIntersection", "[", 
    RowBox[{"V_", ",", 
     RowBox[{"{", "}"}]}], "]"}], ":=", 
   RowBox[{"{", "}"}]}], ";"}]}], "Code",
 CellChangeTimes->{{3.8922024711995707`*^9, 
  3.892202484622326*^9}},ExpressionUUID->"39572516-9e6e-4bf5-ac9f-\
3be243ecaee3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"VectorSpaceIntersection", "[", 
   RowBox[{"V_", ",", "W_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "lenVW", ",", "dimV", ",", "rrfVW", ",", "colcur", ",", "blockB", ",", 
      "counter"}], "}"}], ",", "\n", 
    RowBox[{
     RowBox[{"dimV", "=", 
      RowBox[{"Length", "[", 
       RowBox[{"V", "[", 
        RowBox[{"[", "1", "]"}], "]"}], "]"}]}], ";", "\n", 
     RowBox[{"rrfVW", "=", 
      RowBox[{"RowReduce", "[", 
       RowBox[{"ArrayFlatten", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"V", ",", "V"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"W", ",", "0"}], "}"}]}], "}"}], "]"}], "]"}]}], ";", "\n", 
     RowBox[{"counter", "=", 
      RowBox[{"-", "1"}]}], ";", "\n", 
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{"MatchQ", "[", 
        RowBox[{
         RowBox[{"Chop", "[", 
          RowBox[{"Normal", "[", 
           RowBox[{"rrfVW", "[", 
            RowBox[{"[", 
             RowBox[{"counter", ",", 
              RowBox[{"1", ";;", "dimV"}]}], "]"}], "]"}], "]"}], "]"}], ",", 
         
         RowBox[{"{", 
          RowBox[{"0", ".."}], "}"}]}], "]"}], ",", "\n", 
       RowBox[{
        RowBox[{"counter", "=", 
         RowBox[{"counter", "-", "1"}]}], ";"}]}], "\n", "]"}], ";", "\n", 
     RowBox[{"rrfVW", "[", 
      RowBox[{"[", 
       RowBox[{
        RowBox[{
         RowBox[{"counter", "+", "1"}], ";;", 
         RowBox[{"-", "1"}]}], ",", 
        RowBox[{
         RowBox[{"dimV", "+", "1"}], ";;"}]}], "]"}], "]"}]}]}], "\n", 
   "]"}]}]], "Code",ExpressionUUID->"37ed570a-021b-49f5-8acd-ef5ca49c887f"]
}, Closed]]
}, Closed]],

