Cell[BoxData[
 RowBox[{
  RowBox[{"Commutant", "[", 
   RowBox[{
    RowBox[{"algebra_", "?", "ListQ"}], ",", "opts___Rule", ",", 
    RowBox[{"{", 
     RowBox[{"\"\<2\>\"", ",", "\"\<1\>\""}], "}"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "opbasis", ",", "V", ",", "Vinv", ",", "commsops", ",", "nullspaces", 
      ",", "maximalintersection"}], "}"}], ",", 
    RowBox[{
     RowBox[{"opbasis", "=", 
      RowBox[{"OperatorBasis", "/.", 
       RowBox[{"Join", "[", 
        RowBox[{
         RowBox[{"{", "opts", "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"OperatorBasis", " ", "->", " ", 
           RowBox[{"OperatorBasis", "[", "]"}]}], "}"}]}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"V", "=", 
      RowBox[{"OperatorBasisTransformationMatrix", "[", 
       RowBox[{"opbasis", ",", 
        RowBox[{"ZeemanKetBraOperatorBasis", "[", "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Vinv", "=", 
      RowBox[{"ConjugateTranspose", "[", "V", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"commsops", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"SuperoperatorMatrixRepresentation", "[", 
         RowBox[{
          RowBox[{"CommutationSuperoperator", "[", "#", "]"}], ",", 
          RowBox[{"ZeemanKetBraOperatorBasis", "[", "]"}]}], "]"}], "&"}], "/@",
        "algebra"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"commsops", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"Chop", "@", 
         RowBox[{"Simplify", "[", 
          RowBox[{"V", ".", "#", ".", "Vinv"}], "]"}]}], "&"}], "/@", 
       "commsops"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"maximalintersection", "=", 
      RowBox[{"NullSpace", "[", 
       RowBox[{"ArrayFlatten", "[", 
        RowBox[{"List", "/@", "commsops"}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"MatchQ", "[", 
        RowBox[{"maximalintersection", ",", 
         RowBox[{"{", "}"}]}], "]"}], ",", 
       RowBox[{"{", "}"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"Simplify", "[", 
          RowBox[{"Total", "[", 
           RowBox[{
            RowBox[{"BasisOperators", "[", "opbasis", "]"}], "*", "#"}], 
           "]"}], "]"}], "&"}], "/@", "maximalintersection"}]}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
