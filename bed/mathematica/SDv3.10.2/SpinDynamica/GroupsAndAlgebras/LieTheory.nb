 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"isomorphismicreduction", "[", 
     RowBox[{
      RowBox[{"SNrep", "[", 
       RowBox[{"tab", ":", 
        RowBox[{"{", "___", "}"}]}], "]"}], ",", "set_", ",", "nspins_"}], 
     "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"Ystart", ",", "Ycycle", ",", "lengthcheck"}], "}"}], ",", 
      "\n", 
      RowBox[{
       RowBox[{"Ystart", "=", 
        RowBox[{"constructisomorphism", "[", 
         RowBox[{"SNrep", "[", "tab", "]"}], "]"}]}], ";", "\n", 
       RowBox[{"Ycycle", "=", 
