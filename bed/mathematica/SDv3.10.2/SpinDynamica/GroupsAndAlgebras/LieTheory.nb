     RowBox[{
      RowBox[{"k_.", "*", 
       RowBox[{"J", "[", "j1_", "]"}]}], ",", "j2_", ",", "\"\<2\>\""}], 
     "]"}], ":=", 
    RowBox[{"k", "*", 
     RowBox[{"J", "/@", 
      RowBox[{"Range", "[", 
       RowBox[{
        RowBox[{"Abs", "[", 
