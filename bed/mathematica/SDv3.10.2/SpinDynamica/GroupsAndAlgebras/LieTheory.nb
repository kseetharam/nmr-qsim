Cell[BoxData[
 RowBox[{
  RowBox[{"InaccessibleOperatorQ", "[", 
   RowBox[{
    RowBox[{"Qa_", "->", "Qb_"}], ",", "Halg_", ",", "opts___Rule", ",", 
