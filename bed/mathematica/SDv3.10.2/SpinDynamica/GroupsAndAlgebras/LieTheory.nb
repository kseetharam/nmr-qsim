Cell[CellGroupData[{

Cell["MaximalAbelianQ", "Section",
 CellChangeTimes->{{3.844505106193314*^9, 3.844505110275084*^9}, {
   3.8479726623493013`*^9, 3.8479726647483473`*^9}, 3.8479726982678714`*^9, {
   3.892185626129051*^9, 
   3.8921856285102596`*^9}},ExpressionUUID->"e8433762-1a02-42fd-b77f-\
cf295904ad7f"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"MaximalAbelianQ", "::", "usage"}], " ", "=", " ", "\n", 
   "\"\<MaximalAbelianQ determines whether a given Abelian subalgebra A={\!\(\
\*SubscriptBox[\(A\), \(1\)]\),\!\(\*SubscriptBox[\(A\), \(2\)]\), \
...,\!\(\*SubscriptBox[\(A\), \(n\)]\)} is maximal Abelian (Cartan) or not.\n\
\nThe syntax distinguishes two important cases:\n\n1) \
MaximalAbelianQ[{\!\(\*SubscriptBox[\(A\), \(1\)]\),\!\(\*SubscriptBox[\(A\), \
\(2\)]\),...,\!\(\*SubscriptBox[\(A\), \(n\)]\)}] checks if A is a maximal \
Abelian subalgebra for all of Liouville space.\n\n2) \
MaximalAbelianQ[{{\!\(\*SubscriptBox[\(A\), \
\(1\)]\),\!\(\*SubscriptBox[\(A\), \(2\)]\),...,\!\(\*SubscriptBox[\(A\), \(n\
\)]\)}, {\!\(\*SubscriptBox[\(B\), \(1\)]\),\!\(\*SubscriptBox[\(B\), \
\(2\)]\),...,\!\(\*SubscriptBox[\(B\), \(N\)]\)}}] checks if A is a maximal \
Abelian subalgebra inside B={\!\(\*SubscriptBox[\(B\), \
\(1\)]\),\!\(\*SubscriptBox[\(B\), \(2\)]\),...,\!\(\*SubscriptBox[\(B\), \(N\
\)]\)} under the assumption that A is an Abelian subalgebra of B, in example \
A \[Subset] B and [A,A]=0. \n\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.547025606968602*^9, 3.547025615213552*^9}, {
   3.682594281787702*^9, 3.682594297089982*^9}, 3.7195728001256537`*^9, {
