Cell[CellGroupData[{

Cell["decomposition functions", "Subsection",ExpressionUUID->"53da8878-b5dd-48d0-acf8-c24421c33c70"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"pairingstep", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"Ylist_", ",", "Jlist_", ",", "decomp_", ",", "nspins_"}], 
       "}"}], ",", "j1_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "eqs1", ",", "eqs2", ",", "Yset", ",", "tupsraw", ",", "tupsY", ",", 
        "SnxSmdecomp", ",", "SO3decomp", ",", "Yproductset", ",", 
        "decomptemp"}], "}"}], ",", "\n", 
      RowBox[{
       RowBox[{"Yset", "=", 
        RowBox[{"decomp", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";", "\n", 
       RowBox[{"eqs1", "=", 
        RowBox[{"Join", "[", 
         RowBox[{
          RowBox[{"MapThread", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"Total", "[", "#1", "]"}], "==", 
              RowBox[{"Total", "[", "#2", "]"}]}], "&"}], ",", 
            RowBox[{"{", 
             RowBox[{"Ylist", ",", "Jlist"}], "}"}]}], "]"}], ",", 
          RowBox[{"Flatten", "@", 
           RowBox[{"{", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"Thread", "[", 
               RowBox[{
                RowBox[{"Flatten", "[", "Ylist", "]"}], "==", 
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"isomorphismicreduction", "[", 
                   RowBox[{
                    RowBox[{"Flatten", "[", "Ylist", "]"}], ",", "Yset", ",", 
                    "nspins"}], "]"}], "/.", "decomp"}], ")"}]}], "]"}], "/.", 
              RowBox[{"{", 
               RowBox[{"True", "->", " ", "Nothing"}], "}"}]}], ")"}], 
            "}"}]}]}], "]"}]}], ";", "\n", 
       RowBox[{"tupsraw", "=", 
        RowBox[{"Select", "[", 
         RowBox[{
          RowBox[{"Tuples", "[", 
           RowBox[{
            RowBox[{"Rest", "@", 
             RowBox[{"(", 
              RowBox[{"Yset", "/.", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"SNrep", "[", "tab_", "]"}], ":>", " ", "tab"}], 
                "}"}]}], ")"}]}], ",", "2"}], "]"}], ",", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"Total", "[", 
              RowBox[{"Flatten", "@", "#"}], "]"}], "<=", "nspins"}], "&"}], 
           ")"}]}], "]"}]}], ";", "\n", 
       RowBox[{"tupsY", "=", 
        RowBox[{"tupsraw", "/.", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"tab", ":", 
            RowBox[{"{", 
             RowBox[{"i_Integer", ",", "___"}], "}"}]}], ":>", " ", 
           RowBox[{"SNrep", "[", "tab", "]"}]}], "}"}]}]}], ";", "\n", 
       RowBox[{"SnxSmdecomp", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"LRRuleSO3", "[", 
           RowBox[{"#", ",", "j1"}], "]"}], "&"}], "/@", "tupsraw"}]}], ";", 
       "\n", 
       RowBox[{"SO3decomp", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"amcoupling", "[", "#", "]"}], "&"}], "/@", 
         RowBox[{"(", 
          RowBox[{"tupsY", "/.", "decomp"}], ")"}]}]}], ";", "\n", 
       RowBox[{"Yproductset", "=", 
        RowBox[{"DeleteDuplicates", "@", 
         RowBox[{"(", 
          RowBox[{"SNrep", "/@", 
           RowBox[{"Flatten", "[", 
            RowBox[{"SnxSmdecomp", ",", "1"}], "]"}]}], ")"}]}]}], ";", "\n", 
       
       RowBox[{"eqs2", "=", 
        RowBox[{"DeleteDuplicates", "@", 
         RowBox[{"Join", "[", 
          RowBox[{
           RowBox[{"Flatten", "@", 
            RowBox[{"{", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"Thread", "[", 
                RowBox[{"Yproductset", "==", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"isomorphismicreduction", "[", 
                    RowBox[{"Yproductset", ",", "Yset", ",", "nspins"}], 
                    "]"}], "/.", "decomp"}], ")"}]}], "]"}], "/.", 
               RowBox[{"{", 
                RowBox[{"True", "->", " ", "Nothing"}], "}"}]}], ")"}], 
             "}"}]}], ",", 
           RowBox[{"MapThread", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"Total", "[", 
                RowBox[{"SNrep", "/@", "#1"}], "]"}], "==", "#2"}], "&"}], 
             ",", 
             RowBox[{"{", 
              RowBox[{"SnxSmdecomp", ",", "SO3decomp"}], "}"}]}], "]"}]}], 
          "]"}]}]}], ";", "\n", 
       RowBox[{"decomptemp", "=", 
        RowBox[{"DeleteDuplicates", "@", 
         RowBox[{"Join", "[", 
          RowBox[{"decomp", ",", 
           RowBox[{"First", "@", 
            RowBox[{"Quiet", "@", 
             RowBox[{"Solve", "[", 
              RowBox[{"Join", "[", 
               RowBox[{"eqs1", ",", "eqs2"}], "]"}], "]"}]}]}]}], "]"}]}]}], 
       ";", "\n", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"SNdp", "[", 
          RowBox[{"Flatten", "[", "Ylist", "]"}], "]"}], ",", 
         RowBox[{"amcoupling", "[", 
          RowBox[{
           RowBox[{"List", "/@", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"Flatten", "[", "Ylist", "]"}], "/.", "decomptemp"}], 
             ")"}]}], ",", "j1"}], "]"}], ",", "decomptemp", ",", 
         RowBox[{"nspins", "+", "1"}]}], "}"}]}]}], "\n", "]"}]}], ";"}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"DualPairing", "[", 
    RowBox[{"n_", ",", "j1_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "dim", ",", "dummy", ",", "Ylist", ",", "Jlist", ",", "decomp", ",", 
       "JstartRange"}], "}"}], ",", "\n", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"IntegerQ", "[", "n", "]"}], ",", " ", "\n", "True", ",", " ",
         "\n", 
        RowBox[{
         RowBox[{"Message", "[", 
          RowBox[{"DualPairing", "::", "wrongnspins"}], "]"}], ";", 
         RowBox[{"Abort", "[", "]"}]}]}], "\n", "]"}], ";", "\n", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"IntegerQ", "[", 
         RowBox[{"2", "*", "j1"}], "]"}], ",", " ", "\n", "True", ",", " ", 
        "\n", 
        RowBox[{
         RowBox[{"Message", "[", 
          RowBox[{"DualPairing", "::", "wrongangularmomentum"}], "]"}], ";", 
         RowBox[{"Abort", "[", "]"}]}]}], "\n", "]"}], ";", "\n", 
      RowBox[{"dim", "=", 
       RowBox[{
        RowBox[{"2", "j1"}], "+", "1"}]}], ";", "\n", 
      RowBox[{"JstartRange", "=", 
       RowBox[{"Range", "[", 
        RowBox[{"0", ",", 
         RowBox[{"2", "j1"}]}], "]"}]}], ";", "\n", 
      RowBox[{"decomp", "=", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"IntegerQ", "[", "j1", "]"}], ",", "\n", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"SNrep", "[", 
             RowBox[{"ConstantArray", "[", 
              RowBox[{"0", ",", "dim"}], "]"}], "]"}], "->", " ", 
            RowBox[{"J", "[", "0", "]"}]}], ",", "\n", 
           RowBox[{
            RowBox[{"SNrep", "[", 
             RowBox[{"Join", "[", 
              RowBox[{
               RowBox[{"{", "1", "}"}], ",", 
               RowBox[{"ConstantArray", "[", 
                RowBox[{"0", ",", 
                 RowBox[{"dim", "-", "1"}]}], "]"}]}], "]"}], "]"}], "->", 
            RowBox[{"J", "[", "j1", "]"}]}], ",", "\n", 
           RowBox[{
            RowBox[{"SNrep", "[", 
             RowBox[{"Join", "[", 
              RowBox[{
               RowBox[{"{", "2", "}"}], ",", 
               RowBox[{"ConstantArray", "[", 
                RowBox[{"0", ",", 
                 RowBox[{"dim", "-", "1"}]}], "]"}]}], "]"}], "]"}], "->", 
            RowBox[{"Total", "[", 
             RowBox[{"J", "/@", 
              RowBox[{"Select", "[", 
               RowBox[{"JstartRange", ",", "EvenQ"}], "]"}]}], "]"}]}], ",", 
           "\n", 
           RowBox[{
            RowBox[{"SNrep", "[", 
             RowBox[{"Join", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"1", ",", "1"}], "}"}], ",", 
               RowBox[{"ConstantArray", "[", 
                RowBox[{"0", ",", 
                 RowBox[{"dim", "-", "2"}]}], "]"}]}], "]"}], "]"}], "->", 
            RowBox[{"Total", "[", 
             RowBox[{"J", "/@", 
              RowBox[{"Select", "[", 
               RowBox[{"JstartRange", ",", "OddQ"}], "]"}]}], "]"}]}]}], "\n",
           "}"}], ",", "\n", 
         RowBox[{"{", "\n", 
          RowBox[{
           RowBox[{
            RowBox[{"SNrep", "[", 
             RowBox[{"ConstantArray", "[", 
              RowBox[{"0", ",", "dim"}], "]"}], "]"}], "->", " ", 
            RowBox[{"J", "[", "0", "]"}]}], ",", "\n", 
           RowBox[{
            RowBox[{"SNrep", "[", 
             RowBox[{"Join", "[", 
              RowBox[{
               RowBox[{"{", "1", "}"}], ",", 
               RowBox[{"ConstantArray", "[", 
                RowBox[{"0", ",", 
                 RowBox[{"dim", "-", "1"}]}], "]"}]}], "]"}], "]"}], "->", 
            RowBox[{"J", "[", "j1", "]"}]}], ",", "\n", 
           RowBox[{
            RowBox[{"SNrep", "[", 
             RowBox[{"Join", "[", 
              RowBox[{
               RowBox[{"{", "2", "}"}], ",", 
               RowBox[{"ConstantArray", "[", 
                RowBox[{"0", ",", 
                 RowBox[{"dim", "-", "1"}]}], "]"}]}], "]"}], "]"}], "->", 
            RowBox[{"Total", "[", 
             RowBox[{"J", "/@", 
              RowBox[{"Select", "[", 
               RowBox[{"JstartRange", ",", "OddQ"}], "]"}]}], "]"}]}], ",", 
           "\n", 
           RowBox[{
            RowBox[{"SNrep", "[", 
             RowBox[{"Join", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"1", ",", "1"}], "}"}], ",", 
               RowBox[{"ConstantArray", "[", 
                RowBox[{"0", ",", 
                 RowBox[{"dim", "-", "2"}]}], "]"}]}], "]"}], "]"}], "->", 
            RowBox[{"Total", "[", 
             RowBox[{"J", "/@", 
              RowBox[{"Select", "[", 
               RowBox[{"JstartRange", ",", "EvenQ"}], "]"}]}], "]"}]}]}], 
          "\n", "}"}]}], "\n", "]"}]}], ";", "\n", 
      RowBox[{"Ylist", "=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"SNrep", "[", 
           RowBox[{"Join", "[", 
            RowBox[{
             RowBox[{"{", "2", "}"}], ",", 
             RowBox[{"ConstantArray", "[", 
              RowBox[{"0", ",", 
               RowBox[{"dim", "-", "1"}]}], "]"}]}], "]"}], "]"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"SNrep", "[", 
           RowBox[{"Join", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"1", ",", "1"}], "}"}], ",", 
             RowBox[{"ConstantArray", "[", 
              RowBox[{"0", ",", 
               RowBox[{"dim", "-", "2"}]}], "]"}]}], "]"}], "]"}], "}"}]}], 
        "}"}]}], ";", "\n", 
      RowBox[{"Jlist", "=", 
       RowBox[{"List", "/@", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Flatten", "[", "Ylist", "]"}], "/.", "decomp"}], ")"}]}]}],
       ";", "\n", 
      RowBox[{"Multicolumn", "[", 
       RowBox[{"dualpairingplot", "/@", 
        RowBox[{"Cases", "[", 
         RowBox[{
          RowBox[{"Rest", "[", 
           RowBox[{
            RowBox[{"Nest", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"pairingstep", "[", 
                RowBox[{"#", ",", "j1"}], "]"}], "&"}], ",", 
              RowBox[{"{", 
               RowBox[{"Ylist", ",", "Jlist", ",", "decomp", ",", "2"}], 
               "}"}], ",", 
              RowBox[{"n", "-", "1"}]}], "]"}], "[", 
            RowBox[{"[", "3", "]"}], "]"}], "]"}], ",", 
          RowBox[{"_", "?", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"Total", "[", 
               RowBox[{"#", "[", 
                RowBox[{"[", 
                 RowBox[{"1", ",", "1"}], "]"}], "]"}], "]"}], "==", "n"}], 
             "&"}], ")"}]}]}], "]"}]}], "]"}]}]}], "\n", "]"}]}], 
  ";"}]}], "Code",
 CellChangeTimes->{{3.788078688592554*^9, 3.7880786906818013`*^9}, {
   3.78807886395183*^9, 3.7880789326386147`*^9}, {3.788078990942007*^9, 
