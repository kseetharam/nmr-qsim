802280b61ace"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"DualPairing", "::", "usage"}], " ", "=", " ", "\n", 
   "\"\<DualPairing determintes the dual pairing between irreducible \
representations of S(n) and SO(3). The syntax is as follows: \
dualpairing[nspins, angularmomentum].\n\nThe symbol nspins is an integer \
representing the number of identical spins and\nangularmomentum is an integer \
or half-integer representing the angular momentum of the spins.\n\nThe dual \
pairing for three identical spin-1/2 particles would be calcualted as \
follows: dualpairing[3, 1/2]\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.547025606968602*^9, 3.547025615213552*^9}, {
   3.682594281787702*^9, 3.682594297089982*^9}, 3.7195728001256537`*^9, {
