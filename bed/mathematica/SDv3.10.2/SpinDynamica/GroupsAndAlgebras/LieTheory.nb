 RowBox[{
  RowBox[{"MaximalAbelianQ", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"operators_", ",", "algebra_"}], "}"}], ",", "opts___Rule", ",", 
    
    RowBox[{"{", 
     RowBox[{"\"\<2\>\"", ",", "\"\<2\>\""}], "}"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "projalg", ",", "somats", ",", "opbasis", ",", "algdim", ",", "opdim"}], 
     "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"opbasis", "=", 
      RowBox[{
       RowBox[{"OperatorBasis", "/.", 
        RowBox[{"{", "opts", "}"}]}], "/.", 
       RowBox[{"Options", "[", "MaximalAbelianQ", "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"algdim", "=", 
      RowBox[{"Length", "[", "algebra", "]"}]}], ";", "\n", 
     RowBox[{"opdim", "=", 
      RowBox[{"Length", "[", "operators", "]"}]}], ";", "\n", 
     RowBox[{"projalg", "=", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"OperatorVectorRepresentation", "[", 
          RowBox[{"#", ",", "opbasis"}], "]"}], "&"}], "/@", "algebra"}], "//",
        "SparseArray"}]}], ";", "\[IndentingNewLine]", 
