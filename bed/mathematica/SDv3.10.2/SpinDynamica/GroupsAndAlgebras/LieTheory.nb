 RowBox[{
  RowBox[{"InaccessibleOperatorQ", "[", 
   RowBox[{
    RowBox[{"Qa_", "->", "Qb_"}], ",", "Halg_", ",", "opts___Rule", ",", 
    RowBox[{"{", 
     RowBox[{"\"\<1\>\"", ",", "\"\<0\>\""}], "}"}]}], "]"}], ":=", 
  RowBox[{"Which", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"MatchQ", "[", 
     RowBox[{
      RowBox[{"{", "True", "}"}], ",", 
      RowBox[{"DeleteDuplicates", "@", 
       RowBox[{"Join", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"OperatorQ", "[", "Qa", "]"}], ",", 
           RowBox[{"OperatorQ", "[", "Qb", "]"}]}], "}"}], ",", 
         RowBox[{"OperatorQ", "/@", "Halg"}]}], "]"}]}]}], "]"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"InaccessibleOperatorQ", "[", 
     RowBox[{
      RowBox[{"Qa", "->", "Qb"}], ",", "Halg", ",", "opts", ",", 
      RowBox[{"{", 
       RowBox[{"\"\<2\>\"", ",", "\"\<1\>\""}], "}"}]}], "]"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"MatchQ", "[", 
     RowBox[{
      RowBox[{"{", "True", "}"}], ",", 
      RowBox[{"DeleteDuplicates", "@", 
       RowBox[{"Join", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"OperatorQ", "[", "Qa", "]"}], "}"}], ",", 
         RowBox[{"OperatorQ", "/@", 
          RowBox[{"Flatten", "[", 
           RowBox[{"{", "Qb", "}"}], "]"}]}], ",", 
         RowBox[{"OperatorQ", "/@", "Halg"}]}], "]"}]}]}], "]"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"InaccessibleOperatorQ", "[", 
     RowBox[{
      RowBox[{"Qa", "->", "Qb"}], ",", "Halg", ",", "opts", ",", 
