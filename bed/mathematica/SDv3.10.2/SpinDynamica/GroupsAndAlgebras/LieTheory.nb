Cell[BoxData[
 RowBox[{
  RowBox[{"InaccessibleOperatorQ", "[", 
   RowBox[{
    RowBox[{"Qa_", "->", "Qbset_"}], ",", 
    RowBox[{"Halg", ":", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"_", "?", "OperatorQ"}], ".."}], "}"}]}], ",", "opts___Rule", 
    ",", 
    RowBox[{"{", 
     RowBox[{"\"\<2\>\"", ",", "\"\<2\>\""}], "}"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "ddots", ",", "opbasis", ",", "basis", ",", "field", ",", "Halgmats", 
      ",", "Qamat", ",", "Qbmats", ",", "commops", ",", "accset", ",", "la", 
      ",", "lb"}], "}"}], ",", "\n", 
    RowBox[{
     RowBox[{"opbasis", "=", 
      RowBox[{
       RowBox[{"OperatorBasis", "/.", 
        RowBox[{"{", "opts", "}"}]}], "/.", 
       RowBox[{"Options", "[", "LieAlgebra", "]"}]}]}], ";", "\n", 
     RowBox[{"basis", "=", 
      RowBox[{
       RowBox[{"Basis", "/.", 
        RowBox[{"{", "opts", "}"}]}], "/.", 
       RowBox[{"Options", "[", "LieAlgebra", "]"}]}]}], ";", "\n", 
     RowBox[{"field", "=", 
      RowBox[{
       RowBox[{"LieAlgebraField", "/.", 
        RowBox[{"{", "opts", "}"}]}], "/.", 
       RowBox[{"Options", "[", "LieAlgebra", "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Halgmats", "=", 
      RowBox[{"SparseArray", "/@", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"MatrixRepresentation", "[", 
           RowBox[{"#", ",", "basis"}], "]"}], "&"}], "/@", "Halg"}], 
        ")"}]}]}], ";", "\n", 
     RowBox[{"Qamat", "=", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"MatrixRepresentation", "[", 
         RowBox[{"Qa", ",", "basis"}], "]"}], ")"}], "//", "Simplify"}]}], 
     ";", "\n", 
     RowBox[{"Qbmats", "=", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"MatrixRepresentation", "[", 
           RowBox[{"#", ",", "basis"}], "]"}], "&"}], "/@", "Qbset"}], ")"}], 
       "//", "Simplify"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"ddots", "=", 
      RowBox[{"DownValues", "[", "Dot", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Unprotect", "[", "Dot", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"DownValues", "[", "Dot", "]"}], "=", 
      RowBox[{"{", "}"}]}], ";", "\n", 
     RowBox[{"commops", "=", 
      RowBox[{"Join", "[", 
       RowBox[{
        RowBox[{"{", "Qamat", "}"}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"-", "I"}], 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"#", ".", "Qamat"}], "-", 
             RowBox[{"Qamat", ".", "#"}]}], ")"}]}], "&"}], "/@", 
         "Halgmats"}]}], "]"}]}], ";", "\n", 
     RowBox[{"accset", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"Simplify", "[", 
         RowBox[{"#", "/", 
          RowBox[{"Sqrt", "[", 
           RowBox[{"Tr", "[", 
            RowBox[{
             RowBox[{"ConjugateTranspose", "[", "#", "]"}], ".", "#"}], "]"}],
            "]"}]}], "]"}], "&"}], "/@", 
       RowBox[{"commops", "\[LeftDoubleBracket]", 
        RowBox[{"rrefgetpivots", "[", 
         RowBox[{"RowReduce", "[", 
          RowBox[{"Transpose", "[", 
           RowBox[{"Flatten", "/@", "commops"}], "]"}], "]"}], "]"}], 
        "\[RightDoubleBracket]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"la", "=", "1"}], ";", "\n", 
     RowBox[{"lb", "=", "0"}], ";", "\n", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Length", "[", "accset", "]"}], "==", "0"}], ",", "\n", 
       RowBox[{
        RowBox[{
         RowBox[{"DownValues", "[", "Dot", "]"}], "=", "ddots"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Protect", "[", "Dot", "]"}], ";", "\n", 
        RowBox[{"ConstantArray", "[", 
         RowBox[{"True", ",", 
          RowBox[{"Length", "[", "Qbset", "]"}]}], "]"}]}], ",", "\n", 
       RowBox[{
        RowBox[{"While", "[", 
         RowBox[{
          RowBox[{"la", "!=", "lb"}], ",", "\n", 
          RowBox[{
           RowBox[{"la", "=", 
            RowBox[{"Length", "[", "accset", "]"}]}], ";", "\n", 
           RowBox[{"commops", "=", 
            RowBox[{"Flatten", "[", 
             RowBox[{
              RowBox[{"Outer", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{
                  RowBox[{"-", "I"}], 
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{"#2", ".", "#1"}], "-", 
                    RowBox[{"#1", ".", "#2"}]}], ")"}]}], "&"}], ",", 
                "Halgmats", ",", "accset", ",", "1"}], "]"}], ",", "1"}], 
             "]"}]}], ";", "\n", 
           RowBox[{"commops", "=", 
            RowBox[{"Join", "[", 
             RowBox[{"accset", ",", "commops"}], "]"}]}], ";", "\n", 
           RowBox[{"accset", "=", 
            RowBox[{
             RowBox[{
              RowBox[{"Simplify", "[", 
               RowBox[{"#", "/", 
                RowBox[{"Sqrt", "[", 
                 RowBox[{"Tr", "[", 
                  RowBox[{
                   RowBox[{"ConjugateTranspose", "[", "#", "]"}], ".", "#"}], 
                  "]"}], "]"}]}], "]"}], "&"}], "/@", 
             RowBox[{"commops", "\[LeftDoubleBracket]", 
              RowBox[{"rrefgetpivots", "[", 
               RowBox[{"RowReduce", "[", 
                RowBox[{"Transpose", "[", 
                 RowBox[{"Flatten", "/@", "commops"}], "]"}], "]"}], "]"}], 
              "\[RightDoubleBracket]"}]}]}], ";", "\n", 
           RowBox[{"lb", "=", 
            RowBox[{"Length", "[", "accset", "]"}]}], ";"}]}], "\n", "]"}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"DownValues", "[", "Dot", "]"}], "=", "ddots"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Protect", "[", "Dot", "]"}], ";", "\n", 
        RowBox[{
         RowBox[{
          RowBox[{"MatchQ", "[", 
           RowBox[{
            RowBox[{"Chop", "[", 
             RowBox[{
              RowBox[{"Conjugate", "[", 
               RowBox[{"Flatten", "/@", 
                RowBox[{"N", "[", "accset", "]"}]}], "]"}], ".", 
              RowBox[{"Flatten", "[", "#", "]"}]}], "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"0", ".."}], "}"}]}], "]"}], "&"}], "/@", "Qbmats"}]}]}],
       "\n", "]"}]}]}], "\[IndentingNewLine]", "]"}]}]], "Code",
 CellChangeTimes->{{3.788078672577361*^9, 3.788078679593325*^9}, {
