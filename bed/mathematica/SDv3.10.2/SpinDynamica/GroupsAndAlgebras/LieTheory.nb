Cell[CellGroupData[{

Cell["AbelianSubalgebra", "Section",
 CellChangeTimes->{{3.844505106193314*^9, 3.844505110275084*^9}, {
   3.8479726623493013`*^9, 3.8479726647483473`*^9}, 3.8479726982678714`*^9, {
   3.892185626129051*^9, 3.8921856285102596`*^9}, {3.892207170973716*^9, 
   3.892207173521263*^9}},ExpressionUUID->"04b0e013-8fc9-4253-81e9-\
2ac589e60ba6"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"AbelianSubalgebra", "::", "usage"}], " ", "=", " ", 
   "\"\<AbelianSubalgebra extends an initial Hermitian-Abelian subalgebra A={\
\!\(\*SubscriptBox[\(A\), \(1\)]\),\!\(\*SubscriptBox[\(A\), \(2\)]\), ...,\!\
\(\*SubscriptBox[\(A\), \(n\)]\)} \[Subset] B to its maximal rank with \
respect to Lie algebra basis B={\!\(\*SubscriptBox[\(B\), \
\(1\)]\),\!\(\*SubscriptBox[\(B\), \(2\)]\), ...,\!\(\*SubscriptBox[\(B\), \
\(N\)]\)}.\n\nThe syntax distinguishes two cases:\n\n1) AbelianSubalgebra[{\!\
\(\*SubscriptBox[\(A\), \(1\)]\),\!\(\*SubscriptBox[\(A\), \(2\)]\), ...,\!\(\
\*SubscriptBox[\(A\), \(n\)]\)}] extends A to its maximal abelian rank with \
respect to all of Liouville space.\n\n2) \
AbelianSubalgebra[{{\!\(\*SubscriptBox[\(A\), \(1\)]\),\!\(\*SubscriptBox[\(A\
\), \(2\)]\), ...,\!\(\*SubscriptBox[\(A\), \(n\)]\)}, \
{\!\(\*SubscriptBox[\(B\), \(1\)]\),\!\(\*SubscriptBox[\(B\), \(2\)]\), \
...,\!\(\*SubscriptBox[\(B\), \(N\)]\)}}] extends A to its maximal abelian \
rank inside B={\!\(\*SubscriptBox[\(B\), \(1\)]\),\!\(\*SubscriptBox[\(B\), \
\(2\)]\), ...,\!\(\*SubscriptBox[\(B\), \(N\)]\)} under the assumption that A \
is an Abelian subalgebra of B, in example A \[Subset] B and [A,A]=0. \n\
\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.547025606968602*^9, 3.547025615213552*^9}, {
   3.682594281787702*^9, 3.682594297089982*^9}, 3.7195728001256537`*^9, {
