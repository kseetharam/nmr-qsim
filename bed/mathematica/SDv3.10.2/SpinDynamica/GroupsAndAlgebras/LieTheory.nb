Cell[BoxData[
 RowBox[{
  RowBox[{"rrefgetpivots", "[", "rre_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"j", ",", "pivot", ",", "pivotpos", ",", "maxdim"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"maxdim", "=", 
      RowBox[{
       RowBox[{"Dimensions", "[", "rre", "]"}], "\[LeftDoubleBracket]", "2", 
       "\[RightDoubleBracket]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"j", "=", "1"}], ";", "\[IndentingNewLine]", 
     RowBox[{"pivot", "=", 
      RowBox[{"FirstPosition", "[", 
       RowBox[{
        RowBox[{"rre", "\[LeftDoubleBracket]", "j", "\[RightDoubleBracket]"}],
         ",", "1"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"pivotpos", "=", 
      RowBox[{"{", "pivot", "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"!", 
         RowBox[{"MatchQ", "[", 
          RowBox[{"pivot", ",", 
           RowBox[{"Missing", "[", "\"\<NotFound\>\"", "]"}]}], "]"}]}], 
        "\[And]", 
        RowBox[{"j", "<", 
         RowBox[{"maxdim", "+", "1"}]}]}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"j", "=", 
         RowBox[{"j", "+", "1"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"pivot", "=", 
         RowBox[{"FirstPosition", "[", 
          RowBox[{
           RowBox[{
           "rre", "\[LeftDoubleBracket]", "j", "\[RightDoubleBracket]"}], ",",
            "1"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"AppendTo", "[", 
         RowBox[{"pivotpos", ",", "pivot"}], "]"}], ";"}]}], 
      "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Flatten", "[", 
      RowBox[{"pivotpos", "/.", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Missing", "[", "\"\<NotFound\>\"", "]"}], "->", "Nothing"}],
         "}"}]}], "]"}]}]}], "\[IndentingNewLine]", "]"}]}]], "Code",
