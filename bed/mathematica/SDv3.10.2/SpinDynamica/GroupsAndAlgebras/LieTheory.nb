Cell[BoxData[
 RowBox[{
  RowBox[{"MaximalAbelianQ", "[", 
   RowBox[{"alg_", ",", "opts___Rule", ",", 
    RowBox[{"{", 
     RowBox[{"\"\<2\>\"", ",", "\"\<1\>\""}], "}"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "somats", ",", "opbasis", ",", "basis", ",", "algdim", ",", "dim"}], 
     "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"opbasis", "=", 
      RowBox[{
       RowBox[{"OperatorBasis", "/.", 
        RowBox[{"{", "opts", "}"}]}], "/.", 
       RowBox[{"Options", "[", "MaximalAbelianQ", "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"dim", "=", 
      RowBox[{"BasisDimension", "[", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"algdim", "=", 
      RowBox[{"Length", "[", "alg", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"somats", "=", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"SuperoperatorMatrixRepresentation", "[", 
          RowBox[{
           RowBox[{"CommutationSuperoperator", "[", "#", "]"}], ",", 
           "opbasis"}], "]"}], "&"}], "/@", "alg"}], ")"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"dim", "^", "2"}], "-", "1"}], ")"}], "-", 
        RowBox[{"MatrixRank", "[", 
         RowBox[{
          RowBox[{"RandomReal", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "100"}], ",", "100"}], "}"}], ",", "algdim"}], 
           "]"}], ".", "somats"}], "]"}]}], ")"}], "==", "algdim"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Code",
