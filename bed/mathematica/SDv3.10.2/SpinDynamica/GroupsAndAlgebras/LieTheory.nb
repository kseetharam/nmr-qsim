Cell[BoxData[
 RowBox[{
  RowBox[{"AbelianSubalgebra", "[", 
   RowBox[{
    RowBox[{"operators", ":", 
     RowBox[{"{", "___", "}"}]}], ",", "opts___Rule", ",", 
    RowBox[{"{", 
     RowBox[{"\"\<2\>\"", ",", "\"\<1\>\""}], "}"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "idop", ",", "bops", ",", "opbasis", ",", "abelianalg", ",", "nsQ", ",", 
      "nsA", ",", "nsB", ",", "temp", ",", "pivots", ",", "la", ",", "lb"}], 
     "}"}], ",", "\n", 
    RowBox[{
     RowBox[{"opbasis", "=", 
      RowBox[{
       RowBox[{"OperatorBasis", "/.", 
        RowBox[{"{", "opts", "}"}]}], "/.", 
       RowBox[{"Options", "[", "AbelianSubalgebra", "]"}]}]}], ";", "\n", 
     RowBox[{"bops", "=", 
      RowBox[{"BasisOperators", "[", "opbasis", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"abelianalg", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"OperatorVectorRepresentation", "[", 
         RowBox[{"#", ",", "opbasis"}], "]"}], "&"}], "/@", "operators"}]}], 
     ";", "\n", 
     RowBox[{"nsQ", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"SparseArray", "@", 
         RowBox[{"NullSpace", "[", 
          RowBox[{"SuperoperatorMatrixRepresentation", "[", 
           RowBox[{
            RowBox[{"CommutationSuperoperator", "[", "#", "]"}], ",", 
            "opbasis"}], "]"}], "]"}]}], "&"}], "/@", "operators"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"nsA", "=", 
      RowBox[{"SparseArray", "@", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "operators", "]"}], "==", "1"}], ",", 
         RowBox[{"First", "[", "nsQ", "]"}], ",", 
         RowBox[{"Fold", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"VectorSpaceIntersection", "[", 
             RowBox[{"#1", ",", "#2"}], "]"}], "&"}], ",", 
           RowBox[{"First", "[", "nsQ", "]"}], ",", 
           RowBox[{"Rest", "[", "nsQ", "]"}]}], "]"}]}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"temp", "=", 
      RowBox[{"Join", "[", 
       RowBox[{"abelianalg", ",", "nsA"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"pivots", "=", 
      RowBox[{"rrefgetpivots", "[", 
       RowBox[{"RowReduce", "[", 
        RowBox[{"Transpose", "[", "temp", "]"}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"la", "=", 
      RowBox[{"Length", "[", "abelianalg", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"lb", "=", 
      RowBox[{"Length", "[", "pivots", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{"la", "!=", "lb"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"AppendTo", "[", 
         RowBox[{"abelianalg", ",", 
          RowBox[{"temp", "\[LeftDoubleBracket]", 
           RowBox[{"pivots", "\[LeftDoubleBracket]", 
            RowBox[{"la", "+", "1"}], "\[RightDoubleBracket]"}], 
           "\[RightDoubleBracket]"}]}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"la", "=", 
         RowBox[{"Length", "[", "abelianalg", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"nsB", "=", 
         RowBox[{"SparseArray", "@", 
          RowBox[{"NullSpace", "[", 
           RowBox[{"SuperoperatorMatrixRepresentation", "[", 
            RowBox[{
             RowBox[{"CommutationSuperoperator", "[", 
              RowBox[{
               RowBox[{"Last", "[", "abelianalg", "]"}], ".", "bops"}], "]"}],
              ",", "opbasis"}], "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
        
        RowBox[{"nsA", "=", 
         RowBox[{"SparseArray", "@", 
          RowBox[{"VectorSpaceIntersection", "[", 
           RowBox[{"nsA", ",", "nsB"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"temp", "=", 
         RowBox[{"Join", "[", 
          RowBox[{"abelianalg", ",", "nsA"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"pivots", "=", 
         RowBox[{"rrefgetpivots", "[", 
          RowBox[{"RowReduce", "[", 
           RowBox[{"Transpose", "[", "temp", "]"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"lb", "=", 
         RowBox[{"Length", "[", "nsA", "]"}]}]}]}], "]"}], ";", "\n", 
     RowBox[{"idop", "=", 
      RowBox[{"OperatorVectorRepresentation", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"UnityOperator", "[", "]"}], "/", 
         RowBox[{"Sqrt", "[", 
          RowBox[{"BasisDimension", "[", "]"}], "]"}]}], ",", "opbasis"}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"DeleteCases", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"#", "-", 
               RowBox[{
                RowBox[{"idop", ".", "#"}], " ", "idop"}]}], ")"}], "&"}], "/@",
             "abelianalg"}], ")"}], ".", "bops"}], "//", "Simplify"}], "//", 
        "Chop"}], ",", "0"}], "]"}]}]}], "\n", "]"}]}]], "Code",
