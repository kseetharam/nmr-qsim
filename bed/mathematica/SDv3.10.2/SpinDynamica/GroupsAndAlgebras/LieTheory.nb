Cell[CellGroupData[{

Cell["\<\
Littlewood-Richardson-Rule \
(http://sporadic.stanford.edu/bump/match/weight/lwr.html)\
\>", "Subsection",
 CellChangeTimes->{{3.844505297775963*^9, 
  3.844505298820218*^9}},ExpressionUUID->"2f2fa438-4712-48b0-a84c-\
9be78b3cabcc"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"NextPartition", "[", "p_", "]"}], ":=", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"p", "[", 
        RowBox[{"[", "1", "]"}], "]"}], "==", "1"}], ",", 
      RowBox[{"{", 
       RowBox[{"-", "1"}], "}"}], ",", 
      RowBox[{"Block", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"k", ",", "q", ",", "l", ",", "s"}], "}"}], ",", 
        RowBox[{
         RowBox[{"For", "[", 
          RowBox[{
           RowBox[{"k", "=", 
            RowBox[{"PartitionLength", "[", "p", "]"}]}], ",", 
           RowBox[{
            RowBox[{"p", "[", 
             RowBox[{"[", "k", "]"}], "]"}], "<=", "1"}], ",", 
           RowBox[{"k", "=", 
            RowBox[{"k", "-", "1"}]}]}], "]"}], ";", "\n", 
         RowBox[{"q", "=", 
          RowBox[{"Take", "[", 
           RowBox[{"p", ",", 
            RowBox[{"k", "-", "1"}]}], "]"}]}], ";", "\n", 
         RowBox[{"l", "=", 
          RowBox[{
           RowBox[{"p", "[", 
            RowBox[{"[", "k", "]"}], "]"}], "-", "1"}]}], ";", "\n", 
         RowBox[{"While", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"s", "=", 
              RowBox[{
               RowBox[{"Plus", "@@", "p"}], "-", 
               RowBox[{"Plus", "@@", "q"}]}]}], ")"}], ">=", "l"}], ",", 
           RowBox[{"q", "=", 
            RowBox[{"Append", "[", 
             RowBox[{"q", ",", "l"}], "]"}]}]}], "]"}], ";", "\n", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"s", "==", "0"}], ",", "q", ",", 
           RowBox[{"Append", "[", 
            RowBox[{"q", ",", "s"}], "]"}]}], "]"}]}]}], "]"}]}], "]"}]}], 
   ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Partitions", "[", "n_", "]"}], ":=", 
    RowBox[{
     RowBox[{"Partitions", "[", "n", "]"}], "=", 
     RowBox[{"Block", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"l", ",", "p"}], "}"}], ",", 
       RowBox[{
        RowBox[{"l", "=", 
         RowBox[{"{", 
          RowBox[{"{", "n", "}"}], "}"}]}], ";", "\n", 
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"p", "=", 
           RowBox[{"{", "n", "}"}]}], ",", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"p", "=", 
             RowBox[{"NextPartition", "[", "p", "]"}]}], ")"}], "!=", 
           RowBox[{"{", 
            RowBox[{"-", "1"}], "}"}]}], ",", "None", ",", 
          RowBox[{"l", "=", 
           RowBox[{"Append", "[", 
            RowBox[{"l", ",", "p"}], "]"}]}]}], "]"}], ";", "l"}]}], 
      "]"}]}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"PartitionCompare", "[", 
     RowBox[{"p_", ",", "q_"}], "]"}], ":=", 
