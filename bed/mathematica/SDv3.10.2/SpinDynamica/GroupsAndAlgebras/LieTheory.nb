  3.847430120565759*^9}, {3.847523211482456*^9, 3.847523232034253*^9}, {
  3.8477879674987297`*^9, 3.847787968685877*^9}, {3.847950893122135*^9, 
  3.8479509310173907`*^9}, {3.8921131021801777`*^9, 
  3.892113104081551*^9}},ExpressionUUID->"cc6f209e-4530-4f60-8c07-\
c98f3c0e67ba"],

Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{
   RowBox[{"LieAlgebra", "[", 
    RowBox[{"opset_", ",", "opts___Rule"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "opbasis", ",", "basis", ",", "l1", ",", "l2", ",", "setA", ",", "setB",
        ",", "setOB", ",", "norm", ",", "ddots"}], "}"}], ",", "\n", 
     RowBox[{
      RowBox[{"opbasis", "=", 
       RowBox[{
        RowBox[{"OperatorBasis", "/.", 
         RowBox[{"{", "opts", "}"}]}], "/.", 
        RowBox[{"{", 
         RowBox[{"OperatorBasis", "\[Rule]", 
          RowBox[{"OperatorBasis", "[", "]"}]}], "}"}]}]}], ";", "\n", 
      RowBox[{"basis", "=", 
       RowBox[{
        RowBox[{"Basis", "/.", 
         RowBox[{"{", "opts", "}"}]}], "/.", 
        RowBox[{"{", 
         RowBox[{"Basis", "\[Rule]", 
          RowBox[{"Basis", "[", "]"}]}], "}"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"setA", "=", 
       RowBox[{"SparseArray", "/@", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"MatrixRepresentation", "[", 
            RowBox[{"#", ",", "basis"}], "]"}], "&"}], "/@", "opset"}], 
         ")"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"ddots", "=", 
       RowBox[{"DownValues", "[", "Dot", "]"}]}], ";", "\[IndentingNewLine]", 
      
      RowBox[{"Unprotect", "[", "Dot", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"ddots", "=", 
       RowBox[{"DownValues", "[", "Dot", "]"}]}], ";", "\[IndentingNewLine]", 
      
      RowBox[{"setB", "=", "setA"}], ";", "\[IndentingNewLine]", 
      RowBox[{"l1", "=", "0"}], ";", "\[IndentingNewLine]", 
      RowBox[{"l2", "=", "1"}], ";", "\[IndentingNewLine]", 
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{"l1", "\[NotEqual]", "l2"}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"l1", "=", 
          RowBox[{"Length", "[", "setA", "]"}]}], ";", "\[IndentingNewLine]", 
         
         RowBox[{"setB", "=", 
          RowBox[{"DeleteCases", "[", 
           RowBox[{
            RowBox[{"Flatten", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"-", "I"}], " ", 
               RowBox[{"Chop", "@", 
                RowBox[{"Outer", "[", 
                 RowBox[{
                  RowBox[{
                   RowBox[{
                    RowBox[{"#1", ".", "#2"}], "-", 
                    RowBox[{"#2", ".", "#1"}]}], "&"}], ",", "setA", ",", 
                  "setB", ",", "1"}], "]"}]}]}], ",", "1"}], "]"}], ",", 
            RowBox[{"_", "?", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"MatchQ", "[", 
                RowBox[{
                 RowBox[{"#", "[", "\"\<NonzeroPositions\>\"", "]"}], ",", 
                 RowBox[{"{", "}"}]}], "]"}], "&"}], ")"}]}]}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"setOB", "=", "setA"}], ";", "\[IndentingNewLine]", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"AppendTo", "[", 
            RowBox[{"setOB", ",", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{
              "setB", "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}], 
              "-", 
              RowBox[{"Sum", "[", "\[IndentingNewLine]", 
               RowBox[{
                RowBox[{
                 RowBox[{"norm", "=", 
                  RowBox[{"Chop", "[", 
                   RowBox[{"Tr", "[", 
                    RowBox[{
                    RowBox[{"ConjugateTranspose", "[", 
                    RowBox[{
                    "setOB", "\[LeftDoubleBracket]", "j", 
                    "\[RightDoubleBracket]"}], "]"}], ".", 
                    RowBox[{
                    "setOB", "\[LeftDoubleBracket]", "j", 
                    "\[RightDoubleBracket]"}]}], "]"}], "]"}]}], ";", 
                 "\[IndentingNewLine]", 
                 RowBox[{"If", "[", 
                  RowBox[{
                   RowBox[{"norm", "\[Equal]", "0"}], ",", "0", ",", 
                   RowBox[{
                    RowBox[{
                    "setOB", "\[LeftDoubleBracket]", "j", 
                    "\[RightDoubleBracket]"}], 
                    RowBox[{
                    RowBox[{"Tr", "[", 
                    RowBox[{
                    RowBox[{"ConjugateTranspose", "[", 
                    RowBox[{
                    "setOB", "\[LeftDoubleBracket]", "j", 
                    "\[RightDoubleBracket]"}], "]"}], ".", 
                    RowBox[{
                    "setB", "\[LeftDoubleBracket]", "i", 
                    "\[RightDoubleBracket]"}]}], "]"}], "/", "norm"}]}]}], 
                  "]"}]}], ",", 
                RowBox[{"{", 
                 RowBox[{"j", ",", "1", ",", 
                  RowBox[{"Length", "[", "setOB", "]"}]}], "}"}]}], "]"}]}]}],
             "]"}], ",", "\[IndentingNewLine]", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", 
             RowBox[{"Length", "[", "setB", "]"}]}], "}"}]}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"setA", "=", 
          RowBox[{"DeleteCases", "[", 
           RowBox[{
            RowBox[{"Chop", "[", "setOB", "]"}], ",", 
            RowBox[{"_", "?", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"MatchQ", "[", 
                RowBox[{
                 RowBox[{"#", "[", "\"\<NonzeroPositions\>\"", "]"}], ",", 
                 RowBox[{"{", "}"}]}], "]"}], "&"}], ")"}]}]}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"setB", "=", 
          RowBox[{"setA", "\[LeftDoubleBracket]", 
           RowBox[{
            RowBox[{"l1", "+", "1"}], ";;"}], "\[RightDoubleBracket]"}]}], 
         ";", "\[IndentingNewLine]", 
         RowBox[{"l2", "=", 
          RowBox[{"Length", "[", "setA", "]"}]}], ";"}]}], 
       "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"DownValues", "[", "Dot", "]"}], "=", "ddots"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Protect", "[", "Dot", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Simplify", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"ExpressOperator", "[", 
          RowBox[{"#", ",", "opbasis"}], "]"}], "&"}], "/@", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"Operator", "[", 
            RowBox[{"#", ",", "basis"}], "]"}], "&"}], "/@", "setA"}], 
         ")"}]}], "]"}]}]}], "\[IndentingNewLine]", "]"}]}], "*)"}]], "Code",
 CellChangeTimes->{{3.788078672577361*^9, 3.788078679593325*^9}, {
   3.847972759602776*^9, 3.847972794083925*^9}, {3.847990815312167*^9, 
