        RowBox[{
         RowBox[{
          RowBox[{"!", 
           RowBox[{"MemberQ", "[", 
            RowBox[{"set", ",", "Ystart"}], "]"}]}], "&&", 
          RowBox[{"!", 
           RowBox[{"MemberQ", "[", 
            RowBox[{"Ycycle", ",", "Ystart"}], "]"}]}]}], ",", "\n", 
         RowBox[{
          RowBox[{"Ystart", "=", 
           RowBox[{"constructisomorphism", "[", "Ystart", "]"}]}], ";", "\n", 
          
          RowBox[{"Ycycle", "=", 
           RowBox[{"Append", "[", 
            RowBox[{"Ycycle", ",", "Ystart"}], "]"}]}], ";"}]}], "\n", "]"}], 
       ";", "\n", 
       RowBox[{"If", "[", 
