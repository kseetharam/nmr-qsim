Cell[BoxData[
 RowBox[{
  RowBox[{"LieAlgebra", "[", 
   RowBox[{"opset_", ",", "opts___Rule"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "field", ",", "ddots", ",", "opbasis", ",", "basis", ",", "la", ",", 
      "lb", ",", "setA", ",", "setB", ",", "comms", ",", "commsAB"}], "}"}], 
    ",", "\n", 
    RowBox[{
     RowBox[{"opbasis", "=", 
      RowBox[{
       RowBox[{"OperatorBasis", "/.", 
        RowBox[{"{", "opts", "}"}]}], "/.", 
       RowBox[{"Options", "[", "LieAlgebra", "]"}]}]}], ";", "\n", 
     RowBox[{"basis", "=", 
      RowBox[{
       RowBox[{"Basis", "/.", 
        RowBox[{"{", "opts", "}"}]}], "/.", 
       RowBox[{"Options", "[", "LieAlgebra", "]"}]}]}], ";", "\n", 
     RowBox[{"field", "=", 
      RowBox[{
       RowBox[{"LieAlgebraField", "/.", 
        RowBox[{"{", "opts", "}"}]}], "/.", 
       RowBox[{"Options", "[", "LieAlgebra", "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"setA", "=", 
      RowBox[{"SparseArray", "/@", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"MatrixRepresentation", "[", 
           RowBox[{"#", ",", "basis"}], "]"}], "&"}], "/@", "opset"}], 
        ")"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"ddots", "=", 
      RowBox[{"DownValues", "[", "Dot", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Unprotect", "[", "Dot", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"DownValues", "[", "Dot", "]"}], "=", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"setB", "=", "setA"}], ";", "\[IndentingNewLine]", 
     RowBox[{"la", "=", 
      RowBox[{"Length", "[", "setA", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"lb", "=", 
      RowBox[{"Length", "[", "setB", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"comms", "=", 
      RowBox[{"Flatten", "[", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"a", ",", "b"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"a", ",", "1", ",", "la"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"b", ",", "a", ",", "lb"}], "}"}]}], "]"}], ",", "1"}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"commsAB", "=", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"-", "I"}], 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"setA", "\[LeftDoubleBracket]", 
             RowBox[{
             "#", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], 
             "\[RightDoubleBracket]"}], ".", 
            RowBox[{"setB", "\[LeftDoubleBracket]", 
             RowBox[{
             "#", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}], 
             "\[RightDoubleBracket]"}]}], "-", 
           RowBox[{
            RowBox[{"setB", "\[LeftDoubleBracket]", 
             RowBox[{
             "#", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}], 
             "\[RightDoubleBracket]"}], ".", 
            RowBox[{"setA", "\[LeftDoubleBracket]", 
             RowBox[{
             "#", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], 
             "\[RightDoubleBracket]"}]}]}], ")"}]}], "&"}], "/@", "comms"}]}],
      ";", "\[IndentingNewLine]", 
     RowBox[{"setA", "=", 
      RowBox[{"LieAlgebraLinIndepOperators", "[", 
       RowBox[{
        RowBox[{"Join", "[", 
         RowBox[{"setA", ",", "commsAB"}], "]"}], ",", "field"}], "]"}]}], 
     ";", "\n", 
     RowBox[{"la", "=", "0"}], ";", "\n", 
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Length", "[", "setA", "]"}], "!=", "la"}], ",", "\n", 
       RowBox[{
        RowBox[{"setB", "=", 
         RowBox[{"setA", "\[LeftDoubleBracket]", 
          RowBox[{
           RowBox[{"la", "+", "1"}], ";;"}], "\[RightDoubleBracket]"}]}], ";",
         "\[IndentingNewLine]", 
        RowBox[{"la", "=", 
         RowBox[{"Length", "[", "setA", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"lb", "=", 
         RowBox[{"Length", "[", "setB", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"comms", "=", 
         RowBox[{"Flatten", "[", 
          RowBox[{
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"a", ",", "b"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"a", ",", "1", ",", "la"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"b", ",", "1", ",", "lb"}], "}"}]}], "]"}], ",", "1"}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"commsAB", "=", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"-", "I"}], 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"setA", "\[LeftDoubleBracket]", 
                RowBox[{
                "#", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], 
                "\[RightDoubleBracket]"}], ".", 
               RowBox[{"setB", "\[LeftDoubleBracket]", 
                RowBox[{
                "#", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}], 
                "\[RightDoubleBracket]"}]}], "-", 
              RowBox[{
               RowBox[{"setB", "\[LeftDoubleBracket]", 
                RowBox[{
                "#", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}], 
                "\[RightDoubleBracket]"}], ".", 
               RowBox[{"setA", "\[LeftDoubleBracket]", 
                RowBox[{
                "#", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], 
                "\[RightDoubleBracket]"}]}]}], ")"}]}], "&"}], "/@", 
          "comms"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"setA", "=", 
         RowBox[{"LieAlgebraLinIndepOperators", "[", 
          RowBox[{
           RowBox[{"Join", "[", 
            RowBox[{"setA", ",", "commsAB"}], "]"}], ",", "field"}], "]"}]}], 
        ";"}]}], "\n", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"DownValues", "[", "Dot", "]"}], "=", "ddots"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Protect", "[", "Dot", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Simplify", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"ExpressOperator", "[", 
         RowBox[{"#", ",", "opbasis"}], "]"}], "&"}], "/@", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"Operator", "[", 
           RowBox[{"#", ",", "basis"}], "]"}], "&"}], "/@", "setA"}], ")"}]}],
       "]"}]}]}], "\[IndentingNewLine]", "]"}]}]], "Code",
