Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"LieAlgebra", "::", "usage"}], " ", "=", " ", "\n", 
   "\"\<LieAlgebra calculates the Lie algebra with respect to the a \
generating set of opertors {\!\(\*SubscriptBox[\(Q\), \(1\)]\), \
\!\(\*SubscriptBox[\(Q\), \(2\)]\),..., \!\(\*SubscriptBox[\(Q\), \(N\)]\)}. \
The syntax is as follows: LieAlgebra[{\!\(\*SubscriptBox[\(Q\), \(1\)]\), \
\!\(\*SubscriptBox[\(Q\), \(2\)]\),..., \!\(\*SubscriptBox[\(Q\), \(N\)]\)}], \
for example LieAlgebra[{opI[\\\"x\\\"],opI[\\\"y\\\"]}] calculates the Lie \
algebra of the rotation group SO(3).\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.547025606968602*^9, 3.547025615213552*^9}, {
   3.682594281787702*^9, 3.682594297089982*^9}, 3.7195728001256537`*^9, {
