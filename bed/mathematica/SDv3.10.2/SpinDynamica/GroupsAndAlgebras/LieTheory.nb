Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"LieAlgebraLinIndepOperators", "[", 
    RowBox[{"ops_", ",", "\"\<R\>\""}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"rre", ",", "dim", ",", "j", ",", "pivot", ",", "pivotpos"}], 
      "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"dim", "=", 
       RowBox[{"Length", "[", "ops", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"rre", "=", 
       RowBox[{"RowReduce", "[", 
        RowBox[{"Transpose", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Join", "[", 
            RowBox[{
             RowBox[{"Re", "[", "#", "]"}], ",", 
             RowBox[{"Im", "[", "#", "]"}]}], "]"}], "&"}], "/@", 
          RowBox[{"Flatten", "/@", "ops"}]}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"j", "=", "1"}], ";", "\[IndentingNewLine]", 
      RowBox[{"pivot", "=", 
       RowBox[{"FirstPosition", "[", 
        RowBox[{
         RowBox[{
         "rre", "\[LeftDoubleBracket]", "j", "\[RightDoubleBracket]"}], ",", 
         "1"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"pivotpos", "=", 
       RowBox[{"{", "pivot", "}"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"!", 
          RowBox[{"MatchQ", "[", 
           RowBox[{"pivot", ",", 
            RowBox[{"Missing", "[", "\"\<NotFound\>\"", "]"}]}], "]"}]}], 
         "\[And]", 
         RowBox[{"j", "<", 
          RowBox[{"dim", "+", "1"}]}]}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"j", "=", 
          RowBox[{"j", "+", "1"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"pivot", "=", 
          RowBox[{"FirstPosition", "[", 
           RowBox[{
            RowBox[{
            "rre", "\[LeftDoubleBracket]", "j", "\[RightDoubleBracket]"}], 
            ",", "1"}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"AppendTo", "[", 
          RowBox[{"pivotpos", ",", "pivot"}], "]"}], ";"}]}], 
       "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"ops", "\[LeftDoubleBracket]", 
       RowBox[{"Flatten", "[", 
        RowBox[{"pivotpos", "/.", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Missing", "[", "\"\<NotFound\>\"", "]"}], "->", 
           "Nothing"}], "}"}]}], "]"}], "\[RightDoubleBracket]"}]}]}], 
    "\[IndentingNewLine]", "]"}]}], "\n"}], "\n", 
