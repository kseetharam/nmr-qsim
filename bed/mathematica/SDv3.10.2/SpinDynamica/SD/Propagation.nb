        RowBox[{"MatrixRepresentation", "[", 
         RowBox[{"\[Rho]", ",", "basis"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Ufw", "=", 
        RowBox[{"MatrixRepresentation", "[", 
         RowBox[{
          RowBox[{"NPropagationOperator", "[", 
           RowBox[{"evlist", ",", "opts"}], "]"}], ",", "basis", ",", 
          "opts"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Ubw", "=", 
        RowBox[{"ConjugateTranspose", "@", "Ufw"}]}], ";", 
