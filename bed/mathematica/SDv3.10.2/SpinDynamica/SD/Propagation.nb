Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"NPropagationOperator", "[", 
     RowBox[{"True", ",", 
      RowBox[{"{", 
       RowBox[{"True", ",", "4"}], "}"}], ",", "InitialPropagator_", ",", 
      "\[IndentingNewLine]", 
      RowBox[{"ev", ":", 
       RowBox[{"Event", "[", 
        RowBox[{
         RowBox[{"st", ":", 
          RowBox[{"True", "|", 
           RowBox[{"{", 
            RowBox[{"True", ".."}], "}"}]}]}], ",", "ch_", ",", 
         "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Hfunc", ":", 
            RowBox[{"TimeDependentGeneratorFunction", "[", 
             RowBox[{"args__", ",", 
              RowBox[{"op_", "?", "OperatorQ"}], ",", 
              "tdepgenfuncopts___Rule"}], "]"}]}], ",", "\[Tau]_"}], "}"}], 
         ",", "evopts___Rule"}], "\[IndentingNewLine]", "]"}]}], ",", 
      "\[IndentingNewLine]", "opbasis_", ",", "basis_", ",", "opts___Rule"}], 
     "]"}], "/;", 
    RowBox[{"MatchQ", "[", 
     RowBox[{
      RowBox[{"PropagatorCalculationProcedure", "[", "ev", "]"}], ",", 
      "IntegrateEvolutionOverTime"}], "]"}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "tb", ",", "ta", ",", "Hmatfunc", ",", "NDSolveopts", ",", "n", ",", 
       "u", ",", "uvec", ",", "uvecplain", ",", "uvecflat", ",", "umat", ",", 
       "h", ",", "hvec", ",", "hmat", ",", "t$", ",", "sol", ",", "Ufunc"}], 
      "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"tb", ",", "ta"}], "}"}], "=", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"FinalTimePoint", "[", "ev", "]"}], ",", 
          RowBox[{"InitialTimePoint", "[", "ev", "]"}]}], "}"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Hmatfunc", "=", "\[IndentingNewLine]", 
        RowBox[{"Function", "[", 
         RowBox[{"tinternal", ",", "\[IndentingNewLine]", 
          RowBox[{"Evaluate", "[", "\[IndentingNewLine]", 
           RowBox[{"Normal", "@", 
            RowBox[{"MatrixRepresentation", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"Hfunc", "[", 
                RowBox[{"tinternal", ",", "ta", ",", "tb"}], "]"}], "/.", 
               RowBox[{"{", 
                RowBox[{"evopts", ",", "opts"}], "}"}]}], ",", "basis"}], 
             "]"}]}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"NDSolveopts", "=", 
        RowBox[{"Sequence", "@@", 
         RowBox[{"FilterRules", "[", 
          RowBox[{
           RowBox[{"SimplifyRules", "[", 
            RowBox[{"{", 
             RowBox[{"evopts", ",", "opts"}], "}"}], "]"}], ",", 
           RowBox[{"Options", "[", "NDSolve", "]"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"n", "=", 
        RowBox[{"BasisDimension", "[", 
         RowBox[{"Basis", "[", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"uvec", "[", "t$_", "]"}], ":=", 
        RowBox[{"Evaluate", "[", 
         RowBox[{"Array", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"u", "[", 
              RowBox[{"#1", ",", "#2"}], "]"}], "[", "t$", "]"}], "&"}], ",", 
           
           RowBox[{"{", 
            RowBox[{"n", ",", "n"}], "}"}]}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"uvecflat", "[", "t$_", "]"}], ":=", 
        RowBox[{"Evaluate", "[", 
         RowBox[{"Flatten", "[", 
          RowBox[{"Array", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"u", "[", 
               RowBox[{"#1", ",", "#2"}], "]"}], "[", "t$", "]"}], "&"}], ",", 
            RowBox[{"{", 
             RowBox[{"n", ",", "n"}], "}"}]}], "]"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"uvecplain", "=", 
        RowBox[{"Evaluate", "[", 
         RowBox[{"Array", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"u", "[", 
             RowBox[{"#1", ",", "#2"}], "]"}], "&"}], ",", 
           RowBox[{"{", 
            RowBox[{"n", ",", "n"}], "}"}]}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"sol", "=", 
        RowBox[{"NDSolveValue", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"D", "[", 
              RowBox[{
               RowBox[{"uvecflat", "[", "t$", "]"}], ",", "t$"}], "]"}], 
             "\[Equal]", 
             RowBox[{
              RowBox[{"-", "I"}], " ", 
              RowBox[{"(", 
               RowBox[{"Flatten", "[", 
                RowBox[{
                 RowBox[{"Hmatfunc", "[", "t$", "]"}], ".", 
                 RowBox[{"uvec", "[", "t$", "]"}]}], "]"}], ")"}]}]}], ",", 
            RowBox[{
             RowBox[{"uvecflat", "[", "ta", "]"}], "\[Equal]", 
             RowBox[{"Flatten", "[", 
              RowBox[{"Normal", "@", 
               RowBox[{"MatrixRepresentation", "[", 
                RowBox[{"InitialPropagator", ",", "basis"}], "]"}]}], 
              "]"}]}]}], "}"}], ",", "uvecplain", ",", 
          RowBox[{"{", 
           RowBox[{"t$", ",", "ta", ",", "tb"}], "}"}], ",", "NDSolveopts"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Ufunc", "=", 
        RowBox[{"Function", "[", 
         RowBox[{"t", ",", 
          RowBox[{"Evaluate", "[", "\[IndentingNewLine]", 
           RowBox[{"Operator", "[", "\[IndentingNewLine]", 
            RowBox[{"(*", 
             RowBox[{"SparseArray", "@"}], "*)"}], 
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"Through", "[", 
                 RowBox[{"#", "[", "t", "]"}], "]"}], "&"}], "/@", "sol"}], 
              ")"}], ",", "\[IndentingNewLine]", "basis", ",", 
             RowBox[{"CheckOperatorType", "\[Rule]", " ", "False"}]}], "]"}], 
           "\[IndentingNewLine]", "]"}]}], "]"}]}]}], "\[IndentingNewLine]", 
      ")"}]}], "]"}]}], ";"}]], "Input",
