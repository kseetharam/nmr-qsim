             RowBox[{"StandardizeGenerator", "[", 
              RowBox[{
               RowBox[{"Lfunc", "[", 
                RowBox[{"t$", ",", "ta", ",", "tb"}], "]"}], "/.", 
               RowBox[{"{", 
                RowBox[{"evopts", ",", "opts"}], "}"}]}], "]"}], ",", 
             "opbasis"}], "]"}], "]"}]}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"uvec", "[", "t$_", "]"}], ":=", 
