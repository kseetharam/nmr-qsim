Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"NPropagationSuperoperator", "[", 
    RowBox[{"True", ",", "False", ",", 
     RowBox[{"Event", "[", 
      RowBox[{
       RowBox[{"st", ":", 
        RowBox[{"(", 
         RowBox[{"True", "|", 
          RowBox[{"{", 
           RowBox[{"True", ",", "True"}], "}"}]}], ")"}]}], ",", 
       RowBox[{"ch", ":", 
        RowBox[{"{", 
         RowBox[{
         "_", ",", "_", ",", "_", ",", "IntegrateEvolutionOverTime", ",", 
          "__"}], "}"}]}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Lsop", ":", 
          RowBox[{"HoldPattern", "@", 
           RowBox[{"Superoperator", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"_", "?", "MatrixQ"}], ",", "_List", ",", 
               RowBox[{"_", "?", "MatrixQ"}]}], "}"}], ",", "opbasis1_", ",", 
             "basis1_", ",", "___Rule"}], "]"}]}]}], ",", "\[Tau]_"}], "}"}], 
       ",", "evopts___Rule"}], "]"}], ",", "opbasis2_", ",", "basis2_", ",", 
     "opts___Rule"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"X", ",", "evals", ",", "Xinv"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Lsop", "=", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"opbasis1", "===", "opbasis2"}], ",", "Lsop", ",", 
          RowBox[{"NDiagonalize", "[", 
           RowBox[{
            RowBox[{"StandardizeGenerator", "[", "Lsop", "]"}], ",", 
            "opbasis2"}], "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"X", ",", "evals", ",", "Xinv"}], "}"}], "=", 
        RowBox[{"First", "@", "Lsop"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Superoperator", "[", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"SparseArray", "@"}], "*)"}], "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Chop", "[", 
          RowBox[{"X", ".", 
           RowBox[{"DiagonalMatrix", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"Exp", "[", 
               RowBox[{"\[Tau]", "*", "#"}], "]"}], "&"}], "/@", "evals"}], 
            "]"}], ".", "Xinv"}], "]"}], ",", "\[IndentingNewLine]", 
         "opbasis2", ",", "\[IndentingNewLine]", 
         RowBox[{"Sequence", "@@", 
          RowBox[{"FilterRules", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"Join", "[", 
             RowBox[{
              RowBox[{"{", "opts", "}"}], ",", 
              RowBox[{"Options", "[", "NPropagationSuperoperator", "]"}]}], 
             "]"}], ",", "\[IndentingNewLine]", 
            RowBox[{"Options", "[", "Operator", "]"}]}], 
           "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", "]"}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
 PageWidth:>WindowWidth,
