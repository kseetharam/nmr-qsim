Cell[CellGroupData[{

Cell["FastNumericalMatrixRepresentationOfRotationOperator", "Subsubtitle",
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{
  3.605545641519261*^9, 3.605546445799432*^9, 3.629385531775414*^9, {
   3.691438143429953*^9, 3.6914381546757927`*^9}, {3.6965797671349716`*^9, 
   3.696579780686881*^9}, {3.6966060571434784`*^9, 3.6966060587828045`*^9}, 
   3.6968826366089125`*^9, {3.697374327521062*^9, 3.697374337474808*^9}, 
   3.827052621313*^9},
 AspectRatioFixed->
  True,ExpressionUUID->"78182c50-5a79-4f84-b3ce-b133d984c906"],

Cell["\<\
MatrixExp works much faster when applied to a purely numerical matrix. This \
routine avoids slow symbolic evaluation in the context of a rotation \
operator. It is a clumsy construction which might be avoided by a \
redefinition of the MatrixRepresentation routine, which I want to avoid at \
present. \
\>", "Text",
 CellChangeTimes->{{3.827052657706913*^9, 
  3.827052745729537*^9}},ExpressionUUID->"8c40e223-78bf-467d-9f7c-\
98f6443c63c7"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"HoldPattern", "@", 
    RowBox[{"FastNumericalMatrixRepresentationOfRotationOperator", "[", 
     RowBox[{
      RowBox[{"opR", "[", 
       RowBox[{"spins_", ",", 
        RowBox[{"{", 
         RowBox[{"\[Beta]_", ",", "axis_String"}], "}"}]}], "]"}], ",", 
      "basis_"}], "]"}]}], ":=", 
   RowBox[{"MatrixExp", "@", 
    RowBox[{"N", "@", 
     RowBox[{"MatrixRepresentation", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "I"}], " ", "\[Beta]", " ", 
        RowBox[{"opI", "[", 
         RowBox[{"spins", ",", "axis"}], "]"}]}], ",", "basis"}], "]"}]}]}]}],
   ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.827049658388417*^9, 3.827049707570601*^9}, {
   3.827049744567375*^9, 3.827049812818497*^9}, 
   3.8270518011897078`*^9},ExpressionUUID->"7aa3e5c7-2f24-455b-a4fe-\
73767caa3cdb"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"HoldPattern", "@", 
    RowBox[{"FastNumericalMatrixRepresentationOfRotationOperator", "[", 
     RowBox[{
      RowBox[{"OperatorProduct", "[", 
       RowBox[{
        RowBox[{"rotops", ":", 
         RowBox[{"_opR", ".."}]}], ",", "___Rule"}], "]"}], ",", "basis_"}], 
     "]"}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "terms", "}"}], ",", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"terms", "=", 
        RowBox[{
         RowBox[{"{", "rotops", "}"}], "/.", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"HoldPattern", "@", 
            RowBox[{"opR", "[", 
             RowBox[{"j_", ",", 
              RowBox[{"{", 
               RowBox[{"\[Beta]_", ",", "axis_String"}], "}"}]}], "]"}]}], 
           "\[RuleDelayed]", 
           RowBox[{"FastNumericalMatrixRepresentationOfRotationOperator", "[", 
            RowBox[{
             RowBox[{"opR", "[", 
              RowBox[{"j", ",", 
               RowBox[{"{", 
                RowBox[{"\[Beta]", ",", "axis"}], "}"}]}], "]"}], ",", 
             "basis"}], "]"}]}], "}"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Fold", "[", 
        RowBox[{"Dot", ",", 
         RowBox[{"First", "@", "terms"}], ",", 
         RowBox[{"Rest", "@", "terms"}]}], "]"}]}], ")"}]}], "]"}]}], 
  ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.8270489627020407`*^9, 3.827049087940633*^9}, {
   3.827049157793909*^9, 3.827049266732509*^9}, 3.8270494766404877`*^9, {
