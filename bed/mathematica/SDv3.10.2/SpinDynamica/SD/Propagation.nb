Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"NPropagate", "[", 
     RowBox[{"\[Rho]_", ",", "True", ",", 
      RowBox[{"{", 
       RowBox[{"True", ",", "4"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"False", ",", 
        RowBox[{"ev", ":", 
         RowBox[{"Event", "[", 
          RowBox[{
           RowBox[{"st", ":", 
            RowBox[{"(", 
             RowBox[{"True", "|", 
              RowBox[{"{", 
               RowBox[{"True", ",", "True"}], "}"}]}], ")"}]}], ",", 
           RowBox[{"ch", ":", 
            RowBox[{"{", 
             RowBox[{
             "_", ",", "_", ",", "_", ",", "IntegrateEvolutionOverTime", ",", 
              "__"}], "}"}]}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Lsop_", "?", "SuperoperatorQ"}], ",", "\[Tau]_"}], 
            "}"}], ",", "evopts___Rule"}], "]"}]}]}], "}"}], ",", "opbasis_", 
      ",", "basis_", ",", "opts___Rule"}], "]"}], "/;", 
    RowBox[{"MatchQ", "[", 
     RowBox[{
      RowBox[{"PropagatorCalculationProcedure", "[", "ev", "]"}], ",", 
      "IntegrateEvolutionOverTime"}], "]"}]}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Rho]vec", ",", "ta", ",", "tb", ",", "t", ",", "evals", ",", "X", 
       ",", "Xinv", ",", "reserveopbasis", ",", "locopbasis", ",", "tdummy", 
       ",", "\[Tau]dummy", ",", "Tdummy", ",", "ndiagoutput"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"locopbasis", "=", "opbasis"}], ";", "\[IndentingNewLine]", 
       RowBox[{"ndiagoutput", "=", 
        RowBox[{"NDiagonalize", "[", 
         RowBox[{
          RowBox[{"StandardizeGenerator", "[", "Lsop", "]"}], ",", "opbasis", 
          ",", "opts"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Switch", "[", "\[IndentingNewLine]", 
        RowBox[{
        "ndiagoutput", ",", "\[IndentingNewLine]", "$Failed", ",", 
         "\[IndentingNewLine]", 
         RowBox[{"(", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"Message", "[", 
            RowBox[{"NPropagate", "::", "trydirect"}], "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"NPropagate", "[", 
            RowBox[{"\[Rho]", ",", "True", ",", 
             RowBox[{"{", 
              RowBox[{"True", ",", "4"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"False", ",", 
               RowBox[{"Event", "[", 
                RowBox[{"st", ",", "ch", ",", 
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"TimeDependentGeneratorFunction", "[", 
                    RowBox[{"tdummy", ",", 
                    RowBox[{"{", 
                    RowBox[{"{", 
                    RowBox[{"\[Tau]dummy", ",", 
                    RowBox[{"1", "/", "2"}]}], "}"}], "}"}], ",", "Tdummy", 
                    ",", "Lsop"}], "]"}], ",", "\[Tau]"}], "}"}], ",", 
                 "evopts"}], "]"}]}], "}"}], ",", "opbasis", ",", "basis", 
             ",", "opts"}], "]"}]}], "\[IndentingNewLine]", ")"}], ",", 
         "\[IndentingNewLine]", "_", ",", "\[IndentingNewLine]", 
         RowBox[{"(", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{"X", ",", "evals", ",", "Xinv"}], "}"}], "=", 
            RowBox[{"First", "@", "ndiagoutput"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"\[Rho]vec", "=", 
            RowBox[{"OperatorVectorRepresentation", "[", 
             RowBox[{"\[Rho]", ",", "locopbasis"}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"tb", ",", "ta"}], "}"}], "=", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"FinalTimePoint", "[", "ev", "]"}], ",", 
              RowBox[{"InitialTimePoint", "[", "ev", "]"}]}], "}"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"Function", "[", 
            RowBox[{"t", ",", "\[IndentingNewLine]", 
             RowBox[{"Evaluate", "@", 
              RowBox[{"Operator", "[", 
               RowBox[{"(*", 
                RowBox[{"SparseArray", "@"}], "*)"}], "\[IndentingNewLine]", 
               RowBox[{
                RowBox[{"Chop", "@", 
                 RowBox[{"N", "@", 
                  RowBox[{"ExpToTrig", "@", 
                   RowBox[{"Normal", "[", 
                    RowBox[{"Dot", "[", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{
                    "MultiplyMatricesAndMatrixInterpolationFunctions", "[", 
                    RowBox[{"X", ",", 
                    RowBox[{"DiagonalMatrix", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"Exp", "[", 
                    RowBox[{"#", "\[Times]", 
                    RowBox[{"(", 
                    RowBox[{"t", "-", "ta"}], ")"}]}], "]"}], "&"}], "/@", 
                    "evals"}], "]"}], ",", "Xinv"}], "]"}], ")"}], ",", 
                    "\[Rho]vec"}], "]"}], "]"}]}]}]}], ",", "locopbasis", ",",
                 "basis", ",", 
                RowBox[{"CheckOperatorType", "\[Rule]", "False"}]}], 
               "]"}]}]}], "\[IndentingNewLine]", "]"}]}], 
          "\[IndentingNewLine]", ")"}]}], "\[IndentingNewLine]", "]"}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
