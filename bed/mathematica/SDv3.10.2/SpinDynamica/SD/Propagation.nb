 RowBox[{
  RowBox[{
   RowBox[{"HoldPattern", "@", 
    RowBox[{"NPropagationOperator", "[", 
     RowBox[{
      RowBox[{"status", ":", 
       RowBox[{"{", 
        RowBox[{"False", ",", "morestatus___"}], "}"}]}], ",", 
      RowBox[{"cont_", "?", "BooleanQ"}], ",", "events_", ",", "basis_", ",", 
      "opts___Rule"}], "]"}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "evbackg", "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"evbackg", "=", 
        RowBox[{"StandardizeGenerator", "[", 
         RowBox[{
