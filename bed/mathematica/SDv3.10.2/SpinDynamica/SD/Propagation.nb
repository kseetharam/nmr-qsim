          RowBox[{"{", 
           RowBox[{"nL", ",", "nL"}], "}"}]}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"uvecflat", "[", "t$_", "]"}], ":=", 
       RowBox[{"Evaluate", "[", 
        RowBox[{"Flatten", "[", 
         RowBox[{"Array", "[", 
