            RowBox[{"{", 
             RowBox[{"tb0", ",", "ta0"}], "}"}]}], "}"}], ",", "morech"}], 
         "}"}], ",", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"HilbertSpaceCompatibility", "[", "evlist", "]"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"NPropagationOperator", "[", 
           RowBox[{"evlist", ",", "\[IndentingNewLine]", 
            RowBox[{"SimplifyRules", "[", 
