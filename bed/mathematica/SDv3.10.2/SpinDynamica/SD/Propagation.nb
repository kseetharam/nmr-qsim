     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"splitevents", "=", 
       RowBox[{"SplitBy", "[", 
        RowBox[{"events", ",", 
         RowBox[{
          RowBox[{"HilbertSpaceCompatibility", "[", 
           RowBox[{"#", ",", "opts"}], "]"}], "&"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"eventsig", "=", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"HilbertSpaceCompatibility", "[", "#", "]"}], "&"}], "/@", 
         "splitevents"}], ")"}]}], ";", "\[IndentingNewLine]", 
