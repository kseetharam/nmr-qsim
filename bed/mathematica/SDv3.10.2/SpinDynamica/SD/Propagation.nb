Cell[BoxData[
 RowBox[{
  RowBox[{"geometricphase", "[", 
   RowBox[{"funcs_", ",", "len_", ",", "\[Lambda]vals_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "\[Lambda]a", ",", "\[Lambda]b", ",", "scalarfuncs", ",", "\[Phi]", ",", 
      "\[Phi]geo", ",", "\[Phi]geoplain", ",", "\[Phi]geoini", ",", "sol"}], 
     "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[Lambda]a", ",", "\[Lambda]b"}], "}"}], "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"First", "[", "\[Lambda]vals", "]"}], ",", 
        RowBox[{"Last", "[", "\[Lambda]vals", "]"}]}], "}"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"scalarfuncs", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"Interpolation", "[", 
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{"\[Lambda]vals", ",", 
            RowBox[{"Chop", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"Im", "[", 
                RowBox[{
                 RowBox[{"Conjugate", "[", 
                  RowBox[{
                   RowBox[{
                   "funcs", "\[LeftDoubleBracket]", "j", 
                    "\[RightDoubleBracket]"}], "[", "#", "]"}], "]"}], ".", 
                 RowBox[{
                  RowBox[{
                   RowBox[{
                   "funcs", "\[LeftDoubleBracket]", "j", 
                    "\[RightDoubleBracket]"}], "'"}], "[", "#", "]"}]}], 
                "]"}], "&"}], "/@", "\[Lambda]vals"}], "]"}]}], "}"}], "]"}], 
         "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", 
          RowBox[{"Range", "[", "len", "]"}]}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[Phi]geo", "[", "\[Lambda]$_", "]"}], ":=", 
      RowBox[{"Evaluate", "[", 
       RowBox[{"Array", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"\[Phi]", "[", "#", "]"}], "[", "\[Lambda]$", "]"}], "&"}],
          ",", "len"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"\[Phi]geoplain", "=", 
      RowBox[{"Evaluate", "[", 
       RowBox[{"Array", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"\[Phi]", "[", "#", "]"}], "&"}], ",", "len"}], "]"}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"\[Phi]geoini", "=", 
      RowBox[{"ConstantArray", "[", 
       RowBox[{"0", ",", "len"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"sol", "=", 
      RowBox[{"Through", "[", 
       RowBox[{
        RowBox[{"NDSolveValue", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"D", "[", 
              RowBox[{
               RowBox[{"\[Phi]geo", "[", "\[Lambda]$", "]"}], ",", 
               "\[Lambda]$"}], "]"}], "\[Equal]", 
             RowBox[{"Through", "[", 
              RowBox[{"scalarfuncs", "[", "\[Lambda]$", "]"}], "]"}]}], ",", 
            RowBox[{
             RowBox[{"\[Phi]geo", "[", "\[Lambda]a", "]"}], "\[Equal]", 
             "\[Phi]geoini"}]}], "}"}], ",", "\[Phi]geoplain", ",", 
          RowBox[{"{", 
           RowBox[{"\[Lambda]$", ",", "\[Lambda]a", ",", "\[Lambda]b"}], 
           "}"}]}], "]"}], "[", "\[Lambda]b", "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Exp", "[", 
      RowBox[{
       RowBox[{"-", "I"}], "*", 
       RowBox[{"Re", "@", 
        RowBox[{"Chop", "[", "sol", "]"}]}]}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
