Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Precalculate", "[", 
    RowBox[{
     RowBox[{"evlist", ":", 
      RowBox[{"EventList", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"True", "|", 
         RowBox[{"{", 
          RowBox[{"True", ",", "__"}], "}"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"dur_", ",", 
            RowBox[{"{", 
             RowBox[{"tb_", ",", "ta_"}], "}"}], ",", "pts_", ",", 
            RowBox[{"{", 
             RowBox[{"tb0_", ",", "ta0_"}], "}"}]}], "}"}], ",", 
          "\[IndentingNewLine]", "morech___"}], "}"}], ",", 
        "\[IndentingNewLine]", "more___"}], "]"}]}], ",", 
     "\[IndentingNewLine]", "opts___Rule"}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{"PrecalculatedEvent", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"dur", ",", 
            RowBox[{"{", 
