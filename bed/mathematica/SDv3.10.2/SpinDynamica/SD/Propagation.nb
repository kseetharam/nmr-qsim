Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"NPropagate", "[", 
    RowBox[{"\[Rho]_", ",", 
     RowBox[{"status", ":", 
      RowBox[{"{", 
       RowBox[{"True", ",", "True", ",", "False", ",", "morestatus___"}], 
       "}"}]}], ",", 
     RowBox[{"cont_", "?", "BooleanQ"}], ",", 
     RowBox[{"events", ":", 
      RowBox[{"Except", "[", 
       RowBox[{"EventList", "[", 
        RowBox[{
         RowBox[{"True", "|", 
          RowBox[{"{", 
           RowBox[{"True", ",", "_"}], "}"}]}], ",", "___"}], "]"}], "]"}]}], 
     ",", 
     RowBox[{"more", ":", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Except", "[", "_Rule", "]"}], "..."}], ")"}]}], ",", 
     "opts___Rule"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"NPropagate", "[", 
    RowBox[{"\[Rho]", ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"True", ",", "True", ",", "False", ",", "morestatus"}], "}"}], 
     ",", "cont", ",", "\[IndentingNewLine]", 
     RowBox[{"EventList", "[", 
      RowBox[{"events", ",", "\[IndentingNewLine]", 
       RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Chronology", "\[Rule]", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Chronology", "/.", 
             RowBox[{"{", "opts", "}"}]}], "/.", 
            RowBox[{"Options", "[", "NPropagate", "]"}]}], ")"}]}], ",", 
