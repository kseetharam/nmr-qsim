Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"NPropagationOperator", "[", 
     RowBox[{"True", ",", 
      RowBox[{"{", 
       RowBox[{"True", ",", "4"}], "}"}], ",", "InitialPropagator_", ",", 
      "\[IndentingNewLine]", 
      RowBox[{"ev", ":", 
       RowBox[{"Event", "[", 
        RowBox[{
         RowBox[{"st", ":", 
          RowBox[{"True", "|", 
           RowBox[{"{", 
            RowBox[{"True", ".."}], "}"}]}]}], ",", "ch_", ",", 
         "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Hop_", "?", "OperatorQ"}], ",", "\[Tau]_"}], "}"}], ",", 
         "evopts___Rule"}], "]"}]}], ",", "\[IndentingNewLine]", "opbasis_", 
      ",", "basis_", ",", "opts___Rule"}], "]"}], "/;", 
    RowBox[{"MatchQ", "[", 
     RowBox[{
      RowBox[{"PropagatorCalculationProcedure", "[", "ev", "]"}], ",", 
      "IntegrateEvolutionOverTime"}], "]"}]}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "tb", ",", "ta", ",", "Umatini", ",", "t", ",", "evals", ",", "evecs", 
       ",", "X", ",", "Xinv"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"tb", ",", "ta"}], "}"}], "=", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"FinalTimePoint", "[", "ev", "]"}], ",", 
          RowBox[{"InitialTimePoint", "[", "ev", "]"}]}], "}"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Umatini", "=", 
        RowBox[{"MatrixRepresentation", "[", 
         RowBox[{"InitialPropagator", ",", "basis"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Function", "[", 
        RowBox[{"t", ",", "\[IndentingNewLine]", 
         RowBox[{"Evaluate", "@", 
          RowBox[{"Operator", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"{", 
               RowBox[{"X", ",", "evals", ",", "Xinv"}], "}"}], "=", 
              RowBox[{"First", "@", 
               RowBox[{"NDiagonalize", "[", 
                RowBox[{"Hop", ",", "basis", ",", "opts"}], "]"}]}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"(*", 
              RowBox[{"SparseArray", "@"}], "*)"}], "\[IndentingNewLine]", 
             RowBox[{"Chop", "@", 
              RowBox[{"N", "@", 
               RowBox[{"ExpToTrig", "@", 
                RowBox[{"Normal", "[", "\[IndentingNewLine]", 
                 RowBox[{
                 "MultiplyMatricesAndMatrixInterpolationFunctions", "[", 
                  "\[IndentingNewLine]", 
                  RowBox[{"X", ",", "\[IndentingNewLine]", 
                   RowBox[{"DiagonalMatrix", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"Exp", "[", 
                    RowBox[{
                    RowBox[{"-", "I"}], "*", "#", "\[Times]", 
                    RowBox[{"(", 
                    RowBox[{"t", "-", "ta"}], ")"}]}], "]"}], "&"}], "/@", 
                    "evals"}], "]"}], ",", "\[IndentingNewLine]", "Xinv", ",",
                    "\[IndentingNewLine]", "Umatini"}], "\[IndentingNewLine]",
                   "]"}], "\[IndentingNewLine]", "]"}]}]}]}]}], ",", 
            "\[IndentingNewLine]", "basis", ",", 
            RowBox[{"CheckOperatorType", "\[Rule]", "False"}]}], 
           "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", "]"}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
