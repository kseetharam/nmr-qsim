Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"NPropagate", "[", 
     RowBox[{"\[Rho]_", ",", "True", ",", 
      RowBox[{"{", 
       RowBox[{"True", ",", "4"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"True", ",", 
        RowBox[{"ev", ":", 
         RowBox[{"Event", "[", 
          RowBox[{
           RowBox[{"st", ":", 
            RowBox[{"True", "|", 
             RowBox[{"{", 
              RowBox[{"True", ".."}], "}"}]}]}], ",", "ch_", ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Hop_", "?", "OperatorQ"}], ",", "\[Tau]_"}], "}"}], ",",
            "evopts___Rule"}], "]"}]}]}], "}"}], ",", "opbasis_", ",", 
      "basis_", ",", "opts___Rule"}], "]"}], "/;", 
    RowBox[{"MatchQ", "[", 
     RowBox[{
      RowBox[{"PropagatorCalculationProcedure", "[", "ev", "]"}], ",", 
      "IntegrateEvolutionOverTime"}], "]"}]}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "tb", ",", "ta", ",", "\[Rho]matrep", ",", "evals", ",", "evecs", ",", 
       "X", ",", "Xinv", ",", "\[IndentingNewLine]", "exp\[CapitalLambda]", 
       ",", "exp\[CapitalLambda]inv", ",", "exp\[CapitalLambda]T", ",", 
       "exp\[CapitalLambda]Tinv", ",", "\[Rho]finmat", ",", 
       "\[Rho]finmatarules", ",", "\[IndentingNewLine]", "opmatrep", ",", 
       "t$", ",", "arrayrules"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"\[Rho]matrep", "=", 
        RowBox[{"MatrixRepresentation", "[", 
         RowBox[{"\[Rho]", ",", "basis"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"tb", ",", "ta"}], "}"}], "=", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"FinalTimePoint", "[", "ev", "]"}], ",", 
          RowBox[{"InitialTimePoint", "[", "ev", "]"}]}], "}"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"X", ",", "evals", ",", "Xinv"}], "}"}], "=", 
        RowBox[{"First", "@", 
         RowBox[{"NDiagonalize", "[", 
          RowBox[{"Hop", ",", "basis", ",", "opts"}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"exp\[CapitalLambda]", "[", "t_", "]"}], "=", 
        RowBox[{"SparseArray", "[", 
         RowBox[{
          RowBox[{"Band", "[", 
           RowBox[{"{", 
            RowBox[{"1", ",", "1"}], "}"}], "]"}], "\[Rule]", 
          RowBox[{"ComplexExpand", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Exp", "[", 
              RowBox[{
               RowBox[{"-", "I"}], " ", 
               RowBox[{"(", 
                RowBox[{"t", "-", "ta"}], ")"}], "#"}], "]"}], "&"}], "/@", 
            "evals"}], "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"exp\[CapitalLambda]inv", "[", "t_", "]"}], "=", 
        RowBox[{"SparseArray", "[", 
         RowBox[{
          RowBox[{"Band", "[", 
           RowBox[{"{", 
            RowBox[{"1", ",", "1"}], "}"}], "]"}], "\[Rule]", 
          RowBox[{"ComplexExpand", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Exp", "[", 
              RowBox[{
               RowBox[{"+", "I"}], " ", 
               RowBox[{"(", 
                RowBox[{"t", "-", "ta"}], ")"}], "#"}], "]"}], "&"}], "/@", 
            "evals"}], "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"exp\[CapitalLambda]T", "[", "t_", "]"}], "=", 
        RowBox[{"X", ".", 
         RowBox[{"exp\[CapitalLambda]", "[", "t", "]"}], ".", "Xinv"}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"exp\[CapitalLambda]Tinv", "[", "t_", "]"}], "=", 
        RowBox[{"X", ".", 
         RowBox[{"exp\[CapitalLambda]inv", "[", "t", "]"}], ".", "Xinv"}]}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"\[Rho]finmat", "[", "t_", "]"}], "=", 
        RowBox[{"Normal", "[", 
         RowBox[{
          RowBox[{"exp\[CapitalLambda]T", "[", "t", "]"}], ".", 
          "\[Rho]matrep", ".", 
          RowBox[{"exp\[CapitalLambda]Tinv", "[", "t", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Function", "[", 
        RowBox[{"t", ",", 
         RowBox[{"Evaluate", "@", 
          RowBox[{"Operator", "[", 
           RowBox[{
            RowBox[{"\[Rho]finmat", "[", "t", "]"}], ",", "basis", ",", 
            RowBox[{"CheckOperatorType", "\[Rule]", "False"}]}], "]"}]}]}], 
        "]"}]}], "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
