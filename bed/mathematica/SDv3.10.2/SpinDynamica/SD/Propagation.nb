Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"NPropagate", "[", 
    RowBox[{"\[Rho]_", ",", "True", ",", 
     RowBox[{"{", 
      RowBox[{"True", ",", "3"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"eventlist", ":", 
      RowBox[{"EventList", "[", 
       RowBox[{"st_", ",", "ch_", ",", 
        RowBox[{"events", ":", 
         RowBox[{"{", 
          RowBox[{"_Event", ".."}], "}"}]}], ",", "evlistopts___Rule"}], 
       "]"}]}], ",", "opbasis_", ",", "basis_", ",", "opts___Rule"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "sortedevents", ",", "zbasis", ",", "funcsLtoR", ",", 
       "timeintervalsLtoR", ",", "intervals", ",", "funcs", ",", 
       "lasttimepoint"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"timeintervalsLtoR", "=", 
        RowBox[{"Reverse", "[", 
         RowBox[{"Reverse", "/@", 
          RowBox[{"EventTimeIntervals", "[", "eventlist", "]"}]}], "]"}]}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"sortedevents", "=", 
        RowBox[{"Reverse", "[", 
         RowBox[{"SortVectorSpaceCompatibility", "[", "eventlist", "]"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"funcsLtoR", "=", 
        RowBox[{"Rest", "@", 
         RowBox[{"FoldList", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"NPropagate", "[", 
             RowBox[{
              RowBox[{"#1", "[", 
               RowBox[{"InitialTimePoint", "[", 
                RowBox[{
                "#2", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}], 
                "]"}], "]"}], ",", "True", ",", 
              RowBox[{"{", 
               RowBox[{"True", ",", "4"}], "}"}], ",", "#2", ",", "opbasis", 
              ",", "basis", ",", "opts"}], "]"}], "&"}], ",", 
           RowBox[{"Function", "[", "\[Rho]", "]"}], ",", "sortedevents"}], 
          "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"FreeQ", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"timeintervalsLtoR", ",", "funcsLtoR"}], "}"}], ",", 
           "$Failed"}], "]"}], ",", "\[IndentingNewLine]", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{"intervals", ",", "funcs"}], "}"}], "=", 
            RowBox[{"Transpose", "@", 
             RowBox[{"Cases", "[", 
              RowBox[{
               RowBox[{"Transpose", "[", 
                RowBox[{"{", 
                 RowBox[{"timeintervalsLtoR", ",", "funcsLtoR"}], "}"}], 
                "]"}], ",", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{"_", ",", "_"}], "}"}], ",", 
                 RowBox[{"_InterpolatingFunction", "|", "_Function"}]}], 
                "}"}]}], "]"}]}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"Function", "[", 
            RowBox[{"t", ",", "\[IndentingNewLine]", 
             RowBox[{"Evaluate", "@", 
              RowBox[{"Chop", "[", "\[IndentingNewLine]", 
               RowBox[{"N", "@", 
                RowBox[{"Piecewise", "[", "\[IndentingNewLine]", 
                 RowBox[{
                  RowBox[{"MapThread", "[", 
                   RowBox[{
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"#1", "[", "t", "]"}], ",", "#2"}], "}"}], "&"}], 
                    ",", "\[IndentingNewLine]", 
                    RowBox[{"{", 
                    RowBox[{"funcs", ",", "\[IndentingNewLine]", 
                    RowBox[{"Join", "[", "\[IndentingNewLine]", 
                    RowBox[{
                    RowBox[{
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{
                    "#", "\[LeftDoubleBracket]", "1", 
                    "\[RightDoubleBracket]"}], "\[LessEqual]", "t", "<", 
                    RowBox[{
                    "#", "\[LeftDoubleBracket]", "2", 
                    "\[RightDoubleBracket]"}]}], ")"}], "&"}], "/@", 
                    RowBox[{"Most", "[", "intervals", "]"}]}], ",", 
                    "\[IndentingNewLine]", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{
                    "#", "\[LeftDoubleBracket]", "1", 
                    "\[RightDoubleBracket]"}], "\[LessEqual]", "t", 
                    "\[LessEqual]", 
                    RowBox[{
                    "#", "\[LeftDoubleBracket]", "2", 
                    "\[RightDoubleBracket]"}]}], ")"}], "&"}], "/@", 
                    RowBox[{"{", 
                    RowBox[{"Last", "[", "intervals", "]"}], "}"}]}]}], 
                    "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
                    "}"}]}], "\[IndentingNewLine]", "]"}], ",", 
                  "\[IndentingNewLine]", "Undefined"}], "\[IndentingNewLine]",
                  "]"}]}], "\[IndentingNewLine]", "]"}]}]}], 
            "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", ")"}], ",",
          "\[IndentingNewLine]", "$Failed"}], "\[IndentingNewLine]", "]"}]}], 
