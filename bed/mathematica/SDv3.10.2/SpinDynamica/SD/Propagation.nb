Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"NPropagationOperator", "[", "\[IndentingNewLine]", 
    RowBox[{"True", ",", "False", ",", "\[IndentingNewLine]", 
     RowBox[{"EventList", "[", 
      RowBox[{"st_", ",", "chars_", ",", 
       RowBox[{"events", ":", 
        RowBox[{"{", 
         RowBox[{"_Event", ".."}], "}"}]}], ",", "evlistopts___Rule"}], "]"}],
      ",", "\[IndentingNewLine]", "basis_", ",", "opts___Rule"}], "]"}], ":=",
    "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"zbmatreps", ",", "zbasis"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"Print", "[", "2", "]"}], ";"}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"zbasis", "=", 
        RowBox[{"ZeemanBasis", "[", 
         RowBox[{"SpinSystem", "[", "basis", "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"zbmatreps", "=", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"MatrixRepresentation", "[", 
           RowBox[{
            RowBox[{"NPropagationOperator", "[", 
             RowBox[{
             "True", ",", "False", ",", "#", ",", "zbasis", ",", "opts"}], 
             "]"}], ",", "zbasis"}], "]"}], "&"}], "/@", "events"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Operator", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Length", "[", "zbmatreps", "]"}], "\[Equal]", "1"}], ",", 
           RowBox[{"First", "@", "zbmatreps"}], ",", 
           RowBox[{"Fold", "[", 
            RowBox[{"Dot", ",", 
             RowBox[{"First", "@", "zbmatreps"}], ",", 
             RowBox[{"Drop", "[", 
              RowBox[{"zbmatreps", ",", "1"}], "]"}]}], "]"}]}], "]"}], ",", 
         "\[IndentingNewLine]", "zbasis", ",", "\[IndentingNewLine]", 
         RowBox[{"Sequence", "@@", 
          RowBox[{"FilterRules", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"Join", "[", 
             RowBox[{
              RowBox[{"{", "opts", "}"}], ",", 
              RowBox[{"Options", "[", "NPropagationOperator", "]"}]}], "]"}], 
            ",", "\[IndentingNewLine]", 
            RowBox[{"Options", "[", "Operator", "]"}]}], 
           "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", "]"}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
