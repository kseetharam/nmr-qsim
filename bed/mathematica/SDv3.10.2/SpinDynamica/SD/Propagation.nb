Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"NPropagationSuperoperator", "[", 
     RowBox[{"True", ",", "False", ",", 
      RowBox[{"Event", "[", 
       RowBox[{
        RowBox[{"st", ":", 
         RowBox[{"(", 
          RowBox[{"True", "|", 
           RowBox[{"{", 
            RowBox[{"True", ",", "True"}], "}"}]}], ")"}]}], ",", 
        RowBox[{"ch", ":", 
         RowBox[{"{", 
          RowBox[{
          "_", ",", "_", ",", "_", ",", "IntegrateEvolutionOverTime", ",", 
           "__"}], "}"}]}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Lsop_", "?", "SuperoperatorQ"}], ",", "\[Tau]_"}], "}"}], 
        ",", "evopts___Rule"}], "]"}], ",", "opbasis_", ",", "basis_", ",", 
      "opts___Rule"}], "]"}], "/;", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"UseMatrixExpWhenPossible", "/.", 
       RowBox[{"{", "opts", "}"}]}], "/.", 
      RowBox[{"Options", "[", "NPropagationSuperoperator", "]"}]}], ")"}]}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "matrep", "}"}], ",", 
