Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"NPropagationSuperoperator", "[", 
     RowBox[{"True", ",", "True", ",", 
      RowBox[{"ev", ":", 
       RowBox[{"Event", "[", 
        RowBox[{
         RowBox[{"st", ":", 
          RowBox[{"(", 
           RowBox[{"True", "|", 
            RowBox[{"{", 
             RowBox[{"True", ",", "True"}], "}"}]}], ")"}]}], ",", "ch_", ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"TimeDependentGeneratorFunction", "[", 
            RowBox[{"t_", ",", 
             RowBox[{"\[Tau]xpairs_", "?", "MatrixQ"}], ",", "T_", ",", 
             RowBox[{"CommutationSuperoperator", "[", 
              RowBox[{"op_", ",", "___Rule"}], "]"}], ",", 
             "tdepgenfuncopts___Rule"}], "]"}], ",", "\[Tau]_"}], "}"}], ",", 
         "\[IndentingNewLine]", "evopts___Rule"}], "]"}]}], ",", "opbasis_", 
      ",", "basis_", ",", "opts___Rule"}], "]"}], "/;", 
    RowBox[{
     RowBox[{"MatchQ", "[", 
      RowBox[{
