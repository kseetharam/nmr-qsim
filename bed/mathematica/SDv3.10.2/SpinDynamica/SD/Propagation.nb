Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"NPropagationSuperoperator", "[", 
     RowBox[{"True", ",", "True", ",", 
      RowBox[{"ev", ":", 
       RowBox[{"Event", "[", 
        RowBox[{
         RowBox[{"st", ":", 
          RowBox[{"(", 
           RowBox[{"True", "|", 
            RowBox[{"{", 
             RowBox[{"True", ",", "True"}], "}"}]}], ")"}]}], ",", 
         RowBox[{"ch", ":", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"_", ",", 
              RowBox[{"{", 
               RowBox[{"tb_", ",", "ta_"}], "}"}], ",", "moretch___"}], "}"}],
             ",", "__"}], "}"}]}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Hfunc", ":", 
            RowBox[{"TimeDependentGeneratorFunction", "[", 
             RowBox[{"t_", ",", 
              RowBox[{"\[Tau]xpairs_", "?", "MatrixQ"}], ",", "T_", ",", 
              RowBox[{"op_", "?", "OperatorQ"}], ",", 
              "tdepgenfuncopts___Rule"}], "]"}]}], ",", "\[Tau]_"}], "}"}], 
         ",", "evopts___Rule"}], "]"}]}], ",", "opbasis_", ",", "basis_", ",",
       "opts___Rule"}], "]"}], "/;", 
    RowBox[{
     RowBox[{"MatchQ", "[", 
      RowBox[{
       RowBox[{"PropagatorCalculationProcedure", "[", "ev", "]"}], ",", 
       "IntegrateEvolutionOverTime"}], "]"}], "&&", 
     RowBox[{"BackgroundGeneratorImplemented", "[", "ev", "]"}]}]}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "n", ",", "NDSolveopts", ",", "u", ",", "uvec", ",", "uvecflat", ",", 
       "sol", ",", "uvecplain", ",", "Uini", ",", "Ufunc", ",", "Hmatfunc", 
       ",", "U"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"NDSolveopts", "=", 
       RowBox[{"Sequence", "@@", 
        RowBox[{"FilterRules", "[", 
         RowBox[{
          RowBox[{"SimplifyRules", "[", 
           RowBox[{"{", 
            RowBox[{"evopts", ",", "opts"}], "}"}], "]"}], ",", 
          RowBox[{"Options", "[", "NDSolve", "]"}]}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"n", "=", 
       RowBox[{"BasisDimension", "[", "basis", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Hmatfunc", "=", "\[IndentingNewLine]", 
       RowBox[{"Function", "[", 
        RowBox[{"t$", ",", "\[IndentingNewLine]", 
         RowBox[{"Evaluate", "[", "\[IndentingNewLine]", 
          RowBox[{"Normal", "@", 
           RowBox[{"MatrixRepresentation", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"Hfunc", "[", 
               RowBox[{"t$", ",", "ta", ",", "tb"}], "]"}], "/.", 
              RowBox[{"{", 
               RowBox[{"evopts", ",", "opts"}], "}"}]}], ",", "basis"}], 
            "]"}]}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"uvec", "[", "t$_", "]"}], ":=", 
       RowBox[{"Evaluate", "[", 
        RowBox[{"Array", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"u", "[", 
             RowBox[{"#1", ",", "#2"}], "]"}], "[", "t$", "]"}], "&"}], ",", 
          RowBox[{"{", 
           RowBox[{"n", ",", "n"}], "}"}]}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"uvecflat", "[", "t$_", "]"}], ":=", 
       RowBox[{"Evaluate", "[", 
        RowBox[{"Flatten", "[", 
         RowBox[{"Array", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"u", "[", 
              RowBox[{"#1", ",", "#2"}], "]"}], "[", "t$", "]"}], "&"}], ",", 
           
           RowBox[{"{", 
            RowBox[{"n", ",", "n"}], "}"}]}], "]"}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"uvecplain", "=", 
       RowBox[{"Evaluate", "[", 
        RowBox[{"Array", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"u", "[", 
            RowBox[{"#1", ",", "#2"}], "]"}], "&"}], ",", 
          RowBox[{"{", 
           RowBox[{"n", ",", "n"}], "}"}]}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Uini", "=", 
       RowBox[{"IdentityMatrix", "[", 
        RowBox[{"BasisDimension", "[", "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"sol", "=", 
       RowBox[{"NDSolveValue", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"D", "[", 
             RowBox[{
              RowBox[{"uvecflat", "[", "t$", "]"}], ",", "t$"}], "]"}], 
            "\[Equal]", 
            RowBox[{
             RowBox[{"-", "I"}], " ", 
             RowBox[{"(", 
              RowBox[{"Flatten", "[", 
               RowBox[{
                RowBox[{"Hmatfunc", "[", "t$", "]"}], ".", 
                RowBox[{"uvec", "[", "t$", "]"}]}], "]"}], ")"}]}]}], ",", 
           RowBox[{
            RowBox[{"uvecflat", "[", "ta", "]"}], "\[Equal]", 
            RowBox[{"Flatten", "[", "Uini", "]"}]}]}], "}"}], ",", 
         "uvecplain", ",", 
         RowBox[{"{", 
          RowBox[{"t$", ",", "ta", ",", "tb"}], "}"}], ",", "NDSolveopts"}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Operator", "[", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"SparseArray", "@"}], "*)"}], "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Chop", "[", 
         RowBox[{"N", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Through", "[", 
             RowBox[{"#", "[", "tb", "]"}], "]"}], "&"}], "/@", "sol"}], 
          "]"}], "]"}], ",", "\[IndentingNewLine]", "basis", ",", 
        "\[IndentingNewLine]", 
        RowBox[{"Sequence", "@@", 
         RowBox[{"FilterRules", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"Join", "[", 
            RowBox[{
             RowBox[{"{", "opts", "}"}], ",", 
             RowBox[{"Options", "[", "NPropagationSuperoperator", "]"}]}], 
            "]"}], ",", "\[IndentingNewLine]", 
           RowBox[{"Options", "[", "Operator", "]"}]}], "\[IndentingNewLine]",
           "]"}]}]}], "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]",
     "]"}]}], ";"}]], "Input",
 InitializationCell->True,
