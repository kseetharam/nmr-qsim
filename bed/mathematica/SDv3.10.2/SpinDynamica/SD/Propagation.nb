Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"HoldPattern", "@", 
    RowBox[{"NPropagationOperator", "[", 
     RowBox[{"True", ",", 
      RowBox[{"{", 
       RowBox[{"True", ",", "3"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"eventlist", ":", 
       RowBox[{"EventList", "[", 
        RowBox[{"st_", ",", "ch_", ",", 
         RowBox[{"events", ":", 
          RowBox[{"{", 
           RowBox[{"_Event", ".."}], "}"}]}], ",", "evlistopts___Rule"}], 
        "]"}]}], ",", "opbasis_", ",", "basis_", ",", "opts___Rule"}], 
     "]"}]}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "funcsLtoR", ",", "timeintervalsLtoR", ",", "intervals", ",", "funcs", 
       ",", "lasttimepoint", ",", "InitialPropagator"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"timeintervalsLtoR", "=", 
        RowBox[{"Reverse", "[", 
         RowBox[{"Reverse", "/@", 
          RowBox[{"EventTimeIntervals", "[", "eventlist", "]"}]}], "]"}]}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"funcsLtoR", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"Drop", "[", 
           RowBox[{"#", ",", "1"}], "]"}], "&"}], "@", "\[IndentingNewLine]", 
         
         RowBox[{"FoldList", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{
            RowBox[{"NPropagationOperator", "[", 
             RowBox[{"True", ",", 
              RowBox[{"{", 
               RowBox[{"True", ",", "4"}], "}"}], ",", 
              RowBox[{"#1", "[", 
               RowBox[{"InitialTimePoint", "[", "#2", "]"}], "]"}], ",", "#2",
               ",", "opbasis", ",", "basis", ",", "opts"}], "]"}], "&"}], ",",
            "\[IndentingNewLine]", 
           RowBox[{"Function", "[", 
            RowBox[{"UnityOperator", "[", "]"}], "]"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"Reverse", "@", "events"}]}], "\[IndentingNewLine]", 
          "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"intervals", ",", "funcs"}], "}"}], "=", 
        RowBox[{"Transpose", "@", 
         RowBox[{"Cases", "[", 
          RowBox[{
           RowBox[{"Transpose", "[", 
            RowBox[{"{", 
             RowBox[{"timeintervalsLtoR", ",", "funcsLtoR"}], "}"}], "]"}], 
           ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"_", ",", "_"}], "}"}], ",", 
             RowBox[{"_InterpolatingFunction", "|", "_Function"}]}], "}"}]}], 
          "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"FreeQ", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"timeintervalsLtoR", ",", "funcsLtoR"}], "}"}], ",", 
           "$Failed"}], "]"}], ",", "\[IndentingNewLine]", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{"intervals", ",", "funcs"}], "}"}], "=", 
            RowBox[{"Transpose", "@", 
             RowBox[{"Cases", "[", 
              RowBox[{
               RowBox[{"Transpose", "[", 
                RowBox[{"{", 
                 RowBox[{"timeintervalsLtoR", ",", "funcsLtoR"}], "}"}], 
                "]"}], ",", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{"_", ",", "_"}], "}"}], ",", 
                 RowBox[{"_InterpolatingFunction", "|", "_Function"}]}], 
                "}"}]}], "]"}]}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"Function", "[", 
            RowBox[{"t", ",", "\[IndentingNewLine]", 
             RowBox[{"Evaluate", "@", 
              RowBox[{"Chop", "[", "\[IndentingNewLine]", 
               RowBox[{"N", "@", 
                RowBox[{"Piecewise", "[", "\[IndentingNewLine]", 
                 RowBox[{
                  RowBox[{"MapThread", "[", 
                   RowBox[{
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"#1", "[", "t", "]"}], ",", "#2"}], "}"}], "&"}], 
                    ",", "\[IndentingNewLine]", 
                    RowBox[{"{", 
                    RowBox[{"funcs", ",", "\[IndentingNewLine]", 
                    RowBox[{"Join", "[", "\[IndentingNewLine]", 
                    RowBox[{
                    RowBox[{
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{
                    "#", "\[LeftDoubleBracket]", "1", 
                    "\[RightDoubleBracket]"}], "\[LessEqual]", "t", "<", 
                    RowBox[{
                    "#", "\[LeftDoubleBracket]", "2", 
                    "\[RightDoubleBracket]"}]}], ")"}], "&"}], "/@", 
                    RowBox[{"Most", "[", "intervals", "]"}]}], ",", 
                    "\[IndentingNewLine]", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{
                    "#", "\[LeftDoubleBracket]", "1", 
                    "\[RightDoubleBracket]"}], "\[LessEqual]", "t", 
                    "\[LessEqual]", 
                    RowBox[{
                    "#", "\[LeftDoubleBracket]", "2", 
                    "\[RightDoubleBracket]"}]}], ")"}], "&"}], "/@", 
                    RowBox[{"{", 
                    RowBox[{"Last", "[", "intervals", "]"}], "}"}]}]}], 
                    "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
                    "}"}]}], "\[IndentingNewLine]", "]"}], ",", 
                  "\[IndentingNewLine]", "Undefined"}], "\[IndentingNewLine]",
                  "]"}]}], "\[IndentingNewLine]", "]"}]}]}], 
            "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", ")"}], ",",
          "\[IndentingNewLine]", "$Failed"}], "\[IndentingNewLine]", "]"}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
