 RowBox[{
  RowBox[{
   RowBox[{"OperatorTrajectoryFunction", "::", "usage"}], "=", 
   "\"\<OperatorTrajectoryFunction[timerange,trajectory] is a function which \
provides an operator when evaluated at any time point within timerange. It is \
provided as the output of a NPropagate or NPropagationOperator evaluation \
with option Continuous\[Rule]True.\>\""}], ";"}]], "Input",
