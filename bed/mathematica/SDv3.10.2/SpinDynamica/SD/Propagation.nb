Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"NPropagate", "[", 
    RowBox[{
    "\[Rho]_", ",", "True", ",", "False", ",", 
     "MixedHilbertSpaceCompatibility", ",", 
     RowBox[{"ev", ":", 
      RowBox[{"EventList", "[", 
       RowBox[{"st_", ",", "chars_", ",", 
        RowBox[{"events", ":", 
         RowBox[{"{", 
          RowBox[{"_Event", ".."}], "}"}]}], ",", "evlistopts___Rule"}], 
       "]"}]}], ",", "opbasis_", ",", "\[IndentingNewLine]", "basis_", ",", 
     "opts___Rule"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"\[Rho]final", ",", "splitevents"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"Print", "[", "\"\<1; Mixed HSC\>\"", "]"}], ";"}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"splitevents", "=", 
        RowBox[{"SplitBy", "[", 
         RowBox[{"events", ",", "HilbertSpaceCompatibility"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Fold", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"NPropagate", "[", 
           RowBox[{"#1", ",", "True", ",", "False", ",", 
            RowBox[{"HilbertSpaceCompatibility", "[", "#2", "]"}], ",", 
            RowBox[{"EventList", "[", "#2", "]"}], ",", "opbasis", ",", 
            "basis", ",", "opts"}], "]"}], "&"}], ",", "\[Rho]", ",", 
         RowBox[{"Reverse", "@", "splitevents"}]}], "]"}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
