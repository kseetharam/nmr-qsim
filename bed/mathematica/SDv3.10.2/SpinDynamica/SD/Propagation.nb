Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"NPropagationSuperoperator", "[", 
    RowBox[{"True", ",", "True", ",", 
     RowBox[{"EventList", "[", 
      RowBox[{"st_", ",", "chars_", ",", 
       RowBox[{"events", ":", 
        RowBox[{"{", 
         RowBox[{"_Event", ".."}], "}"}]}], ",", "evlistopts___Rule"}], "]"}],
      ",", "opbasis_", ",", "basis_", ",", "opts___Rule"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"Hfunc", ",", "matreps", ",", "Ufw", ",", "Ubw"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"matreps", "=", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"MatrixRepresentation", "[", 
           RowBox[{
            RowBox[{"NPropagationSuperoperator", "[", 
             RowBox[{
             "True", ",", "True", ",", "#", ",", "opbasis", ",", "basis", ",",
               "opts"}], "]"}], ",", "basis"}], "]"}], "&"}], "/@", 
         "events"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Ufw", "=", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Length", "[", "matreps", "]"}], "\[Equal]", "1"}], ",", 
          RowBox[{"First", "@", "matreps"}], ",", 
          RowBox[{"Fold", "[", 
           RowBox[{"Dot", ",", 
            RowBox[{"First", "@", "matreps"}], ",", 
            RowBox[{"Drop", "[", 
             RowBox[{"matreps", ",", "1"}], "]"}]}], "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Ubw", "=", 
        RowBox[{"ConjugateTranspose", "@", "Ufw"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Superoperator", "[", 
        RowBox[{
         RowBox[{"KroneckerProduct", "[", 
          RowBox[{"Ufw", ",", 
           RowBox[{"Transpose", "@", "Ubw"}]}], "]"}], ",", 
         RowBox[{"ZeemanKetBraOperatorBasis", "[", "]"}], ",", "basis", ",", 
         "\[IndentingNewLine]", 
         RowBox[{"Sequence", "@@", 
          RowBox[{"FilterRules", "[", 
           RowBox[{
            RowBox[{"Join", "[", 
             RowBox[{
              RowBox[{"{", "opts", "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"CheckOperatorType", "\[Rule]", " ", "False"}], "}"}], 
              ",", 
              RowBox[{"Options", "[", "NPropagationSuperoperator", "]"}]}], 
             "]"}], ",", 
            RowBox[{"Options", "[", "Superoperator", "]"}]}], "]"}]}]}], 
        "]"}]}], "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
