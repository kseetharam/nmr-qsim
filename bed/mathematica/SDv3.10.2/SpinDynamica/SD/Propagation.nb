Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"NPropagationOperator", "[", 
    RowBox[{
     RowBox[{"status", ":", 
      RowBox[{"{", 
       RowBox[{"True", ",", "False", ",", "morestatus___"}], "}"}]}], ",", 
     RowBox[{"cont_", "?", "BooleanQ"}], ",", 
     RowBox[{"events", ":", 
      RowBox[{"Except", "[", "_EventList", "]"}]}], ",", 
     RowBox[{"more", ":", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Except", "[", "_Rule", "]"}], "..."}], ")"}]}], ",", 
     "opts___Rule"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"NPropagationOperator", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"True", ",", "False", ",", "morestatus"}], "}"}], ",", "cont", 
     ",", "\[IndentingNewLine]", 
     RowBox[{"EventList", "[", 
      RowBox[{"events", ",", "\[IndentingNewLine]", 
       RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Chronology", "\[Rule]", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Chronology", "/.", 
             RowBox[{"{", "opts", "}"}]}], "/.", 
            RowBox[{"Options", "[", "NPropagationOperator", "]"}]}], ")"}]}], 
         ",", "\[IndentingNewLine]", 
         RowBox[{"ImplementBackgroundGenerator", "\[Rule]", "True"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"ExpandRepeatedEvents", "\[Rule]", 
          RowBox[{"If", "[", 
           RowBox[{"cont", ",", "True", ",", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"ExpandRepeatedEvents", "/.", 
              RowBox[{"{", "opts", "}"}]}], "/.", 
             RowBox[{"Options", "[", "NPropagationOperator", "]"}]}]}], 
           "\[IndentingNewLine]", "]"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"Sequence", "@@", 
          RowBox[{"FilterRules", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"Join", "[", 
             RowBox[{
              RowBox[{"{", "opts", "}"}], ",", 
              RowBox[{"Options", "[", "NPropagationOperator", "]"}]}], "]"}], 
            ",", "\[IndentingNewLine]", 
            RowBox[{"Join", "[", 
             RowBox[{
              RowBox[{"Options", "[", "EventList", "]"}], ",", 
              RowBox[{"Options", "[", "NDSolve", "]"}]}], "]"}]}], 
           "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", "]"}]}], 
      "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", "more", ",", 
     "opts"}], "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
