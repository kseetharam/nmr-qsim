Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"NPropagationSuperoperator", "[", 
    RowBox[{"True", ",", 
     RowBox[{"(", 
      RowBox[{"False", "|", "MixedHilbertSpaceCompatibility"}], ")"}], ",", 
     RowBox[{"ev", ":", 
      RowBox[{"EventList", "[", 
       RowBox[{"st_", ",", "chars_", ",", 
        RowBox[{"events", ":", 
         RowBox[{"{", 
          RowBox[{"_Event", ".."}], "}"}]}], ",", "evlistopts___Rule"}], 
       "]"}]}], ",", "opbasis_", ",", "\[IndentingNewLine]", "basis_", ",", 
     "opts___Rule"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"U", ",", "Umatreps", ",", "sortedevents"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"sortedevents", "=", 
        RowBox[{"SortVectorSpaceCompatibility", "[", "ev", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Umatreps", "=", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"SuperoperatorMatrixRepresentation", "[", 
            RowBox[{
             RowBox[{"HilbPropToLiouvProp", "[", 
              RowBox[{
               RowBox[{"NPropagationSuperoperator", "[", 
                RowBox[{"True", ",", 
                 RowBox[{"Sequence", "@@", "#"}], ",", "opbasis", ",", 
                 "basis", ",", "opts"}], "]"}], ",", "basis", ",", "opts"}], 
              "]"}], ",", "opbasis"}], "]"}], "&"}], "/@", "sortedevents"}], 
         ")"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"U", "=", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Length", "[", "Umatreps", "]"}], "\[Equal]", "1"}], ",", 
          RowBox[{"First", "@", "Umatreps"}], ",", 
          RowBox[{"Fold", "[", 
           RowBox[{"Dot", ",", 
            RowBox[{"First", "@", "Umatreps"}], ",", 
            RowBox[{"Drop", "[", 
             RowBox[{"Umatreps", ",", "1"}], "]"}]}], "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Superoperator", "[", 
        RowBox[{"U", ",", "opbasis", ",", "basis", ",", "\[IndentingNewLine]", 
         RowBox[{"Sequence", "@@", 
          RowBox[{"FilterRules", "[", 
           RowBox[{
            RowBox[{"Join", "[", 
             RowBox[{
              RowBox[{"{", "opts", "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"CheckOperatorType", "\[Rule]", " ", "False"}], "}"}], 
              ",", 
              RowBox[{"Options", "[", "NPropagationSuperoperator", "]"}]}], 
             "]"}], ",", 
            RowBox[{"Options", "[", "Superoperator", "]"}]}], "]"}]}]}], 
        "]"}]}], "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
