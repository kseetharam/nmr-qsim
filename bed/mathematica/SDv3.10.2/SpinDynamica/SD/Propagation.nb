Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"NPropagationSuperoperator", "[", 
    RowBox[{"True", ",", "True", ",", 
     RowBox[{"Event", "[", 
      RowBox[{
       RowBox[{"st", ":", 
        RowBox[{"(", 
         RowBox[{"True", "|", 
          RowBox[{"{", 
           RowBox[{"True", ",", "True"}], "}"}]}], ")"}]}], ",", 
       RowBox[{"ch", ":", 
        RowBox[{"{", 
         RowBox[{
         "_", ",", "_", ",", "_", ",", "IntegrateEvolutionOverTime", ",", 
          "__"}], "}"}]}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Hop", ":", 
          RowBox[{"HoldPattern", "@", 
           RowBox[{"Operator", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"_", "?", "MatrixQ"}], ",", "_List", ",", 
               RowBox[{"_", "?", "MatrixQ"}]}], "}"}], ",", "basis1_", ",", 
             "___Rule"}], "]"}]}]}], ",", "\[Tau]_"}], "}"}], ",", 
       "evopts___Rule"}], "]"}], ",", "opbasis_", ",", "basis2_", ",", 
     "opts___Rule"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"X", ",", "evals", ",", "Xinv"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Hop", "=", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"basis1", "\[Equal]", "basis2"}], ",", "Hop", ",", 
          RowBox[{"NDiagonalize", "[", 
           RowBox[{"Hop", ",", "basis2"}], "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"X", ",", "evals", ",", "Xinv"}], "}"}], "=", 
        RowBox[{"First", "@", "Hop"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Operator", "[", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"SparseArray", "@"}], "*)"}], "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Chop", "@", 
          RowBox[{"N", "[", 
           RowBox[{"X", ".", 
            RowBox[{"DiagonalMatrix", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"Exp", "[", 
                RowBox[{
                 RowBox[{"-", "I"}], "*", "\[Tau]", "*", "#"}], "]"}], "&"}], 
              "/@", "evals"}], "]"}], ".", "Xinv"}], "]"}]}], ",", 
         "\[IndentingNewLine]", "basis2", ",", "\[IndentingNewLine]", 
         RowBox[{"Sequence", "@@", 
          RowBox[{"FilterRules", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"Join", "[", 
             RowBox[{
              RowBox[{"{", "opts", "}"}], ",", 
              RowBox[{"Options", "[", "NPropagationSuperoperator", "]"}]}], 
             "]"}], ",", "\[IndentingNewLine]", 
            RowBox[{"Options", "[", "Operator", "]"}]}], 
           "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", "]"}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
