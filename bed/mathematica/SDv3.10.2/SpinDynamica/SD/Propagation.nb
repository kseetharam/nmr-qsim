Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"HilbPropToLiouvProp", "[", 
     RowBox[{
      RowBox[{"k_.", "*", 
       RowBox[{"A", ":", 
        RowBox[{"(", 
         RowBox[{
         "_Operator", "|", "_RotationOperator", "|", "_OperatorProduct"}], 
         ")"}]}]}], ",", "basis_", ",", "opts___Rule"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"Ufw", ",", "Ubw"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Ufw", "=", 
        RowBox[{"MatrixRepresentation", "[", 
         RowBox[{
          RowBox[{"k", "*", "A"}], ",", 
          RowBox[{"ZeemanBasis", "[", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Ubw", "=", 
        RowBox[{"ConjugateTranspose", "@", "Ufw"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Superoperator", "[", 
        RowBox[{
         RowBox[{"KroneckerProduct", "[", 
          RowBox[{"Ufw", ",", 
           RowBox[{"Transpose", "@", "Ubw"}]}], "]"}], ",", 
         RowBox[{"ZeemanKetBraOperatorBasis", "[", "]"}], ",", "basis", ",", 
         "\[IndentingNewLine]", 
         RowBox[{"Sequence", "@@", 
          RowBox[{"FilterRules", "[", 
           RowBox[{
            RowBox[{"Join", "[", 
             RowBox[{
              RowBox[{"{", "opts", "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"CheckOperatorType", "\[Rule]", " ", "False"}], "}"}], 
              ",", 
              RowBox[{"Options", "[", "NPropagationSuperoperator", "]"}]}], 
             "]"}], ",", 
            RowBox[{"Options", "[", "Superoperator", "]"}]}], "]"}]}]}], 
        "]"}]}]}], "\[IndentingNewLine]", "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"HilbPropToLiouvProp", "[", 
    RowBox[{
     RowBox[{"A", ":", 
      RowBox[{"(", "_Superoperator", ")"}]}], ",", "basis_", ",", 
     "opts___Rule"}], "]"}], ":=", "A"}], ";"}]}], "Input",
