Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"NPropagationSuperoperator", "[", 
     RowBox[{"True", ",", "True", ",", 
      RowBox[{"Event", "[", 
       RowBox[{
        RowBox[{"st", ":", 
         RowBox[{"(", 
          RowBox[{"True", "|", 
           RowBox[{"{", 
            RowBox[{"True", ",", "True"}], "}"}]}], ")"}]}], ",", 
        RowBox[{"ch", ":", 
         RowBox[{"{", 
          RowBox[{
          "_", ",", "_", ",", "_", ",", "IntegrateEvolutionOverTime", ",", 
           "__"}], "}"}]}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Hop_", "?", "OperatorQ"}], ",", "\[Tau]_"}], "}"}], ",", 
        "evopts___Rule"}], "]"}], ",", "opbasis_", ",", "basis_", ",", 
      "opts___Rule"}], "]"}], "/;", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"UseMatrixExpWhenPossible", "/.", 
       RowBox[{"{", "opts", "}"}]}], "/.", 
      RowBox[{"Options", "[", "NPropagationSuperoperator", "]"}]}], ")"}]}], ":=",
    "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "matrep", "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"matrep", "=", 
