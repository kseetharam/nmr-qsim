Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"NPropagationOperator", "[", "\[IndentingNewLine]", 
     RowBox[{"True", ",", "False", ",", "\[IndentingNewLine]", 
      RowBox[{"ev", ":", 
       RowBox[{"Event", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"st", ":", 
          RowBox[{"(", 
           RowBox[{"True", "|", 
            RowBox[{"{", 
             RowBox[{"True", ",", "True"}], "}"}]}], ")"}]}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"ch", ":", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"_", ",", 
              RowBox[{"{", 
               RowBox[{"tb_", ",", "ta_"}], "}"}], ",", "moretch___"}], "}"}],
             ",", "__"}], "}"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Hfunc", ":", 
            RowBox[{"TimeDependentGeneratorFunction", "[", 
             RowBox[{"t_", ",", 
              RowBox[{"\[Tau]xpairs_", "?", "MatrixQ"}], ",", "T_", ",", 
              RowBox[{"op_", "?", "OperatorQ"}], ",", 
              "tdepgenfuncopts___Rule"}], "]"}]}], ",", "\[Tau]_"}], "}"}], 
         ",", "\[IndentingNewLine]", "evopts___Rule"}], "\[IndentingNewLine]",
         "]"}]}], ",", "\[IndentingNewLine]", "basis_", ",", "opts___Rule"}], 
     "]"}], "/;", 
    RowBox[{
     RowBox[{"MatchQ", "[", 
      RowBox[{
       RowBox[{"PropagatorCalculationProcedure", "[", "ev", "]"}], ",", 
       "IntegrateEvolutionOverTime"}], "]"}], "&&", 
     RowBox[{"BackgroundGeneratorImplemented", "[", "ev", "]"}]}]}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "n", ",", "u", ",", "uvec", ",", "umat", ",", "h", ",", "hvec", ",", 
       "hmat", ",", "t$", ",", "maineqns", ",", "initialconds", ",", 
       "Hmatfunc", ",", "NDSolveopts"}], "}"}], ",", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"NDSolveopts", "=", 
        RowBox[{"Sequence", "@@", 
         RowBox[{"FilterRules", "[", 
          RowBox[{
           RowBox[{"SimplifyRules", "[", 
            RowBox[{"Join", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"evopts", ",", "opts"}], "}"}], ",", 
              RowBox[{"Options", "[", "NPropagationOperator", "]"}]}], "]"}], 
            "]"}], ",", 
           RowBox[{"Options", "[", "NDSolveValue", "]"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Hmatfunc", "=", "\[IndentingNewLine]", 
        RowBox[{"Function", "[", 
         RowBox[{"t$", ",", "\[IndentingNewLine]", 
          RowBox[{"Evaluate", "[", "\[IndentingNewLine]", 
           RowBox[{"Normal", "@", 
            RowBox[{"MatrixRepresentation", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"Hfunc", "[", 
                RowBox[{"t$", ",", "ta", ",", "tb"}], "]"}], "/.", 
               RowBox[{"{", 
                RowBox[{"evopts", ",", "opts"}], "}"}]}], ",", "basis"}], 
             "]"}]}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"n", "=", 
        RowBox[{"BasisDimension", "[", "basis", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"uvec", "[", "t$_", "]"}], "=", 
        RowBox[{"Through", "[", 
         RowBox[{
          RowBox[{"Flatten", "[", 
           RowBox[{"Array", "[", 
            RowBox[{"u", ",", 
             RowBox[{"{", 
              RowBox[{"n", ",", "n"}], "}"}]}], "]"}], "]"}], "[", "t$", 
          "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"hmat", "[", "t$_", "]"}], "=", 
        RowBox[{"Partition", "[", 
         RowBox[{
          RowBox[{"Through", "[", 
           RowBox[{
            RowBox[{"Flatten", "[", 
             RowBox[{"Array", "[", 
              RowBox[{"h", ",", 
               RowBox[{"{", 
                RowBox[{"n", ",", "n"}], "}"}]}], "]"}], "]"}], "[", "t$", 
            "]"}], "]"}], ",", "n"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"umat", "[", "t$_", "]"}], "=", 
        RowBox[{"Partition", "[", 
         RowBox[{
          RowBox[{"uvec", "[", "t$", "]"}], ",", "n"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"maineqns", "=", 
        RowBox[{"Inner", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"#1", "\[Equal]", "#2"}], ")"}], "&"}], ",", 
          RowBox[{"D", "[", 
           RowBox[{
            RowBox[{"uvec", "[", "t$", "]"}], ",", "t$"}], "]"}], ",", 
          RowBox[{"Flatten", "[", 
           RowBox[{
            RowBox[{"-", "I"}], " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"hmat", "[", "t$", "]"}], ".", 
              RowBox[{"umat", "[", "t$", "]"}]}], ")"}]}], "]"}], ",", 
          "List"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"initialconds", "=", 
        RowBox[{"Flatten", "[", 
         RowBox[{
          RowBox[{"umat", "[", "ta", "]"}], "/.", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"u", "[", 
               RowBox[{"r_", ",", "r_"}], "]"}], "[", "_", "]"}], 
             "\[RuleDelayed]", 
             RowBox[{
              RowBox[{
               RowBox[{"u", "[", 
                RowBox[{"r", ",", "r"}], "]"}], "[", "ta", "]"}], "\[Equal]", 
              "1"}]}], ",", 
            RowBox[{
             RowBox[{
              RowBox[{"u", "[", 
               RowBox[{"r_", ",", "s_"}], "]"}], "[", "_", "]"}], 
             "\[RuleDelayed]", 
             RowBox[{
              RowBox[{
               RowBox[{"u", "[", 
                RowBox[{"r", ",", "s"}], "]"}], "[", "ta", "]"}], "\[Equal]", 
              "0"}]}]}], "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Operator", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Partition", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{
            RowBox[{"NDSolveValue", "[", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"Join", "[", "\[IndentingNewLine]", 
               RowBox[{
                RowBox[{"maineqns", "/.", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"h", "[", 
                    RowBox[{"r_", ",", "s_"}], "]"}], "[", "t$_", "]"}], 
                  "\[RuleDelayed]", 
                  RowBox[{
                   RowBox[{"Hmatfunc", "[", "t$", "]"}], 
                   "\[LeftDoubleBracket]", 
                   RowBox[{"r", ",", "s"}], "\[RightDoubleBracket]"}]}]}], 
                ",", "\[IndentingNewLine]", "initialconds"}], 
               "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
              RowBox[{"uvec", "[", "t$", "]"}], ",", "\[IndentingNewLine]", 
              RowBox[{"{", 
               RowBox[{"t$", ",", "ta", ",", "tb"}], "}"}], ",", 
              "NDSolveopts"}], "\[IndentingNewLine]", "]"}], "/.", 
            RowBox[{"t$", "\[Rule]", "tb"}]}], ",", "\[IndentingNewLine]", 
           "n"}], "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
         "basis", ",", "\[IndentingNewLine]", 
         RowBox[{"Sequence", "@@", 
          RowBox[{"FilterRules", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"Join", "[", 
             RowBox[{
              RowBox[{"{", "opts", "}"}], ",", 
              RowBox[{"Options", "[", "NPropagationOperator", "]"}]}], "]"}], 
            ",", "\[IndentingNewLine]", 
            RowBox[{"Options", "[", "Operator", "]"}]}], 
           "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", "]"}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.691395946973058*^9, 3.691396247603812*^9}, {
   3.691396284376388*^9, 3.6913963092851677`*^9}, {3.691396339815465*^9, 
   3.691396356869803*^9}, {3.691396406343808*^9, 3.691396506956386*^9}, {
