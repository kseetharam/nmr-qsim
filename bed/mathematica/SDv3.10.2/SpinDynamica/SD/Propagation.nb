Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"NPropagationSuperoperator", "[", 
     RowBox[{"True", ",", "False", ",", 
      RowBox[{"ev", ":", 
       RowBox[{"Event", "[", 
        RowBox[{
         RowBox[{"st", ":", 
          RowBox[{"(", 
           RowBox[{"True", "|", 
            RowBox[{"{", 
             RowBox[{"True", ",", "True"}], "}"}]}], ")"}]}], ",", 
         RowBox[{"ch", ":", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"_", ",", 
              RowBox[{"{", 
               RowBox[{"tb_", ",", "ta_"}], "}"}], ",", "moretch___"}], "}"}],
             ",", "__"}], "}"}]}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Lfunc", ":", 
            RowBox[{"TimeDependentGeneratorFunction", "[", 
             RowBox[{"t_", ",", 
              RowBox[{"\[Tau]xpairs_", "?", "MatrixQ"}], ",", "T_", ",", 
              RowBox[{"op_", "?", "SuperoperatorQ"}], ",", 
              "tdepgenfuncopts___Rule"}], "]"}]}], ",", "\[Tau]_"}], "}"}], 
         ",", "evopts___Rule"}], "]"}]}], ",", "opbasis_", ",", "basis_", ",",
       "opts___Rule"}], "]"}], "/;", 
    RowBox[{
     RowBox[{"MatchQ", "[", 
      RowBox[{
       RowBox[{"PropagatorCalculationProcedure", "[", "ev", "]"}], ",", 
       "IntegrateEvolutionOverTime"}], "]"}], "&&", 
     RowBox[{"BackgroundGeneratorImplemented", "[", "ev", "]"}]}]}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "nL", ",", "u", ",", "uvecflat", ",", "uvec", ",", "uvecplain", ",", 
       "NDSolveopts", ",", "Uini", ",", "Lmatfunc", ",", "sol"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"NDSolveopts", "=", 
       RowBox[{"Sequence", "@@", 
        RowBox[{"FilterRules", "[", 
         RowBox[{
          RowBox[{"SimplifyRules", "[", 
           RowBox[{"{", 
            RowBox[{"evopts", ",", "opts"}], "}"}], "]"}], ",", 
          RowBox[{"Options", "[", "NDSolve", "]"}]}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"nL", "=", 
       RowBox[{
        RowBox[{"BasisDimension", "[", "]"}], "^", "2"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Lmatfunc", "=", 
       RowBox[{"Function", "[", 
        RowBox[{"t$", ",", 
         RowBox[{"Evaluate", "@", 
          RowBox[{"N", "[", 
           RowBox[{"SuperoperatorMatrixRepresentation", "[", 
