 RowBox[{
  RowBox[{
   RowBox[{"NPropagate", "[", 
    RowBox[{"\[Rho]_", ",", "True", ",", "False", ",", "True", ",", 
     RowBox[{"evlist", ":", 
      RowBox[{"EventList", "[", 
       RowBox[{"st_", ",", "chars_", ",", 
        RowBox[{"events", ":", 
         RowBox[{"{", 
          RowBox[{"_Event", ".."}], "}"}]}], ",", "evlistopts___Rule"}], 
       "]"}]}], ",", "opbasis_", ",", "basis_", ",", "opts___Rule"}], "]"}], ":=",
    "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"\[Rho]matrep", ",", "Ufw", ",", "Ubw"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
