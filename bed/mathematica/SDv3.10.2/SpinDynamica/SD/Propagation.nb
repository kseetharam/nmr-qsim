Cell["\<\
generate propagator in the Zeeman basis. This avoids multiple unnecessary \
basis transformations. \
\>", "Text",
 CellChangeTimes->{{3.691057269564514*^9, 3.691057292161083*^9}, {
  3.691057336291565*^9, 3.69105735297647*^9}, {3.691057497310364*^9, 
