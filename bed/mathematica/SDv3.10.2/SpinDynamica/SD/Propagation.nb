Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"NPropagate", "[", 
     RowBox[{"\[Rho]_", ",", "True", ",", 
      RowBox[{"{", 
       RowBox[{"True", ",", "4"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"False", ",", 
        RowBox[{"ev", ":", 
         RowBox[{"Event", "[", 
          RowBox[{
           RowBox[{"st", ":", 
            RowBox[{"True", "|", 
             RowBox[{"{", 
              RowBox[{"True", ".."}], "}"}]}]}], ",", 
           RowBox[{"ch", ":", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"_", ",", 
                RowBox[{"{", 
                 RowBox[{"tb_", ",", "ta_"}], "}"}], ",", "moretch___"}], 
               "}"}], ",", "__"}], "}"}]}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Lfunc", ":", 
              RowBox[{"TimeDependentGeneratorFunction", "[", 
               RowBox[{"t_", ",", 
                RowBox[{"\[Tau]xpairs_", "?", "MatrixQ"}], ",", "T_", ",", 
                RowBox[{"op_", "?", "SuperoperatorQ"}]}], "]"}]}], ",", 
             "\[Tau]_", ",", "tdepgenfuncopts___Rule"}], "}"}], ",", 
           "evopts___Rule"}], "]"}]}]}], "}"}], ",", "opbasis_", ",", 
      "basis_", ",", "opts___Rule"}], "]"}], "/;", 
    RowBox[{
     RowBox[{"MatchQ", "[", 
      RowBox[{
       RowBox[{"PropagatorCalculationProcedure", "[", "ev", "]"}], ",", 
       "IntegrateEvolutionOverTime"}], "]"}], "&&", 
     RowBox[{"BackgroundGeneratorImplemented", "[", "ev", "]"}]}]}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "dim", ",", "NDSolveopts", ",", "\[Rho]vecflat", ",", "\[Rho]vecplain", 
       ",", "\[Rho]ini", ",", "\[Rho]$", ",", "t$", ",", "sol", ",", 
       "Lmatfunc"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"dim", "=", 
       RowBox[{"BasisDimension", "[", "basis", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Lmatfunc", "=", 
       RowBox[{"Function", "[", 
        RowBox[{"t$", ",", 
         RowBox[{"Evaluate", "@", 
          RowBox[{"N", "[", 
           RowBox[{"SuperoperatorMatrixRepresentation", "[", 
            RowBox[{
             RowBox[{"StandardizeGenerator", "[", 
              RowBox[{
               RowBox[{"Lfunc", "[", 
                RowBox[{"t$", ",", "ta", ",", "tb"}], "]"}], "/.", 
               RowBox[{"{", 
                RowBox[{"evopts", ",", "opts"}], "}"}]}], "]"}], ",", 
             "opbasis"}], "]"}], "]"}]}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"NDSolveopts", "=", 
       RowBox[{"Sequence", "@@", 
        RowBox[{"FilterRules", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"evopts", ",", "opts"}], "}"}], ",", 
          RowBox[{"Options", "[", "NDSolve", "]"}]}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"\[Rho]vecflat", "[", "t$_", "]"}], ":=", 
       RowBox[{"Evaluate", "[", 
        RowBox[{"Flatten", "[", 
         RowBox[{"Array", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"\[Rho]$", "[", 
              RowBox[{"#1", ",", "#2"}], "]"}], "[", "t$", "]"}], "&"}], ",", 
           
           RowBox[{"{", 
            RowBox[{"dim", ",", "dim"}], "}"}]}], "]"}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"\[Rho]vecplain", "=", 
       RowBox[{"Evaluate", "[", 
        RowBox[{"Array", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"\[Rho]$", "[", 
            RowBox[{"#1", ",", "#2"}], "]"}], "&"}], ",", 
          RowBox[{"{", 
           RowBox[{"dim", ",", "dim"}], "}"}]}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"\[Rho]ini", "=", 
       RowBox[{"OperatorVectorRepresentation", "[", 
        RowBox[{"\[Rho]", ",", "opbasis"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"sol", "=", 
       RowBox[{"NDSolveValue", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"D", "[", 
             RowBox[{
              RowBox[{"\[Rho]vecflat", "[", "t$", "]"}], ",", "t$"}], "]"}], 
            "\[Equal]", 
            RowBox[{"Flatten", "@", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"Lmatfunc", "[", "t$", "]"}], ".", 
               RowBox[{"\[Rho]vecflat", "[", "t$", "]"}]}], ")"}]}]}], ",", 
           RowBox[{
            RowBox[{"\[Rho]vecflat", "[", "ta", "]"}], "\[Equal]", 
            RowBox[{"Flatten", "[", 
             RowBox[{"Normal", "@", "\[Rho]ini"}], "]"}]}]}], "}"}], ",", 
         RowBox[{"Flatten", "@", "\[Rho]vecplain"}], ",", 
         RowBox[{"{", 
          RowBox[{"t$", ",", "ta", ",", "tb"}], "}"}], ",", "NDSolveopts"}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Function", "[", 
       RowBox[{"t$", ",", 
        RowBox[{"Evaluate", "@", 
         RowBox[{"Operator", "[", "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{"SparseArray", "@"}], "*)"}], 
          RowBox[{
           RowBox[{"Chop", "[", 
            RowBox[{"N", "[", 
             RowBox[{"Through", "[", 
              RowBox[{"sol", "[", "t$", "]"}], "]"}], "]"}], "]"}], ",", 
           "\[IndentingNewLine]", "opbasis", ",", "basis", ",", 
           RowBox[{"Sequence", "@@", 
            RowBox[{"FilterRules", "[", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"Join", "[", 
               RowBox[{
                RowBox[{"{", "opts", "}"}], ",", 
                RowBox[{"Options", "[", "NPropagate", "]"}]}], "]"}], ",", 
              "\[IndentingNewLine]", 
              RowBox[{"Options", "[", "Operator", "]"}]}], 
             "\[IndentingNewLine]", "]"}]}]}], "]"}]}]}], "]"}]}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.691395946973058*^9, 3.691396247603812*^9}, {
