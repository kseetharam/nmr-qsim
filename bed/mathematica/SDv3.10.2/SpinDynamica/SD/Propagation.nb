Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"NPropagationOperator", "::", "usage"}], "=", 
   "\"\<NPropagationOperator[events, opts] generates the unitary Operator for \
propagation under the specified events. The options opts may include a \
specification for Basis and options to be passed into NDSolve.\n\nThe output \
of NPropagate is an operator, for the case Continuous\[Rule]False, or an \
OperatorTrajectoryFunction, for the case Continuous\[Rule]True.\n\>\""}], 
  ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.534309991630437*^9, 3.534310111415*^9}, {
  3.534390129169463*^9, 3.534390135625058*^9}, {3.683108691583698*^9, 
