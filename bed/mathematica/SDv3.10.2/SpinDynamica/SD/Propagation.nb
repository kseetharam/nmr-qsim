Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"NPropagationSuperoperator", "[", 
     RowBox[{"True", ",", "False", ",", 
      RowBox[{"ev", ":", 
       RowBox[{"Event", "[", 
        RowBox[{
         RowBox[{"st", ":", 
          RowBox[{"(", 
           RowBox[{"True", "|", 
            RowBox[{"{", 
             RowBox[{"True", ",", "True"}], "}"}]}], ")"}]}], ",", 
         RowBox[{"ch", ":", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"_", ",", 
              RowBox[{"{", 
               RowBox[{"tb_", ",", "ta_"}], "}"}], ",", "moretch___"}], "}"}],
             ",", "__"}], "}"}]}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Hfunc", ":", 
            RowBox[{"TimeDependentGeneratorFunction", "[", 
             RowBox[{"args___", ",", "op_"}], "]"}]}], ",", "\[Tau]_"}], 
          "}"}], ",", "evopts___Rule"}], "]"}]}], ",", "opbasis_", ",", 
      "basis_", ",", "opts___Rule"}], "]"}], "/;", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"MatchQ", "[", 
       RowBox[{
        RowBox[{"PropagatorCalculationProcedure", "[", "ev", "]"}], ",", 
        "IntegrateEvolutionOverTime"}], "]"}], "&&", 
      RowBox[{"BackgroundGeneratorImplemented", "[", "ev", "]"}], "&&", 
      RowBox[{"MatchQ", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"PropagationMethod", "/.", 
           RowBox[{"{", "evopts", "}"}]}], "/.", 
          RowBox[{"Options", "[", "Event", "]"}]}], ")"}], ",", "Adiabatic"}],
        "]"}]}], ")"}]}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "Hlist", ",", "Ht", ",", "\[Lambda]$", ",", "tloc", ",", 
       "parametergrid", ",", "timegrid", ",", "evals", ",", "evecs", ",", 
       "H\[Lambda]", ",", "adiabaticparts", ",", "nonadiabaticparts", ",", 
       "adiabaticfactor", ",", "adiabaticparameter", ",", "spinsys"}], "}"}], 
     ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"spinsys", "=", 
        RowBox[{"SpinSystem", "[", "basis", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"timegrid", "=", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"Which", "[", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"MatchQ", "[", 
              RowBox[{"#", ",", 
               RowBox[{"{", "_Integer", "}"}]}], "]"}], ",", 
             RowBox[{"ta", "+", 
              RowBox[{
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"tb", "-", "ta"}], ")"}], "/", 
                RowBox[{"First", "[", "#", "]"}]}], "*", 
               RowBox[{"Range", "[", 
                RowBox[{"0", ",", 
                 RowBox[{"First", "[", "#", "]"}]}], "]"}]}]}], ",", 
             "\[IndentingNewLine]", 
             RowBox[{"MatchQ", "[", 
              RowBox[{"#", ",", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"_", "?", "NumericQ"}], ".."}], "}"}]}], "]"}], ",", 
             "#", ",", "\[IndentingNewLine]", 
             RowBox[{"MatchQ", "[", 
              RowBox[{"#", ",", "None"}], "]"}], ",", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"Message", "[", 
                RowBox[{"NPropagate", "::", "autoevsampling"}], "]"}], ";", 
               RowBox[{"ta", "+", 
                RowBox[{
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{"tb", "-", "ta"}], ")"}], "/", "100"}], "*", 
                 RowBox[{"Range", "[", 
                  RowBox[{"0", ",", "100"}], "]"}]}]}]}], ")"}], ",", 
             RowBox[{"#", "\[Equal]", "#"}], ",", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"Message", "[", 
                RowBox[{"NPropagate", "::", "wrongevsampling"}], "]"}], ";", 
               RowBox[{"Abort", "[", "]"}]}], ")"}]}], "]"}], "&"}], "@", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"EventSampling", "/.", 
             RowBox[{"{", "evopts", "}"}]}], "/.", 
            RowBox[{"Options", "[", "Event", "]"}]}], ")"}]}], 
         "\[IndentingNewLine]", ")"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "timegrid", "]"}], "\[LessEqual]", " ", 
          "4"}], ",", 
         RowBox[{"Message", "[", 
          RowBox[{"NPropagate", "::", "smalltimegrid"}], "]"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Ht", "=", 
        RowBox[{"Hfunc", "[", 
         RowBox[{"tloc", ",", "ta", ",", "tb"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Hlist", "=", 
        RowBox[{"Rest", "[", 
         RowBox[{"List", "@@", 
          RowBox[{"(", 
           RowBox[{"\"\<dummy\>\"", "+", 
            RowBox[{"ExpandAll", "[", "Ht", "]"}]}], ")"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"adiabaticparts", "=", 
        RowBox[{"Total", "@", 
         RowBox[{"Select", "[", 
          RowBox[{"Hlist", ",", 
           RowBox[{
            RowBox[{"!", 
             RowBox[{"FreeQ", "[", 
              RowBox[{"#", ",", "tloc"}], "]"}]}], "&"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"adiabaticparts", "=", 
        RowBox[{"Together", "[", 
         RowBox[{"Collect", "[", 
          RowBox[{"adiabaticparts", ",", "tloc"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"nonadiabaticparts", "=", 
        RowBox[{"Expand", "[", 
         RowBox[{
          RowBox[{"Total", "@", 
           RowBox[{"Select", "[", 
            RowBox[{"Hlist", ",", 
             RowBox[{
              RowBox[{"FreeQ", "[", 
               RowBox[{"#", ",", "tloc"}], "]"}], "&"}]}], "]"}]}], ",", 
          "OperatorPattern"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"adiabaticfactor", "=", 
        RowBox[{
         RowBox[{"First", "[", 
          RowBox[{"Rest", "[", 
           RowBox[{"List", "@@", 
            RowBox[{"(", 
             RowBox[{"\"\<dummy\>\"", "+", "adiabaticparts"}], ")"}]}], "]"}],
           "]"}], "/.", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"k_.", "tloc", "*", 
            RowBox[{"_", "?", "OperatorQ"}]}], "\[RuleDelayed]", " ", 
           RowBox[{"k", " ", "tloc"}]}], "}"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"adiabaticparameter", "=", 
        RowBox[{"First", "@", 
         RowBox[{"Cases", "[", 
          RowBox[{
           RowBox[{"Flatten", "@", 
            RowBox[{"{", "adiabaticfactor", "}"}]}], ",", 
           RowBox[{"tloc", "*", "___"}], ",", "\[Infinity]"}], "]"}]}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"H\[Lambda]", "=", 
        RowBox[{"nonadiabaticparts", "+", 
         RowBox[{"(", 
          RowBox[{"adiabaticparts", "/.", 
           RowBox[{"{", 
            RowBox[{"adiabaticparameter", "\[Rule]", " ", "\[Lambda]$"}], 
            "}"}]}], ")"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"parametergrid", "=", 
        RowBox[{"Map", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"adiabaticparameter", "/.", 
            RowBox[{"{", 
             RowBox[{"tloc", "\[Rule]", " ", "#"}], "}"}]}], "&"}], ",", 
          "timegrid"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"evals", ",", "evecs"}], "}"}], "=", 
        RowBox[{"CorrelatedEigensystems", "[", 
         RowBox[{"H\[Lambda]", ",", 
          RowBox[{"Join", "[", 
           RowBox[{
            RowBox[{"{", "\[Lambda]$", "}"}], ",", 
            RowBox[{"{", "parametergrid", "}"}]}], "]"}], ",", 
          RowBox[{"ReturnDetailedEigensystem", "\[Rule]", " ", "False"}], ",", 
          RowBox[{"Basis", "\[Rule]", " ", 
           RowBox[{"ZeemanBasis", "[", "spinsys", "]"}]}], ",", 
          "\"\<Operator\>\"", ",", 
          RowBox[{"{", 
           RowBox[{"\"\<1\>\"", ",", "\"\<4\>\""}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"AdiabaticPropagationSuperoperator", "[", 
        RowBox[{
         RowBox[{"Transpose", "[", "evals", "]"}], ",", "evecs", ",", 
         "parametergrid", ",", "timegrid", ",", "spinsys", ",", "evopts"}], 
        "]"}]}], "\[IndentingNewLine]", ")"}]}], "\[IndentingNewLine]", 
    "]"}]}], ";"}]], "Input",
