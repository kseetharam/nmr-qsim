Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"NPropagationOperator", "[", "\[IndentingNewLine]", 
     RowBox[{"True", ",", "False", ",", "\[IndentingNewLine]", 
      RowBox[{"Event", "[", 
       RowBox[{
        RowBox[{"st", ":", 
         RowBox[{"(", 
          RowBox[{"True", "|", 
           RowBox[{"{", 
            RowBox[{"True", ",", "True"}], "}"}]}], ")"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"ch", ":", 
         RowBox[{"{", 
          RowBox[{
          "_", ",", "_", ",", "_", ",", "IntegrateEvolutionOverTime", ",", 
           "__"}], "}"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Hop_", "?", "OperatorQ"}], ",", "\[Tau]_"}], "}"}], ",", 
        "evopts___Rule"}], "]"}], ",", "\[IndentingNewLine]", "basis_", ",", 
      "\[IndentingNewLine]", "opts___Rule"}], "]"}], "/;", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"UseMatrixExpWhenPossible", "/.", 
       RowBox[{"{", "opts", "}"}]}], "/.", 
      RowBox[{"Options", "[", "NPropagationOperator", "]"}]}], ")"}]}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"matrep", ",", "zbasis"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"zbasis", "=", 
        RowBox[{"ZeemanBasis", "[", 
         RowBox[{"SpinSystem", "[", "basis", "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"matrep", "=", 
        RowBox[{"MatrixRepresentation", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"-", "I"}], " ", "Hop", "\[Times]", " ", "\[Tau]"}], "/.", 
            RowBox[{"{", 
             RowBox[{"evopts", ",", "opts"}], "}"}]}], ")"}], ",", "zbasis"}],
          "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Operator", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"SparseArray", "@", 
          RowBox[{"N", "@", 
           RowBox[{"Chop", "@", 
            RowBox[{"MatrixExp", "[", 
             RowBox[{"N", "@", "matrep"}], "]"}]}]}]}], ",", 
         "\[IndentingNewLine]", "zbasis", ",", "\[IndentingNewLine]", 
         RowBox[{"Sequence", "@@", 
          RowBox[{"FilterRules", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"Join", "[", 
             RowBox[{
              RowBox[{"{", "opts", "}"}], ",", 
              RowBox[{"Options", "[", "NPropagationOperator", "]"}]}], "]"}], 
            ",", "\[IndentingNewLine]", 
            RowBox[{"Options", "[", "Operator", "]"}]}], 
           "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", "]"}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
