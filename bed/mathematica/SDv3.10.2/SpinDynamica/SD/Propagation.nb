Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"HoldPattern", "@", 
     RowBox[{"NPropagationOperator", "[", "\[IndentingNewLine]", 
      RowBox[{"True", ",", "False", ",", "\[IndentingNewLine]", 
       RowBox[{"ev", ":", 
        RowBox[{"Event", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"st", ":", 
           RowBox[{"(", 
            RowBox[{"True", "|", 
             RowBox[{"{", 
              RowBox[{"True", ",", "True"}], "}"}]}], ")"}]}], ",", "ch_", 
          ",", "\[IndentingNewLine]", 
          RowBox[{"Repeat", "[", 
           RowBox[{
           "evlist_EventList", ",", "n_Integer", ",", "evtropts___Rule"}], 
           "]"}], ",", "\[IndentingNewLine]", "evopts___Rule"}], 
         "\[IndentingNewLine]", "]"}]}], ",", "\[IndentingNewLine]", "basis_",
        ",", "\[IndentingNewLine]", "opts___Rule"}], "\[IndentingNewLine]", 
      "]"}]}], "/;", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"MatchQ", "[", 
      RowBox[{
       RowBox[{"PropagatorCalculationProcedure", "[", "ev", "]"}], ",", 
       "RepeatPropagator"}], "]"}], "&&", 
     RowBox[{"BackgroundGeneratorImplemented", "[", "ev", "]"}]}]}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "zbasis", "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"zbasis", "=", 
        RowBox[{"ZeemanBasis", "[", 
         RowBox[{"SpinSystem", "[", "basis", "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Operator", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"MatrixPower", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"MatrixRepresentation", "[", 
            RowBox[{
             RowBox[{"NPropagationOperator", "[", 
              RowBox[{
              "True", ",", "False", ",", "evlist", ",", "zbasis", ",", 
               "opts"}], "]"}], ",", "zbasis"}], "]"}], ",", 
           "\[IndentingNewLine]", "n"}], "\[IndentingNewLine]", "]"}], ",", 
         "\[IndentingNewLine]", "zbasis", ",", "\[IndentingNewLine]", 
         RowBox[{"Sequence", "@@", 
          RowBox[{"FilterRules", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"Join", "[", 
             RowBox[{
              RowBox[{"{", "opts", "}"}], ",", 
              RowBox[{"Options", "[", "NPropagationOperator", "]"}]}], "]"}], 
            ",", "\[IndentingNewLine]", 
            RowBox[{"Options", "[", "Operator", "]"}]}], 
           "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", "]"}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
 PageWidth:>WindowWidth,
