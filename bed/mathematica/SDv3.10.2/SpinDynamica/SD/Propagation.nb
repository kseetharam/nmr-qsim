    RowBox[{"NPropagationOperator", "[", "\[IndentingNewLine]", 
     RowBox[{"True", ",", "False", ",", "\[IndentingNewLine]", 
      RowBox[{"ev", ":", 
       RowBox[{"Event", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"st", ":", 
          RowBox[{"(", 
           RowBox[{"True", "|", 
            RowBox[{"{", 
             RowBox[{"True", ",", "True"}], "}"}]}], ")"}]}], ",", "ch_", ",",
          "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"TimeDependentGeneratorFunction", "[", 
            RowBox[{"t_", ",", 
             RowBox[{"\[Tau]xpairs_", "?", "MatrixQ"}], ",", "T_", ",", 
             RowBox[{"CommutationSuperoperator", "[", 
              RowBox[{"op_", ",", "___Rule"}], "]"}], ",", 
             "tdepgenfuncopts___Rule"}], "]"}], ",", "\[Tau]_"}], "}"}], ",", 
         "\[IndentingNewLine]", "evopts___Rule"}], "]"}]}], ",", 
