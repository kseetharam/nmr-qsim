Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"NPropagate", "[", 
     RowBox[{"\[Rho]_", ",", "True", ",", 
      RowBox[{"{", 
       RowBox[{"True", ",", "4"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"True", ",", 
        RowBox[{"ev", ":", 
         RowBox[{"Event", "[", 
          RowBox[{
           RowBox[{"st", ":", 
            RowBox[{"True", "|", 
             RowBox[{"{", 
              RowBox[{"True", ".."}], "}"}]}]}], ",", "ch_", ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Hfunc", ":", 
              RowBox[{"TimeDependentGeneratorFunction", "[", 
               RowBox[{"args__", ",", 
                RowBox[{"op_", "?", "OperatorQ"}], ",", "___Rule"}], "]"}]}], 
             ",", "\[Tau]_", ",", "tdepgenfuncopts___Rule"}], "}"}], ",", 
           "evopts___Rule"}], "]"}]}]}], "}"}], ",", "opbasis_", ",", 
      "basis_", ",", "opts___Rule"}], "]"}], "/;", 
    RowBox[{"MatchQ", "[", 
     RowBox[{
      RowBox[{"PropagatorCalculationProcedure", "[", "ev", "]"}], ",", 
      "IntegrateEvolutionOverTime"}], "]"}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "dim", ",", "tb", ",", "ta", ",", "Hmatfunc", ",", "NDSolveopts", ",", 
       "\[Rho]vec", ",", "\[Rho]vecflat", ",", "\[Rho]vecplain", ",", 
       "\[Rho]ini", ",", "\[Rho]$", ",", "sol"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"dim", "=", 
        RowBox[{"BasisDimension", "[", "basis", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"tb", ",", "ta"}], "}"}], "=", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"FinalTimePoint", "[", "ev", "]"}], ",", 
          RowBox[{"InitialTimePoint", "[", "ev", "]"}]}], "}"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Hmatfunc", "=", 
        RowBox[{"Function", "[", 
         RowBox[{"t$", ",", 
          RowBox[{"Evaluate", "[", 
           RowBox[{"N", "@", 
            RowBox[{"Normal", "@", 
             RowBox[{"MatrixRepresentation", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"Hfunc", "[", 
                 RowBox[{"t$", ",", "ta", ",", "tb"}], "]"}], "/.", 
                RowBox[{"{", 
                 RowBox[{"evopts", ",", "opts"}], "}"}]}], ",", 
               RowBox[{"ZeemanBasis", "[", "]"}]}], "]"}]}]}], "]"}]}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"NDSolveopts", "=", 
        RowBox[{"Sequence", "@@", 
         RowBox[{"FilterRules", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"evopts", ",", "opts"}], "}"}], ",", 
           RowBox[{"Options", "[", "NDSolve", "]"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"\[Rho]vec", "[", "t$_", "]"}], ":=", 
        RowBox[{"Evaluate", "[", 
         RowBox[{"Array", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"\[Rho]$", "[", 
              RowBox[{"#1", ",", "#2"}], "]"}], "[", "t$", "]"}], "&"}], ",", 
           
           RowBox[{"{", 
            RowBox[{"dim", ",", "dim"}], "}"}]}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"\[Rho]vecflat", "[", "t$_", "]"}], ":=", 
        RowBox[{"Evaluate", "[", 
         RowBox[{"Flatten", "[", 
          RowBox[{"Array", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"\[Rho]$", "[", 
               RowBox[{"#1", ",", "#2"}], "]"}], "[", "t$", "]"}], "&"}], ",", 
            RowBox[{"{", 
             RowBox[{"dim", ",", "dim"}], "}"}]}], "]"}], "]"}], "]"}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"\[Rho]vecplain", "=", 
        RowBox[{"Evaluate", "[", 
         RowBox[{"Array", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"\[Rho]$", "[", 
             RowBox[{"#1", ",", "#2"}], "]"}], "&"}], ",", 
           RowBox[{"{", 
            RowBox[{"dim", ",", "dim"}], "}"}]}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"\[Rho]ini", "=", 
        RowBox[{"MatrixRepresentation", "[", 
         RowBox[{"\[Rho]", ",", "basis"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"sol", "=", 
        RowBox[{"NDSolveValue", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"D", "[", 
              RowBox[{
               RowBox[{"\[Rho]vecflat", "[", "t$", "]"}], ",", "t$"}], "]"}], 
             "\[Equal]", 
             RowBox[{
              RowBox[{"-", "I"}], " ", 
              RowBox[{"Flatten", "@", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{
                  RowBox[{"Hmatfunc", "[", "t$", "]"}], ".", 
                  RowBox[{"\[Rho]vec", "[", "t$", "]"}]}], "-", 
                 RowBox[{
                  RowBox[{"\[Rho]vec", "[", "t$", "]"}], ".", 
                  RowBox[{"Hmatfunc", "[", "t$", "]"}]}]}], ")"}]}]}]}], ",", 
            
            RowBox[{
             RowBox[{"\[Rho]vecflat", "[", "ta", "]"}], "\[Equal]", 
             RowBox[{"Flatten", "[", 
              RowBox[{"Normal", "@", "\[Rho]ini"}], "]"}]}]}], "}"}], ",", 
          RowBox[{"Flatten", "@", "\[Rho]vecplain"}], ",", 
          RowBox[{"{", 
           RowBox[{"t$", ",", "ta", ",", "tb"}], "}"}], ",", "NDSolveopts"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Function", "[", 
        RowBox[{"t", ",", 
         RowBox[{"Evaluate", "@", 
          RowBox[{"Operator", "[", 
           RowBox[{
            RowBox[{"Chop", "[", 
             RowBox[{"N", "[", 
              RowBox[{"Through", "[", 
               RowBox[{"sol", "[", "t", "]"}], "]"}], "]"}], "]"}], ",", 
            RowBox[{"ZeemanKetBraOperatorBasis", "[", "]"}], ",", 
            RowBox[{"ZeemanBasis", "[", "]"}], ",", 
            RowBox[{"Sequence", "@@", 
             RowBox[{"FilterRules", "[", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"Join", "[", 
                RowBox[{
                 RowBox[{"{", "opts", "}"}], ",", 
                 RowBox[{"Options", "[", "NPropagate", "]"}]}], "]"}], ",", 
               "\[IndentingNewLine]", 
               RowBox[{"Options", "[", "Operator", "]"}]}], 
              "\[IndentingNewLine]", "]"}]}]}], "]"}]}]}], "]"}]}], " ", 
      RowBox[{"(*", 
       RowBox[{"SparseArray", " ", "removed"}], "*)"}], "\[IndentingNewLine]",
       ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
