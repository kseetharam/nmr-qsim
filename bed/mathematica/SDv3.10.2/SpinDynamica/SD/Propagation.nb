        RowBox[{"True", ",", "False", ",", "morestatus___"}], "}"}]}], ",", 
      RowBox[{"cont_", "?", "BooleanQ"}], ",", "events_", ",", "opbasis_", 
      ",", "basis_", ",", "opts___Rule"}], "]"}]}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
