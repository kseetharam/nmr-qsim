Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"NPropagationOperator", "[", "\[IndentingNewLine]", 
    RowBox[{"True", ",", "False", ",", "\[IndentingNewLine]", 
     RowBox[{"Event", "[", 
      RowBox[{
       RowBox[{"st", ":", 
        RowBox[{"(", 
         RowBox[{"True", "|", 
          RowBox[{"{", 
           RowBox[{"True", ",", "True"}], "}"}]}], ")"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"ch", ":", 
        RowBox[{"{", 
         RowBox[{
         "_", ",", "_", ",", "_", ",", "IntegrateEvolutionOverTime", ",", 
          "__"}], "}"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Hop", ":", 
          RowBox[{"HoldPattern", "@", 
           RowBox[{"Operator", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"_", "?", "MatrixQ"}], ",", "_List", ",", 
               RowBox[{"_", "?", "MatrixQ"}]}], "}"}], ",", "basis1_", ",", 
             "___Rule"}], "]"}]}]}], ",", "\[Tau]_"}], "}"}], ",", 
       "evopts___Rule"}], "]"}], ",", "\[IndentingNewLine]", "basis_", ",", 
     "\[IndentingNewLine]", "opts___Rule"}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"X", ",", "evals", ",", "Xinv"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"X", ",", "evals", ",", "Xinv"}], "}"}], "=", 
        RowBox[{"First", "@", 
         RowBox[{"NDiagonalize", "[", 
          RowBox[{"Hop", ",", "basis"}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Operator", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"SparseArray", "@", 
          RowBox[{"Chop", "[", 
           RowBox[{"X", ".", 
            RowBox[{"DiagonalMatrix", "[", 
             RowBox[{"Exp", "[", 
              RowBox[{
               RowBox[{"-", "I"}], "*", "\[Tau]", "*", "evals"}], "]"}], 
             "]"}], ".", "Xinv"}], "]"}]}], ",", "\[IndentingNewLine]", 
         "basis", ",", "\[IndentingNewLine]", 
         RowBox[{"Sequence", "@@", 
          RowBox[{"FilterRules", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"Join", "[", 
             RowBox[{
              RowBox[{"{", "opts", "}"}], ",", 
              RowBox[{"Options", "[", "NPropagationOperator", "]"}]}], "]"}], 
            ",", "\[IndentingNewLine]", 
            RowBox[{"Options", "[", "Operator", "]"}]}], 
           "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", "]"}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
