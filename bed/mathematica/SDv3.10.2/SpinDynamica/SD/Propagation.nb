Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Precalculate", "::", "usage"}], "=", 
   "\"\<Precalculate[events, options] calculates the propagator for a set of \
events and stores it as a PrecalculatedEvent object for future use. The \
output is a PrecalculatedEvent object. This may save calculation time in some \
cases. The options may contain a rule of the form \
BackgroundGenerator\[Rule]<backgen>. This uses the specified background \
generator <backgen> when calculating the propagator for the event. A \
PrecalculatedEvent may only be used in a context for which the \
BackgroundGenerator is the same as that applying when the PrecalculatedEvent \
was constructed. \nThe option Precalculate\[Rule]True or \
Precalculate\[Rule]False is also used as an option for some propagation \
routines to indicate whether an attempt is made to detect and precalculate \
common events, in order to reduce computation time.\>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 CellChangeTimes->{{3.452685645562502*^9, 3.45268596259144*^9}, {
