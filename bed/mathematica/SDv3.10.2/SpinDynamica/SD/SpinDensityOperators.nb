Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ThermalEquilibriumDensityOperator", "::", "usage"}], "=", 
   "\"\<ThermalEquilibriumDensityOperator[Hlab, Temperature,options] sets up \
a thermal equilibrium density operator under the laboratory frame Hamiltonian \
Hlab at the specified temperature. The syntax \
ThermalEquilibriumDensityOperator[{Hlab, Temperature},options] may also be \
used.\nThe options may include HighTemperatureApproximation\[Rule]False or \
HighTemperatureApproximation\[Rule]True.\>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 CellChangeTimes->{{3.461322189599052*^9, 3.461322301335417*^9}, {
