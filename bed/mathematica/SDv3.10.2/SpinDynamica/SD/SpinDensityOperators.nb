Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"HighTemperatureApproximationWarningThreshold", "::", "usage"}], 
   "=", "\"\<HighTemperatureApproximationWarningThreshold is an option for \
ThermalEquilibriumDensityOperator and ThermalizeSuperoperator. The default is \
HighTemperatureApproximationWarningThreshold\[Rule]0.9. A warning is given if \
HighTemperatureApproximation\[Rule]True and one of the exponential factors in \
the Boltzmann distribution is less than this number. The warning may be \
disabled using HighTemperatureApproximationWarningThreshold\[Rule]0.\>\""}], 
  ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
