          RowBox[{"UnityOperator", "[", "]"}], "+", 
          RowBox[{"2", " ", "pol", " ", 
           RowBox[{"opI", "[", 
            RowBox[{"j", ",", "axis"}], "]"}]}]}], ")"}]}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
