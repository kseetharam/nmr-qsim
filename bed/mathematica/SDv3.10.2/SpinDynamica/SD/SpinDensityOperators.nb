Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SingletPolarizedDensityOperator", "[", 
    RowBox[{
     RowBox[{"polpairs", ":", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Except", "[", "_List", "]"}], ",", 
            RowBox[{"Except", "[", "_List", "]"}]}], "}"}], ",", "_"}], "}"}],
         ".."}], "}"}]}], ",", 
     RowBox[{"spinsys_", "?", "MatrixQ"}]}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"If", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"FreeQ", "[", 
        RowBox[{"#", ",", "$Failed"}], "]"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"SingletPolarizedDensityOperator", "[", 
         RowBox[{"polpairs", ",", "spinsys"}], "]"}], "=", 
        RowBox[{"Simplify", "@", 
         RowBox[{"Expand", "[", "#", "]"}]}]}], ",", "\[IndentingNewLine]", 
       "$Failed"}], "]"}], "&"}], "@", "\[IndentingNewLine]", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "dim", "}"}], ",", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"dim", "=", 
         RowBox[{"BasisDimension", "[", 
          RowBox[{"ZeemanBasis", "[", "spinsys", "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"SingletPolarizedDensityOperator", "[", 
          RowBox[{"polpairs", ",", "spinsys"}], "]"}], "=", 
         RowBox[{"Simplify", "[", 
          RowBox[{
           RowBox[{"dim", "^", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"Length", "[", "polpairs", "]"}], "-", "1"}], ")"}]}], 
           "\[Times]", "\[IndentingNewLine]", 
           RowBox[{"Apply", "[", 
            RowBox[{"Dot", ",", 
             RowBox[{
              RowBox[{
               RowBox[{"SingletPolarizedDensityOperator", "[", 
                RowBox[{"#", ",", "spinsys"}], "]"}], "&"}], "/@", 
              "polpairs"}]}], "]"}]}], "\[IndentingNewLine]", "]"}]}]}], 
       "\[IndentingNewLine]", ")"}]}], "]"}]}]}], ";"}]], "Input",
 InitializationCell->True,
