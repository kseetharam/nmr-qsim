          RowBox[{"\[HBar]", ",", "kB"}], "}"}]}]}], "]"}], ",", 
      RowBox[{"{", "}"}]}], "]"}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "H\[Theta]mat", ",", "H\[Theta]evals", ",", "H\[Theta]evecs", ",", 
       "expfacs", ",", "Z", ",", "htapprox", ",", "htapproxwth", ",", 
       "numericH\[Theta]mat", ",", "X", ",", "Xinv"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"htapprox", ",", "htapproxwth"}], "}"}], "=", 
