Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SingletPolarizedDensityOperator", "::", "usage"}], "=", 
   "\[IndentingNewLine]", 
   "\"\<SingletPolarizedDensityOperator[<args>] sets up a density operator in \
which one spin pair, or several spin pairs, exhibit singlet polarization. In \
general the polarization levels and polarization directions may be defined \
individually for each spin pair.\nIn the case where the current SpinSystem[] \
is a spin-1/2 pair, SingletPolarizedDensityOperator[p] generates a density \
operator with singlet polarization p. \nIf the current SpinSystem[] contains \
more than two spins-1/2, the syntax SingletPolarizedDensityOperator[{j,k},p] \
generates a density operator with singlet polarization p for the spin pair \
{j,k}, and the syntax SingletPolarizedDensityOperator[{{j,k},{l,m}},p] \
generates a density operator with singlet polarization p for the spin pairs \
{j,k} and {l,m}. \nThe most general syntax is \
SingletPolarizedDensityOperator[{{{j,k},pjk},{{l,m},plm}..},spinsystem] which \
allows individual singlet polarization levels for distinct spin pairs. If \
spinsystem is omitted, the current SpinSystem[] is assumed.\n\>\""}], 
  ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.66729666829174*^9, 3.667296837921706*^9}, {
  3.667297248558276*^9, 3.667297275129602*^9}, {3.667297309174063*^9, 
