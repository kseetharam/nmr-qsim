Cell[CellGroupData[{

Cell["explanation", "Subsubsection",
 InitializationCell->True,
 CellChangeTimes->{{3.674559277367179*^9, 3.674559288278892*^9}, {
  3.6745609265418777`*^9, 
  3.6745609283510118`*^9}},ExpressionUUID->"6aa5a114-52f0-4ef3-b812-\
aa960fa4c48c"],

Cell[TextData[{
 "First consider a single spin pair in a system of just that pair. \nAssume \
\[Rho](p) = a(p) |",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["S", "0"], ">", "<", 
     SubscriptBox["S", "0"]}], "|", " ", 
    RowBox[{"+", " ", "b"}]}], TraditionalForm]],ExpressionUUID->
  "d90ca2d3-6f81-4469-9cc0-dbf8bd7df717"],
 "(p) ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderscriptBox["\[Sum]", "M"], 
    RowBox[{"|", 
     RowBox[{
      SubscriptBox["T", "M"], ">", "<", 
      SubscriptBox["T", "M"]}], "|"}]}], TraditionalForm]],ExpressionUUID->
  "5aa65f10-7f33-4537-b7a3-de9974c5a55e"],
 "\nwhere ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"a", "(", "p", ")"}], "=", 
    RowBox[{
     SubscriptBox["a", "0"], "+", 
     RowBox[{
      SubscriptBox["a", "1"], "p"}]}]}], TraditionalForm]],ExpressionUUID->
  "cdf86647-536f-47c1-ba5c-7c8b023f37f8"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"b", "(", "p", ")"}], "=", 
    RowBox[{
     SubscriptBox["b", "0"], "+", 
     RowBox[{
      SubscriptBox["b", "1"], "p"}]}]}], TraditionalForm]],ExpressionUUID->
  "52b6f936-24dd-44cb-bfcb-7f2a39e93861"],
 ".\nSince the trace must always be 1 then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"a", "(", "p", ")"}], "+", 
     RowBox[{"3", 
      RowBox[{"b", "(", "p", ")"}]}]}], "=", "1"}], TraditionalForm]],
  ExpressionUUID->"ee28d45f-c4e6-4e8f-957c-27e90b5a5c01"],
 "\nWhen p=1, a(1)=1 and b(1)=0. Hence ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["a", "0"], "+", 
     SubscriptBox["a", "1"]}], "=", "1"}], TraditionalForm]],ExpressionUUID->
  "5fbc0eb4-a4ce-4a2d-be47-8e368607cbc0"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["b", "0"], "+", 
     SubscriptBox["b", "1"]}], "=", "0"}], TraditionalForm]],ExpressionUUID->
  "078a5545-e686-42a6-ae25-c3b848d869a3"],
 ".\nWhen p=-1/3, a(-1/3)=0 and b(-1/3)=1/3. Hence ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["a", "0"], "-", 
     RowBox[{
      SubscriptBox["a", "1"], "/", "3"}]}], " ", "=", "0"}], 
   TraditionalForm]],ExpressionUUID->"1fb1bf36-b5cc-4f82-b88a-a713af75252a"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["b", "0"], "-", 
     RowBox[{
      SubscriptBox["b", "1"], "/", "3"}]}], " ", "=", 
    RowBox[{"1", "/", "3"}]}], TraditionalForm]],ExpressionUUID->
  "667f46d9-4514-478a-b851-d63829d6eb43"],
 ".\nSolve these to get ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "0"], "=", 
    RowBox[{"1", "/", "4"}]}], TraditionalForm]],ExpressionUUID->
  "854a5357-271e-4096-a1e8-d166afdf7c55"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["a", "1"], "=", 
     RowBox[{"3", "/", "4"}]}], ","}], TraditionalForm]],ExpressionUUID->
  "116ed2b6-f572-452f-b82c-8c0b8faca42d"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["b", "0"], "=", 
    RowBox[{"1", "/", "4"}]}], TraditionalForm]],ExpressionUUID->
  "262f2e2f-c70c-43d7-b6fc-df705daf3c49"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["b", "1"], "=", 
    RowBox[{
     RowBox[{"-", "1"}], "/", "4."}]}], TraditionalForm]],ExpressionUUID->
  "e1d45c95-6d77-4179-910a-e2e9cc249700"],
 "\nHence ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"a", "(", "p", ")"}], "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "+", 
       RowBox[{"3", "p"}]}], ")"}], "/", "4"}]}], TraditionalForm]],
  ExpressionUUID->"e62817c5-2142-40f3-a065-598c8f420288"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"b", "(", "p", ")"}], "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "-", "p"}], ")"}], "/", "4."}]}], TraditionalForm]],
  ExpressionUUID->"aa0fe4f3-eb44-4dd7-bbee-54d429c2f328"],
 "\nThis satisfies a(p)+3b(p)=1 as required.\nThe operator form of \[Rho](p) \
is (1/4)1 - p opI[j].opI[k] (verified by using ExpressOperator)\n\nWhen the \
single spin pair is embedded in a larger system, this operator must be \
divided by dim/4, where dim is the dimension of the complete Hilbert space, \
to ensure that the trace over the complete basis is unity."
}], "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.674629911193356*^9, 3.674629924269278*^9}, 
   3.674630095525378*^9, {3.674630395976224*^9, 3.674630749810213*^9}, {
   3.674630806750792*^9, 3.6746308561078672`*^9}, {3.674630936952667*^9, 
   3.674630963726383*^9}, {3.67463101359097*^9, 3.6746310841136303`*^9}, {
   3.67463112637194*^9, 3.67463116078375*^9}, {3.674631280083807*^9, 
   3.674631359716166*^9}, {3.674631408305276*^9, 3.674631408673617*^9}, {
   3.6746320935063*^9, 
   3.674632102141048*^9}},ExpressionUUID->"3c346860-1f43-47e2-a6c8-\
979b75d78dd6"]
}, Closed]]
}, Closed]],

