Cell[CellGroupData[{

Cell["code", "Subsubsection",
 InitializationCell->True,
 CellChangeTimes->{{3.674559277367179*^9, 
  3.674559284971189*^9}},ExpressionUUID->"15f5d68f-0a88-4a23-96ee-\
3e91027c85ae"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SingletPolarizedDensityOperator", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"j", ":", 
          RowBox[{"Except", "[", "_List", "]"}]}], ",", 
         RowBox[{"k", ":", 
          RowBox[{"Except", "[", "_List", "]"}]}]}], "}"}], ",", 
       RowBox[{"pol", ":", 
        RowBox[{"Except", "[", "_List", "]"}]}]}], "}"}], ",", 
     RowBox[{"spinsys_", "?", "MatrixQ"}]}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "dim", "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"dim", "=", 
        RowBox[{"BasisDimension", "[", 
         RowBox[{"ZeemanBasis", "[", "spinsys", "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"SingletPolarizedDensityOperator", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"j", ",", "k"}], "}"}], ",", "pol"}], "}"}], ",", 
          "spinsys"}], "]"}], "=", 
        RowBox[{"Simplify", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"4", "/", "dim"}], ")"}], 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"1", "/", "4"}], ")"}], 
             RowBox[{"UnityOperator", "[", "]"}]}], "-", " ", 
            RowBox[{"pol", " ", 
             RowBox[{
              RowBox[{"opI", "[", "j", "]"}], ".", 
              RowBox[{"opI", "[", "k", "]"}]}]}]}], ")"}]}], "]"}]}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.674473140492069*^9, 3.674473162440585*^9}, {
  3.674552114758463*^9, 3.674552117557595*^9}, {3.674560086428432*^9, 
  3.6745600970357947`*^9}, {3.674560369421224*^9, 3.674560393832149*^9}, {
  3.674560438876622*^9, 3.674560479502294*^9}, {3.674560680223908*^9, 
