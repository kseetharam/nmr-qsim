Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SingleSpinPolarizedDensityOperator", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"j_", ",", 
       RowBox[{"{", 
        RowBox[{"pol_", ",", "axis_"}], "}"}]}], "}"}], ",", 
     RowBox[{"spinsys_", "?", "MatrixQ"}]}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "dim", "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"dim", "=", 
        RowBox[{"BasisDimension", "[", 
         RowBox[{"ZeemanBasis", "[", "spinsys", "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
