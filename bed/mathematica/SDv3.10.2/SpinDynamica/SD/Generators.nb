Cell[CellGroupData[{

Cell["\<\
evaluation at a particular time, specifying the centre point of the event\
\>", "Subsubsection",
 InitializationCell->True,
 CellChangeTimes->{{3.506931571737793*^9, 3.506931575121702*^9}, {
  3.506931632830904*^9, 3.506931692337262*^9}, {3.506931975370141*^9, 
  3.5069320040755253`*^9}},ExpressionUUID->"728c08dd-bb6e-4853-8977-\
e5e47a798e27"],

Cell["\<\
The TimeDependentGeneratorFunction is evaluated at a general time tval, \
specifying also the centre point of the event. Evaluation only works if the \
relative time variable \[Tau] is referenced to the same centre point, i.e. \
using {{\[Tau],1/2}..} shape specifications.\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.5402816027763996`*^9, 3.540281710143366*^9}, 
   3.816848359921973*^9},ExpressionUUID->"4e760c55-f0cc-4527-977b-\
00fbe29eda58"],

Cell["\<\
very complex syntax is needed to allow the time arguments to be replaced \
inside SparseArrays. This does not work by default.\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.532184693682878*^9, 
  3.532184727212405*^9}},ExpressionUUID->"24b4e468-e872-435b-856f-\
b8c46657089e"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"TimeDependentGeneratorFunction", "[", 
      RowBox[{"t_", ",", 
       RowBox[{"\[Tau]xpairs_", "?", "MatrixQ"}], ",", "T_", ",", "contents_",
        ",", "opts___Rule"}], "]"}], "[", 
     RowBox[{"tval_", ",", "t0_"}], "]"}], "/;", "\[IndentingNewLine]", 
    RowBox[{"(", 
     RowBox[{"And", "@@", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Chop", "[", 
            RowBox[{
             RowBox[{"Last", "[", "#", "]"}], "-", 
             RowBox[{"(", 
              RowBox[{"1", "/", "2"}], ")"}]}], "]"}], "\[Equal]", "0"}], 
          ")"}], "&"}], "/@", "\[Tau]xpairs"}], ")"}]}], ")"}]}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "rules", "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"rules", "=", 
        RowBox[{"Sequence", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"HoldPattern", "[", "t", "]"}], "\[Rule]", "tval"}], ",", 
          RowBox[{"Sequence", "@@", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"First", "[", "#", "]"}], "\[Rule]", 
                RowBox[{"tval", "-", "t0"}]}], ")"}], "&"}], "/@", 
             "\[Tau]xpairs"}], ")"}]}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"ReleaseHold", "@", 
        RowBox[{"ReplaceEverywhere", "[", 
         RowBox[{
          RowBox[{"Hold", "[", "contents", "]"}], ",", "rules"}], "]"}]}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.504201025112627*^9, 3.504201075179572*^9}, {
   3.504201169821226*^9, 3.504201182794263*^9}, {3.50423985162332*^9, 
