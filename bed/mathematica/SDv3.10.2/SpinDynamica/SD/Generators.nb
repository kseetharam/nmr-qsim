Cell[BoxData[
 RowBox[{
  RowBox[{"NonStandardNullGeneratorPattern", "=", 
   RowBox[{"None", "|", "0", "|", 
    RowBox[{"n_", "?", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"MatchQ", "[", 
          RowBox[{"#", ",", 
           RowBox[{"_", "?", "NumericQ"}]}], "]"}], "&&", 
         RowBox[{
          RowBox[{"Chop", "[", 
           RowBox[{"Expand", "[", "#", "]"}], "]"}], "\[Equal]", "0"}]}], 
        ")"}], "&"}], ")"}]}], "|", 
    RowBox[{"NullSuperoperator", "[", "]"}], "|", 
    RowBox[{"HoldPattern", "@", 
     RowBox[{"Function", "[", 
      RowBox[{"___", ",", 
       RowBox[{"0", "|", 
        RowBox[{"n_", "?", 
         RowBox[{"(", 
