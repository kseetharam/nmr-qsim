Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"PeriodicFunction", "::", "usage"}], "=", 
   "\"\<PeriodicFunction[t,T,expression] defines a periodic Hamiltonian or \
Liouvillian with period T. The term expression is a function of the time \
variable t. A periodic function which has been defined through \
func=PeriodicFunction[t,T,expression] may be applied using the syntax func[t] \
to generate the expression as a function of time. The period argument T \
determines when derived propagators may be reused.\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.507025311416098*^9, 3.507025418491522*^9}, {
  3.5070255948990803`*^9, 3.507025623996673*^9}},
 CellLabel->
  "In[190]:=",ExpressionUUID->"e992aa1a-9736-44d9-986e-afee30d950c2"]
}, Closed]],

