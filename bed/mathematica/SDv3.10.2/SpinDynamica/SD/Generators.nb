  RowBox[{
   RowBox[{"StandardizeGenerator", "[", 
    RowBox[{
     RowBox[{"PeriodicFunction", "[", 
      RowBox[{"t_", ",", "T_", ",", "args_"}], "]"}], ",", "opts___Rule"}], 
    "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"tloc", ",", "\[Tau]", ",", "x"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"StandardizeGenerator", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"TimeDependentGeneratorFunction", "[", 
        RowBox[{"tloc", ",", 
         RowBox[{"{", 
