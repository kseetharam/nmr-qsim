\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.531994436831575*^9, 3.531994453501894*^9}, 
   3.816848360044869*^9},ExpressionUUID->"8947ec21-65e7-4e03-b71b-\
f26f1ddc5620"],

Cell["\<\
do not check the OperatorType or SuperoperatorType since this is difficult to \
do for time-dependent expressions\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.53225506963398*^9, 
  3.532255098949807*^9}},ExpressionUUID->"72ede494-6aa5-4ad3-98ad-\
6a5f5fe84ae6"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"StandardizeGenerator", "[", 
    RowBox[{
     RowBox[{"HoldPattern", "@", 
      RowBox[{"TimeDependentGeneratorFunction", "[", 
       RowBox[{"t_", ",", 
        RowBox[{"\[Tau]xpairs_", "?", "MatrixQ"}], ",", "T_", ",", "expr_"}], 
       "]"}]}], ",", "opts___Rule"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Tau]vars", ",", "\[Tau]loc", ",", "\[Tau]locvars", ",", "tloc"}], 
      "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"\[Tau]vars", "=", 
        RowBox[{"First", "/@", "\[Tau]xpairs"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"\[Tau]locvars", "=", 
        RowBox[{"Array", "[", 
         RowBox[{"\[Tau]loc", ",", 
          RowBox[{"Length", "[", "\[Tau]vars", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"TimeDependentGeneratorFunction", "[", 
        RowBox[{"tloc", ",", "\[IndentingNewLine]", 
         RowBox[{"Evaluate", "@", 
          RowBox[{"Transpose", "[", 
           RowBox[{"{", 
            RowBox[{"\[Tau]locvars", ",", 
             RowBox[{"Last", "/@", "\[Tau]xpairs"}]}], "}"}], "]"}]}], ",", 
         "\[IndentingNewLine]", "T", ",", "\[IndentingNewLine]", 
         RowBox[{"Evaluate", "@", 
          RowBox[{"StandardizeGenerator", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"ReleaseHold", "@", 
             RowBox[{"ReplaceEverywhere", "[", 
              RowBox[{
               RowBox[{"Hold", "[", "expr", "]"}], ",", 
               RowBox[{"Join", "[", "\[IndentingNewLine]", 
                RowBox[{
                 RowBox[{"MapThread", "[", 
                  RowBox[{"Rule", ",", 
                   RowBox[{"{", 
                    RowBox[{"\[Tau]vars", ",", "\[Tau]locvars"}], "}"}]}], 
                  "]"}], ",", 
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"HoldPattern", "[", "t", "]"}], "\[Rule]", 
                   "tloc"}], "}"}]}], "]"}]}], "]"}]}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"Evaluate", "@", 
             RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"CheckOperatorType", "\[Rule]", "False"}], ",", 
               "\[IndentingNewLine]", 
               RowBox[{"CheckSuperoperatorType", "\[Rule]", "False"}], ",", 
               "\[IndentingNewLine]", "opts"}], "]"}]}]}], 
           "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", "]"}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.506955309176689*^9, 3.50695532926353*^9}, {
   3.5070099037691917`*^9, 3.5070099078882504`*^9}, {3.507011040978593*^9, 
