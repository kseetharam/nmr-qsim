Cell["\<\
great care is taken below to make sure the \[Tau] variables of the two \
different shape functions do not interfere, even if they were defined using \
the same name.\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.507011783708209*^9, 
  3.507011838406197*^9}},ExpressionUUID->"e3f8acec-9276-4b0f-b862-\
1368d6bd446f"],

Cell["\<\
even more care is needed to protect the time arguments in the case that they \
are defined outside the function\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.540293488245371*^9, 
  3.540293516933378*^9}},ExpressionUUID->"6634a7dc-b88c-4450-b1b5-\
62470d6a9a8c"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"CombineGenerators", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"func1", ":", 
      RowBox[{"HoldPattern", "@", 
       RowBox[{"TimeDependentGeneratorFunction", "[", 
        RowBox[{"t1_", ",", 
         RowBox[{"\[Tau]xpairs1_", "?", "MatrixQ"}], ",", "T1_", ",", 
         "args1_", ",", "opts1___Rule"}], "]"}]}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"func2", ":", 
      RowBox[{"HoldPattern", "@", 
       RowBox[{"TimeDependentGeneratorFunction", "[", 
        RowBox[{"t2_", ",", 
         RowBox[{"\[Tau]xpairs2_", "?", "MatrixQ"}], ",", "T2_", ",", 
         "args2_", ",", "opts2___Rule"}], "]"}]}]}], ",", 
     "\[IndentingNewLine]", "opts___Rule"}], "\[IndentingNewLine]", "]"}], ":=",
    "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "t3", ",", "\[Tau]vars1", ",", "\[Tau]loc1", ",", "\[Tau]locvars1", ",",
        "\[Tau]vars2", ",", "\[Tau]loc2", ",", "\[Tau]locvars2"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"\[Tau]vars1", "=", 
        RowBox[{"First", "/@", "\[Tau]xpairs1"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"\[Tau]locvars1", "=", 
        RowBox[{"Array", "[", 
         RowBox[{"\[Tau]loc1", ",", 
          RowBox[{"Length", "[", "\[Tau]vars1", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"\[Tau]vars2", "=", 
        RowBox[{"First", "/@", "\[Tau]xpairs2"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"\[Tau]locvars2", "=", 
        RowBox[{"Array", "[", 
         RowBox[{"\[Tau]loc2", ",", 
          RowBox[{"Length", "[", "\[Tau]vars2", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"TimeDependentGeneratorFunction", "[", 
        RowBox[{"t3", ",", "\[IndentingNewLine]", 
         RowBox[{"Evaluate", "@", 
          RowBox[{"Join", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"Transpose", "[", 
             RowBox[{"{", 
              RowBox[{"\[Tau]locvars1", ",", 
               RowBox[{"Last", "/@", "\[Tau]xpairs1"}]}], "}"}], "]"}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"Transpose", "[", 
             RowBox[{"{", 
              RowBox[{"\[Tau]locvars2", ",", 
               RowBox[{"Last", "/@", "\[Tau]xpairs2"}]}], "}"}], "]"}]}], 
           "\[IndentingNewLine]", "]"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"Evaluate", "@", 
          RowBox[{"CommonPeriod", "[", 
           RowBox[{"T1", ",", "T2"}], "]"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"Evaluate", "@", "\[IndentingNewLine]", 
          RowBox[{"CombineGenerators", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"ReleaseHold", "@", 
             RowBox[{"ReplaceEverywhere", "[", 
              RowBox[{
               RowBox[{"Hold", "[", "args1", "]"}], ",", 
               RowBox[{"Join", "[", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"HoldPattern", "[", "t1", "]"}], "\[Rule]", "t3"}],
                   "}"}], ",", 
                 RowBox[{"MapThread", "[", 
                  RowBox[{"Rule", ",", 
                   RowBox[{"{", 
                    RowBox[{"\[Tau]vars1", ",", "\[Tau]locvars1"}], "}"}]}], 
                  "]"}]}], "]"}]}], "]"}]}], ",", "\[IndentingNewLine]", 
            RowBox[{"ReleaseHold", "@", 
             RowBox[{"ReplaceEverywhere", "[", 
              RowBox[{
               RowBox[{"Hold", "[", "args2", "]"}], ",", 
               RowBox[{"Join", "[", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"HoldPattern", "[", "t2", "]"}], "\[Rule]", "t3"}],
                   "}"}], ",", 
                 RowBox[{"MapThread", "[", 
                  RowBox[{"Rule", ",", 
                   RowBox[{"{", 
                    RowBox[{"\[Tau]vars2", ",", "\[Tau]locvars2"}], "}"}]}], 
                  "]"}]}], "]"}]}], "]"}]}], ",", "\[IndentingNewLine]", 
            "opts1", ",", "opts2", ",", "opts"}], "\[IndentingNewLine]", 
           "]"}]}]}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
      ")"}]}], "]"}]}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
