               RowBox[{"Expand", "[", "#", "]"}], "]"}], "\[Equal]", "0"}]}], 
            ")"}], "&"}], ")"}]}], "|", "None", "|", 
        RowBox[{"NullOperator", "[", "]"}], "|", 
        RowBox[{"NullSuperoperator", "[", "]"}]}]}], "]"}]}], "|", 
    RowBox[{"HoldPattern", "@", 
     RowBox[{"TimeDependentGeneratorFunction", "[", 
      RowBox[{"___", ",", 
       RowBox[{"0", "|", 
        RowBox[{"n_", "?", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"MatchQ", "[", 
              RowBox[{"#", ",", 
               RowBox[{"_", "?", "NumericQ"}]}], "]"}], "&&", 
             RowBox[{
              RowBox[{"Chop", "[", 
               RowBox[{"Expand", "[", "#", "]"}], "]"}], "\[Equal]", "0"}]}], 
            ")"}], "&"}], ")"}]}], "|", "None", "|", 
        RowBox[{"NullOperator", "[", "]"}], "|", 
        RowBox[{"NullSuperoperator", "[", "]"}]}]}], "]"}]}]}]}], 
  ";"}]], "Input",
