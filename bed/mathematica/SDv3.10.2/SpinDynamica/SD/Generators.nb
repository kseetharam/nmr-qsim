Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"HoldPattern", "@", 
    RowBox[{"CommonPeriod", "[", 
     RowBox[{"a_", ",", 
      RowBox[{"CommonPeriod", "[", 
       RowBox[{"b_", ",", "c_", ",", "opts1___Rule"}], "]"}], ",", 
      "opts2___Rule"}], "]"}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "union", "}"}], ",", 
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{"CommonPeriod", "[", 
        RowBox[{
