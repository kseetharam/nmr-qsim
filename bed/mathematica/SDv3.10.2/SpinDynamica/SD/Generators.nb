c2730da06e0e"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"BackgroundGenerator", "::", "usage"}], "=", 
   "\"\<BackgroundGenerator is an option for Event, NPropagate, Trajectory, \
TransformationAmplitude and other spin dynamical routines. \
BackgroundGenerator may be an operator, a superoperator, a time-dependent \
operator function, or a time-dependent superoperator function. The value of \
BackgroundGenerator is combined with the specified sequence of events to \
create the complete Liouvillian for the dynamic evolution of the system. \
Often BackgroundGenerator is used specify the internal Hamiltonian and/or \
relaxation superoperator, while the sequence of events is used to specify the \
applied pulse sequence, or similar.\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.816353784590524*^9, 3.816353789263376*^9}, {
  3.816353842096684*^9, 3.8163538450013447`*^9}, {3.816353923552806*^9, 
