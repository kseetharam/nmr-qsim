Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"StandardizeGenerator", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"HoldPattern", "@", 
      RowBox[{"Function", "[", 
       RowBox[{"t_", ",", "args_"}], "]"}]}], ",", "opts___Rule"}], "]"}], ":=",
    "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"tloc", ",", "\[Tau]", ",", "x"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"StandardizeGenerator", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"TimeDependentGeneratorFunction", "[", 
        RowBox[{"tloc", ",", 
         RowBox[{"{", 
          RowBox[{"\[Tau]", ",", "x"}], "}"}], ",", "None", ",", 
         "\[IndentingNewLine]", 
         RowBox[{"Evaluate", "@", 
          RowBox[{"ReleaseHold", "@", 
