  3.5663740247546*^9}},ExpressionUUID->"4660458b-ee6f-4848-8e84-306b38604b8d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"PeriodicFunction", "[", 
     RowBox[{"t_", ",", "T_", ",", "contents_"}], "]"}], "/;", 
    RowBox[{"!", 
     RowBox[{"MatchQ", "[", 
      RowBox[{"t", ",", 
       RowBox[{"_Symbol", "|", "_Pattern", "|", "_Blank", "|", 
        RowBox[{"{", 
