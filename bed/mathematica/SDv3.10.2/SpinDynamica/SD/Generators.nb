Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"TimeDependentGeneratorFunction", "[", 
      RowBox[{"t_", ",", 
       RowBox[{"\[Tau]xpairs_", "?", "MatrixQ"}], ",", "T_", ",", "contents_",
        ",", "opts___Rule"}], "]"}], "[", "tval_", "]"}], "/;", 
    RowBox[{"And", "@@", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"FreeQ", "[", 
         RowBox[{"contents", ",", 
          RowBox[{"First", "[", "#", "]"}]}], "]"}], "&"}], "/@", 
       "\[Tau]xpairs"}], ")"}]}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"ReleaseHold", "@", 
    RowBox[{"ReplaceEverywhere", "[", 
     RowBox[{
      RowBox[{"Hold", "[", "contents", "]"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"HoldPattern", "[", "t", "]"}], "\[Rule]", "tval"}], "}"}]}], 
     "]"}]}]}], ";"}]], "Input",
 InitializationCell->True,
