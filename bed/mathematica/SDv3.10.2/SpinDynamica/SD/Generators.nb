Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"PermittedTimeShift", "::", "usage"}], "=", 
   "\"\<PermittedTimeShift is property of a generator or event used \
internally by SpinDynamica. It specifies the time shift through which a \
generator or event may be translated while still retaining the same effect. \
It may have the values None, All, or take a numerical value. \>\""}], 
  ";"}]], "Input",
 InitializationCell->True,
