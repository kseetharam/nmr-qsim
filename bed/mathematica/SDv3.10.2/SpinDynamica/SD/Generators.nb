Cell[CellGroupData[{

Cell["operator", "Subsubsection",
 InitializationCell->True,
 CellChangeTimes->{{3.58341649466994*^9, 
  3.583416518658838*^9}},ExpressionUUID->"d7db4805-e466-4c24-bbde-\
f4bfc2f7bdf0"],

Cell["\<\
Hermitian operators are converted to CommutationSuperoperators\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.583420231986434*^9, 3.583420263610317*^9}, {
  3.586348664662888*^9, 
  3.5863486654753513`*^9}},ExpressionUUID->"333a989e-0b91-4f67-a73e-\
79182e5bc74a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Liouvillian", "[", 
     RowBox[{
      RowBox[{"op_", "?", "OperatorQ"}], ",", "opts___Rule"}], "]"}], "/;", 
    RowBox[{"!", 
     RowBox[{"MatchQ", "[", 
      RowBox[{"op", ",", "_Operator"}], "]"}]}]}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Liouvillian", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Operator", "[", 
      RowBox[{"op", ",", "\[IndentingNewLine]", 
       RowBox[{"Sequence", "@@", 
        RowBox[{"FilterRules", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Join", "[", 
           RowBox[{
            RowBox[{"{", "opts", "}"}], ",", 
            RowBox[{"Options", "[", "Liouvillian", "]"}]}], "]"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"Options", "[", "Operator", "]"}]}], "\[IndentingNewLine]", 
         "]"}]}], ",", "\[IndentingNewLine]", "opts"}], "\[IndentingNewLine]",
       "]"}], ",", "\[IndentingNewLine]", "opts"}], "\[IndentingNewLine]", 
    "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.583416538380761*^9, 3.58341656170991*^9}, {
  3.5834166067447643`*^9, 3.583416684883268*^9}, {3.618481056363311*^9, 
  3.618481119207583*^9}},
 CellLabel->
  "In[330]:=",ExpressionUUID->"ace9f130-2bea-44c5-a969-d716eb62398d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Liouvillian", "[", 
     RowBox[{"op_Operator", ",", "opts___Rule"}], "]"}], "/;", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"CheckOperatorType", "/.", 
        RowBox[{"{", "opts", "}"}]}], "/.", 
       RowBox[{"Options", "[", "Liouvillian", "]"}]}], ")"}], "&&", 
     RowBox[{"!", 
      RowBox[{"MatchQ", "[", 
       RowBox[{
        RowBox[{"OperatorType", "[", "op", "]"}], ",", "\"\<Hermitian\>\""}], 
       "]"}]}]}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"Message", "[", 
      RowBox[{"Liouvillian", "::", "notherm"}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Liouvillian", "[", 
      RowBox[{"op", ",", "\[IndentingNewLine]", 
       RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"CheckOperatorType", "\[Rule]", "False"}], ",", 
         "\[IndentingNewLine]", "opts"}], "\[IndentingNewLine]", "]"}]}], 
      "\[IndentingNewLine]", "]"}]}], ")"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.583416577089482*^9, 3.583416585575935*^9}, {
  3.583416693141233*^9, 3.583416808784371*^9}},
 CellLabel->
  "In[331]:=",ExpressionUUID->"f8468269-01f3-4f16-927f-5f75ba56fead"],

Cell["\<\
Diagonalized Hermitian Operators are handled separately, since the syntax \
below also multiplies the eigenvectors with -I. \
\>", "Text",
 CellChangeTimes->{{3.702779323299447*^9, 
  3.7027793576098404`*^9}},ExpressionUUID->"19e72164-7bc0-4651-90e2-\
cc2c22d82fd0"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Liouvillian", "[", 
    RowBox[{
     RowBox[{"O", ":", 
      RowBox[{"Operator", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"X_", "?", "MatrixQ"}], ",", "evals_List", ",", 
          RowBox[{"Xinv_", "?", "MatrixQ"}]}], "}"}], ",", "basis_", ",", 
        "opopts___Rule"}], "]"}]}], ",", "opts___Rule"}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"CommutationSuperoperator", "[", 
    RowBox[{
     RowBox[{"Operator", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"X", ",", 
         RowBox[{
          RowBox[{"-", "I"}], "*", "evals"}], ",", "Xinv"}], "}"}], ",", 
       "basis", ",", 
       RowBox[{"SimplifyRules", "[", 
        RowBox[{
         RowBox[{"OperatorType", "\[Rule]", "\"\<AntiHermitian\>\""}], ",", 
         "opopts"}], "]"}]}], "]"}], ",", 
     RowBox[{"Assumptions", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"OperatorType", "\[Rule]", "\"\<AntiHermitian\>\""}], 
       "}"}]}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.583416891110242*^9, 3.583416918502946*^9}, {
  3.583416979164467*^9, 3.5834170031085243`*^9}, {3.58342030672007*^9, 
  3.583420324578837*^9}, {3.583420606507799*^9, 3.583420611698975*^9}, {
  3.583427659589483*^9, 3.583427664889503*^9}, {3.586350456053128*^9, 
  3.586350482614327*^9}, {3.586351694892619*^9, 3.586351701602371*^9}, {
  3.681125484866974*^9, 3.681125487549016*^9}, {3.702778549797307*^9, 
  3.702778565005114*^9}, {3.702778752816878*^9, 3.7027787610797243`*^9}, {
  3.7027788034718637`*^9, 3.702778858637084*^9}, {3.7027789389752026`*^9, 
  3.7027789481637354`*^9}, {3.702778979173782*^9, 3.7027790846117754`*^9}, {
  3.702779193206955*^9, 3.7027792120764*^9}},
 CellLabel->
  "In[332]:=",ExpressionUUID->"68e5db92-3ea6-4afa-8a07-e101f1ff0fc4"],

Cell["\<\
Convert the final operator into a CommutationSuperoperator, diagonalize the \
operator, and flag up the assumed OperatorType for a subsequent NDiagonalize \
routine.\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.586351765290638*^9, 3.586351804872655*^9}, {
  3.586352255081066*^9, 3.586352256316391*^9}, {3.58635239955364*^9, 
  3.58635240323244*^9}, {3.681125477511009*^9, 
  3.681125481671279*^9}},ExpressionUUID->"f945b6f5-bd3f-4d17-ac8d-\
c7d8323b1515"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Liouvillian", "[", 
    RowBox[{"op_Operator", ",", "opts___Rule"}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"CommutationSuperoperator", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "I"}], " ", "op"}], ",", 
     RowBox[{"Assumptions", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"OperatorType", "\[Rule]", "\"\<AntiHermitian\>\""}], 
       "}"}]}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.583416891110242*^9, 3.583416918502946*^9}, {
  3.583416979164467*^9, 3.5834170031085243`*^9}, {3.58342030672007*^9, 
