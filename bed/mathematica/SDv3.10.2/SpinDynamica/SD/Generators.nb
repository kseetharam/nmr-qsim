   3.455259235841276*^9}, {3.464689355678136*^9, 3.464689360101637*^9}, 
   3.506862496155789*^9, {3.5068637961702957`*^9, 3.506863799318846*^9}, {
   3.798559046237907*^9, 3.798559054346725*^9}, 3.816848457612276*^9},
 AspectRatioFixed->
  True,ExpressionUUID->"7713ada2-0eb4-4b84-b442-aabdbecdb920"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"TimeDependentGeneratorFunction", "::", "usage"}], "=", 
   "\"\<TimeDependentGeneratorFunction[t,{\[Tau],x},T,expression] defines a \
time-dependent Hamiltonian or Liouvillian which depends on an absolute time \
variable t and also a relative time variable \[Tau] which is taken relative \
to the event in which the TimeDependentGeneratorFunction is used. The \
variable x is used to specify the time origin of the relative time variable \
\[Tau]. For example x=0 specifies that the time origin is the start of the \
event; x=1 indicates a time origin at the end of the event, and x=1/2 \
indicates a time origin at the middle of the event.  The period argument T \
determines when derived propagators may be reused. A \
TimeDependentGeneratorFunction defined through \
func=TimeDependentGeneratorFunction[t,{\[Tau],x},T,expression] may be \
evaluated at any time during an event that starts at time point ta and ends \
at time point tb using the syntax func[t,ta,tb]. A \
TimeDependentGeneratorFunction may employ multiple relative time variables by \
using the syntax \
TimeDependentGeneratorFunction[t,{{\[Tau]1,x1},{\[Tau]2,x2}..},T,expression].\
\n\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.507025311416098*^9, 3.507025678778759*^9}, {
  3.534738944779448*^9, 3.534739006674241*^9}, {3.564574969700929*^9, 
  3.564574975191656*^9}, {3.816848359815848*^9, 
  3.816848359821507*^9}},ExpressionUUID->"83eaa67e-4e1e-4781-b9ed-\
b2f78a82b582"]
}, Closed]]
}, Closed]],

Cell[CellGroupData[{

Cell["BackgroundGenerator", "Section",
 InitializationCell->True,
 CellChangeTimes->{{3.683186944493711*^9, 3.683186950334387*^9}, {
   3.6831870082461457`*^9, 3.68318701531157*^9}, 3.690555289160674*^9, 
