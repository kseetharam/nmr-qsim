Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Secularize", "[", 
    RowBox[{
     RowBox[{"sop_", "?", "SuperoperatorQ"}], ",", 
     RowBox[{"spinsets", ":", 
      RowBox[{"{", 
       RowBox[{"_List", ".."}], "}"}]}]}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"includedspins", ",", "missingspins"}], "}"}], ",", 
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{"Secularize", "[", 
        RowBox[{"sop", ",", 
         RowBox[{"Append", "[", 
          RowBox[{"spinsets", ",", "missingspins"}], "]"}]}], "]"}], 
       "\[IndentingNewLine]", ")"}], "/;", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"includedspins", "=", 
         RowBox[{"Union", "@@", "spinsets"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"missingspins", "=", 
         RowBox[{"Complement", "[", 
          RowBox[{
           RowBox[{"First", "/@", 
            RowBox[{"SpinSystem", "[", "]"}]}], ",", "includedspins"}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"!", 
         RowBox[{"MatchQ", "[", 
          RowBox[{"missingspins", ",", 
           RowBox[{"{", "}"}]}], "]"}]}]}], "\[IndentingNewLine]", ")"}]}]}], 
    "]"}]}], ";"}]], "Input",
