Cell[CellGroupData[{

Cell["calculate & memorize SecularizationMatrix", "Subsubsection",
 InitializationCell->True,
 CellChangeTimes->{{3.63057044027773*^9, 3.630570467740078*^9}, {
  3.630572241872452*^9, 3.630572259238188*^9}, {3.630572424246961*^9, 
