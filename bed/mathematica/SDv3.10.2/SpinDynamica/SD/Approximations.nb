Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SecularizationMatrix", "[", 
    RowBox[{
     RowBox[{"spinsets", ":", 
      RowBox[{"{", 
       RowBox[{"_List", ".."}], "}"}]}], ",", "zb_ZeemanBasis"}], "]"}], ":=",
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"SecularizationMatrix", "[", 
     RowBox[{"spinsets", ",", "zb"}], "]"}], "=", "\[IndentingNewLine]", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"Mvals", ",", "n"}], "}"}], ",", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Mvals", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"MagneticQuantumNumber", "[", 
            RowBox[{"#", ",", "spinsets"}], "]"}], "&"}], "/@", 
          RowBox[{"BasisKets", "[", "zb", "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"n", "=", 
         RowBox[{"BasisDimension", "[", "zb", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"SparseArray", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"{", 
              RowBox[{"i_", ",", "j_"}], "}"}], "/;", 
             RowBox[{
              RowBox[{
              "Mvals", "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}],
               "\[Equal]", 
              RowBox[{
              "Mvals", "\[LeftDoubleBracket]", "j", 
               "\[RightDoubleBracket]"}]}]}], "\[Rule]", "1"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"n", ",", "n"}], "}"}]}], "]"}]}], "\[IndentingNewLine]", 
