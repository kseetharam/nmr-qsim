Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Secularize", "::", "usage"}], "=", "\[IndentingNewLine]", 
   "\"\<Secularize[op,args] implements secularization of an operator, meaning \
the removal of terms that are non-secular with respect to a particular \
Hamiltonian.\nThe syntax Secularize[op,H0] secularizes the operator op with \
respect to the Hamiltonian H0. This removes all off-diagonal terms in op, \
when expressed in the eigenbasis of H0, unless the off-diagonal terms connect \
degenerate eigenvalues of H0. The syntax Secularize[op,H0,threshold] only \
removes off-diagonal terms if the corresponding eigenvalues differ by more \
than the numerical threshold.    \nThe syntax \
Secularize[op,{spins1,spins2..}] secularizes with respect to a Zeeman \
Hamiltonian in which the sets of spins belong to different isotopic types. If \
only one list of spins is present, the routine assumes a homonuclear system. \
\nThe syntax Secularize[sop,{spins1,spins2..}] secularizes a superoperator \
sop with respect to a Zeeman Hamiltonian in which the sets of spins \
{spins1,spins2..} belong to different isotopic types. Secularization of a \
superoperator implies deletion of all matrix elements connecting different \
sets of coherence orders for the specified spins.\n\>\""}], ";"}]], "Input",
 PageWidth->WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.430893998221677*^9, 3.430894014980308*^9}, {
  3.434525590977869*^9, 3.434525626453712*^9}, {3.447227127127363*^9, 
  3.447227169088076*^9}, {3.44722770952263*^9, 3.447227715456723*^9}, {
  3.447343237954089*^9, 3.447343296828744*^9}, {3.630568838688796*^9, 
  3.63056928668631*^9}, {3.681103094367158*^9, 3.681103121884204*^9}},
 CellLabel->"In[16]:=",ExpressionUUID->"3f62f89a-3c02-468b-b204-f1184513bbe4"]
}, Closed]]
}, Closed]]
}, Closed]],

