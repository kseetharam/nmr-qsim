Cell["\<\
secularize the operator by transforming into the eigenbasis of H0, deleting \
elements connecting eigenvalues which differ by more than the specified \
threshold, and transform back:\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.6305754566295233`*^9, 
  3.6305754951486683`*^9}},ExpressionUUID->"38442d74-fe10-4e18-b702-\
c956761d9159"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Secularize", "[", 
    RowBox[{"op_Operator", ",", 
     RowBox[{"H0", ":", 
      RowBox[{"Operator", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Xmat_", "?", "NumericMatrixQ"}], ",", "evals_List", ",", 
          RowBox[{"Xinvmat_", "?", "NumericMatrixQ"}]}], "}"}], ",", "basis_",
         ",", "opts___Rule"}], "]"}]}], ",", 
     RowBox[{"thresh_", "?", "NumericQ"}]}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"opmatinH0eb", ",", "secmat", ",", "n"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"opmatinH0eb", "=", 
        RowBox[{"Xinvmat", ".", 
         RowBox[{"MatrixRepresentation", "[", 
          RowBox[{"op", ",", "basis"}], "]"}], ".", "Xmat"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"n", "=", 
        RowBox[{"Length", "[", "evals", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"secmat", "=", 
        RowBox[{"SparseArray", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"{", 
              RowBox[{"i_", ",", "j_"}], "}"}], "/;", 
             RowBox[{
              RowBox[{"Abs", "[", 
               RowBox[{
                RowBox[{
                "evals", "\[LeftDoubleBracket]", "i", 
                 "\[RightDoubleBracket]"}], "-", 
                RowBox[{
                "evals", "\[LeftDoubleBracket]", "j", 
                 "\[RightDoubleBracket]"}]}], "]"}], "\[LessEqual]", 
              "thresh"}]}], "\[Rule]", "1"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"n", ",", "n"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Operator", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"SparseArray", "[", 
          RowBox[{"Xmat", ".", 
           RowBox[{"(", 
            RowBox[{"opmatinH0eb", "*", "secmat"}], ")"}], ".", "Xinvmat"}], 
          "]"}], ",", "\[IndentingNewLine]", "basis", ",", 
         "\[IndentingNewLine]", "opts"}], "\[IndentingNewLine]", "]"}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.630573696245317*^9, 3.630573738855513*^9}, {
  3.630573802254353*^9, 3.6305739832676287`*^9}, {3.630574062462582*^9, 
  3.630574068937928*^9}, {3.630574515857189*^9, 3.630574824204751*^9}, {
  3.630574861158437*^9, 3.63057489877102*^9}, {3.6305750960752*^9, 
  3.630575098230262*^9}, {3.630575403154128*^9, 3.630575447955853*^9}},
 CellLabel->"In[49]:=",ExpressionUUID->"eda9993a-7662-4e34-8d4d-49ed5da09777"]
}, Closed]]
}, Closed]],

