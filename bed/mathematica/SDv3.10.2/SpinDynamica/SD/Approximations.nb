  3.631449424524742*^9}},ExpressionUUID->"387e4ba0-aec2-4a98-bac5-\
fcd866222d1a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SecularizationMatrix", "[", 
    RowBox[{
     RowBox[{"spinsets", ":", 
      RowBox[{"{", 
       RowBox[{"_List", ".."}], "}"}]}], ",", 
     RowBox[{"zsecopbasis", ":", 
      RowBox[{"(", 
       RowBox[{
       "_ZeemanKetBraOperatorBasis", "|", "_ShiftAndZOperatorBasis", "|", 
        "_ShiftAndPolarizationOperatorBasis"}], ")"}]}]}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"SecularizationMatrix", "[", 
     RowBox[{"spinsets", ",", "zsecopbasis"}], "]"}], "=", 
    "\[IndentingNewLine]", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"pvals", ",", "n"}], "}"}], ",", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"pvals", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"CoherenceOrder", "[", 
            RowBox[{"spinsets", ",", "#"}], "]"}], "&"}], "/@", 
          RowBox[{"BasisOperators", "[", "zsecopbasis", "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"n", "=", 
         RowBox[{"OperatorBasisDimension", "[", "zsecopbasis", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"SparseArray", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"{", 
              RowBox[{"i_", ",", "j_"}], "}"}], "/;", 
             RowBox[{
              RowBox[{
              "pvals", "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}],
               "\[Equal]", 
              RowBox[{
              "pvals", "\[LeftDoubleBracket]", "j", 
               "\[RightDoubleBracket]"}]}]}], "\[Rule]", "1"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"n", ",", "n"}], "}"}]}], "]"}]}], "\[IndentingNewLine]", 
       ")"}]}], "]"}]}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.630572929394086*^9, 3.630573091334279*^9}, {
   3.630577148193748*^9, 3.630577153814825*^9}, {3.630577687822699*^9, 
   3.630577727089981*^9}, {3.630578489257731*^9, 3.6305785042080507`*^9}, {
