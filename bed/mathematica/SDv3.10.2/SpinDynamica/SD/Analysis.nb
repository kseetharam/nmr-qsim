Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"CorrelatedEigensystems", "[", 
    RowBox[{"Q_", ",", 
     RowBox[{"specs", ":", 
      RowBox[{"{", 
       RowBox[{"par_", ",", "xa_", ",", "xb_", ",", 
        RowBox[{"{", "nx_Integer", "}"}]}], "}"}]}], ",", "opts___Rule", ",", 
     "type_", ",", 
     RowBox[{"{", 
      RowBox[{"\"\<1\>\"", ",", "\"\<4\>\""}], "}"}]}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"TrueQ", "[", 
      RowBox[{"nx", "\[GreaterEqual]", "2"}], "]"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"CorrelatedEigensystems", "[", 
      RowBox[{"Q", ",", 
       RowBox[{"{", 
        RowBox[{"par", ",", "xa", ",", "xb", ",", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"xb", "-", "xa"}], ")"}], "/", 
          RowBox[{"(", 
           RowBox[{"nx", "-", "1"}], ")"}]}]}], "}"}], ",", "opts", ",", 
       "type", ",", 
       RowBox[{"{", 
        RowBox[{"\"\<1\>\"", ",", "\"\<4\>\""}], "}"}]}], "]"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Message", "[", 
        RowBox[{"CorrelatedEigensystems", "::", "badnx"}], "]"}], ";", 
       "$Failed"}], ")"}]}], "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.816356133128089*^9, 3.816356270322*^9}, {
