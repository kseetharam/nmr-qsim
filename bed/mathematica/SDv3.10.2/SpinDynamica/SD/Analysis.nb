Cell[BoxData[
 RowBox[{
  RowBox[{"CorrelatedEigensystems", "[", 
   RowBox[{"Qmat_", ",", 
    RowBox[{"specs", ":", 
     RowBox[{"{", 
      RowBox[{"par_", ",", "vals_"}], "}"}]}], ",", "opts___Rule", 
    ",", "\"\<Superoperator\>\"", ",", 
    RowBox[{"{", 
     RowBox[{"\"\<2\>\"", ",", "\"\<1\>\""}], "}"}]}], "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "bgmat", ",", "backg", ",", "opbasis", ",", "dim", ",", "\[Phi]", ",", 
      "dummybasis", ",", "basisrules", ",", "ev", ",", "vecs"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"backg", "=", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"BackgroundGenerator", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "CorrelatedEigensystems", "]"}]}], ")"}], "/.", 
       RowBox[{"None", "\[Rule]", 
        RowBox[{"NullSuperoperator", "[", "]"}]}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"opbasis", "=", 
      RowBox[{
       RowBox[{"OperatorBasis", "/.", 
        RowBox[{"{", "opts", "}"}]}], "/.", 
       RowBox[{"Options", "[", "CorrelatedEigensystems", "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"bgmat", "=", 
      RowBox[{"SuperoperatorMatrixRepresentation", "[", 
       RowBox[{"backg", ",", "opbasis"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"dim", "=", 
      RowBox[{"OperatorBasisDimension", "[", "opbasis", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"dummybasis", "=", 
      RowBox[{"Array", "[", 
       RowBox[{"\[Phi]", ",", "dim"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"basisrules", "=", 
      RowBox[{"Thread", "[", 
       RowBox[{"dummybasis", "\[Rule]", 
        RowBox[{"BasisOperators", "[", "opbasis", "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"ev", ",", "vecs"}], "}"}], "=", 
      RowBox[{"CorrelatedEigensystems", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"Chop", "@", 
            RowBox[{"N", "@", 
             RowBox[{"ReplaceEverywhere", "[", 
              RowBox[{
               RowBox[{"Qmat", "+", "bgmat"}], ",", 
               RowBox[{"{", 
                RowBox[{"par", "\[Rule]", " ", "#"}], "}"}]}], "]"}]}]}], 
           "&"}], "/@", "vals"}], ")"}], ",", "opts", ",", 
        RowBox[{"{", 
         RowBox[{"\"\<2\>\"", ",", "\"\<2\>\""}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"Evaluate", "@", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"ReturnDetailedEigensystem", "/.", 
           RowBox[{"{", "opts", "}"}]}], "/.", 
          RowBox[{"Options", "[", "CorrelatedEigensystems", "]"}]}], ")"}]}], 
       ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Map", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Transpose", "[", 
             RowBox[{"{", 
              RowBox[{"vals", ",", 
               RowBox[{"ev", "\[LeftDoubleBracket]", 
                RowBox[{"All", ",", "#"}], "\[RightDoubleBracket]"}]}], "}"}],
              "]"}], "&"}], ",", 
           RowBox[{"Range", "[", "dim", "]"}]}], "]"}], ",", 
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{"vals", ",", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"Map", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{
                  RowBox[{"Conjugate", "[", "#1", "]"}], ".", "dummybasis"}], 
                 "&"}], ",", "vecs"}], "]"}], ")"}], "/.", "basisrules"}]}], 
           "}"}], "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"ev", ",", "vecs"}], "}"}]}], "]"}]}]}], 
