Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"TransformationAmplitudeBounds", "[", 
      RowBox[{
       RowBox[{"op_", "?", "OperatorQ"}], ",", "opbasis_", ",", "basis_", ",",
        "opts___Rule"}], "]"}], "[", 
     RowBox[{"\[Rho]ini_", "?", "OperatorQ"}], "]"}], "/;", 
    RowBox[{"NumericQ", "[", 
     RowBox[{
      RowBox[{"NormalizationFactor", "/.", 
       RowBox[{"{", "opts", "}"}]}], "/.", 
      RowBox[{"Options", "[", "TransformationAmplitudeBounds", "]"}]}], 
     "]"}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "norm", ",", "\[CapitalLambda]\[Rho]", ",", "\[CapitalLambda]op"}], 
      "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"norm", "=", 
        RowBox[{
         RowBox[{"NormalizationFactor", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "TransformationAmplitudeBounds", "]"}]}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"\[CapitalLambda]\[Rho]", "=", 
        RowBox[{"SortBy", "[", 
         RowBox[{
          RowBox[{"Eigenvalues", "[", 
           RowBox[{"MatrixRepresentation", "[", 
            RowBox[{"\[Rho]ini", ",", "basis"}], "]"}], "]"}], ",", "N"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"\[CapitalLambda]op", "=", 
        RowBox[{"SortBy", "[", 
         RowBox[{
          RowBox[{"Eigenvalues", "[", 
           RowBox[{"MatrixRepresentation", "[", 
            RowBox[{"op", ",", "basis"}], "]"}], "]"}], ",", "N"}], "]"}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"\[CapitalLambda]\[Rho]", ".", 
           RowBox[{"Reverse", "[", "\[CapitalLambda]op", "]"}]}], "/", 
          RowBox[{"(", 
           RowBox[{"norm", "\[Times]", 
            RowBox[{"\[CapitalLambda]op", ".", "\[CapitalLambda]op"}]}], 
           ")"}]}], ",", 
         RowBox[{
          RowBox[{"\[CapitalLambda]\[Rho]", ".", "\[CapitalLambda]op"}], "/", 
          
          RowBox[{"(", 
           RowBox[{"norm", "\[Times]", 
            RowBox[{"\[CapitalLambda]op", ".", "\[CapitalLambda]op"}]}], 
           ")"}]}]}], "}"}]}], "\[IndentingNewLine]", ")"}]}], "]"}]}], 
  ";"}]], "Input",
