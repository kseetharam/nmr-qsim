         RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"len", "=", 
         RowBox[{"Length", "[", "Qmats", "]"}]}], ";", "\[IndentingNewLine]", 
        
        RowBox[{"range", "=", 
         RowBox[{"Range", "[", 
          RowBox[{"len", "-", "1"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"dim", "=", 
         RowBox[{
          RowBox[{"Dimensions", "[", 
           RowBox[{"First", "[", "Qmats", "]"}], "]"}], "\[LeftDoubleBracket]",
           "1", "\[RightDoubleBracket]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"eigensystems", "=", 
         RowBox[{"Chop", "[", 
          RowBox[{"Eigensystem", "/@", 
           RowBox[{"(", "Qmats", ")"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"evals", "=", 
         RowBox[{"eigensystems", "\[LeftDoubleBracket]", 
          RowBox[{"All", ",", "1"}], "\[RightDoubleBracket]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"evecs", "=", 
         RowBox[{"SparseArray", "[", 
          RowBox[{"Chop", "[", 
           RowBox[{"eigensystems", "\[LeftDoubleBracket]", 
            RowBox[{"All", ",", "2"}], "\[RightDoubleBracket]"}], "]"}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"ambstatus", "=", "False"}], ";", "\[IndentingNewLine]", 
        RowBox[{"correlatedevals", "=", 
