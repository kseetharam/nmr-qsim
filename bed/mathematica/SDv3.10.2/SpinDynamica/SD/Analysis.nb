cdebce14c2d3"]
}, Closed]],

Cell[CellGroupData[{

Cell["the parameter increment is specified; adjust \[Delta]x if necessary", \
"Subsubsection",
 InitializationCell->True,
 CellChangeTimes->{{3.713866875687424*^9, 3.7138668809750795`*^9}, {
  3.7138670514138145`*^9, 3.7138670537728615`*^9}, {3.7138674864137077`*^9, 
  3.713867499393965*^9}, {3.713867699793987*^9, 3.713867705062609*^9}, {
  3.714128562718525*^9, 3.714128568884088*^9}, {3.8163560929086733`*^9, 
  3.8163561001313*^9}},ExpressionUUID->"7745b3a4-4e77-46ae-af02-a791b617a5c8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"CorrelatedEigensystems", "[", 
   RowBox[{"Q_", ",", 
    RowBox[{"specs", ":", 
     RowBox[{"{", 
      RowBox[{"par_", ",", "xa_", ",", "xb_", ",", "\[Delta]x_"}], "}"}]}], ",",
     "opts___Rule", ",", "type_", ",", 
    RowBox[{"{", 
     RowBox[{"\"\<1\>\"", ",", "\"\<4\>\""}], "}"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"new\[Delta]x", ",", "Napprox", ",", "NapproxIP"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Napprox", "=", 
      RowBox[{"N", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"xb", "-", "xa"}], ")"}], "/", "\[Delta]x"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"NapproxIP", "=", 
      RowBox[{"N", "[", 
       RowBox[{"IntegerPart", "[", "Napprox", "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"NapproxIP", "\[Equal]", "Napprox"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"CorrelatedEigensystems", "[", 
        RowBox[{"Q", ",", 
         RowBox[{"{", 
          RowBox[{"par", ",", 
           RowBox[{"Range", "[", 
            RowBox[{"xa", ",", "xb", ",", "\[Delta]x"}], "]"}]}], "}"}], ",", 
         "opts", ",", "type", ",", 
         RowBox[{"{", 
          RowBox[{"\"\<1\>\"", ",", "\"\<5\>\""}], "}"}]}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"new\[Delta]x", "=", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"xb", "-", "xa"}], ")"}], "/", 
          RowBox[{"(", 
           RowBox[{"NapproxIP", "+", "1"}], ")"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Message", "[", 
         RowBox[{
          RowBox[{"CorrelatedEigensystems", "::", "\[Delta]xadj"}], ",", 
          RowBox[{"new\[Delta]x", "//", "EngineeringForm"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"CorrelatedEigensystems", "[", 
         RowBox[{"Q", ",", 
          RowBox[{"{", 
           RowBox[{"par", ",", 
            RowBox[{"Range", "[", 
             RowBox[{"xa", ",", "xb", ",", "new\[Delta]x"}], "]"}]}], "}"}], ",",
           "opts", ",", "type", ",", 
          RowBox[{"{", 
           RowBox[{"\"\<1\>\"", ",", "\"\<5\>\""}], "}"}]}], "]"}]}]}], 
      "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.714128637517984*^9, 3.7141289035060825`*^9}, {
   3.714137576598336*^9, 3.714137591681924*^9}, {3.714138666298357*^9, 
