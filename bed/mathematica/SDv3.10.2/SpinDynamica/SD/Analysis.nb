Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"TransformationAmplitudeBounds", "::", "usage"}], 
   "=", "\"\<TransformationAmplitudeBounds[\[Rho]ini\[Rule]obs] generates the \
bounds {min,max} on the possible amplitude for transformation of an initial \
density operator \[Rho]ini into an observable obs. \
MaximumTransformationAmplitude[\[Rho]ini\[Rule]{op1,op2..}] generates a set \
of transformation amplitude bounds.\>\""}], ";"}]], "Input",
