0c2428e16901"],

Cell[BoxData[
 RowBox[{
  RowBox[{"CorrelatedEigensystems", "[", 
   RowBox[{"Qmat_", ",", 
    RowBox[{"specs", ":", 
     RowBox[{"{", 
      RowBox[{"par_", ",", "vals_"}], "}"}]}], ",", "opts___Rule", 
    ",", "\"\<Operator\>\"", ",", 
    RowBox[{"{", 
     RowBox[{"\"\<2\>\"", ",", "\"\<1\>\""}], "}"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "bgmat", ",", "backg", ",", "basis", ",", "dummybasis", ",", 
      "basisrules", ",", "ev", ",", "vecs", ",", "\[Phi]", ",", "dim"}], 
     "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"backg", "=", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"BackgroundGenerator", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "CorrelatedEigensystems", "]"}]}], ")"}], "/.", 
       RowBox[{"None", "\[Rule]", 
        RowBox[{"NullOperator", "[", "]"}]}]}]}], ";", "\[IndentingNewLine]", 
     
     RowBox[{"basis", "=", 
      RowBox[{
       RowBox[{"Basis", "/.", 
        RowBox[{"{", "opts", "}"}]}], "/.", 
       RowBox[{"Options", "[", "CorrelatedEigensystems", "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"bgmat", "=", 
      RowBox[{"MatrixRepresentation", "[", 
       RowBox[{"backg", ",", "basis"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"dim", "=", 
      RowBox[{"BasisDimension", "[", "basis", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"dummybasis", "=", 
      RowBox[{"Array", "[", 
       RowBox[{"\[Phi]", ",", "dim"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"basisrules", "=", 
      RowBox[{"Thread", "[", 
       RowBox[{"dummybasis", "\[Rule]", " ", 
        RowBox[{"BasisKets", "[", "basis", "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"ev", ",", "vecs"}], "}"}], "=", 
      RowBox[{"CorrelatedEigensystems", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"Chop", "@", 
            RowBox[{"N", "@", 
             RowBox[{"ReplaceEverywhere", "[", 
              RowBox[{
               RowBox[{"Qmat", "+", "bgmat"}], ",", 
               RowBox[{"{", 
                RowBox[{"par", "\[Rule]", " ", "#"}], "}"}]}], "]"}]}]}], 
           "&"}], "/@", "vals"}], ")"}], ",", "opts", ",", 
        RowBox[{"{", 
         RowBox[{"\"\<2\>\"", ",", "\"\<2\>\""}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"Evaluate", "@", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"ReturnDetailedEigensystem", "/.", 
           RowBox[{"{", "opts", "}"}]}], "/.", 
          RowBox[{"Options", "[", "CorrelatedEigensystems", "]"}]}], ")"}]}], 
       ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Map", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Transpose", "[", 
             RowBox[{"{", 
              RowBox[{"vals", ",", 
               RowBox[{"ev", "\[LeftDoubleBracket]", 
                RowBox[{"All", ",", "#"}], "\[RightDoubleBracket]"}]}], "}"}],
              "]"}], "&"}], ",", 
           RowBox[{"Range", "[", "dim", "]"}]}], "]"}], ",", 
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{"vals", ",", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"Map", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{
                  RowBox[{"Conjugate", "[", "#1", "]"}], ".", "dummybasis"}], 
                 "&"}], ",", "vecs"}], "]"}], ")"}], "/.", "basisrules"}]}], 
           "}"}], "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"ev", ",", "vecs"}], "}"}]}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.7138689449642863`*^9, 3.713868951051857*^9}, {
