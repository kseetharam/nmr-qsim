Cell["Correlated Eigensystems", "Section",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{
  3.605545643975979*^9, {3.68259769518991*^9, 3.682597702185166*^9}, {
   3.719572750127195*^9, 3.7195727598988004`*^9}, {3.71978042623323*^9, 
