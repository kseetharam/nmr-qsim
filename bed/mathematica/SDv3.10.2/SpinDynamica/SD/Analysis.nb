     "dim", ",", "len", ",", "pos", ",", "range", ",", "eigensystems", ",", 
      "evecs", ",", "evals", ",", "ambstatus", ",", "auxfunc", ",", 
      "correlatedevals", ",", "correlatedevecs", ",", "temp", ",", 
      "dvalsdot"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Unprotect", "[", "Dot", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"dvalsdot", "=", 
      RowBox[{"DownValues", "[", "Dot", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"CheckAbort", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{
