      RowBox[{"ReplaceEverywhere", "[", 
       RowBox[{"Q", ",", 
        RowBox[{"{", 
         RowBox[{"par", "\[Rule]", " ", 
          RowBox[{"First", "[", "vals", "]"}]}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"MatrixQ", "[", 
