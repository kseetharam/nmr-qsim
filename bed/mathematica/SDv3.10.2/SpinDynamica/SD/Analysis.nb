   RowBox[{"Q_", ",", 
    RowBox[{"specs", ":", 
     RowBox[{"{", 
      RowBox[{"par_", ",", "vals_"}], "}"}]}], ",", "opts___Rule", 
    ",", "\"\<Operator\>\"", ",", 
    RowBox[{"{", 
     RowBox[{"\"\<1\>\"", ",", "\"\<5\>\""}], "}"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"basis", ",", "Qmat", ",", "Qmatnum"}], "}"}], ",", 
