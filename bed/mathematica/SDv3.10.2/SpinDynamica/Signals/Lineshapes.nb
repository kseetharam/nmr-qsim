Cell["Lorentzian", "Subsection",
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.40966287970406*^9, 3.409662882179791*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"26c96333-e1b3-40b9-99cd-3df65e2b0c3f"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Lorentzian", "[", 
    RowBox[{"w_", ",", 
     RowBox[{
      RowBox[{"line", ":", 
       RowBox[{"{", 
        RowBox[{"amp_", ",", "w0_", ",", "lam_"}], "}"}]}], "/;", 
      RowBox[{"TrueQ", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Im", "[", "w0", "]"}], "==", "0"}], "&&", 
        RowBox[{
         RowBox[{"Im", "[", "lam", "]"}], "==", "0"}]}], "]"}]}]}], "]"}], 
   "=", 
   RowBox[{"ComplexExpand", "[", 
    RowBox[{
     FractionBox["amp", 
      RowBox[{"lam", "+", 
       RowBox[{"I", " ", 
        RowBox[{"(", 
         RowBox[{"w", "-", "w0"}], ")"}]}]}]], ",", 
     RowBox[{"{", "amp", "}"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{3.40966288647648*^9},
 AspectRatioFixed->
  True,ExpressionUUID->"61cdb4a5-be05-4b11-9425-d06e4ceb361b"],

