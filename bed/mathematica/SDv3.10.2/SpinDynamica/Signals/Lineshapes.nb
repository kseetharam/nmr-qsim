   RowBox[{"Plus", "@@", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Lorentzian", "[", 
        RowBox[{"w", ",", "#1"}], "]"}], "&"}], ")"}], "/@", "lines"}]}]}], 
  ";"}]], "Input",
