Cell["usages", "Chapter",
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 AspectRatioFixed->
  True,ExpressionUUID->"ba12a9fa-a5b1-4117-bae1-cd5b2dfc3b1c"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Gaussian", "::", "\"\<usage\>\""}], "=", 
   "\"\< Gaussian[w,{amp,w0,width}] generates a Gaussian function of w with \
integral amp, centre freq w0, and hwhh = width;\n\\n\\n \n\
Gaussian[w,{w0,width}] assumes unit amplitude;\\n\\n \n\
Gaussian[w,{{_,_,_}...}] generates a superposition of Gaussians.\>\""}], 
  ";"}]], "Input",
 PageWidth->PaperWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.409662912176852*^9, 3.4096629148977222`*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"39c6b2c3-5ab2-4a25-bc99-433ff5cdcf9c"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Lorentzian", "::", "\"\<usage\>\""}], "=", 
   "\"\< Lorentzian[w,{amp,w0,lam}] generates a complex Lorentzian function \
of w with complex amplitude amp, centre freq w0, and hwhh = lam;\\n\\n \n\
Lorentzian[w,{w0,lam}] assumes unit amplitude;\\n\\n \n\
Lorentzian[w,{{_,_,_}...}] generates a superposition of Lorentzians.\>\""}], 
  ";"}]], "Input",
 PageWidth->PaperWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.409662898022777*^9, 3.409662922585486*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"9b735892-5800-42ec-a2e4-ea57160ddeb9"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Absorption", "::", "\"\<usage\>\""}], "=", 
   "\"\< Absorption[w,{amp,w0,lam}] generates a Absorption  Lorentzian \
function of w with amplitude amp, centre freq w0, and hwhh = lam;\\n\\n \n\
Absorption[w,{w0,lam}] assumes unit amplitude;\\n\\n \n\
Absorption[w,{{_,_,_}...}] generates a superposition of such Absorption \
Lorentzians\>\""}], ";"}]], "Input",
 PageWidth->PaperWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.4096629273248158`*^9, 3.409662930984063*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"62e43d58-f5c6-493b-b340-760d08a66507"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Dispersion", "::", "\"\<usage\>\""}], "=", 
   "\"\< Dispersion[w,{amp,w0,lam}] generates a Dispersion Lorentzian \
function of w with amplitude amp, centre freq w0, and fwhh = lam;\\n\\n \n\
Dispersion[w,{w0,lam}] assumes unit amplitude;\\n\\n\n\
Dispersion[w,{{_,_,_}...}] generates a superposition of such Dispersion \
Lorentzians\>\""}], ";"}]], "Input",
 PageWidth->PaperWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.409662935882656*^9, 3.409662940005351*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"e341c705-97dc-4a38-bf9a-178f46a10fc5"]
}, Closed]],

