Cell[CellGroupData[{

Cell["Gaussian", "Subsection",
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 AspectRatioFixed->
  True,ExpressionUUID->"48e16996-61c6-4bb3-baa9-d2da8533d7f2"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Gaussian", "[", 
    RowBox[{"w_", ",", 
     RowBox[{
      RowBox[{"line", ":", 
       RowBox[{"{", 
        RowBox[{"amp_", ",", "w0_", ",", "width_"}], "}"}]}], "/;", 
      RowBox[{"TrueQ", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Im", "[", "amp", "]"}], "==", "0"}], "&&", 
        RowBox[{
         RowBox[{"Im", "[", "w0", "]"}], "==", "0"}], "&&", 
        RowBox[{
         RowBox[{"Im", "[", "width", "]"}], "==", "0"}]}], "]"}]}]}], "]"}], 
   "=", "\[IndentingNewLine]", 
   RowBox[{"amp", "*", 
    RowBox[{
     RowBox[{"Exp", "[", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"Log", "[", "2", "]"}]}], 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"w", "-", "w0"}], ")"}], "^", "2"}], "/", 
        RowBox[{"width", "^", "2"}]}]}], "]"}], "/", 
     RowBox[{"(", 
      RowBox[{"width", "*", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"Pi", "/", 
         RowBox[{"Log", "[", "2", "]"}]}], "]"}]}], ")"}]}]}]}], 
  ";"}]], "Input",
 InitializationCell->True,
 InitializationGroup->True,
 AspectRatioFixed->
  True,ExpressionUUID->"5a00c3c1-4766-4d96-a963-839d938733c2"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Gaussian", "[", 
    RowBox[{"w_", ",", 
     RowBox[{"lines_", "?", "MatrixQ"}]}], "]"}], ":=", 
   RowBox[{"Plus", "@@", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Gaussian", "[", 
        RowBox[{"w", ",", "#1"}], "]"}], "&"}], ")"}], "/@", "lines"}]}]}], 
  ";"}]], "Input",
 InitializationCell->True,
 InitializationGroup->True,
 AspectRatioFixed->
  True,ExpressionUUID->"8709486e-f2a4-4373-b1bf-e2a9208bb76d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Gaussian", "[", 
   RowBox[{"w_", ",", 
    RowBox[{"{", 
     RowBox[{"w0_", ",", "lam_"}], "}"}]}], "]"}], ":=", 
  RowBox[{"Gaussian", "[", 
   RowBox[{"w", ",", 
    RowBox[{"{", 
     RowBox[{"1", ",", "w0", ",", "lam"}], "}"}]}], "]"}]}]], "Input",
 InitializationCell->True,
 InitializationGroup->True,
 AspectRatioFixed->
  True,ExpressionUUID->"31605081-5a28-4fad-ac4f-11102b9406bf"]
}, Closed]],

