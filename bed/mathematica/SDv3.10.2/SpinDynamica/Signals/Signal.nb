Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Signal", "[", 
    RowBox[{
     RowBox[{"data", ":", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"_", ",", "_"}], "}"}], "..."}], "}"}]}], ",", 
     "opts___Rule"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"tcoords", ",", "amplitudes", ",", "\[Delta]t", ",", "n"}], 
      "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"tcoords", ",", "amplitudes"}], "}"}], "=", 
        RowBox[{"Transpose", "[", "data", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"\[Delta]t", "=", 
        RowBox[{
         RowBox[{
         "tcoords", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}], 
         "-", 
         RowBox[{
         "tcoords", "\[LeftDoubleBracket]", "1", 
          "\[RightDoubleBracket]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"n", "=", 
        RowBox[{"Length", "[", "tcoords", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"Chop", "@", 
           RowBox[{"N", "[", 
            RowBox[{
             RowBox[{"Table", "[", 
              RowBox[{
               RowBox[{"i", "*", "\[Delta]t"}], ",", 
               RowBox[{"{", 
                RowBox[{"i", ",", "0", ",", 
                 RowBox[{"n", "-", "1"}]}], "}"}]}], "]"}], "-", "tcoords"}], 
            "]"}]}], "\[Equal]", 
          RowBox[{"Table", "[", 
           RowBox[{"0", ",", 
            RowBox[{"{", "n", "}"}]}], "]"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"Signal", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"First", "[", "tcoords", "]"}], ",", 
             RowBox[{"Last", "[", "tcoords", "]"}], ",", "\[Delta]t"}], "}"}],
            ",", "amplitudes", ",", 
           RowBox[{"SimplifyRules", "[", 
            RowBox[{
             RowBox[{"EmbedCoordinates", "\[Rule]", "False"}], ",", "opts"}], 
            "]"}]}], "]"}], ",", "\[IndentingNewLine]", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Message", "[", 
            RowBox[{"Signal", "::", "nonuniform\[Delta]t"}], "]"}], ";", 
           "$Failed"}], ")"}]}], "\[IndentingNewLine]", "]"}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
