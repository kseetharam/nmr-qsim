Cell[BoxData[
 RowBox[{
  RowBox[{"Signal", "/:", 
   RowBox[{
    RowBox[{"Expand", "[", 
     RowBox[{"Signal", "[", 
      RowBox[{
       RowBox[{"times", ":", 
        RowBox[{"{", 
         RowBox[{"tmin_", ",", "tmax_", ",", "\[Delta]t_"}], "}"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"type_String", ",", "peaks_List"}], "}"}], ",", 
       "opts___Rule"}], "]"}], "]"}], "/;", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"MatchQ", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "PeaksSnappedToFrequencyGrid", ",", "PeakReductionImplemented", ",",
            "EmbedCoordinates", ",", "LineBroadening", ",", "ZeroFill"}], 
          "}"}], "/.", 
         RowBox[{"{", "opts", "}"}]}], "/.", 
        RowBox[{"Options", "[", "Signal", "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"True", ",", "True", ",", 
         RowBox[{"False", "|", "None"}], ",", 
         RowBox[{"False", "|", "None", "|", "0"}], ",", 
         RowBox[{"_", "?", "NumericQ"}]}], "}"}]}], "]"}], "&&", 
     "\[IndentingNewLine]", 
     RowBox[{"MatchQ", "[", 
      RowBox[{
       RowBox[{"Chop", "[", 
        RowBox[{"Last", "/@", "peaks"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", "..."}], "}"}]}], "]"}]}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "avals", ",", "\[Omega]vals", ",", "\[Lambda]vals", ",", "ivals", ",", 
       "\[Delta]\[Omega]", ",", "n", ",", "ZF", ",", "nZF", ",", 
       "\[Omega]min", ",", "\[Omega]max", ",", "spec"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"ZF", "=", 
        RowBox[{
         RowBox[{"ZeroFill", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "Signal", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"n", "=", 
        RowBox[{
         RowBox[{"Round", "[", 
          RowBox[{"Abs", "[", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"tmax", "-", "tmin"}], ")"}], "/", "\[Delta]t"}], "]"}], 
          "]"}], "+", "1"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"nZF", "=", 
        RowBox[{"ZF", "\[Times]", "n"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"\[Delta]\[Omega]", "=", 
        RowBox[{
         RowBox[{"Abs", "[", 
          RowBox[{"2", 
           RowBox[{"\[Pi]", "/", "\[Delta]t"}]}], "]"}], "/", "nZF"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"avals", ",", "\[Omega]vals", ",", "\[Lambda]vals"}], "}"}], 
        "=", 
        RowBox[{"Transpose", "[", "peaks", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"ivals", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Mod", "[", 
             RowBox[{
              RowBox[{"Round", "[", 
               RowBox[{"#", "/", "\[Delta]\[Omega]"}], "]"}], ",", "nZF"}], 
             "]"}], "+", "1"}], ")"}], "&"}], "/@", "\[Omega]vals"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Chop", "@", 
        RowBox[{
         RowBox[{"Fourier", "[", 
          RowBox[{
           RowBox[{"SparseArray", "[", 
            RowBox[{
             RowBox[{"ivals", "\[Rule]", "avals"}], ",", 
             RowBox[{"{", "nZF", "}"}]}], "]"}], ",", 
           RowBox[{"FourierParameters", "\[Rule]", 
            RowBox[{"{", 
             RowBox[{"1", ",", "1"}], "}"}]}]}], "]"}], 
         "\[LeftDoubleBracket]", 
         RowBox[{"Range", "[", 
          RowBox[{"1", ",", "n"}], "]"}], "\[RightDoubleBracket]"}]}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.5058481173326197`*^9, 3.5058482377210407`*^9}, {
