Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"FT", "[", 
     RowBox[{
      RowBox[{"sig2D_", "?", "MatrixQ"}], ",", "opts___Rule"}], "]"}], "/;", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"MatchQ", "[", 
       RowBox[{
        RowBox[{"Dimensions", "[", "sig2D", "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"_", ",", "3"}], "}"}]}], "]"}], "&&", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"EmbedCoordinates", "/.", 
         RowBox[{"{", "opts", "}"}]}], "/.", 
        RowBox[{"Options", "[", "FT", "]"}]}], ")"}], "&&", 
      "\[IndentingNewLine]", 
      RowBox[{"MatchQ", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"SampleInterval", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "FT", "]"}]}], ",", "Automatic"}], "]"}], "&&", 
      RowBox[{"(", 
       RowBox[{"MatchQ", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"LineBroadening", "/.", 
           RowBox[{"{", "opts", "}"}]}], "/.", 
          RowBox[{"Options", "[", "FT", "]"}]}], ",", 
         RowBox[{"None", "|", "False"}]}], "]"}], ")"}]}], 
     "\[IndentingNewLine]", ")"}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "t1vals", ",", "t2vals", ",", "sigvals", ",", "n1", ",", "n2", ",", 
       "\[Delta]t1", ",", "\[Delta]t2"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"t1vals", ",", "t2vals", ",", "sigvals"}], "}"}], "=", 
        RowBox[{"Transpose", "[", "sig2D", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"\[Delta]t1", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{
            "#", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}], "-", 
            
            RowBox[{
            "#", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]}], 
           ")"}], "&"}], "@", 
         RowBox[{"Union", "[", "t1vals", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"\[Delta]t2", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{
            "#", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}], "-", 
            
            RowBox[{
            "#", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]}], 
           ")"}], "&"}], "@", 
         RowBox[{"Union", "[", "t2vals", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"n1", ",", "n2"}], "}"}], "=", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", 
           RowBox[{"Union", "[", "#", "]"}], "]"}], "&"}], "/@", 
         RowBox[{"{", 
          RowBox[{"t1vals", ",", "t2vals"}], "}"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Chop", "@", 
          RowBox[{"N", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{
             RowBox[{"Flatten", "[", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"Table", "[", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"i1", "*", "\[Delta]t1"}], ",", 
                   RowBox[{"i2", "*", "\[Delta]t2"}]}], "}"}], ",", 
                 RowBox[{"{", 
                  RowBox[{"i1", ",", "0", ",", 
                   RowBox[{"n1", "-", "1"}]}], "}"}], ",", 
                 RowBox[{"{", 
                  RowBox[{"i2", ",", "0", ",", 
                   RowBox[{"n2", "-", "1"}]}], "}"}]}], "]"}], ",", 
               "\[IndentingNewLine]", "1"}], "]"}], "-", 
             RowBox[{"Transpose", "[", 
              RowBox[{"{", 
               RowBox[{"t1vals", ",", "t2vals"}], "}"}], "]"}]}], "\[Equal]", 
            
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"0", ",", "0"}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"n1", "*", "n2"}], "}"}]}], "]"}]}], 
           "\[IndentingNewLine]", "]"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"FT", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"Partition", "[", 
            RowBox[{"sigvals", ",", "n2"}], "]"}], ",", "\[IndentingNewLine]", 
           RowBox[{"EmbedCoordinates", "\[Rule]", "True"}], ",", 
           RowBox[{"SampleInterval", "\[Rule]", 
            RowBox[{"{", 
             RowBox[{"\[Delta]t1", ",", "\[Delta]t2"}], "}"}]}], ",", 
           "opts"}], "]"}], ",", "\[IndentingNewLine]", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Message", "[", 
            RowBox[{"FT", "::", "badtcoords"}], "]"}], ";", "$Failed"}], 
          ")"}]}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
      ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.4515693356284437`*^9, 3.451569345774475*^9}, 
