Cell[CellGroupData[{

Cell["EmbedCoordinates", "Subsection",
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{
  3.451580687968195*^9},ExpressionUUID->"1757a740-5f9a-4e7f-9c9e-\
2c908da7d8f0"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"EmbedCoordinates", "::", "\"\<usage\>\""}], "=", 
   "\"\<EmbedCoordinates is an option for FT. Used to specify the form of the \
data input and the data output. If EmbedCoordinates\[Rule]True is used, the \
time and frequency coordinates are embedded in the individual data points \
(default). The embedded time coordinates are used to calculate the frequency \
coordinates are the FT. If EmbedCoordinates\[Rule]False is used, the input \
and output data lack time or frequency coordinates, in which case the time or \
frequency range of the data must be specified afterwards when the data are \
processed.\>\""}], ";"}]], "Input",
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{
  3.409319697501347*^9, {3.451580689564411*^9, 3.451580755988777*^9}, {
   3.451581276318861*^9, 3.451581291890688*^9}, {3.451581781573007*^9, 
   3.451581785225836*^9}, {3.451637448889881*^9, 
   3.4516375147467823`*^9}},ExpressionUUID->"b15ff5c5-95b8-426b-bbf6-\
441eacacb8ec"]
}, Closed]],

Cell[CellGroupData[{

Cell["FirstPointMultiplicationFactor", "Subsection",
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{
  3.451580687968195*^9, {3.4517251579626207`*^9, 
   3.4517251635370607`*^9}},ExpressionUUID->"44982a24-40b6-44bf-b816-\
5471c70f7c7d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"FirstPointMultiplicationFactor", "::", "\"\<usage\>\""}], "=", 
   "\"\<FirstPointMultiplicationFactor is an option for FT. The default is \
0.5, which states that the first point of the time-domain data is divided by \
2 before application of the FFT algorithm. This prevents a spurious baseline \
shift generated by the discrete FT, in the case that the signal decays to \
zero before the end of the time-domain data. The spurious baseline shift is \
inversely proportional to the number of points. If FT is applied to \
non-decaying signals, an option FirstPointMultiplicationFactor->1 should be \
given. For 2D data, options such as \
FirstPointMultiplicationFactor\[Rule]{0.5,1.0} may be used to specify \
different factors for the two dimensions, in the order {direct, \
indirect}.\>\""}], ";"}]], "Input",
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{
  3.409319697501347*^9, {3.451580689564411*^9, 3.451580755988777*^9}, {
   3.451581276318861*^9, 3.451581291890688*^9}, {3.451581781573007*^9, 
   3.451581785225836*^9}, {3.451637448889881*^9, 3.4516375147467823`*^9}, {
   3.4517251670353727`*^9, 3.4517252846895323`*^9}, {3.453013539872901*^9, 
   3.453013607587204*^9}, 
   3.5058445622601547`*^9},ExpressionUUID->"3bd65eed-db45-42f7-b5d0-\
026d7f4c5972"]
}, Closed]],

Cell[CellGroupData[{

Cell["ZeroFill", "Subsection",
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{
  3.451580687968195*^9, {3.4517251579626207`*^9, 3.4517251635370607`*^9}, {
   3.453013524181899*^9, 
   3.4530135280272284`*^9}},ExpressionUUID->"f977f553-c503-4029-8282-\
3c86bbea4d95"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ZeroFill", "::", "\"\<usage\>\""}], "=", 
   "\"\<ZeroFill is an option for FT. ZeroFill\[Rule]n causes (n-1)*m zeroes \
to be appended to the data prior to FT, where m is the number of data points. \
ZeroFill\[Rule]True is equivalent to ZeroFill\[Rule]2.   ZeroFill->False is \
equivalent to ZeroFill\[Rule]1. Options such as ZeroFill\[Rule]{True,False} \
may be specified for 2D data to indicate different zero-filling in the two \
dimensions, in the order {direct, indirect}.\>\""}], ";"}]], "Input",
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{
  3.409319697501347*^9, {3.451580689564411*^9, 3.451580755988777*^9}, {
   3.451581276318861*^9, 3.451581291890688*^9}, {3.451581781573007*^9, 
   3.451581785225836*^9}, {3.451637448889881*^9, 3.4516375147467823`*^9}, {
   3.4517251670353727`*^9, 3.4517252846895323`*^9}, 3.45301353202172*^9, {
   3.453013615138085*^9, 3.453013729390286*^9}, 3.505844555316132*^9, {
   3.6291029287807217`*^9, 
   3.6291030685082493`*^9}},ExpressionUUID->"2d766cc0-a702-4444-a747-\
9c5543b76fd8"]
}, Closed]]
}, Closed]],

