Cell["\<\
if the SampleFrequency is specified, add the frequency coordinates to the \
data. Adjust the scaling so that the integral of the spectrum equals the \
first point of the FID.\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.4515719840124063`*^9, 3.4515720411708813`*^9}, {
  3.451572169303461*^9, 3.451572180030096*^9}, {3.530538215829337*^9, 
  3.5305382365796556`*^9}},ExpressionUUID->"0a153f24-65b7-4249-9372-\
f3af76042843"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"AddFrequencyCoordinates", "[", 
    RowBox[{
     RowBox[{"fdata", ":", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Except", "[", "_List", "]"}], ".."}], "}"}]}], ",", 
     "opts___Rule"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"sw", ",", "n"}], "}"}], ",", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"n", "=", 
         RowBox[{"Length", "[", "fdata", "]"}]}], ";", "\[IndentingNewLine]", 
        
        RowBox[{"sw", "=", 
         RowBox[{
          RowBox[{"SampleFrequency", "/.", 
           RowBox[{"{", "opts", "}"}]}], "/.", 
          RowBox[{"Options", "[", "FT", "]"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"EvenQ", "[", "n", "]"}], ",", "\[IndentingNewLine]", 
          RowBox[{"Transpose", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{
              RowBox[{"Range", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"-", 
                  RowBox[{"(", 
                   RowBox[{"n", "/", "2"}], ")"}]}], "+", "1"}], ",", 
                RowBox[{"(", 
                 RowBox[{"n", "/", "2"}], ")"}]}], "]"}], "*", 
              RowBox[{"sw", "/", "n"}]}], ",", "fdata"}], "}"}], "]"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"Transpose", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{
              RowBox[{"Range", "[", 
               RowBox[{
                RowBox[{"-", 
                 RowBox[{"Floor", "[", 
                  RowBox[{"n", "/", "2"}], "]"}]}], ",", 
                RowBox[{"Floor", "[", 
                 RowBox[{"n", "/", "2"}], "]"}]}], "]"}], "*", 
              RowBox[{"sw", "/", "n"}]}], ",", "fdata"}], "}"}], "]"}]}], 
         "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", ")"}]}], 
     "]"}], "/;", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"MatchQ", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"SampleFrequency", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "FT", "]"}]}], ",", 
        RowBox[{"Except", "[", "_List", "]"}]}], "]"}], ")"}], "&&", 
     "\[IndentingNewLine]", 
     RowBox[{"!", 
      RowBox[{"MatchQ", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"SampleFrequency", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "FT", "]"}]}], ",", "Automatic"}], 
       "]"}]}]}]}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.451570837836115*^9, 3.4515709494143333`*^9}, {
