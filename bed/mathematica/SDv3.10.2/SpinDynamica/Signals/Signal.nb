Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"CombineData", "[", 
     RowBox[{
      RowBox[{"datasets", ":", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Except", "[", 
          RowBox[{"Signal", "[", "___", "]"}], "]"}], ".."}], "}"}]}], ",", 
      "weights_List", ",", "opts___Rule"}], "]"}], "/;", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "dims", "}"}], ",", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"dims", "=", 
         RowBox[{"Dimensions", "[", 
          RowBox[{"First", "[", "datasets", "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"MatchQ", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"EmbedCoordinates", "/.", 
             RowBox[{"{", "opts", "}"}]}], "/.", 
            RowBox[{"Options", "[", "CombineData", "]"}]}], ",", 
           "Automatic"}], "]"}], "&&", 
         RowBox[{"(", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"!", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"Length", "[", "dims", "]"}], ">", "2"}], ")"}]}], 
