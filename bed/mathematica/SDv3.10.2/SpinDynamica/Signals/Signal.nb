Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ApplyLineBroadening", "[", 
     RowBox[{
      RowBox[{"Signal", "[", 
       RowBox[{
        RowBox[{"times", ":", 
         RowBox[{"{", 
          RowBox[{"tmin_", ",", "tmax_", ",", "\[Delta]t_"}], "}"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"type_String", ",", "peaks_List"}], "}"}], ",", 
        "sigopts___Rule"}], "]"}], ",", "opts___Rule"}], "]"}], "/;", 
    "\[IndentingNewLine]", 
    RowBox[{"MatchQ", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"LineBroadening", "/.", 
        RowBox[{"{", "opts", "}"}]}], "/.", 
       RowBox[{"Options", "[", "ApplyLineBroadening", "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"type", ",", 
        RowBox[{"Except", "[", 
         RowBox[{"0", "|", "None"}], "]"}]}], "}"}]}], "]"}]}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "lb", "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"lb", "=", 
        RowBox[{"Last", "[", 
         RowBox[{
          RowBox[{"LineBroadening", "/.", 
           RowBox[{"{", "opts", "}"}]}], "/.", 
          RowBox[{"Options", "[", "Signal", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Signal", "[", 
        RowBox[{"times", ",", "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"type", ",", 
           RowBox[{
            RowBox[{
             RowBox[{"Plus", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"0", ",", "0", ",", 
                 RowBox[{"lb", "/", "2"}]}], "}"}], ",", "#"}], "]"}], "&"}], 
            "/@", "peaks"}]}], "}"}], ",", "\[IndentingNewLine]", 
         RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"LineBroadening", "\[Rule]", "None"}], ",", 
           "\[IndentingNewLine]", "sigopts", ",", "\[IndentingNewLine]", 
           RowBox[{"Sequence", "@@", 
            RowBox[{"Options", "[", "Signal", "]"}]}]}], 
          "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", "]"}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.505927845710581*^9, 3.505928097759769*^9}, {
