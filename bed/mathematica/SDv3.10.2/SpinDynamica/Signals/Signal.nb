Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ApplyLineBroadening", "[", 
     RowBox[{
      RowBox[{"sig", ":", 
       RowBox[{"Signal", "[", 
        RowBox[{
         RowBox[{"times", ":", 
          RowBox[{"{", 
           RowBox[{"tmin_", ",", "tmax_", ",", "\[Delta]t_"}], "}"}]}], ",", 
         "more___"}], "]"}]}], ",", "\[IndentingNewLine]", "opts___Rule"}], 
     "]"}], "/;", 
    RowBox[{"MatchQ", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"LineBroadening", "/.", 
        RowBox[{"{", "opts", "}"}]}], "/.", 
       RowBox[{"Options", "[", "ApplyLineBroadening", "]"}]}], ",", 
      "Automatic"}], "]"}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "fwhh", "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"fwhh", "=", 
        RowBox[{"N", "[", 
         RowBox[{"4", " ", 
          RowBox[{
           RowBox[{"Log", "[", "10", "]"}], "/", 
           RowBox[{"(", 
            RowBox[{"Abs", "[", 
             RowBox[{"tmax", "-", "tmin"}], "]"}], ")"}]}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Message", "[", 
        RowBox[{
         RowBox[{"ApplyLineBroadening", "::", "autolb"}], ",", 
         RowBox[{"EngineeringForm", "@", 
          RowBox[{"N", "[", 
           RowBox[{"fwhh", "/", 
            RowBox[{"(", 
             RowBox[{"2", "\[Pi]"}], ")"}]}], "]"}]}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"ApplyLineBroadening", "[", "\[IndentingNewLine]", 
        RowBox[{"sig", ",", "\[IndentingNewLine]", 
         RowBox[{"SimplifyRules", "[", 
          RowBox[{
           RowBox[{"LineBroadening", "\[Rule]", 
            RowBox[{"{", 
             RowBox[{"\"\<Lorentzian\>\"", ",", "fwhh"}], "}"}]}], ",", 
           "opts"}], "]"}]}], "\[IndentingNewLine]", "]"}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
