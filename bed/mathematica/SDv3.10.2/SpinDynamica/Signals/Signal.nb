 RowBox[{
  RowBox[{
   RowBox[{"SnapPeaksToFrequencyGrid", "::", "usage"}], "=", 
   "\"\<SnapPeaksToFrequencyGrid is obsolete and has been superseded by \
DigitalFrequencyResolution.\>\""}], ";"}]], "Input",
 PageWidth->WindowWidth,
 InitializationCell->True,
 CellChangeTimes->{{3.469878218285511*^9, 3.469878219035956*^9}, {
  3.469882329319214*^9, 3.46988233483611*^9}, {3.4698823788891363`*^9, 
