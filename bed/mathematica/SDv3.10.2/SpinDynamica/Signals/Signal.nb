Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"CombineData", "[", 
     RowBox[{
      RowBox[{"datasets", ":", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Except", "[", 
          RowBox[{"Signal", "[", "___", "]"}], "]"}], ".."}], "}"}]}], ",", 
      "weights_List", ",", "opts___Rule"}], "]"}], "/;", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"EmbedCoordinates", "/.", 
       RowBox[{"{", "opts", "}"}]}], "/.", 
      RowBox[{"Options", "[", "CombineData", "]"}]}], ")"}]}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"coords", ",", "vals"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"coords", "=", 
        RowBox[{"Most", "/@", 
         RowBox[{"First", "[", "datasets", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"vals", "=", 
        RowBox[{"Map", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"Last", "/@", "#"}], ")"}], "&"}], ",", "datasets"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"MapThread", "[", 
        RowBox[{"Append", ",", 
         RowBox[{"{", 
          RowBox[{"coords", ",", 
           RowBox[{"CombineData", "[", 
            RowBox[{"vals", ",", "weights", ",", 
             RowBox[{"EmbedCoordinates", "\[Rule]", "False"}]}], "]"}]}], 
          "}"}]}], "]"}]}], "\[IndentingNewLine]", ")"}]}], "]"}]}], 
  ";"}]], "Input",
