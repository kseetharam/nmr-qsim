Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ReflectSpectrum", "[", 
     RowBox[{
      RowBox[{"S2D_", "?", "MatrixQ"}], ",", "opts___Rule"}], "]"}], "/;", 
    RowBox[{"MatchQ", "[", 
     RowBox[{
      RowBox[{"Dimensions", "[", "S2D", "]"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"_", "?", "EvenQ"}], ",", "3"}], "}"}]}], "]"}]}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Omega]1vals", ",", "\[Omega]2vals", ",", "amplitudes", ",", "n1", 
       ",", "n2"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"\[Omega]1vals", ",", "\[Omega]2vals", ",", "amplitudes"}], 
         "}"}], "=", 
        RowBox[{"Transpose", "[", "S2D", "]"}]}], ";", "\[IndentingNewLine]", 
       
       RowBox[{
        RowBox[{"{", 
         RowBox[{"n1", ",", "n2"}], "}"}], "=", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", 
           RowBox[{"Union", "[", "#", "]"}], "]"}], "&"}], "/@", 
         RowBox[{"{", 
          RowBox[{"\[Omega]1vals", ",", "\[Omega]2vals"}], "}"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"\[Omega]1vals", ",", "\[Omega]2vals", ",", 
          RowBox[{"Flatten", "[", 
           RowBox[{"ReflectSpectrum", "[", 
            RowBox[{"Partition", "[", 
             RowBox[{"amplitudes", ",", "n2"}], "]"}], "]"}], "]"}]}], 
         "\[IndentingNewLine]", "}"}], "]"}]}], "\[IndentingNewLine]", 
      ")"}]}], "]"}]}], ";"}]], "Input",
