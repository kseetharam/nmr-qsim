Cell[CellGroupData[{

Cell["ApplyLineBroadening", "Subsection",
 InitializationCell->True,
 CellChangeTimes->{
  3.6293853579405823`*^9},ExpressionUUID->"a9db4537-cecf-41e7-a0d2-\
7ac8b40ce33f"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ApplyLineBroadening", "::", "usage"}], "=", 
   "\[IndentingNewLine]", 
   "\"\<ApplyLineBroadening[signal,opts] applies line broadening to a Signal \
object, using the option LineBroadening\[Rule]{type,fwhh}, where fwhh is the \
full-width-at-half-height in rad \!\(\*SuperscriptBox[\(s\), \(-1\)]\). \
Currently type must be equal to \\\"Lorentzian\\\". The default setting is \
Automatic, which sets the Lorentzian LineBroadening such that the signal \
envelope decays to the 1% level at the end of the signal.\>\""}], 
  ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.5059929790377827`*^9, 3.50599313519873*^9}, 
   3.531844748786757*^9},ExpressionUUID->"e5c98564-16bc-46d8-bade-\
afc0ce8b438d"]
}, Closed]],

Cell[CellGroupData[{

Cell["CombineData", "Subsection",
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{
  3.451580687968195*^9, {3.451584862519148*^9, 
   3.451584864741378*^9}},ExpressionUUID->"5eae3261-611c-458f-8edd-\
85b2b59b25fc"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"CombineData", "::", "\"\<usage\>\""}], "=", 
   "\"\<CombineData[{data1,data2..},{w1,w2..}] makes a linear combination of \
time or frequency-domain data using the specified weights. The mean of the \
data is used if the list of weights is omitted. The data sets {data1,data2..} \
may each have the form Signal[..], or may be arrays of data with any set of \
dimensions. In the latter case, the option EmbedCoordinates may be used to \
specify whether the data sets have embedded time and frequency coordinates. \
If EmbedCoordinates->True, the innermost level of each data set is assumed to \
have the form {x1,x2..value}, where {x1,x2..} are time or frequency \
coordinates. In this case, all coordinates must be the same for the combined \
data sets. If EmbedCoordinates->False, the data is assumed to have no \
embedded coordinates. If EmbedCoordinates->Automatic, the routine attempts to \
guess whether coordinates are embedded or not.\>\""}], ";"}]], "Input",
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{
  3.409319697501347*^9, {3.451580689564411*^9, 3.451580755988777*^9}, {
   3.451581276318861*^9, 3.451581291890688*^9}, {3.451581781573007*^9, 
   3.451581785225836*^9}, {3.451584867741522*^9, 3.4515849525064297`*^9}, {
   3.511156280895812*^9, 3.511156500884231*^9}, {3.511156563458872*^9, 
   3.511156634275215*^9}, {3.511156664580413*^9, 
   3.511156680480475*^9}},ExpressionUUID->"efb1be05-26d2-40dd-b96a-\
58ae224ff83e"]
}, Closed]]
}, Closed]],

Cell[CellGroupData[{

Cell["FT and options (* revise *)", "Section",
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{
  3.605545643975979*^9, {3.62938538785876*^9, 3.629385389486678*^9}, {
   3.894193793753435*^9, 
   3.89419379735958*^9}},ExpressionUUID->"3c8fc4c8-2663-41fa-9dfc-\
20937fbc3683"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"FT", "::", "usage"}], "=", 
   "\"\<FT generates a Fourier transform of 1D or 2D time-domain data, \
correcting the arrangement of the data as generated by the FFT algorithm and \
adding frequency coordinates, if required. FT is normally applied to a Signal \
object. However it may be applied to data, directly specified as a list of \
evenly sampled amplitudes or as a matrix of time-amplitude pairs. If the \
option EmbedCoordinates\[Rule]False is used, the input data is either a 1D \
list or a 2D matrix of signal values, and the output has the same form. If \
the option EmbedCoordinates\[Rule]True is used, the input data is a list of \
the type {{0,s1},{\[Delta]t,s2},{2\[Delta]t,s3}..} for 1D data and \
{{0,0,s1},{0,\[Delta]t2,s2},{0,2\[Delta]t2,s3}..{\[Delta]t1,0,s2}..} for 2D \
data. The output is of the same form, but with frequency coordinates instead \
of time coordinates.\>\""}], ";"}]], "Input",
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.451578651101074*^9, 3.45157878112208*^9}, {
  3.451581304491683*^9, 3.451581586995522*^9}, {3.5058445787962418`*^9, 
  3.5058445850798397`*^9}, {3.8941949324496317`*^9, 
  3.894195011826518*^9}},ExpressionUUID->"80bf6414-a02b-4af0-94f1-\
29317b208ddf"],

