Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"CombineData", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"sigs", ":", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Signal", "[", 
          RowBox[{"times_", ",", 
           RowBox[{"{", 
            RowBox[{"type_String", ",", 
             RowBox[{"_", "?", "MatrixQ"}]}], "}"}], ",", "___Rule"}], "]"}], 
         ".."}], "}"}]}], ",", "weights_List", ",", "opts___Rule"}], "]"}], "/;", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Length", "[", "sigs", "]"}], "\[Equal]", 
      RowBox[{"Length", "[", "weights", "]"}]}], ")"}]}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "peakset", ",", "weightedcombinedpeaks", ",", "temp", ",", "sig"}], 
      "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"temp", "=", 
        RowBox[{"PrintTemporary", "[", "\"\<combining signals..\>\"", "]"}]}],
        ";", "\[IndentingNewLine]", 
       RowBox[{"peakset", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"Part", "[", 
           RowBox[{"#", ",", "2", ",", "2"}], "]"}], "&"}], "/@", "sigs"}]}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"weightedcombinedpeaks", "=", "\[IndentingNewLine]", 
        RowBox[{"SortBy", "[", 
         RowBox[{
          RowBox[{"Join", "@@", 
           RowBox[{"MapThread", "[", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"Function", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"w", ",", "pks"}], "}"}], ",", 
               RowBox[{
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"{", 
                    RowBox[{"w", ",", "1", ",", "1"}], "}"}], "\[Times]", 
                   "#"}], ")"}], "&"}], "/@", "pks"}]}], "]"}], ",", 
             "\[IndentingNewLine]", 
             RowBox[{"{", 
              RowBox[{"weights", ",", "peakset"}], "}"}], ",", "1"}], "]"}]}],
           ",", "Rest"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"sig", "=", 
        RowBox[{"Signal", "[", "\[IndentingNewLine]", 
         RowBox[{"times", ",", "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{"type", ",", "weightedcombinedpeaks"}], "}"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"LineBroadening", "\[Rule]", "None"}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"Sequence", "@@", 
             RowBox[{"CombineSignalOptions", "[", "sigs", "]"}]}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"Sequence", "@@", 
             RowBox[{"Options", "[", "Signal", "]"}]}]}], 
           "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", "]"}]}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"NotebookDelete", "[", "temp", "]"}], ";", 
       "\[IndentingNewLine]", "sig"}], "\[IndentingNewLine]", ")"}]}], 
    "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.5295045718323*^9, 3.5295046641954317`*^9}, {
