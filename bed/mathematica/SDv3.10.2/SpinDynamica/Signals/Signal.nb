6fe79e6a05a5"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"CombineComplementarySpectra", "::", "\"\<usage\>\""}], "=", 
   "\"\<CombineComplementarySpectra[{spec1,spec2}] reflects spec2 about the \
\!\(\*SubscriptBox[\(\[Omega]\), \(1\)]\)=0 axis and adds it to spec1. The \
result is divided by 2. This generates a pure absorption 2D spectrum if all \
peaks in the individual spectra have opposite \
\!\(\*SubscriptBox[\(\[Omega]\), \(1\)]\) frequencies and identical real \
amplitudes.\n\>\""}], ";"}]], "Input",
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{
  3.409319697501347*^9, {3.451580689564411*^9, 3.451580755988777*^9}, {
