Cell[CellGroupData[{

Cell["Signal", "Subsection",
 InitializationCell->True,
 CellChangeTimes->{
  3.6293852829208*^9, {3.894193809921968*^9, 3.894193813702475*^9}, {
   3.894194898381464*^9, 
   3.894194898632134*^9}},ExpressionUUID->"144ee31a-9310-4d0a-86c1-\
59c59ac00d79"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Signal", "::", "usage"}], "=", 
   "\"\<Signal[{tmin,tmax,\[Delta]t},data,opts] describes a time-domain \
signal spanning the interval between tmin and tmax with sampling interval \
\[Delta]t. The symbol data may either be a list of numeric signal amplitudes, \
or a peak specification of the form {type,{{a,\[Omega],\[Lambda]},...}} where \
type must currently be equal to \\\"Lorentzian\\\" and each peak is specified \
by a complex amplitude a, a frequency \[Omega] (in rad \
\!\(\*SuperscriptBox[\(s\), \(-1\)]\)), and a time-domain decay parameter \
\[Lambda] (corresponding to the half-width-at-half-height in rad \
\!\(\*SuperscriptBox[\(s\), \(-1\)]\)). \nSignal may be converted to a table \
of {time,amplitude} pairs by using Expand[Signal[...]]. This expansion is \
done implicitly when applying FT or ListPlot to Signal. The operations Re and \
Im may be applied to Signal and apply to the expanded signal amplitudes, not \
to the time coordinates.\nThe options opts determine what happend when Expand \
is applied. If EmbedCoordinates\[Rule]True, explicit time coordinates are \
generated. The option LineBroadening\[Rule]fwhh applies an extra \
linebroadening on expansion, where fwhh is the full-width-at-half-height in \
rad \!\(\*SuperscriptBox[\(s\), \(-1\)]\). The default \
LineBroadening\[Rule]Automatic applies Lorentzian linebroadening that brings \
the signal amplitude down to 1% at the end of the signal. The option \
DigitalFrequencyResolution allows a compromise to be made between computation \
speed and computational accuracy. \n\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.505844995490617*^9, 3.505845296655443*^9}, {
  3.505889321462783*^9, 3.505889377224868*^9}, {3.505892252310782*^9, 
  3.5058923441156073`*^9}, {3.505894581730283*^9, 3.505894644082975*^9}, {
  3.50589600534298*^9, 3.505896197184195*^9}, {3.505896233620352*^9, 
  3.5058963790483913`*^9}, {3.505921685192232*^9, 3.505921727854095*^9}, {
  3.505921778836707*^9, 3.505921851059515*^9}, {3.505929081584772*^9, 
  3.505929119343351*^9}, {3.505929805185773*^9, 3.505929929407469*^9}, {
  3.5306153974071608`*^9, 3.530615418828924*^9}, {3.5318446918932877`*^9, 
  3.5318447127610693`*^9}, {3.629285772911593*^9, 
  3.629285778169106*^9}},ExpressionUUID->"f8190b18-2660-4bf2-a27f-\
14a6d1dd1783"]
}, Closed]],

Cell[CellGroupData[{

Cell["LineBroadening", "Subsection",
 InitializationCell->True,
 CellChangeTimes->{{3.6293852829208*^9, 
  3.629385291212304*^9}},ExpressionUUID->"66eee2a3-e89a-4d59-a70b-\
044247b691bb"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"LineBroadening", "::", "usage"}], "=", 
   "\"\<LineBroadening is an option for Signal. LineBroadening->fwhh gives \
the acquired signal an exponential decay corresponding to a Lorentzian \
linebroadening in the frequency domain with full-width-at-half-height fwhh \
(in rad \!\(\*SuperscriptBox[\(s\), \(-1\)]\)). The same result is obtained \
with the option LineBroadening->{\\\"Lorentzian\\\",fwhh}. Future \
implementations will allow different types of LineBroadening functions. The \
default setting is Automatic, which sets the Lorentzian LineBroadening such \
that the signal envelope decays to the 1% level at the end of the signal. \
\>\""}], ";"}]], "Input",
 PageWidth->WindowWidth,
 InitializationCell->True,
 CellChangeTimes->{{3.469878218285511*^9, 3.469878219035956*^9}, {
   3.469882329319214*^9, 3.46988233483611*^9}, {3.4698823788891363`*^9, 
   3.4698825887486143`*^9}, {3.469882889257883*^9, 3.469882911594975*^9}, {
   3.46988357886088*^9, 3.469883629467374*^9}, {3.4698839918137827`*^9, 
   3.469883993162998*^9}, {3.497350991647491*^9, 3.497351110566373*^9}, {
   3.5058964477382803`*^9, 3.505896522970291*^9}, {3.5059291306478233`*^9, 
   3.505929132023181*^9}, 
   3.53184473303402*^9},ExpressionUUID->"d6449ebe-9f04-4784-8883-\
7663930e243a"]
}, Closed]],

Cell[CellGroupData[{

Cell["DigitalFrequencyResolution", "Subsection",
 InitializationCell->True,
 CellChangeTimes->{
  3.6293853054086027`*^9},ExpressionUUID->"dd794eb4-33f4-4db3-950d-\
499f38c03e2a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"DigitalFrequencyResolution", "::", "usage"}], "=", 
  "\"\<DigitalFrequencyResolution is an option for Signal. \
DigitalFrequencyResolution\[Rule]Automatic shifts each peak frequency to the \
nearest digitized point in the frequency domain, taking into account the \
setting for ZeroFill. This degrades accuracy slightly but allows faster \
computation, especially when combining data from a large ensemble. Setting \
DigitalFrequencyResolution\[Rule]False disables this peak shift at the \
expense of processing speed.\>\""}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.629102638004887*^9, 3.629102674739623*^9}, {
  3.6291027083613253`*^9, 3.629102794799636*^9}, {3.62938531449935*^9, 
  3.62938533410534*^9}},ExpressionUUID->"8482ec2b-5767-4f05-a785-\
2442ea03cfa4"],

