Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ApplyLineBroadening", "[", 
     RowBox[{
      RowBox[{"Signal", "[", 
       RowBox[{
        RowBox[{"times", ":", 
         RowBox[{"{", 
          RowBox[{"tmin_", ",", "tmax_", ",", "\[Delta]t_"}], "}"}]}], ",", 
        RowBox[{"data", ":", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"_", "?", "NumericQ"}], "..."}], "}"}]}], ",", 
        "sigopts___Rule"}], "]"}], ",", "opts___Rule"}], "]"}], "/;", 
    RowBox[{
     RowBox[{"MatchQ", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"LineBroadening", "/.", 
         RowBox[{"{", "opts", "}"}]}], "/.", 
        RowBox[{"Options", "[", "Signal", "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"_String", ",", 
         RowBox[{"Except", "[", 
          RowBox[{"0", "|", "None"}], "]"}]}], "}"}]}], "]"}], "&&", 
     RowBox[{"MatchQ", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"LineBroadening", "/.", 
         RowBox[{"{", "sigopts", "}"}]}], "/.", 
        RowBox[{"Options", "[", "ApplyLineBroadening", "]"}]}], ",", "None"}],
       "]"}]}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"n", ",", "tvals", ",", "lb", ",", "lbtype"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"lbtype", ",", "lb"}], "}"}], "=", 
        RowBox[{
         RowBox[{"LineBroadening", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "Signal", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"n", "=", 
        RowBox[{
         RowBox[{"Round", "[", 
          RowBox[{"Abs", "[", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"tmax", "-", "tmin"}], ")"}], "/", "\[Delta]t"}], "]"}], 
          "]"}], "+", "1"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"tvals", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"tmin", "+", 
           RowBox[{"i", " ", "\[Delta]t"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "0", ",", 
            RowBox[{"n", "-", "1"}]}], "}"}]}], "]"}]}], ";", 
