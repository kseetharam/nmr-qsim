Cell["\<\
Set SnapPeaksToFrequencyGrid\[Dash]>True for the combination if any of the \
combined signals has SnapPeaksToFrequencyGrid\[Dash]>True; 
Set PeakReductionImplemented\[Rule]True only if all peak reductions are True\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.593006661905025*^9, 3.593006701358355*^9}, {
  3.593006763684462*^9, 
  3.59300678557759*^9}},ExpressionUUID->"b9e70535-766a-4733-b0f4-\
db4192e10665"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"CombineSignalOptions", "[", "\[IndentingNewLine]", 
    RowBox[{"sigs", ":", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Signal", "[", 
        RowBox[{"times_", ",", 
         RowBox[{"{", 
          RowBox[{"type_String", ",", 
           RowBox[{"_", "?", "MatrixQ"}]}], "}"}], ",", "___Rule"}], "]"}], 
       ".."}], "}"}]}], "\[IndentingNewLine]", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"sigoptset", ",", "snappeaks", ",", "peakreds"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"sigoptset", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"List", "@@", 
            RowBox[{"#", "\[LeftDoubleBracket]", 
             RowBox[{"3", ";;", 
              RowBox[{"-", "1"}]}], "\[RightDoubleBracket]"}]}], ")"}], "&"}],
          "/@", "sigs"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"snappeaks", "=", 
        RowBox[{"Flatten", "[", 
         RowBox[{
          RowBox[{"SnapPeaksToFrequencyGrid", "/.", 
           RowBox[{"{", "sigoptset", "}"}]}], "/.", 
          RowBox[{"Options", "[", "Signal", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"peakreds", "=", 
        RowBox[{"Flatten", "[", 
         RowBox[{
          RowBox[{"PeakReductionImplemented", "/.", 
           RowBox[{"{", "sigoptset", "}"}]}], "/.", 
          RowBox[{"Options", "[", "Signal", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"{", "\[IndentingNewLine]", 
        RowBox[{"PeakReductionImplemented", "\[Rule]", 
         RowBox[{"!", 
          RowBox[{"And", "@@", "peakreds"}]}]}], "\[IndentingNewLine]", 
        "}"}]}], "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.593006369083722*^9, 3.593006601870626*^9}, {
