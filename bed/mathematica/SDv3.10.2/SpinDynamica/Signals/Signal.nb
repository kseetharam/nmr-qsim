Cell[CellGroupData[{

Cell["\<\
time coordinates are already embedded; deduce sample interval\
\>", "Subsubsection",
 InitializationCell->True,
 CellChangeTimes->{{3.451571591451517*^9, 3.451571606545855*^9}, {
  3.451574862725444*^9, 3.451574864017373*^9}, {3.530536052633671*^9, 
  3.530536053671822*^9}},ExpressionUUID->"90bcbb0e-4c8c-460d-bfbf-\
e66a99e4c138"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"FT", "[", 
     RowBox[{
      RowBox[{"sig1D_", "?", "MatrixQ"}], ",", "opts___Rule"}], "]"}], "/;", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"MatchQ", "[", 
       RowBox[{
        RowBox[{"Dimensions", "[", "sig1D", "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"_", ",", "2"}], "}"}]}], "]"}], "&&", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"EmbedCoordinates", "/.", 
         RowBox[{"{", "opts", "}"}]}], "/.", 
        RowBox[{"Options", "[", "FT", "]"}]}], ")"}], "&&", 
      "\[IndentingNewLine]", 
      RowBox[{"MatchQ", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"SampleInterval", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "FT", "]"}]}], ",", "Automatic"}], "]"}], "&&",
       "\[IndentingNewLine]", 
      RowBox[{"MatchQ", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"LineBroadening", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "FT", "]"}]}], ",", 
        RowBox[{"None", "|", "False"}]}], "]"}]}], "\[IndentingNewLine]", 
     ")"}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"tcoords", ",", "n", ",", "\[Delta]t"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"tcoords", "=", 
        RowBox[{"First", "/@", "sig1D"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"\[Delta]t", "=", 
        RowBox[{
         RowBox[{
         "tcoords", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}], 
         "-", 
         RowBox[{
         "tcoords", "\[LeftDoubleBracket]", "1", 
          "\[RightDoubleBracket]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"n", "=", 
        RowBox[{"Length", "[", "tcoords", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"Chop", "@", 
           RowBox[{"N", "[", 
            RowBox[{
             RowBox[{"Table", "[", 
              RowBox[{
               RowBox[{"i", "*", "\[Delta]t"}], ",", 
               RowBox[{"{", 
                RowBox[{"i", ",", "0", ",", 
                 RowBox[{"n", "-", "1"}]}], "}"}]}], "]"}], "-", "tcoords"}], 
            "]"}]}], "\[Equal]", 
          RowBox[{"Table", "[", 
