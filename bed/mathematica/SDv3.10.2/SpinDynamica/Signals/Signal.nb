Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Signal", "[", 
     RowBox[{
      RowBox[{"times", ":", 
       RowBox[{"{", 
        RowBox[{"tmin_", ",", "tmax_", ",", "\[Delta]t_"}], "}"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"type_String", ",", "peaks_List"}], "}"}], ",", 
      "opts___Rule"}], "]"}], "/;", 
    RowBox[{"!", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"PeakReductionImplemented", "/.", 
        RowBox[{"{", "opts", "}"}]}], "/.", 
       RowBox[{"Options", "[", "Signal", "]"}]}], ")"}]}]}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "avals", ",", "\[Omega]vals", ",", "\[Lambda]vals", ",", 
       "reduced\[Omega]vals", ",", "T", ",", "n", ",", "ZF", ",", "nZF", ",", 
       "\[Delta]\[Omega]", ",", "\[Omega]min", ",", "\[Omega]max", ",", 
       "reducedpeaks", ",", "snapped"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"ZF", ",", "\[Delta]\[Omega]"}], "}"}], "=", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{"ZeroFill", ",", "DigitalFrequencyResolution"}], "}"}], "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "Signal", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"avals", ",", "\[Omega]vals", ",", "\[Lambda]vals"}], "}"}], 
        "=", "\[IndentingNewLine]", 
        RowBox[{"Transpose", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"MatchQ", "[", 
              RowBox[{"#", ",", 
               RowBox[{"{", "}"}]}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"{", 
               RowBox[{"0", ",", "0", ",", "0"}], "}"}], "}"}], ",", "#"}], 
            "]"}], "&"}], "@", "\[IndentingNewLine]", 
          RowBox[{"Select", "[", 
           RowBox[{"peaks", ",", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"Chop", "@", 
                RowBox[{"N", "@", 
                 RowBox[{"First", "[", "#", "]"}]}]}], "\[NotEqual]", "0"}], 
              ")"}], "&"}]}], "]"}]}], "\[IndentingNewLine]", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"reduced\[Omega]vals", ",", "snapped"}], "}"}], "=", 
        RowBox[{"If", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"NumericQ", "[", "\[Delta]\[Omega]", "]"}], "&&", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"Chop", "[", "\[Delta]\[Omega]", "]"}], ">", "0"}], 
            ")"}]}], ",", "\[IndentingNewLine]", "\t", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"T", "=", 
             RowBox[{"tmax", "-", "tmin"}]}], ";", "\[IndentingNewLine]", 
            "\t", 
            RowBox[{"n", "=", 
             RowBox[{
              RowBox[{"Round", "[", 
               RowBox[{"Abs", "[", 
                RowBox[{"T", "/", "\[Delta]t"}], "]"}], "]"}], "+", "1"}]}], 
            ";", "\[IndentingNewLine]", "\t", 
            RowBox[{"nZF", "=", 
             RowBox[{"ZF", "\[Times]", "n"}]}], ";", "\[IndentingNewLine]", 
            "\t", 
            RowBox[{"\[Delta]\[Omega]", "=", 
             RowBox[{
              RowBox[{"Abs", "[", 
               RowBox[{"2", 
                RowBox[{"\[Pi]", "/", "\[Delta]t"}]}], "]"}], "/", "nZF"}]}], 
            ";", "\[IndentingNewLine]", "\t", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"\[Omega]min", ",", "\[Omega]max"}], "}"}], "=", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{
                 RowBox[{"-", 
                  RowBox[{"(", 
                   RowBox[{"nZF", "/", "2"}], ")"}]}], "+", "1"}], ",", 
                RowBox[{"nZF", "/", "2"}]}], "}"}], "\[Times]", 
              "\[Delta]\[Omega]"}]}], ";", "\[IndentingNewLine]", "\t", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"Mod", "[", 
                 RowBox[{
                  RowBox[{"\[Delta]\[Omega]", "\[Times]", 
                   RowBox[{"Round", "[", 
                    RowBox[{"#", "/", "\[Delta]\[Omega]"}], "]"}]}], ",", 
                  RowBox[{"nZF", " ", "\[Delta]\[Omega]"}], ",", 
                  "\[Omega]min"}], "]"}], "&"}], "/@", "\[Omega]vals"}], ",", 
              "True"}], "}"}]}], "\[IndentingNewLine]", ")"}], ",", 
          "\[IndentingNewLine]", "\t", 
          RowBox[{"{", 
           RowBox[{"\[Omega]vals", ",", "False"}], "}"}]}], 
         "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"reducedpeaks", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Apply", "[", 
             RowBox[{"Plus", ",", 
              RowBox[{"First", "[", 
               RowBox[{"Transpose", "[", "#", "]"}], "]"}]}], "]"}], ",", 
            RowBox[{"#", "\[LeftDoubleBracket]", 
             RowBox[{"1", ",", "2"}], "\[RightDoubleBracket]"}], ",", 
            RowBox[{"#", "\[LeftDoubleBracket]", 
             RowBox[{"1", ",", "3"}], "\[RightDoubleBracket]"}]}], "}"}], 
          "&"}], "/@", "\[IndentingNewLine]", 
         RowBox[{"GatherBy", "[", 
          RowBox[{
           RowBox[{"Transpose", "[", 
            RowBox[{"{", 
             RowBox[{
             "avals", ",", "reduced\[Omega]vals", ",", "\[Lambda]vals"}], 
             "}"}], "]"}], ",", "Rest"}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Signal", "[", 
        RowBox[{"times", ",", "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"type", ",", 
           RowBox[{"N", "@", "reducedpeaks"}]}], "}"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"Evaluate", "@", 
          RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"PeakReductionImplemented", "\[Rule]", "True"}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"PeaksSnappedToFrequencyGrid", "\[Rule]", "snapped"}], 
            ",", "\[IndentingNewLine]", "opts"}], "\[IndentingNewLine]", 
           "]"}]}]}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
      ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.5058461400016813`*^9, 3.5058462745850163`*^9}, {
