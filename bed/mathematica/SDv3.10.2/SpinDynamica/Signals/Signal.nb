           RowBox[{"(", 
            RowBox[{
             RowBox[{"First", "[", "dims", "]"}], "\[NotEqual]", "2"}], ")"}],
            "||", "\[IndentingNewLine]", 
           RowBox[{"(", 
            RowBox[{"!", 
             RowBox[{"Equal", "@@", 
              RowBox[{"(", 
               RowBox[{"First", "/@", 
                RowBox[{"Transpose", "/@", "datasets"}]}], ")"}]}]}], ")"}]}],
           "\[IndentingNewLine]", ")"}]}]}], "\[IndentingNewLine]", ")"}]}], 
