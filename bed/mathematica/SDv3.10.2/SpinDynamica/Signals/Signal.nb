Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"AddFrequencyCoordinates", "[", 
    RowBox[{
     RowBox[{"S2D_", "?", "MatrixQ"}], ",", "opts___Rule"}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"sw1", ",", "sw2", ",", "n1", ",", "n2", ",", "freqs"}], "}"}],
       ",", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{"n1", ",", "n2"}], "}"}], "=", 
         RowBox[{"Dimensions", "[", "S2D", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"sw1", ",", "sw2"}], "}"}], "=", 
         RowBox[{
          RowBox[{"SampleFrequency", "/.", 
           RowBox[{"{", "opts", "}"}]}], "/.", 
          RowBox[{"Options", "[", "FT", "]"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"freqs", "=", 
         RowBox[{"Flatten", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"Outer", "[", 
            RowBox[{"List", ",", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"Range", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"-", 
                  RowBox[{"(", 
                   RowBox[{"n1", "/", "2"}], ")"}]}], "+", "1"}], ",", 
                RowBox[{"(", 
                 RowBox[{"n1", "/", "2"}], ")"}]}], "]"}], "*", 
              RowBox[{"sw1", "/", "n1"}]}], ",", 
             RowBox[{
              RowBox[{"Range", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"-", 
                  RowBox[{"(", 
                   RowBox[{"n2", "/", "2"}], ")"}]}], "+", "1"}], ",", 
                RowBox[{"(", 
                 RowBox[{"n2", "/", "2"}], ")"}]}], "]"}], "*", 
              RowBox[{"sw2", "/", "n2"}]}]}], "\[IndentingNewLine]", "]"}], 
           "\[IndentingNewLine]", ",", "1"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Flatten", "/@", 
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"freqs", "/", 
             RowBox[{"(", 
              RowBox[{"sw1", "\[Times]", "sw2"}], ")"}]}], ",", 
            RowBox[{"Flatten", "[", "S2D", "]"}]}], "}"}], "]"}]}]}], 
       "\[IndentingNewLine]", ")"}]}], "]"}], "/;", 
    RowBox[{"(", 
     RowBox[{"MatchQ", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"SampleFrequency", "/.", 
         RowBox[{"{", "opts", "}"}]}], "/.", 
        RowBox[{"Options", "[", "FT", "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"_", ",", "_"}], "}"}]}], "]"}], ")"}]}]}], ";"}]], "Input",
