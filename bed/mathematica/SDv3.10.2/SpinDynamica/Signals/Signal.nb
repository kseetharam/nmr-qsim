Cell[BoxData[
 RowBox[{
  RowBox[{"Signal", "/:", 
   RowBox[{
    RowBox[{"Expand", "[", 
     RowBox[{"Signal", "[", 
      RowBox[{
       RowBox[{"times", ":", 
        RowBox[{"{", 
         RowBox[{"tmin_", ",", "tmax_", ",", "\[Delta]t_"}], "}"}]}], ",", 
       "data_", ",", "opts___Rule"}], "]"}], "]"}], "/;", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"EmbedCoordinates", "/.", 
       RowBox[{"{", "opts", "}"}]}], "/.", 
      RowBox[{"Options", "[", "Signal", "]"}]}], ")"}]}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "n", "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"n", "=", 
        RowBox[{
         RowBox[{"Round", "[", 
          RowBox[{"Abs", "[", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"tmax", "-", "tmin"}], ")"}], "/", "\[Delta]t"}], "]"}], 
          "]"}], "+", "1"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Transpose", "[", "\[IndentingNewLine]", 
        RowBox[{"{", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"tmin", "+", 
             RowBox[{"i", " ", "\[Delta]t"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"i", ",", "0", ",", 
              RowBox[{"n", "-", "1"}]}], "}"}]}], "]"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"Expand", "@", 
           RowBox[{"Signal", "[", 
            RowBox[{"times", ",", "data", ",", "\[IndentingNewLine]", 
             RowBox[{"SimplifyRules", "[", 
              RowBox[{
               RowBox[{"EmbedCoordinates", "\[Rule]", "False"}], ",", 
               "opts"}], "]"}]}], "\[IndentingNewLine]", "]"}]}]}], 
         "\[IndentingNewLine]", "}"}], "\[IndentingNewLine]", "]"}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
