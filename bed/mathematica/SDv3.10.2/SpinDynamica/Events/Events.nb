Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"PropagationMethod", "::", "usage"}], "=", 
   "\"\<PropagationMethod is an option for individual events. Possible \
PropagationMethods are Automatic and Adiabatic. Automatic employs standard \
numerical methods to solve the Schroedinger equation. Adiabatic on the other \
hand assumes adiabaticity along the whole event to solve the Schrodinger \
equation leading to speed improvements in most cases. The default option for \
PropagationMethod is: ProapgationMethod \[Rule] Automatic.\>\""}], 
  ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 CellChangeTimes->{{3.464694550960771*^9, 3.464694675026797*^9}, {
  3.534398274061007*^9, 3.534398286276984*^9}, {3.719834367855938*^9, 
  3.719834370136247*^9}, {3.719834891665898*^9, 3.71983489771011*^9}, {
  3.7280391153480434`*^9, 3.728039246721529*^9}, {3.7280393269141645`*^9, 
  3.72803935532952*^9}, {3.728039413889021*^9, 3.728039447624425*^9}, {
  3.7280398611584682`*^9, 3.7280398931260805`*^9}},
 CellLabel->"In[19]:=",ExpressionUUID->"3d291e98-fded-4198-9a7a-8ee914c2f6e6"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Adiabatic", "::", "usage"}], "=", 
   "\"\<Adiabatic is a possible PropagationMethod for a single event. \
SpinDynamica then assumes adiabaticity for the specified event. A set of \
correlated adiabatic eigenstates may then be calculated along the \
time-trajectory of the event, which may then be used to determine the final \
state of the system.\n\n\tAn adiabatic propagation scheme may be used in \
combination with NPropagate. For\n\tnon adiabatic events the propagation of \
an initial density operator may be achieved\n\tas follows:\n\n\t\
NPropagte[{generator, duration}][rho]\n\n\tThe assumption of an adiabatic \
event may then be specified as shown below:\n\n\tNPropagte[{generator, \
duration, PropagationMethod \[Rule] Adiabatic, EventSampling \[Rule] \
100}][rho]\n\n\tThe PropagationMethod option tells SpinDynamica that this \
event should be considered to be fully adiabatic. The EventSampling option \
tells SpinDynamica how to discretize the total duration for the adiabatic \
propagation scheme. More information on PropagationMethod and EventSampling \
may be found by executing \\\"?PropagationMethod\\\" \
and\\\"?EventSampling\\\".\n\>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 CellChangeTimes->{{3.464694550960771*^9, 3.464694675026797*^9}, {
  3.534398274061007*^9, 3.534398286276984*^9}, {3.719834367855938*^9, 
  3.719834370136247*^9}, {3.719834891665898*^9, 3.71983489771011*^9}, {
  3.719834989309648*^9, 3.7198350220795364`*^9}, {3.728039253025599*^9, 
  3.728039258314784*^9}, {3.728039299690678*^9, 3.728039308786084*^9}, {
  3.728039372450774*^9, 3.7280393964808836`*^9}, {3.72803946753621*^9, 
  3.728039477391576*^9}, {3.728039703903517*^9, 3.728039806943724*^9}, {
  3.7504121920224075`*^9, 3.750412565738083*^9}, {3.7504126146118193`*^9, 
  3.750412628957901*^9}},
 CellLabel->"In[20]:=",ExpressionUUID->"ef655e92-7d05-442d-94b7-6d8905ac8acb"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"EventSampling", "::", "usage"}], "=", 
   "\"\<EventSampling may be used to specify the time-sampling of an \
adiabatic event. EventSampling may be of the following forms:\nUsing an \
integer, N:\n- EventSampling \[Rule] N\nSpinDynamica will then uniformly \
distribute the overall duration of the event into N pieces.\nUsing a specific \
timegrid:\n- EventSampling \[Rule] {\!\(\*SubscriptBox[\(t\), \(1\)]\), \
\!\(\*SubscriptBox[\(t\), \(2\)]\), ..., T}\nSpinDynamica will make use of \
the specified timegrid to calculate the adiabatic eigenstates.\n\>\""}], 
  ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 CellChangeTimes->{{3.464694550960771*^9, 3.464694675026797*^9}, {
   3.534398274061007*^9, 3.534398286276984*^9}, {3.719834367855938*^9, 
   3.719834370136247*^9}, {3.719834891665898*^9, 3.71983489771011*^9}, {
   3.719834989309648*^9, 3.7198350220795364`*^9}, {3.719835800477024*^9, 
   3.719835824487556*^9}, {3.728039483758486*^9, 3.728039660670645*^9}, {
   3.7280402814179797`*^9, 3.728040282937043*^9}, {3.728042208723099*^9, 
   3.728042209716738*^9}, 3.7504119944480505`*^9},
 CellLabel->"In[21]:=",ExpressionUUID->"7879936f-cbf6-4ff0-9b80-1eeb573da296"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"DeleteCoherences", "::", "usage"}], "=", 
   "\"\<DeleteCoherences may be used to specify whether SpinDynamica should \
also propagate coherences during an adiabatic event or not. By default \
SpinDynamica assumes DeleteCoherences \[Rule] True. Coherences will then not \
be propagated and neglected and removed from the initial density operator. If \
DeleteCoherences \[Rule] False is chosen SpinDynamica will also propagate \
coherences. During an adiabatic event coherences will aquire an additional \
phase, \[Phi]. Generally \[Phi] may have two contributions, a dynamic phase \
\!\(\*SubscriptBox[\(\[Phi]\), \(dyn\)]\) and a geometric phase \
\!\(\*SubscriptBox[\(\[Phi]\), \(geo\)]\). SpinDynamica will attempt to \
calculate both of these contributions.\>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 CellChangeTimes->{{3.464694550960771*^9, 3.464694675026797*^9}, {
  3.534398274061007*^9, 3.534398286276984*^9}, {3.719834367855938*^9, 
  3.719834370136247*^9}, {3.719834891665898*^9, 3.71983489771011*^9}, {
  3.719834989309648*^9, 3.7198350220795364`*^9}, {3.719835800477024*^9, 
  3.719835824487556*^9}, {3.719850696470831*^9, 3.7198507210299826`*^9}, {
  3.728039822888203*^9, 3.728039853798623*^9}, {3.728039906783579*^9, 
  3.728039937382136*^9}, {3.728039976885955*^9, 3.72804012718071*^9}, {
  3.7280402078287306`*^9, 3.728040217051194*^9}},
 CellLabel->"In[22]:=",ExpressionUUID->"5d791b3a-cad8-486d-b329-04f00dbddc87"]
}, Closed]]
}, Closed]],

