Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"TransferElement", "[", 
    RowBox[{"source_List", ",", "target_List", ",", "\[Delta]t_"}], "]"}], ":=",
    "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"firstel", ",", "first\[Tau]"}], "}"}], ",", 
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{"TransferElement", "[", 
        RowBox[{
         RowBox[{"Most", "@", "source"}], ",", 
         RowBox[{"Join", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"Last", "@", "source"}], "}"}], ",", "target"}], "]"}], 
         ",", 
         RowBox[{"\[Delta]t", "-", "first\[Tau]"}]}], "]"}], 
       "\[IndentingNewLine]", ")"}], "/;", 
      RowBox[{"(", " ", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Length", "[", "source", "]"}], "\[GreaterEqual]", "1"}], 
         ")"}], "&&", 
        RowBox[{"(", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"firstel", "=", 
           RowBox[{"Last", "@", "source"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"first\[Tau]", "=", 
           RowBox[{"Duration", "[", "firstel", "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"first\[Tau]", "\[LessEqual]", "\[Delta]t"}], ")"}], "&&", 
           RowBox[{
            RowBox[{"Chop", "[", "first\[Tau]", "]"}], "\[NotEqual]", 
            "0"}]}]}], "\[IndentingNewLine]", ")"}]}], "\[IndentingNewLine]", 
