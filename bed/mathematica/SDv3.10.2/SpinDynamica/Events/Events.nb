Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"MixedHilbertSpaceCompatibility", "::", "usage"}], "=", 
   "\"\<MixedHilbertSpaceCompatibility is an event property used internally \
by SpinDynamica. The HilbertSpaceCompatibility of an EventList takes the \
value MixedHilbertSpaceCompatibility if some, but not all, of the contained \
