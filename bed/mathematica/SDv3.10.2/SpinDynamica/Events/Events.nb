Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"EventSpecifications", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"status", ":", 
       RowBox[{"{", 
        RowBox[{"checkstatus_", ",", "False", ",", "nestliststatus_", ",", 
         RowBox[{"{", 
          RowBox[{"True", ",", "morestandstatus___"}], "}"}], ",", 
         "morestatus___"}], "}"}]}], ",", "\[IndentingNewLine]", 
      "evspecs_List", ",", "\[IndentingNewLine]", "opts___Rule"}], 
     "\[IndentingNewLine]", "]"}], "/;", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Count", "[", 
       RowBox[{"evspecs", ",", 
        RowBox[{"EventSpecifications", "[", 
         RowBox[{
          RowBox[{"True", "|", 
           RowBox[{"{", 
            RowBox[{"_", ",", "True", ",", "___"}], "}"}]}], ",", "___"}], 
         "]"}], ",", 
        RowBox[{"{", "1", "}"}]}], "]"}], "\[GreaterEqual]", "1"}], ")"}]}], ":=",
    "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "newstatus", "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"newstatus", "=", 
        RowBox[{"{", 
         RowBox[{
         "checkstatus", ",", "False", ",", "nestliststatus", ",", 
          "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{"True", ",", "morestandstatus"}], "}"}], ",", 
          "morestatus"}], "}"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Verbose", "/.", 
             RowBox[{"{", "opts", "}"}]}], "/.", 
            RowBox[{"Options", "[", "EventSpecifications", "]"}]}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"Print", "[", 
            RowBox[{
            "\"\<EventSpecifications: absorbing EventSpecifications arguments \
with reversed chronology (case 1): \>\"", ",", 
             RowBox[{
              RowBox[{"Expand", "[", "evspecs", "]"}], "/.", 
              RowBox[{"s_TimeDependentGeneratorFunction", "\[RuleDelayed]", 
               RowBox[{"s", "\[LeftDoubleBracket]", 
                RowBox[{"{", "4", "}"}], "\[RightDoubleBracket]"}]}]}]}], 
            "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"EventSpecifications", "[", "\[IndentingNewLine]", 
          RowBox[{"status", ",", "\[IndentingNewLine]", 
           RowBox[{"Replace", "[", "\[IndentingNewLine]", 
            RowBox[{"evspecs", ",", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"EventSpecifications", "[", 
               RowBox[{
                RowBox[{"True", "|", 
                 RowBox[{"{", 
                  RowBox[{"_", ",", "True", ",", "___"}], "}"}]}], ",", 
                RowBox[{"args", ":", 
                 RowBox[{
                  RowBox[{"Except", "[", "_Rule", "]"}], "..."}]}], ",", 
                "___Rule"}], "]"}], "\[RuleDelayed]", 
              RowBox[{"Sequence", "@@", 
               RowBox[{"Reverse", "[", "args", "]"}]}]}], ",", 
             "\[IndentingNewLine]", "1"}], "\[IndentingNewLine]", "]"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"Chronology", "\[Rule]", "\"\<LeftToRight\>\""}], ",", 
             "\[IndentingNewLine]", "opts"}], "\[IndentingNewLine]", "]"}]}], 
          "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", ")"}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
