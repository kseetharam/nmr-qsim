Cell["implement only if the number of repeats is numeric.", "Text",
 CellChangeTimes->{{3.689419161644956*^9, 3.6894191739701366`*^9}, {
  3.689421670780853*^9, 3.689421679155484*^9}, {3.689421721728045*^9, 
