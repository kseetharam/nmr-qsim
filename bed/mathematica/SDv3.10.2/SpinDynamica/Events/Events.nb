Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"HoldPattern", "@", 
    RowBox[{"EventSpecifications", "[", 
     RowBox[{
      RowBox[{"evspecst", ":", 
       RowBox[{"{", 
        RowBox[{
        "checkstatus_", ",", "chronstatus_", ",", "nestliststatus_", ",", 
         "standstatus_", ",", 
         RowBox[{"{", 
          RowBox[{"True", ",", "False"}], "}"}], ",", "otherstatus___"}], 
        "}"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"evsa___", ",", 
        RowBox[{"rep", ":", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Repeat", "[", 
            RowBox[{"_", ",", "1", ",", "___Rule"}], "]"}], ",", "___Rule"}], 
          "}"}]}], ",", "evsb___"}], "}"}], ",", "opts___Rule"}], "]"}]}], ":=",
    "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "edit", "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"Print", "[", "1", "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"Print", "[", 
         RowBox[{"rep", "/.", 
          RowBox[{"Repeat", "\[Rule]", "repeat"}]}], "]"}], ";"}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"edit", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{"chronstatus", ",", "#", ",", 
            RowBox[{"Reverse", "@", "#"}]}], "]"}], "&"}], "@", 
         RowBox[{"rep", "\[LeftDoubleBracket]", 
          RowBox[{"1", ",", "1", ",", "3"}], "\[RightDoubleBracket]"}]}]}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"Print", "[", "edit", "]"}], ";"}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"EventSpecifications", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "False", ",", "chronstatus", ",", "False", ",", "False", ",", 
           "False", ",", "otherstatus"}], "}"}], ",", "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"evsa", ",", 
           RowBox[{"Sequence", "@@", "edit"}], ",", "evsb"}], "}"}], ",", 
         "\[IndentingNewLine]", "opts"}], "\[IndentingNewLine]", "]"}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
