Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SplitElement", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"evgen", ":", 
        RowBox[{"TimeDependentGeneratorFunction", "[", 
         RowBox[{"t_", ",", 
          RowBox[{"\[Tau]xpairs_", "?", "MatrixQ"}], ",", "T_", ",", 
          "func_"}], "]"}]}], ",", "\[Tau]_", ",", "opts___Rule"}], "}"}], 
     ",", "\[Delta]t_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Tau]vals", ",", "xvals", ",", "xvals1", ",", "xvals2", ",", 
       "\[Tau]xpairs1", ",", "\[Tau]xpairs2"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"\[Tau]vals", ",", "xvals"}], "}"}], "=", 
        RowBox[{"Transpose", "[", "\[Tau]xpairs", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"xvals1", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"#", " ", 
            RowBox[{"\[Tau]", "/", "\[Delta]t"}]}], ")"}], "&"}], "/@", 
         "xvals"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"xvals2", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"#", " ", "\[Tau]"}], "-", "\[Delta]t"}], ")"}], "/", 
            RowBox[{"(", 
             RowBox[{"\[Tau]", "-", "\[Delta]t"}], ")"}]}], ")"}], "&"}], "/@",
          "xvals"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"\[Tau]xpairs1", "=", 
        RowBox[{"Transpose", "[", 
         RowBox[{"{", 
          RowBox[{"\[Tau]vals", ",", "xvals1"}], "}"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"\[Tau]xpairs2", "=", 
        RowBox[{"Transpose", "[", 
         RowBox[{"{", 
          RowBox[{"\[Tau]vals", ",", "xvals2"}], "}"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"TimeDependentGeneratorFunction", "[", 
            RowBox[{"t", ",", 
             RowBox[{"Evaluate", "@", "\[Tau]xpairs2"}], ",", "T", ",", 
             "func"}], "]"}], ",", 
           RowBox[{"Chop", "[", 
            RowBox[{"\[Tau]", "-", "\[Delta]t"}], "]"}], ",", "opts"}], "}"}],
          ",", "\[IndentingNewLine]", 
