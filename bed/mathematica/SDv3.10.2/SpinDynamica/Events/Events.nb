         "checkstatus", ",", "True", ",", "nestliststatus", ",", 
          "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{
           "True", ",", "stemp", ",", "stop", ",", "True", ",", 
            "morestandstatus"}], "}"}], ",", "morestatus"}], "}"}]}], ";", 
       "\[IndentingNewLine]", 
