Cell[BoxData[
 RowBox[{
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{"$VersionNumber", "<", "11"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Duration", "::", "usage"}], "=", 
     "\"\<Duration[args] returns the total duration of an event, an event \
sequence, a pulse sequence event, or a PulseSequence object.\>\""}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"UserLevelDependentDefinition", "[", 
     RowBox[{"Duration", ",", "Infinity", ",", "\[IndentingNewLine]", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"Duration", "::", "usage"}], "=", 
         "\"\<Duration is a built-in Mathematica symbol, intended for sound \
and video files. It has been redefined in SpinDynamica to allow calculation \
of the total duration of a SpinDynamica event, an event sequence, a pulse \
sequence event, or a PulseSequence object. The Listable attribute of Duration \
has been removed.\>\""}], ";", "\[IndentingNewLine]", 
        RowBox[{"Off", "[", 
         RowBox[{"Duration", "::", "durinv"}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"ClearAttributes", "[", 
         RowBox[{"Duration", ",", "Listable"}], "]"}], ";"}], 
       "\[IndentingNewLine]", ")"}]}], "\[IndentingNewLine]", "]"}]}], 
