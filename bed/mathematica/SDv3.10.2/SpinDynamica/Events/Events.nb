Cell["\<\
splits an event of finite time into two parts. For time-independent evolution \
generators this is trivial. However handling of the local time variables in \
TimeDependentGeneratorFunction requires care. \
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.626369767265826*^9, 3.626369830092209*^9}, 
   3.8168481758767953`*^9},ExpressionUUID->"307e2706-387d-4317-9bf7-\
02998b01d5af"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SplitElement", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"evgen", ":", 
        RowBox[{"(", 
         RowBox[{"None", "|", 
          RowBox[{"_", "?", "OperatorQ"}], "|", 
          RowBox[{"_", "?", "SuperoperatorQ"}]}], ")"}]}], ",", "\[Tau]_", 
       ",", "opts___Rule"}], "}"}], ",", "\[Delta]t_"}], "]"}], ":=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"evgen", ",", 
       RowBox[{"Chop", "[", 
        RowBox[{"\[Tau]", "-", "\[Delta]t"}], "]"}], ",", "opts"}], "}"}], 
     ",", 
     RowBox[{"{", 
      RowBox[{"evgen", ",", 
       RowBox[{"Chop", "[", "\[Delta]t", "]"}], ",", "opts"}], "}"}]}], 
    "}"}]}], ";"}]], "Input",
 InitializationCell->True,
