Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"EventSpecifications", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"status", ":", 
      RowBox[{"{", 
       RowBox[{
       "checkstatus_", ",", "chronstatus_", ",", "nestliststatus_", ",", 
        RowBox[{"{", 
         RowBox[{
         "True", ",", "stemp_", ",", "stop_", ",", "ststr_", ",", "False"}], 
         "}"}], ",", "morestatus___"}], "}"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"evspecs__", ",", "evspecsopts___Rule"}], "}"}], ",", 
     "opts___Rule"}], "\[IndentingNewLine]", "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"stdevspecs", ",", "newstandstatus", ",", "fevspecpatts"}], 
      "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Verbose", "/.", 
           RowBox[{"{", "opts", "}"}]}], "/.", 
          RowBox[{"Options", "[", "EventSpecifications", "]"}]}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"Print", "[", 
          RowBox[{
          "\"\<EventSpecifications: standardizing event specifications: \>\"",
            ",", 
           RowBox[{
            RowBox[{"Expand", "@", 
             RowBox[{"{", 
              RowBox[{"evspecs", ",", "evspecsopts"}], "}"}]}], "/.", 
            RowBox[{"s_TimeDependentGeneratorFunction", "\[RuleDelayed]", 
             RowBox[{"s", "\[LeftDoubleBracket]", 
              RowBox[{"{", "4", "}"}], "\[RightDoubleBracket]"}]}]}]}], 
          "]"}]}], "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"fevspecpatts", "=", 
        RowBox[{"Alternatives", "@@", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"FurtherEventSpecificationPatterns", "/.", 
            RowBox[{"{", "opts", "}"}]}], "/.", 
           RowBox[{"Options", "[", "EventSpecifications", "]"}]}], ")"}]}]}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"stdevspecs", "=", 
        RowBox[{"Sequence", "@@", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Function", "[", 
            RowBox[{"evspec", ",", "\[IndentingNewLine]", 
             RowBox[{"Switch", "[", 
              RowBox[{"evspec", ",", "\[IndentingNewLine]", 
               RowBox[{"_", "?", "StandardizedEventSpecificationQ"}], ",", 
               "evspec", ",", "\[IndentingNewLine]", "fevspecpatts", ",", 
               "\[IndentingNewLine]", "\t", 
               RowBox[{"StandardizeEventSpecification", "[", 
                RowBox[{"evspec", ",", "opts"}], "]"}], ",", 
               "\[IndentingNewLine]", "NonStandardEventSpecificationPattern", 
               ",", "\[IndentingNewLine]", "\t", 
               RowBox[{"StandardizeEventSpecification", "[", 
                RowBox[{"evspec", ",", "opts"}], "]"}], ",", 
               "\[IndentingNewLine]", 
               RowBox[{
                RowBox[{"EventSpecifications", "[", 
                 RowBox[{"True", ",", "___"}], "]"}], "|", 
                RowBox[{"EventSpecifications", "[", 
                 RowBox[{
                  RowBox[{"{", 
                   RowBox[{"_", ",", "_", ",", "_", ",", "True", ",", "___"}],
                    "}"}], ",", "___"}], "]"}]}], ",", "\[IndentingNewLine]", 
               "\t", "evspec", ",", "\[IndentingNewLine]", "_List", ",", 
               RowBox[{"EventSpecifications", "[", 
                RowBox[{"False", ",", "evspec", ",", 
                 RowBox[{"SimplifyRules", "[", 
                  RowBox[{"evspecsopts", ",", "opts"}], "]"}]}], "]"}], ",", 
               "\[IndentingNewLine]", "_Event", ",", 
               RowBox[{"evspec", "/.", 
                RowBox[{
                 RowBox[{"Event", "[", 
                  RowBox[{"_", ",", "_", ",", 
                   RowBox[{"spec", ":", 
                    RowBox[{"Except", "[", "_Rule", "]"}]}], ",", "___Rule"}],
                   "]"}], "\[RuleDelayed]", "spec"}]}], ",", 
               "\[IndentingNewLine]", "_EventList", ",", 
               RowBox[{"evspec", "/.", 
                RowBox[{
                 RowBox[{"EventList", "[", 
                  RowBox[{"_", ",", "_", ",", "specs_List", ",", "___Rule"}], 
                  "]"}], "\[RuleDelayed]", "\[IndentingNewLine]", 
                 RowBox[{"If", "[", 
                  RowBox[{"chronstatus", ",", 
                   RowBox[{"EventSpecifications", "/@", "specs"}], ",", 
                   RowBox[{"EventSpecifications", "/@", 
                    RowBox[{"Reverse", "[", "specs", "]"}]}]}], "]"}]}]}], 
               ",", "\[IndentingNewLine]", "_", ",", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"Message", "[", 
                  RowBox[{
                   RowBox[{"EventSpecifications", "::", "inval"}], ",", 
                   "evspec"}], "]"}], ";", "$Failed"}], ")"}]}], 
              "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", "]"}], "/@", 
           RowBox[{"{", "evspecs", "}"}]}], ")"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"newstandstatus", "=", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"MemberQ", "[", 
           RowBox[{
            RowBox[{"{", "stdevspecs", "}"}], ",", 
            RowBox[{"EventSpecifications", "[", 
             RowBox[{
              RowBox[{"Except", "[", "True", "]"}], ",", "___"}], "]"}]}], 
           "]"}], ",", "False", ",", "True"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"EventSpecifications", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "checkstatus", ",", "chronstatus", ",", "nestliststatus", ",", 
           "\[IndentingNewLine]", 
           RowBox[{"{", 
            RowBox[{
            "True", ",", "False", ",", "False", ",", "False", ",", 
             "newstandstatus"}], "}"}], ",", "\[IndentingNewLine]", 
           "morestatus"}], "}"}], ",", "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"stdevspecs", ",", 
           RowBox[{"SimplifyRules", "[", 
            RowBox[{"evspecsopts", ",", "opts"}], "]"}]}], "}"}], ",", 
         "\[IndentingNewLine]", "opts"}], "\[IndentingNewLine]", "]"}]}], 
      "\[IndentingNewLine]", ")"}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.691054668801583*^9, 3.691054711842752*^9}, {
   3.691054777532371*^9, 3.691054783858348*^9}, {3.6910548739604397`*^9, 
