Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"EventSpecifications", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"evspecst", ":", 
      RowBox[{"{", 
       RowBox[{
       "checkstatus_", ",", "chronstatus_", ",", "nestliststatus_", ",", 
        "standstatus_", ",", 
        RowBox[{"{", 
         RowBox[{"True", ",", "False"}], "}"}], ",", "otherstatus___"}], 
       "}"}]}], ",", "\[IndentingNewLine]", "evspecs_List", ",", 
     "\[IndentingNewLine]", "opts___Rule"}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"(", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Verbose", "/.", 
         RowBox[{"{", "opts", "}"}]}], "/.", 
        RowBox[{"Options", "[", "EventSpecifications", "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<EventSpecifications: handling Repeat: \>\"", ",", 
         RowBox[{
          RowBox[{"Expand", "@", 
           RowBox[{"{", 
            RowBox[{"evspecst", ",", "evspecs"}], "}"}]}], "/.", 
          RowBox[{"s_TimeDependentGeneratorFunction", "\[RuleDelayed]", 
           RowBox[{"s", "\[LeftDoubleBracket]", 
            RowBox[{"{", "4", "}"}], "\[RightDoubleBracket]"}]}]}]}], "]"}]}],
       "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"EventSpecifications", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "False", ",", "chronstatus", ",", "False", ",", "False", ",", "True", 
         ",", "otherstatus"}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"evspecs", "/.", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{"evsa___", ",", 
            RowBox[{"Repeat", "[", 
             RowBox[{
              RowBox[{"EventList", "[", 
               RowBox[{"_", ",", "_", ",", 
                RowBox[{"events", ":", 
                 RowBox[{"{", 
                  RowBox[{"_Event", ".."}], "}"}]}], ",", 
                "evlistopts___Rule"}], "]"}], ",", "n_Integer", ",", 
              "repevopts___Rule"}], "]"}], ",", "evsb___", ",", 
            "evsopts___Rule"}], "}"}], "/;", 
          RowBox[{"TrueQ", "[", 
           RowBox[{
            RowBox[{"ExpandRepeatedEvents", "/.", 
             RowBox[{"{", 
              RowBox[{"repevopts", ",", "evsopts"}], "}"}]}], "/.", 
            RowBox[{"Options", "[", "EventSpecifications", "]"}]}], "]"}]}], ":>",
          "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"evsa", ",", "\[IndentingNewLine]", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Sequence", "@@", 
              RowBox[{"If", "[", 
               RowBox[{"chronstatus", ",", 
                RowBox[{"Table", "[", 
                 RowBox[{"events", ",", 
                  RowBox[{"{", "n", "}"}]}], "]"}], ",", 
                RowBox[{"Table", "[", 
                 RowBox[{
                  RowBox[{"Reverse", "@", "events"}], ",", 
                  RowBox[{"{", "n", "}"}]}], "]"}]}], "]"}]}], ",", 
             "\[IndentingNewLine]", 
             RowBox[{"Sequence", "@@", 
              RowBox[{"Cases", "[", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"evlistopts", ",", "repevopts"}], "}"}], ",", 
                RowBox[{"Except", "@", 
                 RowBox[{"HoldPattern", "[", 
                  RowBox[{"ExpandRepeatedEvents", "\[Rule]", "_"}], "]"}]}]}],
                "]"}]}]}], "\[IndentingNewLine]", "}"}], ",", 
           "\[IndentingNewLine]", "evsb", ",", "\[IndentingNewLine]", 
           RowBox[{"Sequence", "@@", 
            RowBox[{"Cases", "[", 
             RowBox[{
              RowBox[{"{", "evsopts", "}"}], ",", 
              RowBox[{"Except", "@", 
               RowBox[{"HoldPattern", "[", 
                RowBox[{"ExpandRepeatedEvents", "\[Rule]", "_"}], "]"}]}]}], 
             "]"}]}]}], "\[IndentingNewLine]", "}"}]}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"Sequence", "@@", 
        RowBox[{"Cases", "[", 
         RowBox[{
          RowBox[{"{", "opts", "}"}], ",", 
          RowBox[{"Except", "@", 
           RowBox[{"HoldPattern", "[", 
            RowBox[{"ExpandRepeatedEvents", "\[Rule]", "_"}], "]"}]}]}], 
         "]"}]}]}], "\[IndentingNewLine]", "]"}]}], ")"}]}], ";"}]], "Input",
