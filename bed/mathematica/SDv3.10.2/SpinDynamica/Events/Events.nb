Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"HoldPattern", "@", 
    RowBox[{"Event", "[", 
     RowBox[{
      RowBox[{"evstatus", ":", 
       RowBox[{"{", 
        RowBox[{"False", ",", "numst_"}], "}"}]}], ",", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"timingch", ":", 
         RowBox[{"{", 
          RowBox[{"dur_", ",", "timeptch_", ",", "moretimingch__"}], "}"}]}], 
        ",", "backgch_", ",", "hilbch_", ",", "pcpch_", ",", 
        RowBox[{"{", 
         RowBox[{"Automatic", ",", "True", ",", "False"}], "}"}], ",", 
        "morech___"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"repevs", ":", 
       RowBox[{"Repeat", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"evlist", ":", 
          RowBox[{"EventList", "[", "\[IndentingNewLine]", 
           RowBox[{"evliststatus_", ",", "\[IndentingNewLine]", 
            RowBox[{"evlistchars", ":", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"evlisttchars", ":", 
                RowBox[{"{", 
                 RowBox[{"T_", ",", "_", ",", "pts_", ",", "__"}], "}"}]}], 
               ",", 
               RowBox[{"evlistbckgch", ":", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"evbackg", ":", 
                   RowBox[{"Except", "[", "Undefined", "]"}]}], ",", "_", ",",
                   "True"}], "}"}]}], ",", "moreevlistchars___"}], "}"}]}], 
            ",", "\[IndentingNewLine]", 
            RowBox[{"events", ":", 
             RowBox[{"{", 
              RowBox[{"_Event", ".."}], "}"}]}], ",", "\[IndentingNewLine]", 
            "evlistopts___Rule"}], "]"}]}], ",", "\[IndentingNewLine]", 
         "nrep_", ",", "\[IndentingNewLine]", "repevopts___Rule"}], 
        "\[IndentingNewLine]", "]"}]}], ",", "\[IndentingNewLine]", 
      "evopts___Rule"}], "\[IndentingNewLine]", "]"}]}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "nrepinperiod", ",", "nperiod", ",", "nrem", ",", "remevents", ",", 
       "expandedevents"}], "}"}], ",", 
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"remevents", "=", 
         RowBox[{"Flatten", "[", 
          RowBox[{
           RowBox[{"Table", "[", 
            RowBox[{"events", ",", 
             RowBox[{"{", "nrem", "}"}]}], "]"}], ",", "1"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"expandedevents", "=", 
         RowBox[{"Join", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"nrem", ">", "0"}], ",", "\[IndentingNewLine]", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{
                RowBox[{"First", "[", "remevents", "]"}], "/.", 
                "\[IndentingNewLine]", 
                RowBox[{
                 RowBox[{"Event", "[", 
                  RowBox[{"evstatus$_", ",", 
                   RowBox[{"{", 
                    RowBox[{
                    "tch$_", ",", "backgch$_", ",", "hilbch$_", ",", "pcp$_", 
                    ",", "exprep$_", ",", "precalchk$_", ",", "morech$___"}], 
                    "}"}], ",", "evspecs$_", ",", "evopts$___Rule"}], "]"}], 
                 "\[RuleDelayed]", "\[IndentingNewLine]", 
                 RowBox[{"Event", "[", 
                  RowBox[{
                   RowBox[{"{", 
                    RowBox[{"False", ",", "False"}], "}"}], ",", 
                   RowBox[{"{", 
                    RowBox[{
                    "Undefined", ",", "backgch$", ",", "Undefined", ",", 
                    "Undefined", ",", 
                    RowBox[{"{", 
                    RowBox[{"True", ",", "True", ",", "False"}], "}"}], ",", 
                    "False", ",", "morech$"}], "}"}], ",", "evspecs$", ",", 
                   "\[IndentingNewLine]", 
                   RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
                    RowBox[{
                    RowBox[{"Switch", "[", 
                    RowBox[{"timeptch", ",", "\[IndentingNewLine]", 
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"Except", "[", "Undefined", "]"}], ",", "_"}], 
                    "}"}], ",", 
                    RowBox[{"FinalTimePoint", "\[Rule]", 
                    RowBox[{"First", "[", "timeptch", "]"}]}], ",", 
                    "\[IndentingNewLine]", "_", ",", 
                    RowBox[{"FinalTimePoint", "\[Rule]", "Undefined"}]}], 
                    "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
                    "evopts$"}], "\[IndentingNewLine]", "]"}]}], "]"}]}]}], 
               ",", "\[IndentingNewLine]", 
               RowBox[{"Sequence", "@@", 
                RowBox[{"(", "\[IndentingNewLine]", 
                 RowBox[{
                  RowBox[{"Drop", "[", 
                   RowBox[{"remevents", ",", "1"}], "]"}], "/.", 
                  "\[IndentingNewLine]", 
                  RowBox[{
                   RowBox[{"Event", "[", 
                    RowBox[{"evstatus$_", ",", 
                    RowBox[{"{", 
                    RowBox[{
                    "tch$_", ",", "backgch$_", ",", "hilbch$_", ",", "pcp$_", 
                    ",", "exprep$_", ",", "precalchk$_", ",", "morech$___"}], 
                    "}"}], ",", "evspecs$_", ",", "evopts$___Rule"}], "]"}], 
                   "\[RuleDelayed]", "\[IndentingNewLine]", 
                   RowBox[{"Event", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"False", ",", "False"}], "}"}], ",", 
                    RowBox[{"{", 
                    RowBox[{
                    "Undefined", ",", "backgch$", ",", "Undefined", ",", 
                    "Undefined", ",", 
                    RowBox[{"{", 
                    RowBox[{"True", ",", "True", ",", "False"}], "}"}], ",", 
                    "False", ",", "morech$"}], "}"}], ",", "evspecs$", ",", 
                    "\[IndentingNewLine]", 
                    RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
                    RowBox[{
                    RowBox[{"Switch", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"timeptch", ",", "nperiod"}], "}"}], ",", 
                    "\[IndentingNewLine]", 
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"_", ",", 
                    RowBox[{"Except", "[", "Undefined", "]"}]}], "}"}], ",", 
                    "0"}], "}"}], ",", 
                    RowBox[{"InitialTimePoint", "\[Rule]", 
                    RowBox[{"Last", "[", "timeptch", "]"}]}], ",", 
                    "\[IndentingNewLine]", "_", ",", 
                    RowBox[{"InitialTimePoint", "\[Rule]", "Undefined"}]}], 
                    "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
                    "evopts$"}], "\[IndentingNewLine]", "]"}]}], 
                    "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", 
                 ")"}]}]}], "\[IndentingNewLine]", "}"}], ",", 
             "\[IndentingNewLine]", 
             RowBox[{"{", "}"}]}], "\[IndentingNewLine]", "]"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"nperiod", ">", "0"}], ",", "\[IndentingNewLine]", 
             RowBox[{"{", 
              RowBox[{"Event", "[", "\[IndentingNewLine]", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"False", ",", "False"}], "}"}], ",", 
                "\[IndentingNewLine]", 
                RowBox[{"{", 
                 RowBox[{
                 "Undefined", ",", "backgch", ",", "Undefined", ",", 
                  "Undefined", ",", 
                  RowBox[{"{", 
                   RowBox[{"Automatic", ",", "True", ",", "True"}], "}"}], 
                  ",", "morech"}], "}"}], ",", "\[IndentingNewLine]", 
                RowBox[{"Repeat", "[", "\[IndentingNewLine]", 
                 RowBox[{
                  RowBox[{"EventList", "[", 
                   RowBox[{
                    RowBox[{"{", 
                    RowBox[{"False", ",", "False"}], "}"}], ",", 
                    "\[IndentingNewLine]", 
                    RowBox[{"{", 
                    RowBox[{
