Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"EventList", "[", 
    RowBox[{"evlistst_", ",", 
     RowBox[{"evlistch", ":", 
      RowBox[{"{", 
       RowBox[{"evlisttch_", ",", 
        RowBox[{"evlistbackgch", ":", 
         RowBox[{"{", 
          RowBox[{"backg_", ",", "backgimplreq_", ",", "backgimpl_"}], 
          "}"}]}], ",", "morech___"}], "}"}]}], ",", 
     RowBox[{"args", ":", 
      RowBox[{"{", 
       RowBox[{"___", ",", "_EventList", ",", "___"}], "}"}]}], ",", 
     "evlistopts___Rule"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "eventlists", "}"}], ",", 
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Verbose", "/.", 
            RowBox[{"{", "evlistopts", "}"}]}], "/.", 
           RowBox[{"Options", "[", "EventList", "]"}]}], ",", 
          RowBox[{"Print", "[", 
           RowBox[{
           "\"\<absorbing EventList contained in another EventList (case of \
non-implemented BackgroundGenerator): \>\"", ",", " ", 
            RowBox[{"Expand", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"backg", ",", "backgimplreq", ",", "backgimpl"}], 
               "}"}], "/.", 
              RowBox[{"s_TimeDependentGeneratorFunction", "\[RuleDelayed]", 
               RowBox[{"s", "\[LeftDoubleBracket]", 
                RowBox[{"{", "4", "}"}], "\[RightDoubleBracket]"}]}]}], 
             "]"}]}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"EventList", "[", 
         RowBox[{"evlistst", ",", 
          RowBox[{"{", 
           RowBox[{"evlisttch", ",", "evlistbackgch", ",", "morech"}], "}"}], 
          ",", "\[IndentingNewLine]", 
          RowBox[{"Replace", "[", 
           RowBox[{"args", ",", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"EventList", "[", 
              RowBox[{"_", ",", "_", ",", 
               RowBox[{"evs", ":", 
                RowBox[{"{", 
                 RowBox[{"_Event", ".."}], "}"}]}], ",", "___"}], "]"}], 
             "\[RuleDelayed]", 
             RowBox[{"Sequence", "@@", "evs"}]}], ",", "\[IndentingNewLine]", 
            "1"}], "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
          "evlistopts"}], "\[IndentingNewLine]", "]"}]}], 
       "\[IndentingNewLine]", ")"}], "/;", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"eventlists", "=", 
         RowBox[{"Cases", "[", 
          RowBox[{"args", ",", "_EventList"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"And", "@@", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"MatchQ", "[", 
             RowBox[{"#", ",", 
              RowBox[{"EventList", "[", 
               RowBox[{"_", ",", 
                RowBox[{"{", 
                 RowBox[{"_", ",", 
                  RowBox[{"{", 
                   RowBox[{"_", ",", "_", ",", 
                    RowBox[{"False", "|", "Undefined"}]}], "}"}], ",", "__", 
                  ",", 
                  RowBox[{"True", "|", 
                   RowBox[{"{", 
                    RowBox[{"__", ",", "True"}], "}"}]}]}], "}"}], ",", 
                "___"}], "]"}]}], "]"}], "&"}], "/@", "eventlists"}], 
          ")"}]}]}], "\[IndentingNewLine]", ")"}]}]}], "\[IndentingNewLine]", 
