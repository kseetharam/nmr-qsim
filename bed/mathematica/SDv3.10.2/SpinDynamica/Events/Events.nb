Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"DivideEventSpecifications", "::", "usage"}], "=", 
   "\"\<DivideEventSpecifications[evspecs,{..,\[Tau]2,\[Tau]1}] divides up a \
list of event specifications using intervals {..,\[Tau]2,\[Tau]1} (reading \
from right to left). DivideEventSpecifications[evspecs,n] divides the list of \
event specifications into n sets of equal duration. If the option \
IncludeRepetitionNumbers\[Rule]True is used, the output contains information \
on the number of repetitions of identical event sequences.\>\""}], 
  ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.683111085057692*^9, 3.683111114640679*^9}, {
   3.68311122763102*^9, 3.68311124673007*^9}, {3.683804963404469*^9, 
   3.683805081787279*^9}, {3.683806601666019*^9, 3.683806648989735*^9}, {
   3.684732307040989*^9, 3.684732307047571*^9}, 3.684946126265486*^9},
 CellLabel->"In[9]:=",ExpressionUUID->"569cb565-ba3a-4db0-98d1-5bbe5b16f430"],

