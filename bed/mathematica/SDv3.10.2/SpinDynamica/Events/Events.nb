Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"HoldPattern", "@", 
    RowBox[{"Event", "[", 
     RowBox[{
      RowBox[{"evstatus", ":", 
       RowBox[{"{", 
        RowBox[{"False", ",", "numst_"}], "}"}]}], ",", "\[IndentingNewLine]", 
      RowBox[{"evch", ":", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"evT_", ",", 
           RowBox[{"{", 
            RowBox[{"tb_", ",", 
             RowBox[{"ta", ":", 
              RowBox[{"Except", "[", "Undefined", "]"}]}]}], "}"}], ",", 
           "moreevtch__"}], "}"}], ",", "moreevch__", ",", 
         RowBox[{"True", "|", 
          RowBox[{"{", 
           RowBox[{"__", ",", "True"}], "}"}]}]}], "}"}]}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"Repeat", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"evlist", ":", 
         RowBox[{"EventList", "[", "\[IndentingNewLine]", 
          RowBox[{"evliststatus_", ",", "\[IndentingNewLine]", 
           RowBox[{"evlistchars", ":", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"evlistT_", ",", "Undefined", ",", "moreevlisttch__"}],
                "}"}], ",", "moreevlistch__"}], "}"}]}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"events", ":", 
            RowBox[{"{", 
             RowBox[{"_Event", ".."}], "}"}]}], ",", "\[IndentingNewLine]", 
           "evlistopts___Rule"}], "]"}]}], ",", "\[IndentingNewLine]", 
        "nrep_", ",", "\[IndentingNewLine]", "repevopts___Rule"}], 
       "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
      "evopts___Rule"}], "\[IndentingNewLine]", "]"}]}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Verbose", "/.", 
         RowBox[{"{", "evopts", "}"}]}], "/.", 
        RowBox[{"Options", "[", "Event", "]"}]}], ",", 
       RowBox[{
       "Print", "[", "\"\<passing down timing to EventList inside Repeat\>\"",
         "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Event", "[", 
      RowBox[{"evstatus", ",", "evch", ",", "\[IndentingNewLine]", 
       RowBox[{"Repeat", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"EventList", "[", "\[IndentingNewLine]", 
          RowBox[{
          "evliststatus", ",", "evlistchars", ",", "\[IndentingNewLine]", 
           RowBox[{"events", "/.", 
            RowBox[{
             RowBox[{"Event", "[", 
              RowBox[{"ievst_", ",", 
               RowBox[{"{", 
                RowBox[{"ievttch_", ",", "moreievch__"}], "}"}], ",", 
               "ievspecs_", ",", "ievopts___Rule"}], "]"}], "\[RuleDelayed]", 
             
             RowBox[{"Event", "[", 
              RowBox[{"ievst", ",", 
               RowBox[{"{", 
                RowBox[{"Undefined", ",", "moreievch"}], "}"}], ",", 
               "ievspecs", ",", "ievopts"}], "]"}]}]}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"InitialTimePoint", "\[Rule]", "ta"}], ",", 
             "\[IndentingNewLine]", "evlistopts"}], "\[IndentingNewLine]", 
            "]"}]}], "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]",
          "nrep", ",", "\[IndentingNewLine]", "repevopts"}], 
        "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", "evopts"}], 
      "\[IndentingNewLine]", "]"}]}], ")"}]}], ";"}]], "Input",
 InitializationCell->True,
