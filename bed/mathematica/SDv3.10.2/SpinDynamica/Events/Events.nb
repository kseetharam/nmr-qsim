Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"EventList", "[", 
    RowBox[{
     RowBox[{"st", ":", 
      RowBox[{"{", 
       RowBox[{"False", ",", "_"}], "}"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"timingch_", ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"backg", ":", 
          RowBox[{"Except", "[", "Undefined", "]"}]}], ",", "backgimplreq_", 
         ",", "False"}], "}"}], ",", "morech___"}], "}"}], ",", 
     RowBox[{"events", ":", 
      RowBox[{"{", 
       RowBox[{"_Event", "..."}], "}"}]}], ",", "opts___Rule"}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"(", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Verbose", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "EventList", "]"}]}], ",", 
        RowBox[{"Print", "[", 
         RowBox[{
         "\"\<passing BackgroundGenerator down to events inside EventList: \>\
\"", ",", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"backg", ",", "backgimplreq", ",", "False"}], "}"}], 
             ",", 
             RowBox[{"Expand", "@", "events"}]}], "}"}], "/.", 
           RowBox[{"s_TimeDependentGeneratorFunction", "\[RuleDelayed]", 
