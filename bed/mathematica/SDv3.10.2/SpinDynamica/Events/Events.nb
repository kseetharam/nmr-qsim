Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"HoldPattern", "@", 
    RowBox[{"Event", "[", 
     RowBox[{
      RowBox[{"evstatus", ":", 
       RowBox[{"{", 
        RowBox[{"False", ",", "numst_"}], "}"}]}], ",", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{
       "timingch_", ",", "backgch_", ",", "hilbch_", ",", "pcpch_", ",", 
        RowBox[{"{", 
         RowBox[{"Automatic", ",", "True", ",", "False"}], "}"}], ",", 
        "morech___"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"repevs", ":", 
       RowBox[{"Repeat", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"evlist", ":", 
          RowBox[{"EventList", "[", "\[IndentingNewLine]", 
           RowBox[{"evliststatus_", ",", "\[IndentingNewLine]", 
            RowBox[{"evlistchars", ":", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"T_", ",", "_", ",", "pts_", ",", "__"}], "}"}], ",", 
               
               RowBox[{"{", 
                RowBox[{"__", ",", "True"}], "}"}], ",", "___"}], "}"}]}], 
            ",", "\[IndentingNewLine]", 
            RowBox[{"events", ":", 
             RowBox[{"{", 
              RowBox[{"_Event", ".."}], "}"}]}], ",", "\[IndentingNewLine]", 
            "evlistopts___Rule"}], "]"}]}], ",", "\[IndentingNewLine]", 
         "nrep_", ",", "\[IndentingNewLine]", "repevopts___Rule"}], 
        "\[IndentingNewLine]", "]"}]}], ",", "\[IndentingNewLine]", 
      "evopts___Rule"}], "\[IndentingNewLine]", "]"}]}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"Nperiod", ",", "nperiod"}], "}"}], ",", 
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Verbose", "/.", 
            RowBox[{"{", "evopts", "}"}]}], "/.", 
           RowBox[{"Options", "[", "Event", "]"}]}], ",", 
          RowBox[{
          "Print", "[", "\"\<implementing no repeat event expansion\>\"", 
           "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"Event", "[", 
         RowBox[{"evstatus", ",", 
          RowBox[{"{", 
           RowBox[{
           "timingch", ",", "backgch", ",", "hilbch", ",", "pcpch", ",", 
            RowBox[{"{", 
             RowBox[{"False", ",", "True", ",", "False"}], "}"}], ",", 
            "morech"}], "}"}], ",", "repevs", ",", "evopts"}], "]"}]}], 
       "\[IndentingNewLine]", ")"}], "/;", 
