Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Format", "[", 
    RowBox[{
     RowBox[{"HoldPattern", "@", 
      RowBox[{"Repeat", "[", 
       RowBox[{"evspecs_", ",", "n_", ",", "repopts___Rule"}], "]"}]}], "/;", 
     
     RowBox[{"!", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Expand", "/.", 
         RowBox[{"{", "repopts", "}"}]}], "/.", 
        RowBox[{"Options", "[", "Repeat", "]"}]}], ")"}]}]}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "repevs", "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"repevs", "=", 
        RowBox[{"Reverse", "[", 
         RowBox[{"Last", "/@", 
          RowBox[{
           RowBox[{"Repeat", "[", 
            RowBox[{"evspecs", ",", "n", ",", "repopts"}], "]"}], 
           "\[LeftDoubleBracket]", 
