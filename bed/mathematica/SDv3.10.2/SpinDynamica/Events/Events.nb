Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"TransferElement", "[", 
    RowBox[{"source_List", ",", "target_List", ",", "\[Delta]t_"}], "]"}], ":=",
    "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "firstel", ",", "evgen", ",", "\[Tau]", ",", "splitel1", ",", 
       "splitel2"}], "}"}], ",", 
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{"splitel2", ",", "splitel1"}], "}"}], "=", 
         RowBox[{"SplitElement", "[", 
          RowBox[{"firstel", ",", "\[Delta]t"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"TransferElement", "[", 
         RowBox[{
          RowBox[{"Join", "[", 
           RowBox[{
            RowBox[{"Most", "[", "source", "]"}], ",", 
            RowBox[{"{", "splitel2", "}"}]}], "]"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"Join", "[", 
           RowBox[{
            RowBox[{"{", "splitel1", "}"}], ",", "target"}], "]"}], ",", 
          "0"}], "]"}]}], "\[IndentingNewLine]", ")"}], "/;", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"\[Delta]t", ">", "0"}], ")"}], "&&", 
        RowBox[{
         RowBox[{"Length", "[", "source", "]"}], ">", "0"}], "&&", 
        RowBox[{"(", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"firstel", "=", 
           RowBox[{"Last", "@", "source"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"MatchQ", "[", 
            RowBox[{"firstel", ",", 
             RowBox[{"{", 
              RowBox[{"evgen_", ",", "\[Tau]_", ",", "___Rule"}], "}"}]}], 
            "]"}], "&&", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"Duration", "[", "firstel", "]"}], ">", "\[Delta]t"}]}]}],
          ")"}]}], "\[IndentingNewLine]", ")"}]}]}], "\[IndentingNewLine]", 
    "]"}]}], ";"}]], "Input",
