           RowBox[{"StandardForm", "[", "repevs", "]"}], ",", 
           "\[IndentingNewLine]", "\"\<,\>\"", ",", "\[IndentingNewLine]", 
           RowBox[{"StandardForm", "[", "n", "]"}], ",", 
           "\[IndentingNewLine]", "\"\<]\>\""}], "\[IndentingNewLine]", "}"}],
