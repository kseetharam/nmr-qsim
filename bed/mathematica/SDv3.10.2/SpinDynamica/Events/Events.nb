Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"HoldPattern", "@", 
     RowBox[{"Event", "[", 
      RowBox[{
       RowBox[{"evstatus", ":", 
        RowBox[{"{", 
         RowBox[{"False", ",", "numst_"}], "}"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"evch", ":", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"timingch", ":", 
           RowBox[{"{", 
            RowBox[{"dur_", ",", "timeptch_", ",", "moretimingch__"}], 
            "}"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"evbackg_", ",", "_", ",", "_"}], "}"}], ",", "hilbch_", 
          ",", "propcalcprocchar_", ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"All", "|", "True"}], ",", "True", ",", "False"}], "}"}], 
          ",", "morech___"}], "}"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"repev", ":", 
        RowBox[{"Repeat", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"evlist", ":", 
           RowBox[{"EventList", "[", 
            RowBox[{"evliststatus_", ",", "evlistchars_", ",", 
             RowBox[{"events", ":", 
              RowBox[{"{", 
               RowBox[{"_Event", ".."}], "}"}]}], ",", "evlistopts___Rule"}], 
            "]"}]}], ",", "\[IndentingNewLine]", "nrep_", ",", 
          "\[IndentingNewLine]", "repevopts___Rule"}], "\[IndentingNewLine]", 
         "]"}]}], ",", "\[IndentingNewLine]", "evopts___Rule"}], 
      "\[IndentingNewLine]", "]"}]}], "/;", 
    RowBox[{
     RowBox[{"NumericQ", "[", "nrep", "]"}], "&&", 
     RowBox[{"(", 
      RowBox[{"nrep", "\[GreaterEqual]", "0"}], ")"}]}]}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"newevents", ",", "firstnewevent", ",", "laternewevents"}], 
      "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Verbose", "/.", 
            RowBox[{"{", "evopts", "}"}]}], "/.", 
           RowBox[{"Options", "[", "Event", "]"}]}], ",", 
          RowBox[{
          "Print", "[", "\"\<implementing complete expansion of Repeat\>\"", 
           "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"newevents", "=", 
         RowBox[{"Flatten", "[", 
          RowBox[{
           RowBox[{"Table", "[", 
            RowBox[{"events", ",", 
             RowBox[{"{", "nrep", "}"}]}], "]"}], ",", "1"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Sequence", "@@", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"nrep", ">", "0"}], ",", "\[IndentingNewLine]", 
           RowBox[{"Join", "[", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{
              RowBox[{"Drop", "[", 
               RowBox[{"newevents", ",", 
                RowBox[{"-", "1"}]}], "]"}], "/.", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"Event", "[", 
                RowBox[{"evstatus$_", ",", 
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"{", 
                    RowBox[{"dur$_", ",", "moretch$___"}], "}"}], ",", 
                   "backgch$_", ",", "hilbch$_", ",", "pcp$_", ",", 
                   "exprep$_", ",", "precalchk$_", ",", "morech$___"}], "}"}],
                  ",", "evspecs$_", ",", "evopts$___Rule"}], "]"}], 
               "\[RuleDelayed]", 
               RowBox[{"Event", "[", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{"False", ",", "False"}], "}"}], ",", 
                 RowBox[{"{", 
                  RowBox[{
                  "Undefined", ",", "backgch$", ",", "Undefined", ",", 
                   "Undefined", ",", 
                   RowBox[{"{", 
                    RowBox[{"True", ",", "True", ",", "False"}], "}"}], ",", 
                   "False", ",", "morech$"}], "}"}], ",", "evspecs$", ",", 
                 "evopts$"}], "]"}]}]}], ",", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"Last", "[", "newevents", "]"}], "}"}], "/.", 
              "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"Event", "[", 
                RowBox[{"evstatus$_", ",", 
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"{", 
                    RowBox[{"dur$_", ",", "moretch$___"}], "}"}], ",", 
                   "backgch$_", ",", "hilbch$_", ",", "pcp$_", ",", 
                   "exprep$_", ",", "precalchk$_", ",", "morech$___"}], "}"}],
                  ",", "evspecs$_", ",", "evopts$___Rule"}], "]"}], 
               "\[RuleDelayed]", 
               RowBox[{"Event", "[", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{"False", ",", "False"}], "}"}], ",", 
                 RowBox[{"{", 
                  RowBox[{
                  "Undefined", ",", "backgch$", ",", "Undefined", ",", 
                   "Undefined", ",", 
                   RowBox[{"{", 
                    RowBox[{"True", ",", "True", ",", "False"}], "}"}], ",", 
                   "False", ",", "morech$"}], "}"}], ",", "evspecs$", ",", 
                 "\[IndentingNewLine]", 
                 RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
                  RowBox[{
                   RowBox[{"Switch", "[", 
                    RowBox[{"timeptch", ",", "\[IndentingNewLine]", 
                    RowBox[{"{", 
                    RowBox[{"_", ",", 
                    RowBox[{"Except", "[", 
                    RowBox[{"Undefined", "|", "Automatic"}], "]"}]}], "}"}], 
                    ",", 
                    RowBox[{"InitialTimePoint", "\[Rule]", 
                    RowBox[{"Last", "[", "timeptch", "]"}]}], ",", 
                    "\[IndentingNewLine]", 
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"Except", "[", 
                    RowBox[{"Undefined", "|", "Automatic"}], "]"}], ",", 
                    "_"}], "}"}], ",", 
                    RowBox[{"FinalTimePoint", "\[Rule]", 
                    RowBox[{"First", "[", "timeptch", "]"}]}], ",", 
                    "\[IndentingNewLine]", "_", ",", 
                    RowBox[{"InitialTimePoint", "\[Rule]", "Undefined"}]}], 
                    "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
                   "evopts$"}], "\[IndentingNewLine]", "]"}]}], 
                "\[IndentingNewLine]", "]"}]}]}]}], "\[IndentingNewLine]", 
            "]"}], ",", "\[IndentingNewLine]", 
           RowBox[{"{", "}"}]}], "\[IndentingNewLine]", "]"}]}]}], 
       "\[IndentingNewLine]", ")"}], "\[IndentingNewLine]", ")"}]}], "]"}]}], 
