Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"EventSpecifications", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"status", ":", 
       RowBox[{"{", 
        RowBox[{"checkstatus_", ",", "True", ",", "nestliststatus_", ",", 
         RowBox[{"{", 
          RowBox[{
          "True", ",", "stemp_", ",", "stop_", ",", "False", ",", 
           "morestandstatus___"}], "}"}], ",", "morestatus___"}], "}"}]}], 
      ",", "\[IndentingNewLine]", "evspecs_List", ",", "\[IndentingNewLine]", 
      "opts___Rule"}], "\[IndentingNewLine]", "]"}], "/;", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Count", "[", 
        RowBox[{"evspecs", ",", 
         RowBox[{"EventSpecifications", "[", 
          RowBox[{"True", ",", "___"}], "]"}], ",", 
         RowBox[{"{", "1", "}"}]}], "]"}], "\[GreaterEqual]", "1"}], ")"}], "&&", 
     RowBox[{"FreeQ", "[", 
      RowBox[{"evspecs", ",", 
       RowBox[{"EventSpecifications", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"_", ",", "False", ",", "___"}], "}"}], ",", "___"}], 
        "]"}]}], "]"}]}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "newstatus", "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"newstatus", "=", 
