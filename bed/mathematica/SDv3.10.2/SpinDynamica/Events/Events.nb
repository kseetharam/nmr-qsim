Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Event", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"False", ",", "False"}], "}"}], ",", "chars_List", ",", 
      RowBox[{"more", ":", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Except", "[", "_Rule", "]"}], ".."}], ")"}]}], ",", 
      "opts___Rule"}], "]"}], "/;", 
    RowBox[{
     RowBox[{"FreeQ", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"chars", ",", "more"}], "}"}], ",", "Undefined"}], "]"}], "&&", 
     RowBox[{"MatchQ", "[", 
      RowBox[{"chars", ",", 
       RowBox[{"{", 
        RowBox[{"_", ",", 
         RowBox[{"{", 
          RowBox[{"__", ",", "True"}], "}"}], ",", "_", ",", "_", ",", 
         RowBox[{"True", "|", 
          RowBox[{"{", 
           RowBox[{"__", ",", "True"}], "}"}]}], ",", "___", ",", 
         RowBox[{"True", "|", 
          RowBox[{"{", 
           RowBox[{"__", ",", "True"}], "}"}]}]}], "}"}]}], "]"}]}]}], ":=", 
   RowBox[{"Event", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"True", ",", "False"}], "}"}], ",", "chars", ",", "more", ",", 
     "\[IndentingNewLine]", 
     RowBox[{"Sequence", "@@", 
      RowBox[{"FilterRules", "[", 
       RowBox[{
        RowBox[{"{", "opts", "}"}], ",", 
        RowBox[{"Except", "[", 
