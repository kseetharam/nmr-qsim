Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"EventList", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"False", ",", "numst_"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"dur_", ",", "Undefined", ",", "moretimingch___"}], "}"}], 
       ",", "morech___"}], "}"}], ",", 
     RowBox[{"events", ":", 
      RowBox[{"{", 
       RowBox[{"_Event", "..."}], "}"}]}], ",", "opts___Rule"}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"ta", ",", "tb", ",", "tbvals", ",", "modevents"}], "}"}], ",", 
     
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"tbvals", "=", 
         RowBox[{"Most", "[", 
          RowBox[{"FoldList", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"#1", "-", "#2"}], ")"}], "&"}], ",", "tb", ",", 
            RowBox[{"Duration", "/@", "events"}]}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"modevents", "=", 
         RowBox[{"MapThread", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"#1", "/.", 
              RowBox[{
               RowBox[{"Event", "[", 
                RowBox[{
                 RowBox[{"evspecs", ":", 
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{"Except", "[", "_Rule", "]"}], ".."}], ")"}]}], 
                 ",", "evspecopts___Rule"}], "]"}], "\[RuleDelayed]", 
               RowBox[{"Event", "[", 
                RowBox[{"evspecs", ",", 
                 RowBox[{"SimplifyRules", "[", 
                  RowBox[{
                   RowBox[{"FinalTimePoint", "\[Rule]", "#2"}], ",", 
                   RowBox[{"InitialTimePoint", "\[Rule]", "Automatic"}], ",", 
                   "evspecopts"}], "]"}]}], "]"}]}]}], "\[IndentingNewLine]", 
             ")"}], "&"}], ",", "\[IndentingNewLine]", 
           RowBox[{"{", 
            RowBox[{"events", ",", "tbvals"}], "}"}]}], "\[IndentingNewLine]",
           "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"EventList", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"False", ",", "numst"}], "}"}], ",", 
          RowBox[{"{", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"dur", ",", 
              RowBox[{"{", 
               RowBox[{"tb", ",", 
                RowBox[{"InitialTimePoint", "[", 
                 RowBox[{"Last", "@", "modevents"}], "]"}]}], "}"}], ",", 
              "moretimingch"}], "}"}], ",", "morech"}], "}"}], ",", 
          "\[IndentingNewLine]", "modevents", ",", 
          RowBox[{"Sequence", "@@", 
           RowBox[{"Cases", "[", 
            RowBox[{
             RowBox[{"{", "opts", "}"}], ",", 
             RowBox[{"Except", "[", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"FinalTimePoint", "|", "InitialTimePoint"}], ")"}], 
               "\[Rule]", "_"}], "]"}]}], "]"}]}]}], "]"}]}], 
       "\[IndentingNewLine]", ")"}], "/;", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{"tb", ",", "ta"}], "}"}], "=", 
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{"FinalTimePoint", ",", "InitialTimePoint"}], "}"}], "/.", 
           
           RowBox[{"{", "opts", "}"}]}], "/.", 
          RowBox[{"Options", "[", "EventList", "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"MatchQ", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"tb", ",", "ta"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Except", "[", 
             RowBox[{"Automatic", "|", "Undefined"}], "]"}], ",", 
            RowBox[{"Automatic", "|", "Undefined"}]}], "}"}]}], "]"}]}], 
       "\[IndentingNewLine]", ")"}]}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.683972665614608*^9, 3.6839726803028736`*^9}, {
