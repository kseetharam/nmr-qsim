Cell[CellGroupData[{

Cell["DivideEventSpecifications", "Subsubtitle",
 InitializationCell->True,
 CellChangeTimes->{{3.625294213407867*^9, 3.625294266936805*^9}, {
   3.625296478152717*^9, 3.625296563948032*^9}, {3.625297057398859*^9, 
   3.625297133406013*^9}, {3.625306909740706*^9, 3.625306918234168*^9}, {
   3.625385088964297*^9, 3.625385097994274*^9}, 3.625397189623513*^9, 
   3.625565681131718*^9, {3.625566966384778*^9, 3.6255669875008917`*^9}, {
   3.625567056796273*^9, 3.625567062074286*^9}, {3.625572414691482*^9, 
   3.625572431010044*^9}, 3.625941563348687*^9, 3.6260027343865643`*^9, 
   3.684732307069537*^9},ExpressionUUID->"964bc46f-cc50-42d0-a1fc-\
78c5c0e42b3b"],

Cell["\<\
DivideEventSpecifications[evspecs,intervals] takes an EventSpecifications (in \
standardized chronology) and divides it according to a list of arbitrary time \
intervals. If the option IncludeRepetitionNumbers\[Rule]True is used, the \
divided list has the form {...{nrep2,EventSpecifications[..]},{nrep1, \
EventSpecifications[..]}}, where {nrep1,nrep2..} are integers for the number \
of repetitions of the following event specs. This is used by (for example) \
the COMPUTE algorithm to calculate the propagator sets for a periodic system. \
In some cases the repetitions allows the division of the event specs to be \
carried out efficiently\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.625941358778493*^9, 3.625941472061922*^9}, {
   3.625941514899457*^9, 3.625941529408704*^9}, {3.625941687662161*^9, 
