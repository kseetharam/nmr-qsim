  3.683984046906507*^9}},ExpressionUUID->"15a72b31-1757-4922-8167-\
4d75c001900a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"EventList", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"False", ",", "numst_"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"dur_", ",", "Undefined", ",", "moretimingch___"}], "}"}], 
       ",", "morech___"}], "}"}], ",", 
     RowBox[{"events", ":", 
      RowBox[{"{", 
       RowBox[{"_Event", "..."}], "}"}]}], ",", "opts___Rule"}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"ta", ",", "tb", ",", "tavals", ",", "modevents"}], "}"}], ",", 
     
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"tavals", "=", 
         RowBox[{"Most", "[", 
          RowBox[{"FoldList", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"#1", "+", "#2"}], ")"}], "&"}], ",", "ta", ",", 
            RowBox[{"Duration", "/@", 
             RowBox[{"Reverse", "@", "events"}]}]}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"modevents", "=", 
         RowBox[{"Reverse", "@", 
          RowBox[{"MapThread", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"#1", "/.", 
               RowBox[{
                RowBox[{"Event", "[", 
                 RowBox[{
                  RowBox[{"evspecs", ":", 
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"Except", "[", "_Rule", "]"}], ".."}], ")"}]}], 
                  ",", "evspecopts___Rule"}], "]"}], "\[RuleDelayed]", 
                RowBox[{"Event", "[", 
                 RowBox[{"evspecs", ",", 
                  RowBox[{"SimplifyRules", "[", 
                   RowBox[{
                    RowBox[{"InitialTimePoint", "\[Rule]", "#2"}], ",", 
                    RowBox[{"FinalTimePoint", "\[Rule]", "Automatic"}], ",", 
                    "evspecopts"}], "]"}]}], "]"}]}]}], "\[IndentingNewLine]",
               ")"}], "&"}], ",", "\[IndentingNewLine]", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"Reverse", "@", "events"}], ",", "tavals"}], "}"}]}], 
           "\[IndentingNewLine]", "]"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"EventList", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"False", ",", "numst"}], "}"}], ",", 
          RowBox[{"{", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"dur", ",", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"FinalTimePoint", "[", 
                 RowBox[{"First", "@", "modevents"}], "]"}], ",", "ta"}], 
               "}"}], ",", "moretimingch"}], "}"}], ",", "morech"}], "}"}], 
          ",", "\[IndentingNewLine]", "modevents", ",", 
          RowBox[{"Sequence", "@@", 
           RowBox[{"Cases", "[", 
            RowBox[{
             RowBox[{"{", "opts", "}"}], ",", 
             RowBox[{"Except", "[", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"FinalTimePoint", "|", "InitialTimePoint"}], ")"}], 
               "\[Rule]", "_"}], "]"}]}], "]"}]}]}], "]"}]}], 
       "\[IndentingNewLine]", ")"}], "/;", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{"tb", ",", "ta"}], "}"}], "=", 
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{"FinalTimePoint", ",", "InitialTimePoint"}], "}"}], "/.", 
           
           RowBox[{"{", "opts", "}"}]}], "/.", 
          RowBox[{"Options", "[", "EventList", "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"MatchQ", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"tb", ",", "ta"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Automatic", "|", "Undefined"}], ",", 
            RowBox[{"Except", "[", 
             RowBox[{"Automatic", "|", "Undefined"}], "]"}]}], "}"}]}], 
         "]"}]}], "\[IndentingNewLine]", ")"}]}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.683972665614608*^9, 3.6839726803028736`*^9}, {
