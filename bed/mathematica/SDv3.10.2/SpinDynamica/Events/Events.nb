        RowBox[{"Nperiod", "=", 
         RowBox[{"T", "/", "pts"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"nperiod", "=", 
         RowBox[{"Round", "[", "Nperiod", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"TrueQ", "[", 
          RowBox[{
           RowBox[{"Chop", "@", 
            RowBox[{"N", "[", 
