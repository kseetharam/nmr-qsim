          "]"}], "&&", "\[IndentingNewLine]", 
         RowBox[{"nperiod", "\[GreaterEqual]", "1"}]}]}], 
       "\[IndentingNewLine]", ")"}]}]}], "]"}]}], ";"}]], "Input",
