   3.683957681201801*^9, {3.684500363738378*^9, 3.684500426074274*^9}, 
   3.690554802447773*^9, 
   3.6928482981961527`*^9},ExpressionUUID->"762b9976-b349-489d-ab70-\
7aa340952d8e"]
}, Closed]],

