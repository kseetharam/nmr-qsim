Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"EventSpecifications", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"status", ":", 
      RowBox[{"{", 
       RowBox[{
       "checkstatus_", ",", "chronstatus_", ",", "nestliststatus_", ",", 
        RowBox[{"{", 
         RowBox[{
         "True", ",", "True", ",", "False", ",", "stnoopevs_", ",", "True"}], 
         "}"}], ",", "morestatus___"}], "}"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"evspecs", ":", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"evspecseq", ":", 
         RowBox[{
          RowBox[{"Except", "[", "_Rule", "]"}], ".."}]}], ",", 
        "evspecopts___Rule"}], "}"}]}], ",", "opts___Rule"}], 
    "\[IndentingNewLine]", "]"}], ":=", 
   RowBox[{"(", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Verbose", "/.", 
         RowBox[{"{", "opts", "}"}]}], "/.", 
        RowBox[{"Options", "[", "EventSpecifications", "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{
        "\"\<EventSpecifications: incorporating options: \>\"", ",", " ", 
         RowBox[{
          RowBox[{"Expand", "[", "evspecs", "]"}], "/.", 
          RowBox[{"s_TimeDependentGeneratorFunction", "\[RuleDelayed]", 
           RowBox[{"s", "\[LeftDoubleBracket]", 
            RowBox[{"{", "4", "}"}], "\[RightDoubleBracket]"}]}]}]}], "]"}]}],
       "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"EventSpecifications", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"checkstatus", ",", "chronstatus", ",", "nestliststatus", ",", 
         RowBox[{"{", 
          RowBox[{
          "True", ",", "True", ",", "True", ",", "stnoopevs", ",", "True"}], 
          "}"}], ",", "morestatus"}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"Replace", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"{", "evspecseq", "}"}], ",", "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"sop_", "?", "SuperoperatorQ"}], ",", "evopts___Rule"}],
              "}"}], "\[RuleDelayed]", "\[IndentingNewLine]", 
            RowBox[{"{", 
             RowBox[{"sop", ",", 
              RowBox[{"allowedeventopts", "[", 
               RowBox[{"evopts", ",", "evspecopts", ",", "opts"}], "]"}]}], 
             "}"}]}], ",", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"evgen_", "?", "ValidGeneratorQ"}], ",", 
              RowBox[{"dur", ":", "DurationPattern"}], ",", " ", 
              "evopts___Rule"}], "}"}], ":>", 
            RowBox[{"{", 
             RowBox[{"evgen", ",", "dur", ",", 
              RowBox[{"allowedeventopts", "[", 
               RowBox[{"evopts", ",", "evspecopts", ",", "opts"}], "]"}]}], 
             "}"}]}], ",", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"repev_Repeat", ",", "evopts___Rule"}], "}"}], ":>", 
            RowBox[{"{", 
             RowBox[{"repev", ",", 
              RowBox[{"allowedeventopts", "[", 
               RowBox[{
               "Repeat", ",", "evopts", ",", "evspecopts", ",", "opts"}], 
               "]"}]}], "}"}]}], ",", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"precalev_PrecalculatedEvent", ",", "evopts___Rule"}], 
             "}"}], ":>", 
            RowBox[{"{", 
             RowBox[{"precalev", ",", 
              RowBox[{"allowedeventopts", "[", 
               RowBox[{"evopts", ",", "evspecopts", ",", "opts"}], "]"}]}], 
             "}"}]}]}], "\[IndentingNewLine]", "}"}], ",", 
         "\[IndentingNewLine]", "1"}], "\[IndentingNewLine]", "]"}], ",", 
       "\[IndentingNewLine]", "opts"}], "\[IndentingNewLine]", "]"}]}], 
    ")"}]}], ";"}]], "Input",
 InitializationCell->True,
