           RowBox[{"TimeDependentGeneratorFunction", "[", 
            RowBox[{"t", ",", 
             RowBox[{"Evaluate", "@", "\[Tau]xpairs1"}], ",", "T", ",", 
             "func"}], "]"}], ",", 
           RowBox[{"Chop", "[", "\[Delta]t", "]"}], ",", "opts"}], "}"}]}], 
        "\[IndentingNewLine]", "}"}]}], "\[IndentingNewLine]", ")"}]}], 
    "]"}]}], ";"}]], "Input",
 InitializationCell->True,
