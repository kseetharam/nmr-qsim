Cell[BoxData[
 RowBox[{
  RowBox[{"PulseSequence", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"st", ":", 
     RowBox[{"False", "|", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"_", "?", "BooleanQ"}], ".."}], "}"}]}]}], ",", 
    "\[IndentingNewLine]", "spins_List", ",", "\[IndentingNewLine]", 
    RowBox[{"\[Tau]", ":", 
     RowBox[{"Except", "[", "_List", "]"}]}], ",", "\[IndentingNewLine]", 
    RowBox[{"elements", ":", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"pseqels", ":", 
        RowBox[{"PulseSequenceElementPattern", ".."}]}], ",", "___Rule"}], 
      "}"}]}], ",", "opts___Rule"}], "]"}], ":=", "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "spinsets", "}"}], ",", 
    RowBox[{
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{"PulseSequence", "[", 
       RowBox[{
       "st", ",", "spins", ",", "\[Tau]", ",", "\[IndentingNewLine]", 
        RowBox[{"Replace", "[", "\[IndentingNewLine]", 
         RowBox[{"elements", ",", "\[IndentingNewLine]", 
          RowBox[{"{", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{
             RowBox[{"Pulse", "[", 
              RowBox[{"Automatic", ",", "specs_", ",", "elopts___Rule"}], 
              "]"}], "\[RuleDelayed]", 
             RowBox[{"Pulse", "[", 
              RowBox[{"spins", ",", "specs", ",", "elopts"}], "]"}]}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"ShapedPulse", "[", 
              RowBox[{
              "Automatic", ",", "dur_", ",", "specs_", ",", "elopts___Rule"}],
               "]"}], "\[RuleDelayed]", 
             RowBox[{"ShapedPulse", "[", 
              RowBox[{"spins", ",", "dur", ",", "specs", ",", "elopts"}], 
              "]"}]}], ",", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"HoldPattern", "@", 
              RowBox[{"PulseSequence", "[", 
               RowBox[{
               "status_", ",", "Automatic", ",", "dur_", ",", "more__", ",", 
                "pseqopts___Rule"}], "]"}]}], "\[RuleDelayed]", 
             "\[IndentingNewLine]", 
             RowBox[{"PulseSequence", "[", 
              RowBox[{
              "False", ",", "spins", ",", "Automatic", ",", "more", ",", 
               "pseqopts"}], "]"}]}]}], "\[IndentingNewLine]", "}"}], ",", 
          "\[IndentingNewLine]", "1"}], "]"}], ",", "\[IndentingNewLine]", 
        "opts"}], "]"}], "\[IndentingNewLine]", ")"}], "/;", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"spinsets", "=", 
        RowBox[{"InvolvedSpins", "/@", 
         RowBox[{"{", "pseqels", "}"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"!", 
        RowBox[{"FreeQ", "[", 
         RowBox[{"spinsets", ",", "Automatic"}], "]"}]}]}], 
      "\[IndentingNewLine]", ")"}]}]}], "]"}]}]], "Input",
 InitializationCell->True,
