Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"CoherenceOrderFiltration", "::", "usage"}], "=", 
   "\[IndentingNewLine]", 
   "\"\<CoherenceOrderFiltration[{order1, order2...}] implements filtration \
through a set of coherence orders (all orders in the set {order1, order2...} \
being allowed, with other orders disallowed). \n\
CoherenceOrderFiltration[spins,{order1, order2...}] implements filtration \
through a set of coherence orders of spins (all orders of spins not included \
in {order1, order2...} are suppressed, while all orders for spins not \
included in spins are allowed).\nCoherenceOrderFiltration[{spins1,{order1, \
order2...},{spins2,{order3, order4...}..}] filters successively through \
{order1, order2...} for spins1, orders {order3, order4...} for spins2, etc. \n\
Examples: After SetSpinSystem[4], CoherenceOrderFiltration[0] or \
CoherenceOrderFiltration[{0}] suppresses all coherences which are not \
zero-quantum for all four spins. CoherenceOrderFiltration[{1,2},0] suppresses \
all coherences which are not zero-quantum for spins {1,2}, but permits all \
coherences for spins {3,4}. CoherenceOrderFiltration[{{1,2},0},{{3,4},0}] \
suppresses all terms that are not zero-quantum for both sets of spins {1,2} \
and {3,4}. \nExpand may be applied to a CoherenceOrderFiltration object, in \
order to convert it into an explicit event.  \n\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.683110930825906*^9, 3.683110960429503*^9}, {
   3.683957681054821*^9, 3.683957681056888*^9}, {3.68473148634813*^9, 
