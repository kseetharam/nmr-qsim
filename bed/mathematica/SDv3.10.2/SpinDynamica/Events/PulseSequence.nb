Cell[CellGroupData[{

Cell["SimplifyPulseSequenceElementRules", "Section",
 CellChangeTimes->{
  3.605545643975979*^9, {3.692273171428668*^9, 3.692273178545579*^9}, {
   3.6922732102110233`*^9, 
   3.69227321099354*^9}},ExpressionUUID->"7b0181e9-7006-4996-9f5f-\
365838addce9"],

Cell["\<\
This routine combines options (in a similar way to SimplifyRules) with the \
exception of PhaseShift, which is additive in the case that several \
PhaseShift specifications are present (this happens when PulseSequence passes \
down a PhaseShift option to a Pulse object which already contains a \
PhaseShift option). \
\>", "Text",
 CellChangeTimes->{{3.692273181450912*^9, 3.692273245711873*^9}, {
  3.6922768004005013`*^9, 
  3.6922768519150047`*^9}},ExpressionUUID->"fd9544da-e752-45b6-bd98-\
196a7c86fb97"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SimplifyPulseSequenceElementRules", "[", "opts___Rule", "]"}], ":=",
    "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"\[CapitalPhi]opts", ",", "\[CapitalPhi]tot"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"\[CapitalPhi]opts", "=", 
        RowBox[{"Cases", "[", 
         RowBox[{
          RowBox[{"{", "opts", "}"}], ",", 
          RowBox[{"HoldPattern", "[", 
           RowBox[{"PhaseShift", "\[Rule]", "_"}], "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"\[CapitalPhi]tot", "=", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Length", "[", "\[CapitalPhi]opts", "]"}], 
           "\[GreaterEqual]", "1"}], ",", 
          RowBox[{"Plus", "@@", 
           RowBox[{"(", 
            RowBox[{"Last", "/@", "\[CapitalPhi]opts"}], ")"}]}], ",", "0"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"SimplifyRules", "[", 
        RowBox[{
         RowBox[{"PhaseShift", "->", "\[CapitalPhi]tot"}], ",", "opts"}], 
        "]"}]}], "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.692266470269188*^9, 3.692266525419346*^9}, {
   3.692266835915805*^9, 3.692266959802257*^9}, {3.692267959219981*^9, 
   3.6922681056543913`*^9}, 3.692273266650573*^9},
 CellLabel->"In[20]:=",ExpressionUUID->"ecc5272a-6ea6-4186-89cd-da9b7f7f1d23"]
}, Closed]],

Cell[CellGroupData[{

Cell["FilterPulseSequenceElementOptions", "Section",
 CellChangeTimes->{
  3.605545643975979*^9, {3.692273171428668*^9, 3.692273178545579*^9}, {
