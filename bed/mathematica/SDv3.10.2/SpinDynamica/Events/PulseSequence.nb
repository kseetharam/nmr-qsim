   RowBox[{"LocalGeneratorSymbols", ",", "\[IndentingNewLine]", 
    RowBox[{"TargetFunctions", "\[Rule]", 
     RowBox[{"Union", "@", 
      RowBox[{"Append", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"TargetFunctions", "/.", 
         RowBox[{"Options", "[", "LocalGeneratorSymbols", "]"}]}], ",", 
        "\[IndentingNewLine]", "_ShapedPulse"}], "]"}]}]}]}], 
   "\[IndentingNewLine]", "]"}], ";"}]], "Input",
