Cell[CellGroupData[{

Cell["standard PulseSequence element", "Subsubsection",
 CellChangeTimes->{{3.6925525836271963`*^9, 
  3.692552614267516*^9}},ExpressionUUID->"116d3e99-4256-4094-8746-\
af489a01e456"],

Cell["\<\
exclude any options that unambiguously belong to a different type of \
PulseSequence element\
\>", "Text",
 CellChangeTimes->{{3.692552881544471*^9, 
  3.692552907364786*^9}},ExpressionUUID->"bf437338-8c61-4e18-aef4-\
e579fff03850"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"FilterPulseSequenceElementOptions", "[", 
     RowBox[{"(", 
      RowBox[{"type", ":", 
       RowBox[{"(", 
        RowBox[{"Alternatives", "@@", "PulseSequenceElementTypes"}], ")"}]}], 
      ")"}], "]"}], "[", "opts___Rule", "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"othertypes", ",", "otheroptionpars", ",", "badoptionpars"}], 
      "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"othertypes", "=", 
        RowBox[{"Complement", "[", 
         RowBox[{"PulseSequenceElementTypes", ",", 
          RowBox[{"{", "type", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"otheroptionpars", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Length", "[", "#", "]"}], "\[Equal]", "0"}], ",", 
            RowBox[{"{", "}"}], ",", 
            RowBox[{"Union", "[", 
             RowBox[{"First", "/@", "#"}], "]"}]}], "]"}], "&"}], "@", 
         RowBox[{"Flatten", "[", 
          RowBox[{"Options", "/@", "othertypes"}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"badoptionpars", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Length", "[", "#", "]"}], "\[Equal]", "0"}], ",", 
            "otheroptionpars", ",", 
            RowBox[{"Complement", "[", 
             RowBox[{"otheroptionpars", ",", 
              RowBox[{"First", "/@", "#"}]}], "]"}]}], "]"}], "&"}], "@", 
         RowBox[{"Options", "[", "type", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"SimplifyRules", "[", 
        RowBox[{"Sequence", "@@", 
         RowBox[{"FilterRules", "[", 
          RowBox[{
           RowBox[{"{", "opts", "}"}], ",", 
           RowBox[{"Except", "[", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"Alternatives", "@@", "badoptionpars"}], ")"}], 
             "\[Rule]", "_"}], "]"}]}], "]"}]}], "\[IndentingNewLine]", 
        "]"}]}], "\[IndentingNewLine]", ")"}]}], "\[IndentingNewLine]", 
    "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.6925526232035*^9, 3.692552871541399*^9}, {
   3.692552924764845*^9, 3.692552925939806*^9}, 3.692553236861361*^9, 
   3.6925535155141087`*^9, 3.692553794874281*^9, {3.6925543694334106`*^9, 
   3.6925543808373337`*^9}, 3.6925547598463984`*^9, {3.692555519827445*^9, 
   3.692555539816641*^9}, {3.6925555826847277`*^9, 3.69255566374749*^9}, 
   3.692556032237186*^9, {3.692571623040497*^9, 3.692571724862801*^9}, {
   3.6925717631202602`*^9, 3.6925718749451723`*^9}, {3.769704395146953*^9, 
   3.769704401599268*^9}},
 CellLabel->"In[22]:=",ExpressionUUID->"cb24882b-629d-40f3-b0f9-19f9df6381cb"]
}, Closed]]
}, Closed]],

