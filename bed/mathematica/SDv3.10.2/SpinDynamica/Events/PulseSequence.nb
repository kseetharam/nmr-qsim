Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"PulseSequence", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"HoldPattern", "[", 
       RowBox[{"st", ":", 
        RowBox[{"{", 
         RowBox[{"optst_", ",", "False", ",", "morest___"}], "}"}]}], "]"}], 
      ",", "\[IndentingNewLine]", "spins_", ",", "\[IndentingNewLine]", 
      RowBox[{"\[Tau]", ":", 
       RowBox[{"Except", "[", "Automatic", "]"}]}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"els", ":", 
         RowBox[{"PulseSequenceElementPattern", ".."}]}], ",", "___Rule"}], 
       "}"}], ",", "opts___Rule"}], "]"}], "/;", 
    RowBox[{"!", 
     RowBox[{"FreeQ", "[", 
      RowBox[{
       RowBox[{"{", "els", "}"}], ",", 
       RowBox[{"HoldPattern", "@", 
        RowBox[{"Delay", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"Automatic", ",", "_"}], "}"}], ",", "___"}], "]"}]}], ",", 
       RowBox[{"{", "1", "}"}]}], "]"}]}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "elements", ",", "xtot", ",", "flexdels", ",", "nonflexels", ",", 
       "flex\[Tau]"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"elements", "=", 
        RowBox[{"{", "els", "}"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"flexdels", "=", 
        RowBox[{"Cases", "[", 
         RowBox[{"elements", ",", 
          RowBox[{"HoldPattern", "@", 
           RowBox[{"Delay", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"Automatic", ",", "_"}], "}"}], ",", "___"}], "]"}]}], 
          ",", 
          RowBox[{"{", "1", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"nonflexels", "=", 
        RowBox[{"Complement", "[", 
         RowBox[{"elements", ",", "flexdels"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"flex\[Tau]", "=", 
        RowBox[{"\[Tau]", "-", 
         RowBox[{"Duration", "[", "nonflexels", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"xtot", "=", 
        RowBox[{"Plus", "@@", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"Part", "[", 
             RowBox[{"#", ",", "1", ",", "2"}], "]"}], "&"}], "/@", 
           "flexdels"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"TrueQ", "[", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"flex\[Tau]", "<", "0"}], ")"}], "||", 
           RowBox[{"(", 
            RowBox[{"flex\[Tau]", ">", "\[Tau]"}], ")"}]}], "]"}], ",", 
         "\[IndentingNewLine]", "\t", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Message", "[", 
            RowBox[{"PulseSequence", "::", "negflex\[Tau]"}], "]"}], ";", 
           "$Failed"}], ")"}], ",", "\[IndentingNewLine]", 
         RowBox[{"PulseSequence", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"optst", ",", "True", ",", "morest"}], "}"}], ",", 
           "\[IndentingNewLine]", "spins", ",", "\[Tau]", ",", 
           "\[IndentingNewLine]", 
           RowBox[{"Replace", "[", "\[IndentingNewLine]", 
            RowBox[{"elements", ",", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"Delay", "[", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"Automatic", ",", "x_"}], "}"}], ",", "evgen_", ",", 
                "dopts___Rule"}], "]"}], "\[RuleDelayed]", 
              RowBox[{"Delay", "[", 
               RowBox[{
                RowBox[{"flex\[Tau]", "*", 
                 RowBox[{"(", 
                  RowBox[{"x", "/", "xtot"}], ")"}]}], ",", "evgen", ",", 
                "dopts"}], "]"}]}], ",", "\[IndentingNewLine]", 
             RowBox[{"{", "1", "}"}]}], "\[IndentingNewLine]", "]"}], ",", 
           "\[IndentingNewLine]", "opts"}], "\[IndentingNewLine]", "]"}]}], 
        "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", ")"}]}], 
    "]"}]}], ";"}]], "Input",
