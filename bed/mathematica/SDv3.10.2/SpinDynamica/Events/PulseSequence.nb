Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"PulseSequence", "::", "usage"}], "=", 
   "\"\<PulseSequence[spins, {element1, element2..}, options] generates a \
pulse sequence object which may be used in SpinDynamica calculations. Each \
element may be a Delay, a Pulse, a ShapedPulse, a CoherenceOrderFiltration \
instruction, or another PulseSequence. \nThe spins argument determines which \
spins the pulse sequence elements apply to. If spins is omitted, all spins in \
the current SpinSystem[] are assumed.\nThe form PulseSequence[spins, \[Tau], \
{element1, element2..}, options] adjusts the durations of any \
Delay[Automatic..] elements so as to ensure a total pulse sequence duration \
\[Tau].  \nThe options provide values for any of the internal elements, \
including the Pulse options NutationFrequency, and AmplitudeFactor. These \
options apply to all of the internal elements, unless those elements \
themselves have options, which then take precedence. The option PhaseShift \
specifies a phase shift of all contained pulse sequence elements. \nExpand \
may be applied to a PulseSequence object, in order to convert it into a list \
of explicit events.  \n\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.683110930825906*^9, 3.683110960429503*^9}, {
   3.683957681054821*^9, 3.683957681056888*^9}, {3.68473148634813*^9, 
   3.6847319047868156`*^9}, {3.684732038249943*^9, 3.68473207538481*^9}, {
   3.691833458137909*^9, 3.691833470340055*^9}, {3.691833983726281*^9, 
   3.69183408207032*^9}, {3.6918341224953747`*^9, 3.691834454874242*^9}, {
