Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Pulse", "::", "usage"}], "=", 
    "\"\<Pulse[spins,{\[Beta],\[Phi]},options] specifies a rectangular pulse \
of flip angle \[Beta] and phase \[Phi] applied to spins. The flip angle \
\[Beta] and phase \[Phi] are both specified in radians. The arguments \\\"x\\\
\", \\\"y\\\",\\\"-x\\\",\\\"-y\\\" may also be used for the phase argument. \
\nThe option NutationFrequency may be used to specify the rf field amplitude, \
expressed as a nutation frequency. If NutationFrequency and \[Beta] are both \
specified, the duration of the pulse is adjusted accordingly. \nThe option \
PulseDuration may be used to specify the duration of the pulse in seconds. If \
PulseDuration and \[Beta] are both specified, the nutation frequency of the \
pulse is adjusted accordingly. \nIf neither NutationFrequency nor \
PulseDuration are specified, the pulse is assumed to be infinitesimally \
short. \nThe option AmplitudeFactor may be used to specify the rf field \
amplitude relative to a nominal value. This may be used to simulate the \
effect of rf inhomogeneity. AmplitudeFactor\[Rule]1 indicates a rf field \
amplitude equal to the nominal value. If the value of AmplitudeFactor is less \
than 1, the simulated rf field is weaker than the nominal value (no \
corresponding adjustment to the pulse duration is made). \nExpand may be \
applied to a Pulse object, in order to convert it into an explicit event.  \n\
\>\""}], ";"}], "\n"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.683110930825906*^9, 3.683110960429503*^9}, {
  3.683957681054821*^9, 3.683957681056888*^9}, {3.68473148634813*^9, 
  3.6847319047868156`*^9}, {3.684732038249943*^9, 3.68473207538481*^9}, {
  3.691833458137909*^9, 3.691833470340055*^9}, {3.691833563553875*^9, 
