      RowBox[{"Quantity", "[", "\"\<VacuumPermittivity\>\"", "]"}]}]}]}], ",", 
   RowBox[{"kB", " ", "\[Rule]", " ", 
    RowBox[{"QuantityMagnitude", "@", 
     RowBox[{"UnitConvert", "@", 
      RowBox[{"Quantity", "[", "\"\<BoltzmannConstant\>\"", "]"}]}]}]}], ",", 
   "\[IndentingNewLine]", 
