  RowBox[{
   RowBox[{"c", " ", "\[Rule]", " ", 
    RowBox[{"QuantityMagnitude", "@", 
     RowBox[{"UnitConvert", "@", 
      RowBox[{"Quantity", "[", "\"\<speed of light\>\"", "]"}]}]}]}], ",", 
   "\[IndentingNewLine]", 
