     RowBox[{"UnitConvert", "@", 
      RowBox[{"Quantity", "[", "\"\<AvogadroConstant\>\"", "]"}]}]}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"e", "\[Rule]", 
    RowBox[{"QuantityMagnitude", "@", 
     RowBox[{"UnitConvert", "@", 
      RowBox[{"Quantity", "[", "\"\<ElectronCharge\>\"", "]"}]}]}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"me", "\[Rule]", 
    RowBox[{"QuantityMagnitude", "@", 
     RowBox[{"UnitConvert", "@", 
      RowBox[{"Quantity", "[", "\"\<ElectronMass\>\"", "]"}]}]}]}], ",", 
