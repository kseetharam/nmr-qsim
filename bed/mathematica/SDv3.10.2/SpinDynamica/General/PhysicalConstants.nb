Cell[CellGroupData[{

Cell["use \[OpenCurlyDoubleQuote]PhysicalConstants`\[CloseCurlyDoubleQuote] \
package if less than Mathematica 9", "Subsection",
 PageWidth->WindowWidth,
 InitializationCell->True,
 CellChangeTimes->{{3.574846292735124*^9, 3.574846293156372*^9}, {
  3.5968846508132277`*^9, 3.5968846679313717`*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"2bda5ed9-a6c1-41bd-90a7-ce5710f697a3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{"$VersionNumber", "<", "9"}], ",", "\[IndentingNewLine]", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Needs", "[", "\"\<PhysicalConstants`\>\"", "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"PhysicalConstantValues", "=", 
       RowBox[{"{", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"c", " ", "\[Rule]", " ", 
          RowBox[{"PhysicalConstants`SpeedOfLight", "/", 
           RowBox[{"(", 
            RowBox[{"Meter", "/", "Second"}], ")"}]}]}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"h", " ", "\[Rule]", 
          RowBox[{"PhysicalConstants`PlanckConstant", "/", 
           RowBox[{"(", 
            RowBox[{"Joule", " ", "Second"}], ")"}]}]}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"\[HBar]", " ", "\[Rule]", " ", 
          RowBox[{"PhysicalConstants`PlanckConstantReduced", "/", 
           RowBox[{"(", 
            RowBox[{"Joule", " ", "Second"}], ")"}]}]}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"\[Mu]0", "\[Rule]", 
          RowBox[{"PhysicalConstants`VacuumPermeability", "/", 
           RowBox[{"(", 
            RowBox[{"Second", " ", 
             RowBox[{"Volt", "/", 
              RowBox[{"(", 
               RowBox[{"Meter", " ", "Ampere"}], ")"}]}]}], ")"}]}]}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"\[Epsilon]0", "\[Rule]", 
          RowBox[{"PhysicalConstants`VacuumPermittivity", "/", 
           RowBox[{"(", 
            RowBox[{"Ampere", " ", 
             RowBox[{"Second", "/", 
              RowBox[{"(", 
               RowBox[{"Meter", " ", "Volt"}], ")"}]}]}], ")"}]}]}], ",", 
         RowBox[{"kB", " ", "\[Rule]", " ", 
          RowBox[{"PhysicalConstants`BoltzmannConstant", "/", 
           RowBox[{"(", 
            RowBox[{"Joule", "/", "Kelvin"}], ")"}]}]}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"Nav", " ", "\[Rule]", " ", 
          RowBox[{"PhysicalConstants`AvogadroConstant", "/", 
           RowBox[{"(", 
            RowBox[{"1", "/", "Mole"}], ")"}]}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"e", "\[Rule]", 
          RowBox[{"PhysicalConstants`ElectronCharge", "/", "Coulomb"}]}], ",",
          "\[IndentingNewLine]", 
         RowBox[{"me", "\[Rule]", 
          RowBox[{"PhysicalConstants`ElectronMass", "/", "Kilogram"}]}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"mp", "\[Rule]", 
          RowBox[{"PhysicalConstants`ProtonMass", "/", "Kilogram"}]}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"mn", "\[Rule]", 
          RowBox[{"PhysicalConstants`NeutronMass", "/", "Kilogram"}]}]}], 
        "\[IndentingNewLine]", "}"}]}]}], ")"}]}], "\[IndentingNewLine]", 
   "]"}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.596885685582542*^9, 3.596885690085359*^9}, {
   3.596885758687698*^9, 3.596885774634112*^9}, 3.596886127262281*^9, {
   3.5968867165280867`*^9, 3.596886724509384*^9}, 3.5968876498527603`*^9, {
   3.596887784069169*^9, 3.5968877845859623`*^9}, {3.596887816422132*^9, 
   3.596887828827874*^9}, {3.596887898244855*^9, 3.5968879471541767`*^9}, {
   3.5969719839425583`*^9, 3.596972014216826*^9}, {3.639585149691033*^9, 
   3.639585179666658*^9}},ExpressionUUID->"e9f503f8-d25e-4120-873e-\
5074e5cf05e5"]
}, Closed]],

