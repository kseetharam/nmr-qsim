Cell[BoxData[
 RowBox[{
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{"$VersionNumber", "<", "13.1"}], ",", 
    RowBox[{"(", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"BlockDiagonalMatrix", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"mat1_", "?", "MatrixQ"}], ",", 
         RowBox[{"mat2_", "?", "MatrixQ"}]}], "}"}], "]"}], ":=", 
      "\[IndentingNewLine]", 
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"n1", ",", "n2"}], "}"}], ",", 
        RowBox[{"(", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{"n1", ",", "n2"}], "}"}], "=", 
           RowBox[{"Length", "/@", 
            RowBox[{"{", 
             RowBox[{"mat1", ",", "mat2"}], "}"}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"MatchQ", "[", 
                RowBox[{
                 RowBox[{"Head", "[", "mat1", "]"}], ",", "SparseArray"}], 
                "]"}], "||", 
               RowBox[{"MatchQ", "[", 
                RowBox[{
                 RowBox[{"Head", "[", "mat2", "]"}], ",", "SparseArray"}], 
                "]"}]}], ",", "\[IndentingNewLine]", 
              RowBox[{"SparseArray", "[", "#", "]"}], ",", "#"}], "]"}], 
            "&"}], "@", "\[IndentingNewLine]", 
           RowBox[{"Join", "[", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"Join", "[", 
                RowBox[{"#", ",", 
                 RowBox[{"Table", "[", 
                  RowBox[{"0", ",", 
                   RowBox[{"{", "n2", "}"}]}], "]"}]}], "]"}], "&"}], "/@", 
              "mat1"}], ",", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{
               RowBox[{"Join", "[", 
                RowBox[{
                 RowBox[{"Table", "[", 
                  RowBox[{"0", ",", 
                   RowBox[{"{", "n1", "}"}]}], "]"}], ",", "#"}], "]"}], 
               "&"}], "/@", "mat2"}]}], "\[IndentingNewLine]", "]"}]}]}], 
         "\[IndentingNewLine]", ")"}]}], "]"}]}], "\[IndentingNewLine]", 
     ")"}]}], "]"}], ";"}]], "Input",
