     RowBox[{
      RowBox[{"OptimalBipartiteGraphMatching", "[", "\"\<step2\>\"", "]"}], ":=",
       "\[IndentingNewLine]", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"zmat", "=", 
         RowBox[{"matMR", "/.", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"0", "\[Rule]", " ", "1"}], ",", 
