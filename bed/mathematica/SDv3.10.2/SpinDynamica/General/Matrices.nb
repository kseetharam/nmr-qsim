Cell[BoxData[
 RowBox[{
  RowBox[{"OptimalBipartiteGraphMatching", "[", "mat_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "done", ",", "dim", ",", "zpset", ",", "rcoverc", ",", "ccoverc", ",", 
