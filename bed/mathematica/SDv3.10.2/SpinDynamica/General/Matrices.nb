       ",", "colset", ",", "rowset", ",", "zeroset", ",", "rpos", ",", "zpos",
       ",", "cpos", ",", "zptrack", ",", "zstartrack", ",", "rcover", ",", 
      "findstarredzeroinrow", ",", "finduncoveredzero", ",", "minR"}], "}"}], 
    ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"matMR", "=", "mat"}], ";", "\[IndentingNewLine]", 
