Cell[CellGroupData[{

Cell["NDiagonalize", "Subsection",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 CellChangeTimes->{{3.586070650573553*^9, 
  3.5860706527635736`*^9}},ExpressionUUID->"23ff2fdf-217e-480d-a749-\
37cdd3f25731"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"NDiagonalize", "::", "usage"}], "=", 
   "\"\<NDiagonalize[mat,opts] returns the form {X,evals,Xinv} where X is the \
matrix whose columns are the normalized eigenvectors of mat, and Xinv is the \
inverse of X. The option \
Assumptions\[Rule]{OrthogonalEigenvectors\[Rule]True} may be used to allow \
the use of ConjugateTranspose to invert X.\n\nThe syntax \
NDiagonalize[superop,opbasis,basis,opts] causes a superoperator to be \
converted into diagonalized form in the operator basis opbasis and state \
basis basis (explicit specification of these bases is optional). The option \
Assumptions may be used with NDiagonalize when it is applied to a \
superoperator. If Assumptions\[Rule]Automatic, the setting of \
SuperoperatorType determines whether assumptions of the type Assumptions\
\[Rule]{OrthogonalEigenvectors\[Rule]True} are used.\n\nThe syntax \
NDiagonalize[op,basis,opts] causes an operator to be converted into \
diagonalized form in the Hilbert basis (specification of this is optional). \
The option Assumptions may be used with NDiagonalize when it is applied to an \
operator. If Assumptions\[Rule]Automatic, the setting of OperatorType \
determines whether assumptions of the type \
Assumptions\[Rule]{OrthogonalEigenvectors\[Rule]True} are used.\>\""}], 
  ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.586070826897516*^9, 3.586070845276064*^9}, {
   3.586080044487323*^9, 3.586080055604177*^9}, {3.586089145784408*^9, 
   3.586089167847836*^9}, {3.8970373945836678`*^9, 3.897037396049207*^9}, {
   3.897037431275876*^9, 3.897037449396865*^9}, {3.897037515808775*^9, 
   3.897037542610777*^9}, 3.89703762222972*^9, 
   3.897037672054793*^9},ExpressionUUID->"52c445e3-cf89-4cbb-97d6-\
ba9675c1c321"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"OrthogonalEigenvectors", "::", "usage"}], "=", 
   "\"\<An assumption of the form Assumptions\[Rule]{OrthogonalEigenvectors\
\[Rule]True} may be used in NDiagonalize to allow the use of \
ConjugateTranspose to invert the eigenvector matrix.\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.586070819537876*^9, 
  3.586070905038425*^9}},ExpressionUUID->"7c7e5fc4-ba51-4344-8896-\
b8dffb4f92c6"]
}, Closed]],

