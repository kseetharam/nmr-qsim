      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"minR", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"Min", "[", "#", "]"}], "&"}], "/@", "matMR"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"matMR", "=", 
