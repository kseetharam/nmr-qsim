            RowBox[{"ComplexExpand", "@", 
             RowBox[{"Conjugate", "[", "b", "]"}]}]}], ")"}]}]}], "}"}]}], 
      ",", "\[IndentingNewLine]", 
      RowBox[{"Dimensions", "[", "sa", "]"}]}], "\[IndentingNewLine]", 
     "]"}]}]}], ";"}]], "Input",
 InitializationCell->True,
