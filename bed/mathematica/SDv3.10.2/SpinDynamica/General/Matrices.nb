             RowBox[{"x_", "/;", 
              RowBox[{"x", "\[NotEqual]", "0"}]}], "\[Rule]", " ", "0"}]}], 
           "}"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"zeroset", "=", 
         RowBox[{"Position", "[", 
          RowBox[{"zmat", ",", "1"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"While", "[", 
         RowBox[{
          RowBox[{"rowset", "\[NotEqual]", 
