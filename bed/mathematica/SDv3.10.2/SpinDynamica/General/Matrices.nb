        RowBox[{"(", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"Chop", "[", "#", "]"}], "==", "0"}], ")"}], "&"}], "/@", 
          RowBox[{"Flatten", "@", 
           RowBox[{"Table", "[", " ", 
            RowBox[{
             RowBox[{"Drop", "[", 
              RowBox[{
               RowBox[{"mat", "[", 
