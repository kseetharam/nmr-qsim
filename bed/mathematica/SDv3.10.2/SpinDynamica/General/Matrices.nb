                 RowBox[{"Abs", "[", "#", "]"}], "^", "2"}], ")"}], "&"}], "/@", 
              RowBox[{"Flatten", "[", "X", "]"}]}], ")"}]}]}], "]"}]}]}], 
       "\[Equal]", "0"}], ")"}]}]}], ";"}], "\[IndentingNewLine]"}]], "Input",\

