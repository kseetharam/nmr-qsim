Cell["\<\
DirectProduct[matA_?MatrixQ,matB_?MatrixQ]:=
\tFlatten[#,1]& @
\t\tMap[
\t\t\tFunction[arow,
\t\t\t\tMap[
\t\t\t\t\tFunction[brow,
\t\t\t\t\t\tFlatten[#,2]&@{ 
\t\t\t\t\t\t\tMap[
\t\t\t\t\t\t\t\tFunction[acol,\t\t
\t\t\t\t\t\t\t\t\tacol*brow
\t\t\t\t\t\t\t\t],
\t\t\t\t\t\t\t\tarow
\t\t\t\t\t\t\t] 
\t\t\t\t\t\t}
\t\t\t\t\t],
\t\t\t\t\tmatB
\t\t\t\t]
\t\t\t],
\t\t\tmatA
\t\t]\
\>", "Input",
