Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Adjoint", "[", "sa_SparseArray", "]"}], "/;", 
    RowBox[{"MatrixQ", "[", "sa", "]"}]}], ":=", "\n", "\t", 
   RowBox[{"Transpose", "@", 
    RowBox[{"SparseArray", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"ArrayRules", "[", "sa", "]"}], "/.", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
