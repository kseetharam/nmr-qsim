Cell[CellGroupData[{

Cell["numeric matrix", "Subsection",
 InitializationCell->True,
 CellChangeTimes->{{3.586861877204552*^9, 3.586861898059215*^9}, {
  3.586861932032152*^9, 
  3.58686194825243*^9}},ExpressionUUID->"caff4a70-b622-4096-9d98-\
826de191c54c"],

Cell["\<\
In the case of Assumptions\[Rule]{OrthogonalEigenvectors\[Rule]True}, \
orthogonalization is applied individually to all eigenvector subspaces \
belonging to degenerate eigenvalue sets. The degenerate subspaces are treated \
independently, for the sake of numerical efficiency. The inverse of the X \
matrix may then be calculated by normalizing the eigenvectors and using \
ConjugateTranspose. Surprisingly, in tests, this does not lead to \
computational advantages over just using the Inverse, even for large \
matrices, mainly because of the cost of the Tally operation for large \
vectors. Nevertheless I have kept the code in. Assumptions\[Rule]False may be \
used to force use of the Inverse.\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.586078389076832*^9, 3.586078428036951*^9}, {
  3.586078605140266*^9, 3.586078620824727*^9}, {3.586085037635858*^9, 
  3.586085115476633*^9}, {3.586088423688616*^9, 3.586088429590706*^9}, {
  3.586088523392727*^9, 3.5860885510380793`*^9}, {3.586088582593645*^9, 
  3.586088650115561*^9}},ExpressionUUID->"bb0865da-3808-4e9f-91a4-\
ff4e28dfad2b"],

Cell["\<\
v3.6.1 tests for singularity of eigenvectors and exits with failure in that \
case\
\>", "Text",
 CellChangeTimes->{{3.837839288112564*^9, 3.83783931123635*^9}, {
  3.837931597767592*^9, 
  3.837931613590355*^9}},ExpressionUUID->"69c319a6-415c-4445-ab7f-\
5227bace1661"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"NDiagonalize", "[", 
    RowBox[{
     RowBox[{"mat_", "?", "NumericMatrixQ"}], ",", "opts___Rule"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "evals", ",", "evecs", ",", "X", ",", "Xinv", ",", "ass", ",", 
       "orthogevecs", ",", "degevals", ",", "degevalpositions"}], "}"}], ",", 
     
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"ass", "=", 
        RowBox[{
         RowBox[{"Assumptions", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "NDiagonalize", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"orthogevecs", "=", "\[IndentingNewLine]", 
        RowBox[{"Switch", "[", 
         RowBox[{"ass", ",", "\[IndentingNewLine]", 
          RowBox[{"None", "|", "False", "|", "Automatic"}], ",", "False", ",",
           "\[IndentingNewLine]", 
          RowBox[{"_Rule", "|", 
           RowBox[{"{", 
            RowBox[{"_Rule", "..."}], "}"}]}], ",", "\[IndentingNewLine]", 
          "\t", 
          RowBox[{"OrthogonalEigenvectors", "/.", 
           RowBox[{"Flatten", "[", 
            RowBox[{"{", 
             RowBox[{"ass", ",", 
              RowBox[{"OrthogonalEigenvectors", "\[Rule]", "False"}]}], "}"}],
             "]"}]}], ",", "\[IndentingNewLine]", "_", ",", "False"}], 
         "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"evals", ",", "evecs"}], "}"}], "=", 
        RowBox[{"Eigensystem", "[", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Length", "[", "mat", "]"}], "\[GreaterEqual]", "256"}], 
           ",", 
           RowBox[{"N", "@", 
            RowBox[{"Normal", "@", "mat"}]}], ",", 
           RowBox[{"N", "@", "mat"}]}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{"orthogevecs", ",", "\[IndentingNewLine]", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"degevals", "=", 
            RowBox[{"First", "/@", 
             RowBox[{"Select", "[", 
              RowBox[{
               RowBox[{"Tally", "[", 
                RowBox[{"evals", ",", 
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{"Chop", "[", 
                    RowBox[{"#1", "-", "#2"}], "]"}], "\[Equal]", "0"}], 
                   ")"}], "&"}]}], "]"}], ",", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"Last", "[", "#", "]"}], ">", "1"}], ")"}], "&"}]}],
               "]"}]}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"degevalpositions", "=", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{"Flatten", "@", 
                RowBox[{"Position", "[", 
                 RowBox[{
                  RowBox[{"Chop", "[", 
                   RowBox[{"evals", "-", "#"}], "]"}], ",", "0"}], "]"}]}], 
               ")"}], "&"}], "/@", "degevals"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"evecs", "=", 
            RowBox[{"ReplacePart", "[", 
             RowBox[{"evecs", ",", 
              RowBox[{"Flatten", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"MapThread", "[", 
                  RowBox[{"Rule", ",", 
                   RowBox[{"{", 
                    RowBox[{"#", ",", 
                    RowBox[{"Orthogonalize", "[", 
                    RowBox[{
                    "evecs", "\[LeftDoubleBracket]", "#", 
                    "\[RightDoubleBracket]"}], "]"}]}], "}"}]}], "]"}], "&"}],
                 "/@", "degevalpositions"}], "]"}]}], "]"}]}]}], 
          "\[IndentingNewLine]", ")"}]}], "\[IndentingNewLine]", "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"X", "=", 
        RowBox[{"SparseArray", "@", 
         RowBox[{"Chop", "@", 
          RowBox[{"Transpose", "[", 
           RowBox[{"Normalize", "/@", "evecs"}], "]"}]}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Xinv", "=", 
        RowBox[{"If", "[", 
         RowBox[{"orthogevecs", ",", "\[IndentingNewLine]", 
          RowBox[{"ConjugateTranspose", "[", "X", "]"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"(", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"Chop", "@", 
               RowBox[{"Det", "[", "X", "]"}]}], "==", "0"}], ",", 
             "\[IndentingNewLine]", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"Message", "[", 
                RowBox[{"NDiagonalize", "::", "sing"}], "]"}], ";", 
               "$Failed"}], ")"}], ",", "\[IndentingNewLine]", 
             RowBox[{"SparseArray", "@", 
              RowBox[{"Inverse", "[", "X", "]"}]}]}], "]"}], 
           "\[IndentingNewLine]", ")"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Switch", "[", 
        RowBox[{"Xinv", ",", "\[IndentingNewLine]", 
         RowBox[{"_Inverse", "|", "_PseudoInverse"}], ",", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Message", "[", 
            RowBox[{"NDiagonalize", "::", "fail"}], "]"}], ";", "$Failed"}], 
          ")"}], ",", "\[IndentingNewLine]", "_", ",", 
         RowBox[{"{", 
          RowBox[{"X", ",", "evals", ",", "Xinv"}], "}"}]}], 
