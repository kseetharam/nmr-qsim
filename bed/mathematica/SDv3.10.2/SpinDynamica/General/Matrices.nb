Cell[CellGroupData[{

Cell["DirectProduct", "Subsection",
 PageWidth:>WindowWidth,
 InitializationCell->
  True,ExpressionUUID->"32ac9548-22c8-47a5-814b-fee26f8dd5a3"],

Cell["\<\
DirectProduct::usage=
\t\"DirectProduct[m1,m2] generates direct product of
\tmatrices m1 \\!\\(\[CircleTimes]\\) m2.\\n
\tDirectProduct[v1,m2] generates direct product of row vector v1 and matrix \
m2.\\n
\t\tDirectProduct[m1,v2] generates direct product of matrix m1 and row vector \
v2.\\n
\t\tDirectProduct[v1,v2] generates direct product of row vector v1 and row \
vector v2.\\n
\t\tDirectProduct[a,b,c..] takes many pairwise direct products in sequence, \
i.e. a \\!\\(\[CircleTimes]\\) b \\!\\(\[CircleTimes]\\) c\";\
\>", "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 AspectRatioFixed->
  True,ExpressionUUID->"a100134c-3dd4-4c64-84e6-4a8ffcfe6b62"]
}, Closed]],

