   RowBox[{
    RowBox[{"$VersionNumber", "<", "12"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"SolidAngle", "[", 
      RowBox[{"{", 
       RowBox[{"v1_", ",", "v2_", ",", "v3_"}], "}"}], "]"}], ":=", 
     RowBox[{"0", "/;", 
      RowBox[{
       RowBox[{"v1", "==", "v2"}], "||", 
       RowBox[{"v2", "==", "v3"}], "||", 
       RowBox[{"v3", "==", "v1"}]}]}]}]}], "\[IndentingNewLine]", "]"}], 
  ";"}]], "Input",
