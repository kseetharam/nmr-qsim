       "\n", "\t\t", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"TrueQ", "[", 
          RowBox[{
           RowBox[{"Simplify", "@", 
            RowBox[{"Chop", "@", 
             RowBox[{"N", "[", 
              RowBox[{"vzN", "-", 
               RowBox[{"vxN", "\[Cross]", "vyN"}]}], "]"}]}]}], "==", 
           RowBox[{"{", 
            RowBox[{"0", ",", "0", ",", "0"}], "}"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"vxN", ",", "vyN", ",", "vzN"}], "}"}], ",", 
         RowBox[{"Message", "[", 
