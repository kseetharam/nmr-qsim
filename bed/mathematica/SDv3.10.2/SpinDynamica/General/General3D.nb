Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"AxisSystem", "[", 
    RowBox[{"vx_List", ",", "vz_List"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"vxN", ",", "vyN", ",", "vzN"}], "}"}], ",", 
