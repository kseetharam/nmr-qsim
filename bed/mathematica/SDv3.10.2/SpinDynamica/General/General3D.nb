Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SolidAngle", "::", "\"\<usage\>\""}], "=", 
   "\"\<SolidAngle[{v1,v2,v3}] determines the solid angle subtended at the \
centre of the unit sphere by the triangle with vertices {v1,v2,v3}.\\n \
SolidAngle[{v1,v2,v3,v4}] sums the solid angles of the triangles {v1,v2,v3} \
and {v1,v4,v3}\>\""}], ";"}]], "Input",
 PageWidth:>PaperWidth,
 InitializationCell->True,
 InitializationGroup->True,
 AspectRatioFixed->
  True,ExpressionUUID->"d2b3786b-bccd-4374-a639-bdfbc534ebdf"]
