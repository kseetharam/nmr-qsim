Cell[BoxData[
 RowBox[{
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{"$VersionNumber", "<", "12"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"SolidAngle", "[", 
      RowBox[{"{", 
       RowBox[{"v1_", ",", "v2_", ",", "v3_"}], "}"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "a", ",", "b", ",", "c", ",", "A", ",", "B", ",", "C", ",", "d", ",", 
         "nv1", ",", "nv2", ",", "nv3"}], "}"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{"nv1", ",", "nv2", ",", "nv3"}], "}"}], "=", 
         RowBox[{"Normalize", "/@", 
          RowBox[{"{", 
           RowBox[{"v1", ",", "v2", ",", "v3"}], "}"}]}]}], ";", 
        RowBox[{"c", "=", 
         RowBox[{"ArcCos", "[", 
          RowBox[{"v1", ".", "v2"}], "]"}]}], ";", 
        RowBox[{"a", "=", 
         RowBox[{"ArcCos", "[", 
          RowBox[{"v2", ".", "v3"}], "]"}]}], ";", 
        RowBox[{"b", "=", 
         RowBox[{"ArcCos", "[", 
          RowBox[{"v3", ".", "v1"}], "]"}]}], ";", 
        RowBox[{"A", "=", 
         RowBox[{"ArcCos", "[", 
          FractionBox[
           RowBox[{
            RowBox[{"Cos", "[", "a", "]"}], "-", 
            RowBox[{
             RowBox[{"Cos", "[", "b", "]"}], " ", 
             RowBox[{"Cos", "[", "c", "]"}]}]}], 
           RowBox[{
            RowBox[{"Sin", "[", "b", "]"}], " ", 
            RowBox[{"Sin", "[", "c", "]"}]}]], "]"}]}], ";", 
        RowBox[{"B", "=", 
         RowBox[{"ArcCos", "[", 
          FractionBox[
           RowBox[{
            RowBox[{
             RowBox[{"Cos", "[", "b", "]"}], " ", 
             RowBox[{"Sin", "[", "c", "]"}]}], "-", 
            RowBox[{
             RowBox[{"Cos", "[", "A", "]"}], " ", 
             RowBox[{"Cos", "[", "c", "]"}], " ", 
             RowBox[{"Sin", "[", "b", "]"}]}]}], 
           RowBox[{"Sin", "[", "a", "]"}]], "]"}]}], ";", 
        RowBox[{"C", "=", 
         RowBox[{"ArcCos", "[", 
          FractionBox[
           RowBox[{
            RowBox[{
             RowBox[{"Cos", "[", "c", "]"}], " ", 
             RowBox[{"Sin", "[", "b", "]"}]}], "-", 
            RowBox[{
             RowBox[{"Cos", "[", "A", "]"}], " ", 
             RowBox[{"Cos", "[", "b", "]"}], " ", 
             RowBox[{"Sin", "[", "c", "]"}]}]}], 
           RowBox[{"Sin", "[", "a", "]"}]], "]"}]}], ";", 
        RowBox[{"A", "+", "B", "+", "C", "-", "\[Pi]"}]}]}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}], ";"}]], "Input",
 InitializationCell->True,
