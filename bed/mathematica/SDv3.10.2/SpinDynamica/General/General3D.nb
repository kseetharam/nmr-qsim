   RowBox[{"SubtendedAngle", "::", "\"\<usage\>\""}], "=", 
   "\"\<SubtendedAngle[v1,v2,v3,v4] determines the angle subtended by the \
v1-v2 and v3-v4 vectors. SubtendedAngle[v1,v2,v3] determines the angle \
subtended by the v1-v2 and v2-v3 vectors. \\n\n    SubtendedAngle[v1,v2] \
determines the angle subtended by the 0-v1 and 0-v2 vectors.\>\""}], 
  ";"}]], "Input",
