Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"PolarToVector", "[", 
    RowBox[{"r_", ",", 
     RowBox[{"{", 
      RowBox[{"th_", ",", "ph_"}], "}"}]}], "]"}], ":=", 
   RowBox[{"N", "[", 
    RowBox[{"r", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"Sin", "[", "th", "]"}], " ", 
        RowBox[{"Cos", "[", "ph", "]"}]}], ",", 
       RowBox[{
        RowBox[{"Sin", "[", "th", "]"}], " ", 
        RowBox[{"Sin", "[", "ph", "]"}]}], ",", 
       RowBox[{"Cos", "[", "th", "]"}]}], "}"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 InitializationGroup->True,
 AspectRatioFixed->
  True,ExpressionUUID->"ae361712-cee6-4dc2-ba2d-949a0f8c670b"]
}, Closed]],

Cell[CellGroupData[{

Cell["VectorToPolar", "Subsection",
 InitializationCell->True,
 InitializationGroup->True,
 AspectRatioFixed->
  True,ExpressionUUID->"02718806-33d9-4ce3-93f9-e467ff5375b4"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"VectorToPolar", "[", 
    RowBox[{"vec", ":", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"x_", "?", "NumericQ"}], ",", 
       RowBox[{"y_", "?", "NumericQ"}], ",", 
       RowBox[{"z_", "?", "NumericQ"}]}], "}"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"r", ",", "v", ",", "th", ",", "ph"}], "}"}], ",", 
     RowBox[{
      RowBox[{"r", "=", 
       RowBox[{"Norm", "[", "vec", "]"}]}], ";", 
      RowBox[{"v", "=", 
       RowBox[{"Normalize", "[", "vec", "]"}]}], ";", 
      RowBox[{"th", "=", 
       RowBox[{"ArcCos", "[", 
        RowBox[{"v", "\[LeftDoubleBracket]", "3", "\[RightDoubleBracket]"}], 
        "]"}]}], ";", 
      RowBox[{"ph", "=", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Chop", "[", 
           RowBox[{"N", "[", 
            RowBox[{
             RowBox[{"Abs", "[", 
              RowBox[{
              "v", "\[LeftDoubleBracket]", "3", "\[RightDoubleBracket]"}], 
              "]"}], "-", "1"}], "]"}], "]"}], "==", "0"}], ",", "0", ",", 
         RowBox[{"ArcTan", "[", 
          RowBox[{
           RowBox[{
           "v", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], ",", 
           RowBox[{
           "v", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]}], 
          "]"}]}], "]"}]}], ";", 
      RowBox[{"{", 
       RowBox[{"r", ",", 
        RowBox[{"{", 
         RowBox[{"th", ",", "ph"}], "}"}]}], "}"}]}]}], "]"}]}], 
  ";"}]], "Input",
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{3.409320051339212*^9, 3.409649814891385*^9},
 AspectRatioFixed->
  True,ExpressionUUID->"daa4c857-93b2-4529-950e-6ea4d2d1527d"]
}, Closed]],

