Cell[CellGroupData[{

Cell["AxisSystem", "Subsection",
 InitializationCell->True,
 InitializationGroup->True,
 AspectRatioFixed->
  True,ExpressionUUID->"620be9f2-7512-4a66-b6f4-71705e48eb0f"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"AxisSystem", "::", "\"\<usage\>\""}], "=", 
   "\"\<AxisSystem[vz] generates a normalized right-handed axis system with \
three orthogonal axes, the last one parallel to vz. The first axis is in \
(ex,vz) plane.   \nAxisSystem[vx,vz] generates a normalized right-handed axis \
system with first axis in {vx,vz} plane and third axis parallel to vz.   \n\
AxisSystem[vx,vy,vz] generates a normalized right-handed axis system if the \
input vectors are already orthogonal. \nAxisSystem[] defaults to {ex,ey,ez}.\n\
AxisSystem[{vx,vy,vz}] has the same meaning as AxisSystem[vx,vy,vz]\>\""}], 
  ";"}]], "Input",
 PageWidth:>PaperWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.409814877736721*^9, 3.409814950707582*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"6e42cfb7-e304-4c14-9505-e91e744c4be3"]
}, Closed]],

