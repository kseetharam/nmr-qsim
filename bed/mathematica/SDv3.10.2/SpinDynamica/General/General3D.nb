       RowBox[{
        RowBox[{"{", 
         RowBox[{"vxN", ",", "vzN"}], "}"}], "=", 
        RowBox[{"Simplify", "@", 
         RowBox[{"PowerExpand", "@", 
          RowBox[{"ComplexExpand", "[", 
           RowBox[{"Normalize", "/@", 
            RowBox[{"{", 
             RowBox[{"vx", ",", "vz"}], "}"}]}], "]"}]}]}]}], ";", "\n", 
       "\t\t", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"TrueQ", "[", 
          RowBox[{
           RowBox[{"vxN", "==", "vzN"}], "||", 
           RowBox[{"vxN", "==", 
            RowBox[{"-", "vzN"}]}]}], "]"}], ",", 
         RowBox[{"AxisSystem", "[", "vzN", "]"}], ",", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"vyN", "=", 
             RowBox[{"Simplify", "@", 
              RowBox[{"PowerExpand", "@", 
               RowBox[{"ComplexExpand", "@", 
                RowBox[{"Normalize", "[", 
                 RowBox[{"vzN", "\[Cross]", "vxN"}], "]"}]}]}]}]}], ";", 
            RowBox[{"vxN", "=", 
             RowBox[{"Simplify", "@", 
              RowBox[{"PowerExpand", "@", 
               RowBox[{"ComplexExpand", "@", 
                RowBox[{"Normalize", "[", 
                 RowBox[{"vyN", "\[Cross]", "vzN"}], "]"}]}]}]}]}]}], ")"}], 
          ";", 
          RowBox[{"{", 
           RowBox[{"vxN", ",", "vyN", ",", "vzN"}], "}"}]}]}], "]"}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
