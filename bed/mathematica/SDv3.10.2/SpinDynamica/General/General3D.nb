Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"AxisSystem", "[", 
    RowBox[{"vx_List", ",", "vy_List", ",", "vz_List"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"vxN", ",", "vyN", ",", "vzN"}], "}"}], ",", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"vxN", ",", "vyN", ",", "vzN"}], "}"}], "=", 
