  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"n123", ",", "n234"}], "}"}], ",", 
    RowBox[{
     RowBox[{"n123", "=", 
      RowBox[{"Normalize", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"v2", "-", "v1"}], ")"}], "\[Cross]", 
        RowBox[{"(", 
         RowBox[{"v2", "-", "v3"}], ")"}]}], "]"}]}], ";", 
     RowBox[{"n234", "=", 
      RowBox[{"Normalize", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"v3", "-", "v2"}], ")"}], "\[Cross]", 
        RowBox[{"(", 
         RowBox[{"v3", "-", "v4"}], ")"}]}], "]"}]}], ";", 
     RowBox[{"N", "[", 
      RowBox[{"ArcTan", "[", 
       RowBox[{
        RowBox[{"n123", ".", "n234"}], ",", 
        RowBox[{
         RowBox[{"n123", "\[Cross]", "n234"}], ".", 
