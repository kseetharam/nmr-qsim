    RowBox[{
     RowBox[{"{", "vzN", "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"vzN", "=", 
        RowBox[{"Simplify", "@", 
         RowBox[{"PowerExpand", "@", 
          RowBox[{"ComplexExpand", "@", 
           RowBox[{"Normalize", "[", "vz", "]"}]}]}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Which", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"TrueQ", "[", 
          RowBox[{"vzN", "==", "ex"}], "]"}], ",", 
         RowBox[{"AxisSystem", "[", 
          RowBox[{
           RowBox[{"-", "ez"}], ",", "vzN"}], "]"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"TrueQ", "[", 
          RowBox[{"vzN", "==", 
           RowBox[{"-", "ex"}]}], "]"}], ",", 
         RowBox[{"AxisSystem", "[", 
          RowBox[{"ez", ",", "vzN"}], "]"}], ",", "\[IndentingNewLine]", 
         "True", ",", 
         RowBox[{"AxisSystem", "[", 
          RowBox[{"ex", ",", "vzN"}], "]"}]}], "\[IndentingNewLine]", "]"}]}],
       "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
