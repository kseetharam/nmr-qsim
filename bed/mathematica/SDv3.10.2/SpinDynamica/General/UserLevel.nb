Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"RestoreBuiltInDefinitions", "[", "symb_Symbol", "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "protected", "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"protected", "=", 
        RowBox[{"MemberQ", "[", 
         RowBox[{
          RowBox[{"Attributes", "[", "symb", "]"}], ",", "Protected"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"BuiltInDefinitionsSavedQ", "[", "symb", "]"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"(", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"If", "[", 
            RowBox[{"protected", ",", 
             RowBox[{"Unprotect", "[", "symb", "]"}]}], "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"(*", 
            RowBox[{
             RowBox[{"Print", "[", 
              RowBox[{"\"\<Restoring down & upvalues for \>\"", ",", "symb"}],
               "]"}], ";"}], "*)"}], "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"DownValues", "[", "symb", "]"}], "=", 
            RowBox[{"BuiltInDownValues", "[", "symb", "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"UpValues", "[", "symb", "]"}], "=", 
            RowBox[{"BuiltInUpValues", "[", "symb", "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{"protected", ",", 
             RowBox[{"Protect", "[", "symb", "]"}]}], "]"}]}], 
          "\[IndentingNewLine]", ")"}]}], "]"}], ";"}], "\[IndentingNewLine]",
       ")"}]}], "]"}]}], ";"}]], "Input",
