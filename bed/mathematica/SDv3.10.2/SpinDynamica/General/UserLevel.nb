             RowBox[{"Print", "[", 
              RowBox[{"\"\<clearing definitions for \>\"", ",", "symb"}], 
              "]"}], ";"}], "*)"}], "\[IndentingNewLine]", 
           RowBox[{"RestoreBuiltInDefinitions", "[", "symb", "]"}]}], ")"}]}],
         "]"}], ";", "\[IndentingNewLine]", 
