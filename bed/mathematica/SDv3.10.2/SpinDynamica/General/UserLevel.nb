Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SaveBuiltInDefinitions", "[", "symb_Symbol", "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"(", "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{"Print", "[", 
       RowBox[{"\"\<Storing down & upvalues for \>\"", ",", "symb"}], "]"}], 
      ";"}], "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"BuiltInDownValues", "[", "symb", "]"}], "=", 
      RowBox[{"DownValues", "[", "symb", "]"}]}], ";", "\[IndentingNewLine]", 
     
     RowBox[{
      RowBox[{"BuiltInUpValues", "[", "symb", "]"}], "=", 
      RowBox[{"UpValues", "[", "symb", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"BuiltInDefinitionsSavedQ", "[", "symb", "]"}], "=", "True"}], 
     ";"}], "\[IndentingNewLine]", ")"}]}], ";"}]], "Input",
 InitializationCell->True,
