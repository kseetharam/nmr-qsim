  RowBox[{
   RowBox[{"DeleteUserLevelDependentDefinitions", "[", 
    RowBox[{"symb_Symbol", ",", "uls_List"}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "protected", "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"protected", "=", 
        RowBox[{"MemberQ", "[", 
         RowBox[{
          RowBox[{"Attributes", "[", "symb", "]"}], ",", "Protected"}], 
