   3.745402136228402*^9}},ExpressionUUID->"da32a7d7-f579-4005-b910-\
3957e672571f"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"UserLevelDependentDefinition", "::", "usage"}], "=", 
   "\"\<UserLevelDependentDefinition is used internally by SpinDynamica. \
UserLevelDependentDefinition[symb,level,code] sets up definitions associated \
with symb which are only active when the UserLevel is given by level or \
below. These definitions are inactivated when the UserLevel is set higher \
than level.\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.745397488185357*^9, 3.7453976345783978`*^9}, {
  3.745397675101475*^9, 3.745397679497604*^9}},
 CellLabel->"In[58]:=",ExpressionUUID->"76a08b65-a333-491a-8e8d-04e65e524801"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"UserLevelDependentDefinitions", "::", "usage"}], "=", 
   "\"\<UserLevelDependentDefinitions is used internally by SpinDynamica. \
UserLevelDependentDefinitions[symb,level] returns the definitions associated \
with symb which are only active when the UserLevel is given by level or \
below. These definitions are inactivated when the UserLevel is set higher \
than level. UserLevelDependentDefinitions[symb,{level}]  returns all \
definitions for symb active at user level level and above, and \
UserLevelDependentDefinitions[symb] returns all definitions for symb active \
in the current user level environment. \>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.745397488185357*^9, 3.7453976345783978`*^9}, {
  3.745397675101475*^9, 3.745397679497604*^9}, {3.745402144534951*^9, 
  3.745402162484394*^9}, {3.745413435072736*^9, 
  3.74541360156304*^9}},ExpressionUUID->"268f64e4-74ae-425a-9c95-\
733bcbfde277"]
}, Closed]],

