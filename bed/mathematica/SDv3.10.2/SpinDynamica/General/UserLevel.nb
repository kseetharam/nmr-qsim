Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"SetUserLevel", "::", "ini"}], "=", 
    "\"\<The user level is being initialized to `1`. The user level may be \
set to an integer between 1 and `2` by using SetUserLevel[level]. Low user \
levels provide strong syntax trapping at the expense of slow execution for \
some routines. High user levels relax the syntax trapping in order to provide \
better execution speeds.\>\""}], ";"}], " "}]], "Input",
 InitializationCell->True,
