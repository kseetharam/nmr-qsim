Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SetUserLevel", "::", "usage"}], "=", 
   "\"\<SetUserLevel[n] sets the user level of SpinDynamica. The minimum user \
level of 1 implements a high degree of error trapping and reporting, but may \
have a slow execution speed for some routines. High user levels have fewer \
syntax checks and error traps, but run faster.\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.683118704723757*^9, 3.6831188253620872`*^9}, {
  3.728124564880349*^9, 3.728124566625264*^9}, {3.7281247320878363`*^9, 
  3.7281247598681793`*^9}, {3.728126134877759*^9, 3.7281261348802657`*^9}, {
