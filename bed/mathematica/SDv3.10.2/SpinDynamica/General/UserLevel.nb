Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SetUserLevel", "[", 
    RowBox[{"ul_", ",", "opts___Rule"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"ulstodelete", ",", "ulstoimplement"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"SetOptions", "[", 
        RowBox[{"UserLevel", ",", 
         RowBox[{"UserLevel", "\[Rule]", "ul"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"DeleteUserLevelDependentDefinitions", "[", "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"ImplementUserLevelDependentDefinitions", "@", 
        RowBox[{"Range", "[", 
         RowBox[{"ul", ",", "MaximumUserLevel"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"$KernelID", "\[Equal]", "0"}], ",", "\[IndentingNewLine]", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Switch", "[", 
            RowBox[{"ul", ",", "\[IndentingNewLine]", "1", ",", 
             RowBox[{"Message", "[", 
              RowBox[{
               RowBox[{"SetUserLevel", "::", "minul"}], ",", 
               "MaximumUserLevel"}], "]"}], ",", "\[IndentingNewLine]", 
             "MaximumUserLevel", ",", 
             RowBox[{"Message", "[", 
              RowBox[{
               RowBox[{"SetUserLevel", "::", "maxul"}], ",", " ", "ul"}], 
              "]"}], ",", "\[IndentingNewLine]", "_", ",", 
             RowBox[{"Message", "[", 
              RowBox[{
               RowBox[{"SetUserLevel", "::", "ul"}], ",", " ", "ul"}], 
              "]"}]}], "\[IndentingNewLine]", "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"Message", "[", 
            RowBox[{
             RowBox[{"SetUserLevel", "::", "modsymbs"}], ",", 
             "\[IndentingNewLine]", 
             RowBox[{"Select", "[", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"UserLevelDependentSymbols", "[", 
                RowBox[{"{", "ul", "}"}], "]"}], ",", "\[IndentingNewLine]", 
               RowBox[{
                RowBox[{"MemberQ", "[", 
                 RowBox[{
                  RowBox[{"Attributes", "[", "#", "]"}], ",", "Protected"}], 
                 "]"}], "&"}]}], "\[IndentingNewLine]", "]"}]}], 
            "\[IndentingNewLine]", "]"}]}], ")"}]}], "\[IndentingNewLine]", 
        "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"$KernelID", "\[Equal]", "0"}], "&&", 
          RowBox[{"$KernelCount", ">", "0"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"ParallelEvaluate", "[", 
          RowBox[{"Quiet", "@", 
           RowBox[{"SetUserLevel", "[", "ul", "]"}]}], "]"}]}], 
        "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"UserLevel", "[", "]"}]}], "\[IndentingNewLine]", ")"}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
 InitializationCell->True,
