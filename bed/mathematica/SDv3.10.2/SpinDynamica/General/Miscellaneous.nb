Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"DeclareAsReal", "[", "x_", "]"}], ":=", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"Re", "[", "x", "]"}], "^=", "x"}], ";", 
     RowBox[{
      RowBox[{"Im", "[", "x", "]"}], "^=", "0"}], ";", 
     RowBox[{
      RowBox[{"Conjugate", "[", "x", "]"}], "^=", "x"}], ";", 
     RowBox[{"Message", "[", 
      RowBox[{
       RowBox[{"DeclareAsReal", "::", "dec"}], ",", "x"}], "]"}]}], ")"}]}], 
  ";"}]], "Input",
 InitializationCell->True,
