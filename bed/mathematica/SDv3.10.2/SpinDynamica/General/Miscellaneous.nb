Cell[CellGroupData[{

Cell["identify problematic undefined symbols", "Subsubsection",
 CellChangeTimes->{{3.683965171750427*^9, 3.683965226304183*^9}, {
  3.907407704627326*^9, 
  3.907407718732118*^9}},ExpressionUUID->"f5556ef4-8e14-4aa4-b171-\
a100749e94b3"],

Cell["only detect problematic symbols in the Global context", "Text",
 CellChangeTimes->{{3.683965171750427*^9, 
  3.683965226304183*^9}},ExpressionUUID->"dbc7dea9-8aba-47b9-979f-\
8d21351c94fd"],

Cell["\<\
the complicated code is needed to get inside the SparseArray objects and find \
any unassigned symbols there.\
\>", "Text",
 CellChangeTimes->{{3.9449036135742702`*^9, 
  3.944903634104312*^9}},ExpressionUUID->"ca693835-dee2-46e0-ad90-\
9465cd4f04dc"],

Cell["\<\
the double application of Cases[.._Symbol] in the code below should not be \
necessary. However a bug was found when applying Cases[.._Symbol] to code \
containing TimeDependentGeneratorFunction[..], which was resolved by this \
double application. The reason for this behaviour is unknown, but it may be a \
Mathematica bug when Cases is applied to certain forms. \
\>", "Text",
 CellChangeTimes->{{3.94507296446544*^9, 3.945073056428752*^9}, {
  3.945079596420776*^9, 
  3.9450796282595167`*^9}},ExpressionUUID->"2ca89c98-9060-4035-93ee-\
620bbb19e71d"],

Cell["\<\
v3.10.2b4: exclude flagging up symbols which occur inside a replacement rule \
for a numeric argument, eg {A->2} should not yield an unassigned symbol A, \
since later application of the rule will make it numeric. \
\>", "Text",
 CellChangeTimes->{{3.9722793325106983`*^9, 3.972279411044024*^9}, {
  3.972279544096941*^9, 
  3.9722795904267607`*^9}},ExpressionUUID->"5abfa4a5-2daa-4ba5-8e68-\
ea9a18e7bde2"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"UnassignedSymbols", "[", 
    RowBox[{"arg_", ",", "permittedsymbols_List", ",", "opts___Rule"}], "]"}],
    ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "suspectsymbols", ",", "sparsearraypositions", ",", 
       "sparsearraytargets", ",", "sparsearrayreplacements", ",", "arg2", ",",
        "symbolswithnumericreplacementrules"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"sparsearraypositions", "=", 
        RowBox[{"Position", "[", 
         RowBox[{"arg", ",", "_SparseArray", ",", "Infinity"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"sparsearraytargets", "=", 
        RowBox[{"Extract", "[", 
         RowBox[{"arg", ",", "sparsearraypositions"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"sparsearrayreplacements", "=", 
        RowBox[{"sparsearraytargets", "/.", 
         RowBox[{"sa_SparseArray", ":>", 
          RowBox[{"Normal", "[", "sa", "]"}]}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"arg2", "=", 
        RowBox[{"ReplacePart", "[", 
