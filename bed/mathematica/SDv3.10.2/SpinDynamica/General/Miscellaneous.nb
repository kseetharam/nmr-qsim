Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ReplaceEverywhere", "::", "usage"}], 
   "=", "\"\<ReplaceEverywhere[a, b->c..] is the same as ReplaceAll (/.) but \
works inside SparseArrays, which ReplaceAll does not. ReplaceEverywhere also \
allows the syntax ReplaceEverywhere[a, b->c, b[1]->d..], in which case b[1] \
is replaced by d, instead of by c[1]. This feature is important in the coding \
for ensemble calculations. \n\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.4642549887737627`*^9, 3.4642551029931707`*^9}, {
  3.4642554391933303`*^9, 3.4642554422922688`*^9}, {3.5332025638117657`*^9, 
  3.533202624219545*^9}, {3.944817993342671*^9, 3.9448180665572557`*^9}, {
  3.944819711600614*^9, 3.9448197548871803`*^9}},
 CellLabel->
  "In[395]:=",ExpressionUUID->"960ec574-9c34-4b64-8e3a-631883425f3c"]
}, Closed]],

