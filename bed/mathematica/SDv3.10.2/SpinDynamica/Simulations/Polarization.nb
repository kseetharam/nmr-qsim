0327c57e71f6"],

Cell["\<\
Generates an operator which returns the average polarization level over the \
spin pairs, when used with OperatorAmplitude. The uses of Plus@@ here, rather \
than Mean@, is non-intuitive, but is necessary to generate properly \
normalized results.\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.674558398432225*^9, 3.67455850495749*^9}, {
  3.674563068434957*^9, 
  3.674563070560267*^9}},ExpressionUUID->"095afdeb-1020-4448-86bd-\
51cd3a258e6a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SingletPolarizationLevelOperator", "[", 
    RowBox[{
     RowBox[{"spinpairs", ":", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"_", ",", "_"}], "}"}], ".."}], "}"}]}], ",", "spinsys_"}], 
    "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"FreeQ", "[", 
        RowBox[{"#", ",", "$Failed"}], "]"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"SingletPolarizationLevelOperator", "[", 
         RowBox[{"spinpairs", ",", "spinsys"}], "]"}], "=", "#"}], ",", 
       "\[IndentingNewLine]", "$Failed"}], "\[IndentingNewLine]", "]"}], 
     "&"}], "@", "\[IndentingNewLine]", 
    RowBox[{"Simplify", "[", 
     RowBox[{"Plus", "@@", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"SingletPolarizationLevelOperator", "[", 
          RowBox[{"#", ",", "spinsys"}], "]"}], "&"}], "/@", "spinpairs"}], 
       ")"}]}], "]"}]}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.6672968466189*^9, 3.667296914365736*^9}, {
   3.6672983279243608`*^9, 3.667298345744331*^9}, 3.66729870702059*^9, {
   3.667299386743327*^9, 3.667299433048047*^9}, {3.6740258734829683`*^9, 
