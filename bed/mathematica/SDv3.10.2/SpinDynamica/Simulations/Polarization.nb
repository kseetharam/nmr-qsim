  3.6745583967443933`*^9}},ExpressionUUID->"f2ac1677-6724-4d5f-9236-\
307a4206f5e1"],

Cell["\<\
Generates an operator which returns the average polarization level over the \
spins, when used with OperatorAmplitude. The uses of Plus@@ here, rather than \
Mean@, is non-intuitive, but is necessary to generate properly normalized \
results.\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.674558398432225*^9, 
  3.67455850495749*^9}},ExpressionUUID->"b566be02-d2e0-46aa-aaa0-\
12f85cbc2b4b"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"PolarizationLevelOperator", "[", "spins_List", "]"}], "/;", 
    RowBox[{"!", 
     RowBox[{"DuplicateFreeQ", "[", "spins", "]"}]}]}], ":=", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"Message", "[", 
      RowBox[{
