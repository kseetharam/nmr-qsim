Cell["many spins", "Subsection",
 InitializationCell->True,
 CellChangeTimes->{{3.66732859726386*^9, 3.667328616232379*^9}, {
  3.6740248144387293`*^9, 3.674024816388267*^9}, {3.674025062534934*^9, 
