e22d903762cb"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SingletPolarizationLevelOperator", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"j_", ",", "k_"}], "}"}], ",", "spinsys_"}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"SingletPolarizationLevelOperator", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"j", ",", "k"}], "}"}], ",", "spinsys"}], "]"}], "=", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"(", 
       RowBox[{"4", "/", 
        RowBox[{"BasisDimension", "[", 
         RowBox[{"ZeemanBasis", "[", "spinsys", "]"}], "]"}]}], ")"}]}], 
     RowBox[{
      RowBox[{"opI", "[", "j", "]"}], ".", 
      RowBox[{"opI", "[", "k", "]"}]}]}]}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.674057268493222*^9, 3.67405728267424*^9}, {
   3.67428446270064*^9, 3.6742844693474708`*^9}, 3.6742859087766247`*^9, 
   3.674551725835902*^9, 3.674556784766302*^9, 3.674562093918816*^9, {
