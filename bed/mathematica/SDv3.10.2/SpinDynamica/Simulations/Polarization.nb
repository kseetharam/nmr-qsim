Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SingletPolarizationLevelOperator", "[", 
    RowBox[{
     RowBox[{"spinpairs", ":", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"_", ",", "_"}], "}"}], ".."}], "}"}]}], ",", "spinsys_"}], 
    "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "}"}], ",", 
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Message", "[", 
         RowBox[{"SingletPolarizationLevelOperator", "::", "sharedspins"}], 
         "]"}], ";", "\[IndentingNewLine]", "$Failed"}], 
       "\[IndentingNewLine]", ")"}], "/;", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Length", "[", "spinpairs", "]"}], ">", "1"}], ")"}], "&&", 
        
        RowBox[{"And", "@@", 
         RowBox[{"Apply", "[", 
          RowBox[{"DisjointQ", ",", " ", 
           RowBox[{"Subsets", "[", 
            RowBox[{"spinpairs", ",", 
             RowBox[{"{", "2", "}"}]}], "]"}], ",", 
           RowBox[{"{", "1", "}"}]}], "]"}]}]}], "\[IndentingNewLine]", 
       ")"}]}]}], "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
 InitializationCell->True,
