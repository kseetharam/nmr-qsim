Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SingletPolarizationLevelOperator", "::", "usage"}], "=", 
   "\[IndentingNewLine]", 
   "\"\<SingletPolarizationLevelOperator is an operator for the polarization \
level of the spin system. For example \
OperatorAmplitude[\[Rho]\[Rule]SingletPolarizationLevelOperator[{1,2}]] \
extracts the mean singlet polarization level of spins 1 and 2, for the \
density operator \[Rho].\n\
SingletPolarizationLevelOperator[{{j1,k1},{j2,k2}..}] is the operator for the \
mean level of singlet polarization for the specified spin pairs.\n\
SingletPolarizationLevelOperator may be used as an observable in simulation \
routines (Trajectory, TransformationAmplitude, etc.) in order to simulate the \
singlet polarization level of the spin system. \n\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->CompressedData["
