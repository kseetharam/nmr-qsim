Cell[CellGroupData[{

Cell["main code (* now valid for arbitrary spin *)", "Subsubsection",
 InitializationCell->True,
 CellChangeTimes->{{3.674559277367179*^9, 3.674559284971189*^9}, {
  3.674634042759197*^9, 3.674634043410975*^9}, {3.908792361176899*^9, 
  3.908792371671277*^9}},ExpressionUUID->"02eb89cf-4691-4490-aef1-\
2240dddff53b"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"PolarizationLevelOperator", "[", 
    RowBox[{
     RowBox[{"j", ":", 
      RowBox[{"Except", "[", "_List", "]"}]}], ",", 
     RowBox[{"axis_", "?", "ValidAxisSpecificationQ"}], ",", "spinsys_"}], 
    "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"PolarizationLevelOperator", "[", 
      RowBox[{"axis", ",", "j", ",", "spinsys"}], "]"}], "=", 
     "\[IndentingNewLine]", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"Ij", ",", "dim"}], "}"}], ",", 
       RowBox[{"(", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Ij", "=", 
          RowBox[{"SpinQuantumNumber", "[", 
           RowBox[{"j", ",", "spinsys"}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"dim", "=", 
          RowBox[{"BasisDimension", "[", 
           RowBox[{"ZeemanBasis", "[", "spinsys", "]"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"Simplify", "[", 
          RowBox[{
           RowBox[{"3", "/", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"Ij", "+", "1"}], ")"}], "*", "dim"}], ")"}]}], "*", 
           RowBox[{"opI", "[", 
            RowBox[{"j", ",", "axis"}], "]"}]}], "]"}]}], 
        "\[IndentingNewLine]", ")"}]}], "]"}]}], "\[IndentingNewLine]", 
    ")"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.674552004145714*^9, 3.674552042091813*^9}, {
  3.6745522106661386`*^9, 3.674552215727611*^9}, {3.6745531351489067`*^9, 
  3.6745531422908993`*^9}, {3.6745533014152*^9, 3.674553305013316*^9}, {
  3.674556768544409*^9, 3.67455676927495*^9}, {3.674558359849109*^9, 
  3.674558361715095*^9}},ExpressionUUID->"c8c078b8-b579-4657-b603-\
7d0b4644c39e"]
}, Closed]],

Cell[CellGroupData[{

Cell["explanation", "Subsubsection",
 InitializationCell->True,
 CellChangeTimes->{{3.674559277367179*^9, 3.674559288278892*^9}, {
  3.6745609265418777`*^9, 
  3.6745609283510118`*^9}},ExpressionUUID->"8389fbbb-2724-495e-912d-\
af05b10bd707"],

Cell[TextData[{
 "The factors are calculated as follows:\n\
OperatorAmplitude(\[Rho]\[Rule]PolarizationLevelOperator[j,\
\[CloseCurlyDoubleQuote]z\[CloseCurlyDoubleQuote]]) should generate 1 if \
\[Rho]=|\[Psi]><\[Psi]|, where |\[Psi]> is the extreme eigenstate. Assume \
that PolarizationLevelOperator[j,\[CloseCurlyDoubleQuote]z\
\[CloseCurlyDoubleQuote]]=",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "j"], "="}], TraditionalForm]],ExpressionUUID->
  "bdcb4e27-e857-4e3b-8cf7-eee3f586fc75"],
 "\[Kappa]",
 Cell[BoxData[
  FormBox[
   SubscriptBox["I", "jz"], TraditionalForm]],ExpressionUUID->
  "6f991412-1270-49e4-b4f2-f7456dd9d400"],
 ". \nTo determine \[Kappa], assume\n\
OperatorAmplitude(|\[Psi]><\[Psi]|\[Rule]",
 Cell[BoxData[
  FormBox[
   SubscriptBox["P", "j"], TraditionalForm]],ExpressionUUID->
  "8c89c78d-f957-4630-ac94-d6b12c12e705"],
 ")=1.\nThis is given by\nOperatorAmplitude(|\[Psi]><\[Psi]|\[Rule]",
 Cell[BoxData[
  FormBox[
   SubscriptBox["P", "j"], TraditionalForm]],ExpressionUUID->
  "123f2b54-c823-4c49-85e3-b44b325df940"],
 ") = ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"(", 
     RowBox[{"|", 
      RowBox[{"\[Psi]", ">", "<", "\[Psi]"}], "|", 
      SubscriptBox["P", "j"]}], ")"}], 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["P", "j"], "|", 
      SubscriptBox["P", "j"]}], ")"}]], TraditionalForm]],ExpressionUUID->
  "8d47e7a7-d913-4ae6-968d-7e50157c142d"],
 "\n(",
 Cell[BoxData[
  FormBox[
   RowBox[{"|", 
    RowBox[{"\[Psi]", ">", "<", "\[Psi]"}], "|", 
    SubscriptBox["P", "j"]}], TraditionalForm]],ExpressionUUID->
  "1878ef34-d8b4-4e5c-9395-ad4eaccaa18b"],
 ") = Tr{",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"|", 
     RowBox[{"\[Psi]", ">", "<", "\[Psi]"}], "|", 
     RowBox[{"\[Kappa]", 
      FormBox[
       SubscriptBox["I", "jz"],
       TraditionalForm]}]}], "}"}], TraditionalForm]],ExpressionUUID->
  "87fcd937-41ff-4651-b5ad-a42b178efa3e"],
 " =  \[Kappa] ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["I", "j"], TraditionalForm]],ExpressionUUID->
  "6f39335e-e0c2-420e-b027-830468465675"],
 " since ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["I", "j"], TraditionalForm]],ExpressionUUID->
  "9d4ba7b6-491a-4ba2-b90a-300932af7c42"],
 " is the extreme value of the magnetic quantum number for spin j.\nAlso ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["P", "j"], "|", 
     SubscriptBox["P", "j"]}], ")"}], TraditionalForm]],ExpressionUUID->
  "897005f6-c0e6-46af-a830-4ce4d571b6f7"],
 " = ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[Kappa]", "2"], TraditionalForm]],ExpressionUUID->
  "c76384fa-bbcd-4beb-982b-9ff0e126faa1"],
 "Tr{",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["I", "jz", "2"], "}"}], TraditionalForm]],
  ExpressionUUID->"7e31cede-ff88-4870-8b5d-83d77b8d866b"],
 " = ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[Kappa]", "2"], TraditionalForm]],ExpressionUUID->
  "db8f8032-594f-4f79-a210-5861d39fec2a"],
 "(",
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderoverscriptBox["\[Sum]", 
     RowBox[{"M", "=", 
      RowBox[{"-", "Ij"}]}], "Ij"], 
    SuperscriptBox["M", "2"]}], TraditionalForm]],ExpressionUUID->
  "1ead9e84-23cf-4791-823c-89272523bf26"],
 ") ",
 Cell[BoxData[
  FormBox[
   FractionBox["dim", 
    RowBox[{
     RowBox[{"2", 
      SubscriptBox["I", "j"]}], "+", "1"}]], TraditionalForm]],ExpressionUUID->
  "ad87dc08-223d-4d73-93aa-ee82f1c860aa"],
 "\nwhere dim is the dimension of Hilbert space, so that dim/(",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"2", 
     SubscriptBox["I", "j"]}], "+", "1"}], TraditionalForm]],ExpressionUUID->
  "d15af2cc-bb00-4a70-a2db-e23af61e6d4f"],
 ") is the dimension of the Hilbert subspace excluding spin j.\nSince (",
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderoverscriptBox["\[Sum]", 
     RowBox[{"M", "=", 
      RowBox[{"-", "Ij"}]}], "Ij"], 
    SuperscriptBox["M", "2"]}], TraditionalForm]],ExpressionUUID->
  "d833026c-c1b0-4156-8a3f-1d3369953145"],
 ") = (1/3)",
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    SubscriptBox["I", "j"]}], TraditionalForm]],ExpressionUUID->
  "60c31cae-281b-4414-9b47-ad649e1d1798"],
 "(",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"2", 
     SubscriptBox["I", "j"]}], "+", "1"}], TraditionalForm]],ExpressionUUID->
  "690cee69-fce8-4291-8df0-b39f400e16fb"],
 ")(",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["I", "j"], "+", "1"}], TraditionalForm]],ExpressionUUID->
  "de91b69b-25a3-4d13-9ad3-631f1769d3e1"],
 ")\nwe get",
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["P", "j"], "|", 
      SubscriptBox["P", "j"]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "35032552-c7ad-44d8-9e78-2c396d126273"],
 " = ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[Kappa]", "2"], TraditionalForm]],ExpressionUUID->
  "90cfff84-58e5-40c3-a693-7e0f5435fc9d"],
 "(1/3)",
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    SubscriptBox["I", "j"]}], TraditionalForm]],ExpressionUUID->
  "7a4cf92e-bfe4-4f34-b12e-e3aabb6d642a"],
 "(",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["I", "j"], "+", "1"}], TraditionalForm]],ExpressionUUID->
  "9eb7ed08-af46-46c2-911e-cb1f771d1222"],
 ") dim \nand hence \[Kappa] ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["I", "j"], TraditionalForm]],ExpressionUUID->
  "89ff970b-6b84-4e95-aabf-325eba24d350"],
 "/",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[Kappa]", "2"], TraditionalForm]],ExpressionUUID->
  "a0a92bc5-e97b-434d-ba3d-99922ae69751"],
 "(1/3)",
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    SubscriptBox["I", "j"]}], TraditionalForm]],ExpressionUUID->
  "2dfb8a58-aeb5-4e16-931c-42550e2e4cb7"],
 "(",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["I", "j"], "+", "1"}], TraditionalForm]],ExpressionUUID->
  "0905171c-8247-4856-8250-f4a2ba2ed620"],
 ") dim = 1\ngiving \[Kappa] = 3/((",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["I", "j"], "+", "1"}], TraditionalForm]],ExpressionUUID->
  "4ef4416b-0671-46ba-93c0-e6170c23d516"],
 ") dim). "
}], "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.6745585204043493`*^9, 
  3.674559273228571*^9}},ExpressionUUID->"7498746d-af62-476b-b5a8-\
ac3ceab24497"]
}, Closed]]
}, Closed]],

