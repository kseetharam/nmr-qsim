Cell[CellGroupData[{

Cell["\<\
local routine: DividedEventPropagators (for COMPUTE algorithm)\
\>", "Section",
 InitializationCell->True,
 CellChangeTimes->{
  3.605545643975979*^9, 3.626009314771649*^9, {3.6260163330982223`*^9, 
   3.626016333513719*^9}, {3.626028212004506*^9, 3.626028222012779*^9}, {
   3.6260284142021313`*^9, 3.626028420922085*^9}, {3.626084732193687*^9, 
   3.626084733102336*^9}, {3.629385767728001*^9, 3.629385773846023*^9}, {
   3.701163866709197*^9, 
   3.701163873954282*^9}},ExpressionUUID->"cf303cc7-6f82-407c-bc37-\
2b43692fc72f"],

Cell["\<\
DividedEventPropagators converts the output of DivideEventSpecifications \
(format {..{nrep2,EventSpecifications[..]},{nrep1, EventSpecifications[..]}}) \
into a set of propagators, taking into account specified repetitions, for the \
sake of efficiency. The type Operator or Superoperator is defined in the \
first argument to DividedEventPropagators. The output propagators are in \
RightToLeft chronological order.\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.626008606702052*^9, 3.626008638276084*^9}, 
   3.626008711937054*^9, {3.626016337746071*^9, 3.6260163603125772`*^9}, 
   3.626028401311865*^9, {3.626084753501992*^9, 3.626084764559318*^9}, {
   3.629386002444181*^9, 3.629386034619576*^9}, {3.6340489269883537`*^9, 
   3.634048969167013*^9}, {3.683957724284972*^9, 
   3.6839577243226566`*^9}},ExpressionUUID->"ce8c11db-c164-4f5b-afe0-\
27a6f38c1835"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Options", "[", "DividedEventPropagators", "]"}], "=", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"BackgroundGenerator", "\[Rule]", "None"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"InitialTimePoint", "\[Rule]", "0"}], ",", "\[IndentingNewLine]", 
     RowBox[{"Method", "\[Rule]", "Automatic"}], ",", "\[IndentingNewLine]", 
     RowBox[{"AccuracyGoal", "\[Rule]", "Automatic"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"PrecisionGoal", "\[Rule]", "Automatic"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"MaxStepSize", "\[Rule]", "Automatic"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"MaxSteps", "\[Rule]", "Automatic"}]}], "}"}]}], ";"}]], "Input",\

 InitializationCell->True,
 CellChangeTimes->{{3.626001285649837*^9, 3.62600130004208*^9}, {
   3.626002541009394*^9, 3.626002549401597*^9}, 3.6260087164040194`*^9, {
   3.626015165925542*^9, 3.626015170763397*^9}, 3.626016369250193*^9, {
   3.626028160612364*^9, 3.6260281608736763`*^9}, 3.626028402079693*^9, 
