   3.7224704897905073`*^9}},ExpressionUUID->"d5975089-8cc7-4976-93ef-\
c07f871492a4"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"TransformationAmplitude", "[", 
    RowBox[{
    "True", ",", "True", ",", "True", ",", "\[Rho]ini_", ",", "ops_List", ",",
      "events_", ",", "opts___Rule"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Rho]vecfinal", ",", "norm", ",", "opnormsqlist", ",", "opbasis", ",",
        "basis", ",", "optstopassdown"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"norm", ",", "opbasis", ",", "basis"}], "}"}], "=", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{
           "NormalizationFactor", ",", "OperatorBasis", ",", "Basis"}], "}"}],
           "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "TransformationAmplitude", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"optstopassdown", "=", 
        RowBox[{"Sequence", "@@", 
         RowBox[{"CurrentOptionsToPassDown", "[", 
          RowBox[{"TransformationAmplitude", ",", "NPropagate"}], "]"}]}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"opnormsqlist", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"OperatorNorm", "[", "#", "]"}], "^", "2"}], ")"}], "&"}],
          "/@", "ops"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"\[Rho]vecfinal", "=", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"NPropagate", "[", 
          RowBox[{"events", ",", 
           RowBox[{"OperatorBasis", "\[Rule]", " ", "opbasis"}], ",", 
           RowBox[{"Basis", "\[Rule]", " ", "basis"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"Sequence", "@@", 
            RowBox[{"FilterRules", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"SimplifyRules", "[", 
                RowBox[{
                 RowBox[{"Continuous", "\[Rule]", "False"}], ",", "opts", ",",
                  "optstopassdown"}], "]"}], "}"}], ",", 
              RowBox[{"Join", "[", 
               RowBox[{
                RowBox[{"Options", "[", "NPropagate", "]"}], ",", 
                RowBox[{"Options", "[", "NDSolve", "]"}]}], "]"}]}], 
             "\[IndentingNewLine]", "]"}]}], ",", "opts"}], "]"}], "[", 
         "\[Rho]ini", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"FreeQ", "[", 
           RowBox[{"\[Rho]vecfinal", ",", "$Failed"}], "]"}]}], ",", 
         "\[IndentingNewLine]", "$Failed", ",", "\[IndentingNewLine]", 
         RowBox[{"MapThread", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{
            RowBox[{"Chop", "@", 
             RowBox[{"N", "[", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"Conjugate", "[", 
                  RowBox[{"OperatorVectorRepresentation", "[", 
                   RowBox[{"#1", ",", "opbasis", ",", "basis"}], "]"}], "]"}],
                  ".", 
                 RowBox[{"OperatorVectorRepresentation", "[", 
                  RowBox[{"\[Rho]vecfinal", ",", "opbasis", ",", "basis"}], 
                  "]"}]}], ")"}], "/", 
               RowBox[{"(", 
                RowBox[{"norm", "\[Times]", "#2"}], ")"}]}], "]"}]}], "&"}], ",",
            "\[IndentingNewLine]", 
           RowBox[{"{", 
            RowBox[{"ops", ",", "opnormsqlist"}], "}"}]}], 
          "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", "]"}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 CellChangeTimes->{{3.456510372984645*^9, 3.456510416352416*^9}, 
