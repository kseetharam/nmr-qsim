Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Trajectory", "[", 
    RowBox[{
     RowBox[{"Evaluate", "@", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"prefix", ":", 
         RowBox[{"StatusPatternPrefix", "[", 
          RowBox[{"Trajectory", ",", "\"\<BackgroundGenerator\>\""}], "]"}]}],
         ",", "\[IndentingNewLine]", 
        RowBox[{"locst", ":", 
         RowBox[{"{", 
          RowBox[{"True", ",", "True", ",", "False", ",", "morelocst___"}], 
          "}"}]}], ",", "morest___"}], "}"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"more", ":", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Except", "[", "_Rule", "]"}], "..."}], ")"}]}], ",", 
     "opts___Rule"}], "\[IndentingNewLine]", "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "backg", ",", "ensav", ",", "diagfunc", ",", "opbasis", ",", "basis", ",",
        "shouldnotdiag", ",", "diagbackg", ",", "ndiagoutput"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"backg", "=", 
        RowBox[{"StandardizeGenerator", "[", 
         RowBox[{"(", 
          RowBox[{"ReleaseHold", "[", 
           RowBox[{
            RowBox[{"BackgroundGenerator", "/.", 
             RowBox[{"{", "opts", "}"}]}], "/.", 
            RowBox[{"Options", "[", "Trajectory", "]"}]}], "]"}], ")"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"ensav", "=", 
        RowBox[{
         RowBox[{"EnsembleAverage", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "Trajectory", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"opbasis", ",", "basis"}], "}"}], "=", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{"OperatorBasis", ",", "Basis"}], "}"}], "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "Trajectory", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"shouldnotdiag", "=", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"!", 
           RowBox[{"FreeQ", "[", 
            RowBox[{
             RowBox[{"{", "more", "}"}], ",", "_PrecalculatedEvent"}], 
            "]"}]}], "||", 
          RowBox[{
           RowBox[{"Length", "[", 
            RowBox[{"UnassignedSymbols", "[", 
             RowBox[{"backg", ",", 
              RowBox[{"PermittedSymbols", "\[Rule]", 
               RowBox[{"LocalGeneratorSymbols", "[", "backg", "]"}]}]}], 
             "]"}], "]"}], ">", "0"}]}], ")"}]}], ";", "\[IndentingNewLine]", 
       
       RowBox[{"diagbackg", "=", "\[IndentingNewLine]", 
        RowBox[{"Which", "[", "\[IndentingNewLine]", 
         RowBox[{"shouldnotdiag", ",", "backg", ",", "\[IndentingNewLine]", 
          RowBox[{"OperatorQ", "[", "backg", "]"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"ndiagoutput", "=", 
             RowBox[{"NDiagonalize", "[", 
              RowBox[{"backg", ",", "basis"}], "]"}]}], ";", 
            "\[IndentingNewLine]", "\t", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"MatchQ", "[", 
               RowBox[{"ndiagoutput", ",", "$Failed"}], "]"}], ",", 
              "\[IndentingNewLine]", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"Message", "[", 
                 RowBox[{"Trajectory", "::", "noprediag"}], "]"}], ";", 
                "backg"}], ")"}], ",", "ndiagoutput"}], "]"}]}], ")"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"SuperoperatorQ", "[", "backg", "]"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"ndiagoutput", "=", 
             RowBox[{"NDiagonalize", "[", 
              RowBox[{"backg", ",", "opbasis", ",", "basis"}], "]"}]}], ";", 
            "\[IndentingNewLine]", "\t", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"MatchQ", "[", 
               RowBox[{"ndiagoutput", ",", "$Failed"}], "]"}], ",", 
              "\[IndentingNewLine]", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"Message", "[", 
                 RowBox[{"Trajectory", "::", "noprediag"}], "]"}], ";", 
                "backg"}], ")"}], ",", "ndiagoutput"}], "]"}]}], ")"}], ",", 
          "\[IndentingNewLine]", "True", ",", "backg"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Trajectory", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"prefix", ",", 
           RowBox[{"{", 
            RowBox[{"True", ",", "True", ",", "True", ",", "morelocst"}], 
            "}"}], ",", "morest"}], "}"}], ",", "more", ",", 
         "\[IndentingNewLine]", 
         RowBox[{"Evaluate", "@", 
          RowBox[{"SimplifyRules", "[", 
           RowBox[{
            RowBox[{"BackgroundGenerator", "\[Rule]", "diagbackg"}], ",", 
            "opts"}], "]"}]}]}], "]"}]}], "\[IndentingNewLine]", ")"}]}], 
    "]"}]}], ";"}]], "Input",
