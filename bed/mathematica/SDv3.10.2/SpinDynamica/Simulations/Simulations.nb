Cell["CombineAndSort (local function)", "Subsubsection",
 CellChangeTimes->{{3.721880969768764*^9, 
  3.721880978231934*^9}},ExpressionUUID->"38bef4c2-0114-4fb9-9d6e-\
e16d20a3b010"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"CombineAndSort", "[", "args___", "]"}], "/;", 
    RowBox[{"!", 
     RowBox[{"FreeQ", "[", 
      RowBox[{
       RowBox[{"{", "args", "}"}], ",", "$Failed"}], "]"}]}]}], ":=", 
   "$Failed"}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.722567223962716*^9, 3.722567248708498*^9}},
 CellLabel->
  "In[2014]:=",ExpressionUUID->"a6fbfcaa-15af-49c8-8009-ceba10839880"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"CombineAndSort", "[", 
    RowBox[{
     RowBox[{"data", ":", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"_List", ".."}], "}"}], ".."}], "}"}], ".."}]}], ",", 
     "opts___Rule"}], "]"}], ":=", 
   RowBox[{"CombineAndSort", "[", 
    RowBox[{
     RowBox[{"Join", "@@", "data"}], ",", "opts"}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.721880985036104*^9, 3.721880985038348*^9}, {
  3.72188101536797*^9, 3.721881038381719*^9}, {3.721882151531205*^9, 
  3.721882155687372*^9}, {3.721882211957735*^9, 3.7218822183186607`*^9}},
 CellLabel->
  "In[2015]:=",ExpressionUUID->"9b096558-8029-4570-8eff-da1911f617ed"],

Cell["\<\
combine the batch data, combining points with identical coordinates. Then \
edit in the TableCoordinates. If the TransformationAmplitudeTable has only a \
single output operator, remove the enclosing List. \
\>", "Text",
 CellChangeTimes->{{3.721884355608967*^9, 
  3.721884426685499*^9}},ExpressionUUID->"a4b9acc0-0115-42b6-a782-\
526ab9a1802c"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"CombineAndSort", "[", 
    RowBox[{
     RowBox[{"data", ":", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"Except", "[", "_List", "]"}], ".."}], ",", "_List"}], 
         "}"}], ".."}], "}"}]}], ",", "opts___Rule"}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"decimateddata", ",", "tabcoords", ",", "vals", ",", "output"}],
       "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"tabcoords", "=", 
        RowBox[{
         RowBox[{"TableCoordinates", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "TransformationAmplitudeTable", "]"}]}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"decimateddata", "=", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"SortBy", "[", 
          RowBox[{"data", ",", 
           RowBox[{
            RowBox[{"N", "[", 
             RowBox[{"First", "[", "#", "]"}], "]"}], "&"}]}], "]"}], "//.", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"a___", ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"vars", ":", 
               RowBox[{
                RowBox[{"Except", "[", "_List", "]"}], ".."}]}], ",", 
              "val1_"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"vars", ":", 
               RowBox[{
                RowBox[{"Except", "[", "_List", "]"}], ".."}]}], ",", 
              "val2_"}], "}"}], ",", "b___"}], "}"}], "\[RuleDelayed]", 
          RowBox[{"{", 
           RowBox[{"a", ",", 
            RowBox[{"{", 
             RowBox[{"vars", ",", 
              RowBox[{"val1", "+", "val2"}]}], "}"}], ",", "b"}], "}"}]}]}]}],
        ";", "\[IndentingNewLine]", 
       RowBox[{"vals", "=", 
        RowBox[{"Transpose", "[", 
         RowBox[{"Last", "/@", "decimateddata"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"output", "=", 
        RowBox[{"Map", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Function", "[", 
           RowBox[{"vals", ",", "\[IndentingNewLine]", 
            RowBox[{"MapThread", "[", 
             RowBox[{"Append", ",", 
              RowBox[{"{", 
               RowBox[{"tabcoords", ",", "vals"}], "}"}]}], "]"}]}], 
           "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", "vals"}],
          "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "output", "]"}], "\[Equal]", "1"}], ",", 
         RowBox[{"First", "@", "output"}], ",", "output"}], "]"}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.721882172055948*^9, 3.721882303051622*^9}, {
  3.721884299812639*^9, 3.721884342236257*^9}, {3.744366833753*^9, 
  3.74436685249281*^9}},ExpressionUUID->"86e71367-b066-4507-abd0-\
9e6d09850064"]
}, Closed]]
}, Closed]]
}, Closed]],

