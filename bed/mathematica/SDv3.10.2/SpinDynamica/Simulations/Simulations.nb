 RowBox[{
  RowBox[{
   RowBox[{"TransformationAmplitudeTable", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Evaluate", "@", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"prefix", ":", 
         RowBox[{"StatusPatternPrefix", "[", 
          RowBox[{"TransformationAmplitudeTable", ",", "\"\<Ready\>\""}], 
          "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"True", ",", "False", ",", "morelocst___"}], "}"}], ",", 
        "morest___"}], "}"}]}], ",", "\[IndentingNewLine]", "more___", ",", 
     "opts___Rule"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"ensavvars", ",", "tabvars", ",", "suspectsymbols"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"ensavvars", "=", 
        RowBox[{"UnassignedSymbols", "[", 
         RowBox[{
          RowBox[{"EnsembleAverage", "/.", 
           RowBox[{"{", "opts", "}"}]}], "/.", 
          RowBox[{"Options", "[", "TransformationAmplitudeTable", "]"}]}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"tabvars", "=", 
        RowBox[{
         RowBox[{"TableVariables", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "TransformationAmplitudeTable", "]"}]}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"suspectsymbols", "=", 
        RowBox[{"UnassignedSymbols", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"more", ",", "opts"}], "}"}], ",", 
          RowBox[{"PermittedSymbols", "\[Rule]", 
           RowBox[{"Join", "[", 
