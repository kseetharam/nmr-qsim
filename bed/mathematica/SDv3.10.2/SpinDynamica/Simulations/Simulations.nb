  RowBox[{
   RowBox[{"InitialDensityOperator", "::", "usage"}], 
   "=", "\"\<InitialDensityOperator is an option for Signal1D, indicating the \
initial density operator upon which the Preparation is applied, before data \
acquisition. The default is opI[\\\"z\\\"].\>\""}], ";"}]], "Input",
