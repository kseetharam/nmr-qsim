Cell[CellGroupData[{

Cell["Signal1DCore", "Subsubsection",
 CellChangeTimes->{{3.7011037702229166`*^9, 
  3.701103781922637*^9}},ExpressionUUID->"27b34cab-b069-432c-8a7d-\
c09ca682fede"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"HoldPattern", "@", 
    RowBox[{"Signal1DCore", "[", 
     RowBox[{"\"\<Diagonalization\>\"", ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"tmin_", "?", "NumericQ"}], ",", 
        RowBox[{"tmax_", "?", "NumericQ"}], ",", 
        RowBox[{"\[Delta]t_", "?", "NumericQ"}]}], "}"}], ",", 
      RowBox[{"acqevents", ":", 
       RowBox[{"EventSpecifications", "[", 
        RowBox[{"True", ",", 
         RowBox[{"{", 
          RowBox[{"{", 
           RowBox[{"evgen_", ",", "T_"}], "}"}], "}"}], ",", "___Rule"}], 
        "]"}]}], ",", "opts___Rule"}], "]"}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Rho]0", ",", "Qobs", ",", "prepbackg", ",", "detbackg", ",", 
       "opbasis", ",", "basis", ",", "norm", ",", "tvals", ",", "X", ",", 
       "evals", ",", "Xinv", ",", "Qobsvec", ",", "QobsadjX", ",", 
       "Xinv\[Rho]", ",", "\[Rho]0vec", ",", "avals", ",", "\[Omega]vals", ",",
        "\[Lambda]vals", ",", "blub"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"\[Rho]0", ",", "Qobs", ",", 
          RowBox[{"{", 
           RowBox[{"detbackg", ",", "prepbackg"}], "}"}], ",", "opbasis", ",",
           "basis", ",", "norm"}], "}"}], "=", 
        RowBox[{"ReleaseHold", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{
            "InitialDensityOperator", ",", "Observable", ",", 
             "BackgroundGenerator", ",", "OperatorBasis", ",", "Basis", ",", 
             "NormalizationFactor"}], "}"}], "/.", 
           RowBox[{"{", "opts", "}"}]}], "/.", 
          RowBox[{"Options", "[", "Signal1D", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"opbasis", "=", 
        RowBox[{
         RowBox[{"OperatorBasis", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "Signal1D", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"basis", "=", 
        RowBox[{
         RowBox[{"Basis", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "Signal1D", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"norm", "=", 
        RowBox[{
         RowBox[{"NormalizationFactor", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "Signal1D", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"tvals", "=", 
        RowBox[{"Range", "[", 
         RowBox[{"tmin", ",", "tmax", ",", "\[Delta]t"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"X", ",", "evals", ",", "Xinv"}], "}"}], "=", 
        "\[IndentingNewLine]", 
        RowBox[{"First", "@", 
         RowBox[{"NDiagonalize", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"Liouvillian", "[", 
            RowBox[{"evgen", ",", "detbackg"}], "]"}], ",", 
           "\[IndentingNewLine]", "opbasis", ",", "basis", ",", "opts"}], 
          "\[IndentingNewLine]", "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"\[Rho]0vec", "=", 
        RowBox[{"OperatorVectorRepresentation", "[", 
         RowBox[{"\[Rho]0", ",", "opbasis", ",", "basis"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Qobsvec", "=", 
        RowBox[{"OperatorVectorRepresentation", "[", 
         RowBox[{"Qobs", ",", "opbasis", ",", "basis"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"QobsadjX", "=", 
        RowBox[{
         RowBox[{"Conjugate", "[", "Qobsvec", "]"}], ".", "X"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Xinv\[Rho]", "=", 
        RowBox[{"Xinv", ".", "\[Rho]0vec"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"avals", "=", 
        RowBox[{
         RowBox[{"Chop", "@", 
          RowBox[{"MapThread", "[", 
           RowBox[{"Times", ",", 
            RowBox[{"{", 
             RowBox[{"QobsadjX", ",", "Xinv\[Rho]"}], "}"}]}], "]"}]}], "/", 
         RowBox[{"(", 
          RowBox[{"norm", "\[Times]", 
           RowBox[{
            RowBox[{"Norm", "[", "Qobsvec", "]"}], "^", "2"}]}], ")"}]}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"\[Omega]vals", "=", 
        RowBox[{"Im", "[", "evals", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"\[Lambda]vals", "=", 
        RowBox[{"-", 
         RowBox[{"Re", "[", "evals", "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Signal", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"tmin", ",", "tmax", ",", "\[Delta]t"}], "}"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"\"\<Lorentzian\>\"", ",", 
           RowBox[{"Transpose", "[", 
            RowBox[{"{", 
             RowBox[{"avals", ",", "\[Omega]vals", ",", "\[Lambda]vals"}], 
             "}"}], "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
         RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
          RowBox[{"Sequence", "@@", 
           RowBox[{"FilterRules", "[", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"Join", "[", 
              RowBox[{
               RowBox[{"{", "opts", "}"}], ",", 
               RowBox[{"Options", "@", "Signal1D"}]}], "]"}], ",", 
             "\[IndentingNewLine]", 
             RowBox[{"Options", "[", "Signal", "]"}]}], "\[IndentingNewLine]",
             "]"}]}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
        "]"}]}], "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
