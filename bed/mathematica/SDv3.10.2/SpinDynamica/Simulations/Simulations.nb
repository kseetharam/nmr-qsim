                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{"!", 
                    RowBox[{"IntegerQ", "[", "nv", "]"}]}], ")"}], "||", 
                   RowBox[{"(", 
                    RowBox[{"nv", "<", "1"}], ")"}]}], ",", 
                  RowBox[{"Message", "[", 
                   RowBox[{
                   "TransformationAmplitudeTable", "::", "badnumincr"}], 
                   "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
                RowBox[{"{", 
                 RowBox[{"v", ",", "0", ",", "vmax", ",", 
                  RowBox[{"vmax", "/", 
                   RowBox[{"Max", "[", 
                    RowBox[{
                    RowBox[{"nv", "-", "1"}], ",", "1"}], "]"}]}]}], "}"}]}], 
               ")"}]}]}], "\[IndentingNewLine]", "}"}]}], ")"}], "&"}], ",", 
        "\[IndentingNewLine]", "iterlists"}], "\[IndentingNewLine]", "]"}], 
