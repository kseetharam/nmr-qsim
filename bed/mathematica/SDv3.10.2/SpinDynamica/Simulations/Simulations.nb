           "morest"}], "}"}], ",", "more", ",", "\[IndentingNewLine]", 
         RowBox[{"Evaluate", "@", 
          RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"BackgroundGenerator", "\[Rule]", 
             RowBox[{"StandardizeGenerator", "[", "backg", "]"}]}], ",", 
