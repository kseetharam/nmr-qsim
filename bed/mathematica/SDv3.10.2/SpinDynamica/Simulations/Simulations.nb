Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Signal1D", "[", 
    RowBox[{"True", ",", "timing_", ",", "acqevents_", ",", "opts___Rule"}], 
    "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "ensav", ",", "prep", ",", "backg", ",", "prepbackg", ",", "detbackg", ",",
        "\[Rho]ini", ",", "var", ",", "vals", ",", "weights", ",", "nens", ",",
        "maxbatchsize", ",", "valwbatches", ",", "nbatch", ",", "opbasis", ",",
        "basis", ",", "i", ",", "vardim", ",", "varsubrules", ",", "pvar", ",",
        "pvardim", ",", "pvarsubrules", ",", "temp", ",", "sig", ",", 
       "acqeventlists"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"temp", "=", 
         RowBox[{"PrintTemporary", "[", "\"\<setting up batch..\>\"", "]"}]}],
         ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"opbasis", ",", "basis"}], "}"}], "=", 
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{"OperatorBasis", ",", "Basis"}], "}"}], "/.", 
           RowBox[{"{", "opts", "}"}]}], "/.", 
          RowBox[{"Options", "[", "Signal1D", "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"nens", "=", 
         RowBox[{"Length", "[", 
          RowBox[{"Last", "[", "ensav", "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"varsubrules", "=", 
         RowBox[{"EnsembleSubstitutionRules", "[", "ensav", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"weights", "=", 
         RowBox[{"EnsembleWeights", "[", "ensav", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"SetSharedVariable", "[", 
         RowBox[{"opbasis", ",", "basis"}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"acqeventlists", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"ReleaseHold", "[", 
            RowBox[{"ReplaceEverywhere", "[", 
             RowBox[{
              RowBox[{"Hold", "[", "acqevents", "]"}], ",", "#"}], "]"}], 
            "]"}], "&"}], "/@", "varsubrules"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"DistributeDefinitions", "[", 
         RowBox[{"varsubrules", ",", "acqeventlists"}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"NotebookDelete", "[", "temp", "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"CombineData", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Parallelize", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"Table", "[", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"Signal1D", "[", "\[IndentingNewLine]", 
               RowBox[{"True", ",", "timing", ",", "\[IndentingNewLine]", 
                RowBox[{"Evaluate", "[", 
                 RowBox[{
                 "acqeventlists", "\[LeftDoubleBracket]", "i", 
                  "\[RightDoubleBracket]"}], "]"}], ",", 
                "\[IndentingNewLine]", 
                RowBox[{"Evaluate", "@", 
                 RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
                  RowBox[{
                   RowBox[{"EnsembleAverage", "\[Rule]", "False"}], ",", 
                   "\[IndentingNewLine]", 
                   RowBox[{"OperatorBasis", "\[Rule]", "opbasis"}], ",", 
                   "\[IndentingNewLine]", 
                   RowBox[{"Basis", "\[Rule]", "basis"}], ",", 
                   "\[IndentingNewLine]", 
                   RowBox[{"ReleaseHold", "[", 
                    RowBox[{"(", 
                    RowBox[{"ReplaceEverywhere", "[", 
                    RowBox[{
                    RowBox[{"Hold", "[", "opts", "]"}], ",", 
                    RowBox[{
