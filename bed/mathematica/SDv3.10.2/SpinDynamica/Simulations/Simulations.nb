Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"DividedEventPropagators", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"type_", ",", "T_", ",", "n_"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"divevent", ":", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", "_EventSpecifications"}], "}"}], ".."}], "}"}]}], ",", 
     RowBox[{"more", ":", 
      RowBox[{
       RowBox[{"Except", "[", "_Rule", "]"}], "..."}]}], ",", "opbasis_", ",",
      "basis_", ",", "opts___Rule"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "dim", ",", "tinivals", ",", "tini", ",", "evspeclists", ",", "props", ",",
        "Sjset"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"tini", "=", 
        RowBox[{
         RowBox[{"InitialTimePoint", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "DividedEventPropagators", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"evspeclists", "=", 
        RowBox[{"Last", "/@", "divevent"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"tinivals", "=", 
        RowBox[{"Reverse", "@", 
         RowBox[{"Drop", "[", 
          RowBox[{
           RowBox[{"FoldList", "[", 
            RowBox[{"Plus", ",", "tini", ",", 
             RowBox[{"Duration", "/@", 
              RowBox[{"Reverse", "[", "evspeclists", "]"}]}]}], "]"}], ",", 
           RowBox[{"-", "1"}]}], "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"props", "=", 
        RowBox[{"DividedEventPropagators", "[", "\[IndentingNewLine]", 
         RowBox[{"type", ",", "\[IndentingNewLine]", 
          RowBox[{"MapThread", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{
             RowBox[{"{", 
              RowBox[{"1", ",", 
               RowBox[{"EventList", "[", 
                RowBox[{"#1", ",", 
                 RowBox[{"InitialTimePoint", "\[Rule]", "#2"}], ",", "opts"}],
                 "]"}]}], "}"}], "&"}], ",", "\[IndentingNewLine]", 
            RowBox[{"{", 
             RowBox[{"evspeclists", ",", "tinivals"}], "}"}]}], 
           "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", "more", ",",
           "opts"}], "\[IndentingNewLine]", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Sjset", "=", 
        RowBox[{"Switch", "[", 
         RowBox[{"type", ",", "\[IndentingNewLine]", "Superoperator", ",", 
          RowBox[{
           RowBox[{"dim", "=", 
            RowBox[{
             RowBox[{"BasisDimension", "[", "basis", "]"}], "^", "2"}]}], ";", 
           RowBox[{
            RowBox[{
             RowBox[{"SuperoperatorMatrixRepresentation", "[", 
              RowBox[{"#", ",", "opbasis"}], "]"}], "&"}], "/@", "props"}]}], 
          ",", "\[IndentingNewLine]", "Operator", ",", 
          RowBox[{
           RowBox[{"dim", "=", 
            RowBox[{"BasisDimension", "[", "basis", "]"}]}], ";", 
           RowBox[{
            RowBox[{
             RowBox[{"MatrixRepresentation", "[", 
              RowBox[{"#", ",", "basis"}], "]"}], "&"}], "/@", "props"}]}]}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"FoldList", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"Dot", "[", 
           RowBox[{"#2", ",", "#1"}], "]"}], "&"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"SparseArray", "@", 
          RowBox[{"DiagonalMatrix", "[", 
           RowBox[{"Table", "[", 
            RowBox[{"1", ",", 
             RowBox[{"{", "dim", "}"}]}], "]"}], "]"}]}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"Reverse", "@", "Sjset"}]}], "]"}]}], "\[IndentingNewLine]", 
      ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
