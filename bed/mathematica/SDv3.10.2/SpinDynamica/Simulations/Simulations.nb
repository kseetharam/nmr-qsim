Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Trajectory", "[", "\[IndentingNewLine]", 
    RowBox[{"True", ",", 
     RowBox[{"{", 
      RowBox[{"True", ",", "True", ",", "False"}], "}"}], ",", 
     "\[IndentingNewLine]", "\[Rho]ini_", ",", "obs_", ",", "events_", ",", 
     "\[IndentingNewLine]", "opts___Rule"}], "\[IndentingNewLine]", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "ensav", ",", "weights", ",", "rules", ",", "nens", ",", "vars", ",", 
       "vals", ",", "maxbatchsize", ",", "nbatch", ",", "opbasis", ",", 
       "basis", ",", "ib", ",", "temp", ",", "rulesandweights", ",", 
       "rulesandweightsbatches", ",", "trajectories", ",", "batchresult", ",",
        "parallel", ",", "mapfunc"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"opbasis", ",", "basis", ",", "ensav", ",", "maxbatchsize"}],
          "}"}], "=", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{
           "OperatorBasis", ",", "Basis", ",", "EnsembleAverage", ",", 
            "MaxBatchSize"}], "}"}], "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "Trajectory", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"parallel", "=", 
        RowBox[{"MatchQ", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Parallel", "/.", 
            RowBox[{"{", "opts", "}"}]}], "/.", 
           RowBox[{"Options", "[", "Trajectory", "]"}]}], ",", 
          RowBox[{"True", "|", "All", "|", 
           RowBox[{"_", "?", "NumericQ"}]}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"nens", "=", 
        RowBox[{"Length", "[", 
         RowBox[{"Last", "[", "ensav", "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"vars", "=", 
        RowBox[{"First", "[", "ensav", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"vals", "=", 
        RowBox[{"First", "/@", 
         RowBox[{"Last", "[", "ensav", "]"}]}]}], ";", "\[IndentingNewLine]", 
       
       RowBox[{"weights", "=", 
        RowBox[{"Last", "/@", 
         RowBox[{"Last", "[", "ensav", "]"}]}]}], ";", "\[IndentingNewLine]", 
       
       RowBox[{"rules", "=", 
        RowBox[{"Map", "[", 
         RowBox[{
          RowBox[{"Apply", "[", "Rule", "]"}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"Transpose", "[", 
             RowBox[{"{", 
              RowBox[{"vars", ",", "#"}], "}"}], "]"}], "&"}], "/@", "vals"}],
           ",", 
          RowBox[{"{", "2", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"rulesandweights", "=", 
        RowBox[{"Transpose", "[", 
         RowBox[{"{", 
          RowBox[{"rules", ",", "weights"}], "}"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"rulesandweightsbatches", "=", 
        RowBox[{"Partition", "[", 
         RowBox[{
         "rulesandweights", ",", "maxbatchsize", ",", "maxbatchsize", ",", 
          RowBox[{"{", 
           RowBox[{"1", ",", "1"}], "}"}], ",", 
          RowBox[{"{", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"nbatch", "=", 
        RowBox[{"Length", "[", "rulesandweightsbatches", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"nbatch", "==", "1"}], ",", "\[IndentingNewLine]", 
         RowBox[{
         "PrintTemporary", "[", "\"\<computing using 1 batch ..\>\"", "]"}], ",",
          "\[IndentingNewLine]", 
         RowBox[{"PrintTemporary", "[", 
          RowBox[{"\"\<computing using \>\"", "<>", 
           RowBox[{"ToString", "[", "nbatch", "]"}], 
           "<>", "\"\< batches..\>\""}], "]"}]}], "\[IndentingNewLine]", 
        "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"CombineTrajectoryFunctions", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Monitor", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"(", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"rules", ",", "weights"}], "}"}], "=", 
                RowBox[{"Transpose", "[", 
                 RowBox[{
                 "rulesandweightsbatches", "\[LeftDoubleBracket]", "ib", 
                  "\[RightDoubleBracket]"}], "]"}]}], ";", 
               "\[IndentingNewLine]", 
               RowBox[{"temp", "=", 
                RowBox[{"PrintTemporary", "[", 
                 RowBox[{
                  RowBox[{"If", "[", 
                   RowBox[{
                   "parallel", ",", "\"\<parallel computing batch \>\"", 
                    ",", "\"\<computing batch \>\""}], "]"}], "<>", 
                  RowBox[{"ToString", "[", "ib", "]"}], "<>", "\"\< of \>\"", 
                  "<>", 
                  RowBox[{"ToString", "[", "nbatch", "]"}], 
                  "<>", "\"\< with \>\"", "<>", 
                  RowBox[{"ToString", "[", 
                   RowBox[{"Length", "[", "weights", "]"}], "]"}], 
                  "<>", "\"\< elements..\>\""}], "]"}]}], ";", 
               "\[IndentingNewLine]", 
               RowBox[{"mapfunc", "=", 
                RowBox[{"If", "[", 
                 RowBox[{"parallel", ",", "ParallelMap", ",", "Map"}], 
                 "]"}]}], ";", "\[IndentingNewLine]", 
               RowBox[{"trajectories", "=", 
                RowBox[{"mapfunc", "[", "\[IndentingNewLine]", 
                 RowBox[{
                  RowBox[{"Function", "[", 
                   RowBox[{"rule", ",", "\[IndentingNewLine]", 
                    RowBox[{"Trajectory", "[", "\[IndentingNewLine]", 
                    RowBox[{
                    "True", ",", "True", ",", "False", ",", 
                    "\[IndentingNewLine]", 
                    RowBox[{"Evaluate", "@", "\[Rho]ini"}], ",", 
                    "\[IndentingNewLine]", 
                    RowBox[{"Evaluate", "@", "obs"}], ",", 
                    "\[IndentingNewLine]", 
                    RowBox[{"Evaluate", "[", 
                    RowBox[{"ReplaceEverywhere", "[", 
                    RowBox[{"events", ",", "rule"}], "]"}], "]"}], ",", 
                    "\[IndentingNewLine]", 
                    RowBox[{"Evaluate", "[", 
                    RowBox[{"Sequence", "@@", 
                    RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
                    RowBox[{"FilterRules", "[", "\[IndentingNewLine]", 
                    RowBox[{
                    RowBox[{"ReplaceEverywhere", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"EnsembleAverage", "\[Rule]", "None"}], ",", 
                    "opts"}], "}"}], ",", "rule"}], "]"}], ",", 
                    "\[IndentingNewLine]", 
                    RowBox[{"Join", "[", 
                    RowBox[{
                    RowBox[{"Options", "[", "NPropagate", "]"}], ",", 
                    RowBox[{"Options", "[", "NDSolve", "]"}], ",", 
                    RowBox[{"Options", "[", "Trajectory", "]"}]}], "]"}]}], 
                    "\[IndentingNewLine]", "]"}], "]"}]}], 
                    "\[IndentingNewLine]", "]"}]}], "]"}]}], 
                   "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
                  "rules", ",", "\[IndentingNewLine]", 
                  RowBox[{"Evaluate", "[", "\[IndentingNewLine]", 
                   RowBox[{"Sequence", "@@", 
                    RowBox[{"FilterRules", "[", "\[IndentingNewLine]", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"Method", "\[Rule]", "\"\<CoarsestGrained\>\""}], 
                    ",", "\[IndentingNewLine]", 
                    RowBox[{
                    "DistributedContexts", "\[Rule]", "\"\<Global`\>\""}]}], 
                    "}"}], ",", "\[IndentingNewLine]", 
                    RowBox[{"Options", "[", "mapfunc", "]"}]}], 
                    "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
                   "]"}]}], "\[IndentingNewLine]", "]"}]}], ";", 
               "\[IndentingNewLine]", 
               RowBox[{"batchresult", "=", "\[IndentingNewLine]", 
                RowBox[{
                "CombineTrajectoryFunctions", "[", "\[IndentingNewLine]", 
                 RowBox[{
                 "trajectories", ",", "weights", ",", "\[IndentingNewLine]", 
                  RowBox[{"Sequence", "@@", 
                   RowBox[{"FilterRules", "[", "\[IndentingNewLine]", 
                    RowBox[{
                    RowBox[{"Join", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"Parallel", "\[Rule]", "False"}], ",", "opts"}], 
                    "}"}], ",", "\[IndentingNewLine]", 
                    RowBox[{"Options", "[", "Trajectory", "]"}]}], "]"}], ",",
                     "\[IndentingNewLine]", 
                    RowBox[{
                    "Options", "[", "CombineTrajectoryFunctions", "]"}]}], 
                    "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", 
                 "]"}]}], ";", "\[IndentingNewLine]", 
               RowBox[{"NotebookDelete", "[", "temp", "]"}], ";", 
               "\[IndentingNewLine]", "batchresult"}], "\[IndentingNewLine]", 
              ")"}], ",", "\[IndentingNewLine]", 
             RowBox[{"{", 
              RowBox[{"ib", ",", "1", ",", "nbatch"}], "}"}]}], 
            "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
           RowBox[{"ProgressIndicator", "[", 
            RowBox[{"ib", ",", 
             RowBox[{"{", 
              RowBox[{"1", ",", 
               RowBox[{"nbatch", "+", "1"}]}], "}"}]}], "]"}]}], 
          "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
         RowBox[{"Table", "[", 
          RowBox[{"1", ",", 
           RowBox[{"{", "nbatch", "}"}]}], "]"}]}], "\[IndentingNewLine]", 
        "]"}]}], "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
