   3.565973918345532*^9}},ExpressionUUID->"53baca82-64cc-45d8-b332-\
9b64952a5f64"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Signal1D", "[", 
    RowBox[{"True", ",", "timing_", ",", "acqevents_", ",", "opts___Rule"}], 
    "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "ensav", ",", "prep", ",", "backg", ",", "prepbackg", ",", "detbackg", ",",
        "\[Rho]ini", ",", "var", ",", "vals", ",", "weights", ",", "nens", ",",
        "maxbatchsize", ",", "valwbatches", ",", "nbatch", ",", "lb", ",", 
       "opbasis", ",", "basis", ",", "ib", ",", "temp", ",", "sig"}], "}"}], ",",
      "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{"opbasis", ",", "basis"}], "}"}], "=", 
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{"OperatorBasis", ",", "Basis"}], "}"}], "/.", 
           RowBox[{"{", "opts", "}"}]}], "/.", 
          RowBox[{"Options", "[", "Signal1D", "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"nens", "=", 
         RowBox[{"Length", "[", 
          RowBox[{"Last", "[", "ensav", "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"maxbatchsize", "=", 
         RowBox[{"Min", "[", 
          RowBox[{
           RowBox[{"Max", "[", 
            RowBox[{"maxbatchsize", ",", "1"}], "]"}], ",", "nens"}], "]"}]}],
         ";", "\[IndentingNewLine]", 
        RowBox[{"var", "=", 
         RowBox[{"First", "[", "ensav", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"valwbatches", "=", 
         RowBox[{"Partition", "[", 
          RowBox[{
           RowBox[{"Last", "[", "ensav", "]"}], ",", "maxbatchsize", ",", 
           "maxbatchsize", ",", 
           RowBox[{"{", 
            RowBox[{"1", ",", "1"}], "}"}], ",", 
           RowBox[{"{", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"nbatch", "=", 
         RowBox[{"Length", "[", "valwbatches", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"nbatch", "==", "1"}], ",", "\[IndentingNewLine]", 
          RowBox[{
          "PrintTemporary", "[", "\"\<ensemble averaging using 1 batch ..\>\"",
            "]"}], ",", "\[IndentingNewLine]", 
          RowBox[{"PrintTemporary", "[", 
           RowBox[{"\"\<ensemble averaging using \>\"", "<>", 
            RowBox[{"ToString", "[", "nbatch", "]"}], 
            "<>", "\"\< batches..\>\""}], "]"}]}], "\[IndentingNewLine]", 
         "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"CombineData", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Monitor", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"Table", "[", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"(", "\[IndentingNewLine]", 
               RowBox[{
                RowBox[{"temp", "=", 
                 RowBox[{"PrintTemporary", "[", 
                  RowBox[{"\"\<computing batch \>\"", "<>", 
                   RowBox[{"ToString", "[", "ib", "]"}], "<>", "\"\< of \>\"",
                    "<>", 
                   RowBox[{"ToString", "[", "nbatch", "]"}], 
                   "<>", "\"\<..\>\""}], "]"}]}], ";", "\[IndentingNewLine]", 
                
                RowBox[{"sig", "=", 
                 RowBox[{"Signal1D", "[", 
                  RowBox[{
                  "True", ",", "timing", ",", "acqevents", ",", 
                   "\[IndentingNewLine]", 
                   RowBox[{"Evaluate", "@", 
