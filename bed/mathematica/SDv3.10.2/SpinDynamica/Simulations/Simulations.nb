Cell["divide into batches, calculate and combine", "Subsection",
 InitializationCell->True,
 CellChangeTimes->{{3.506767146878869*^9, 3.5067671531811543`*^9}, {
   3.507554915952759*^9, 3.507554918310874*^9}, {3.507556747116287*^9, 
   3.507556755028116*^9}, {3.565419601881979*^9, 3.565419618207242*^9}, 
