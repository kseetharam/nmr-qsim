Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Signal1D", "[", 
     RowBox[{"True", ",", "timing_", ",", "acqevents_", ",", "opts___Rule"}], 
     "]"}], "/;", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"MatchQ", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"SignalCalculationMethod", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "Signal1D", "]"}]}], 
        ",", "\"\<COMPUTE\>\""}], "]"}], "&&", "\[IndentingNewLine]", 
      RowBox[{"MatchQ", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"SignalGeneratorPeriod", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "Signal1D", "]"}]}], ",", 
        RowBox[{"_", "?", "NumericQ"}]}], "]"}], "&&", "\[IndentingNewLine]", 
      
      RowBox[{"MatchQ", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"EnsembleAverage", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "Signal1D", "]"}]}], ",", 
        RowBox[{"False", "|", "None"}]}], "]"}], "&&", "\[IndentingNewLine]", 
      
      RowBox[{"MatchQ", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Preparation", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "Signal1D", "]"}]}], ",", 
        RowBox[{"None", "|", 
         RowBox[{"EventSpecifications", "@", 
          RowBox[{"UnitySuperoperator", "[", "]"}]}]}]}], "]"}], "&&", 
      "\[IndentingNewLine]", 
      RowBox[{"MatchQ", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"InitialDensityOperator", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "Signal1D", "]"}]}], ",", "_Operator"}], 
       "]"}]}], "\[IndentingNewLine]", ")"}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Signal1DCore", "[", 
    RowBox[{"\"\<COMPUTE\>\"", ",", "timing", ",", "acqevents", ",", 
     "\[IndentingNewLine]", 
     RowBox[{"Evaluate", "@", 
      RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"BackgroundGenerator", "\[Rule]", 
         RowBox[{"HeldGeneratorSymbol", "[", 
          RowBox[{"First", "@", 
           RowBox[{"ReleaseHold", "[", 
            RowBox[{
             RowBox[{"BackgroundGenerator", "/.", 
              RowBox[{"{", "opts", "}"}]}], "/.", 
             RowBox[{"Options", "[", "Signal1D", "]"}]}], "]"}]}], 
          "\[IndentingNewLine]", "]"}]}], ",", "\[IndentingNewLine]", 
        "opts"}], "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", 
    "]"}]}], ";"}]], "Input",
