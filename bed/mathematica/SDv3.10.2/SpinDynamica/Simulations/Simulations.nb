Cell["\<\
v2.5.4: New code avoids the use of the problematic FunctionInterpolation \
routine, at the expense of much coding complexity\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.5622198329044657`*^9, 3.56221987496484*^9}, {
  3.5622248281180778`*^9, 3.56222484477143*^9}, {3.56222827530713*^9, 
  3.562228291033123*^9}},ExpressionUUID->"664ea4d8-432d-4463-b7b0-\
4c3c848d3b0b"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"CombineTrajectoryFunctions", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"tfuncs", ":", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"TrajectoryFunction", "[", 
          RowBox[{"interval_", ",", "__"}], "]"}], ".."}], "}"}]}], ",", 
      "\[IndentingNewLine]", "weights_List", ",", "opts___Rule"}], "]"}], "/;", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Length", "[", "tfuncs", "]"}], "\[Equal]", 
      RowBox[{"Length", "[", "weights", "]"}]}], ")"}]}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "tintervals", ",", "nintervals", ",", "pwtfuncs", ",", "pwtfunc", ",", 
       "ninterps", ",", "maxstepsize", ",", "interppoints", ",", "tinterps", ",",
        "combtfuncs", ",", "tfin", ",", "tini", ",", "t", ",", "temp"}], 
      "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"temp", "=", 
        RowBox[{
        "PrintTemporary", "[", "\"\<combining trajectories..\>\"", "]"}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"maxstepsize", ",", "interppoints"}], "}"}], "=", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{"InterpolationStepSize", ",", "InterpolationPoints"}], 
           "}"}], "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Join", "[", 
          RowBox[{
           RowBox[{"Options", "[", "Trajectory", "]"}], ",", 
           RowBox[{"Options", "[", "NDSolve", "]"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"tintervals", "=", 
        RowBox[{"Partition", "[", 
         RowBox[{
          RowBox[{"Sort", "@", 
           RowBox[{"Union", "@", 
            RowBox[{"Flatten", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"First", "[", "#", "]"}], ",", 
                 RowBox[{"Last", "[", "#", "]"}]}], "}"}], "&"}], "/@", 
              RowBox[{"Cases", "[", 
               RowBox[{"tfuncs", ",", 
                RowBox[{
                "_Inequality", "|", "_Greater", "|", "_GreaterEqual", "|", 
                 "_LessEqual"}], ",", "Infinity"}], "]"}]}], "]"}]}]}], ",", 
          "\[IndentingNewLine]", "2", ",", "1"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"tfin", ",", "tini"}], "}"}], "=", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Max", "[", "#", "]"}], ",", 
            RowBox[{"Min", "[", "#", "]"}]}], "}"}], "&"}], "@", 
         RowBox[{"Flatten", "[", "tintervals", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"nintervals", "=", 
        RowBox[{"Length", "[", "tintervals", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"pwtfuncs", "=", "\[IndentingNewLine]", 
        RowBox[{"Transpose", "@", 
         RowBox[{"Map", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"Function", "[", 
            RowBox[{"tfunc", ",", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{
               RowBox[{"Function", "[", 
                RowBox[{"t", ",", 
                 RowBox[{"Evaluate", "@", 
                  RowBox[{"Assuming", "[", 
                   RowBox[{
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"First", "[", "#", "]"}], "<", "t", "<", 
                    RowBox[{"Last", "[", "#", "]"}]}], ")"}], ",", 
                    RowBox[{"Refine", "[", 
                    RowBox[{
                    RowBox[{
                    "tfunc", "\[LeftDoubleBracket]", "2", 
                    "\[RightDoubleBracket]"}], "[", "t", "]"}], "]"}]}], 
                   "]"}]}]}], "]"}], "&"}], "/@", "tintervals"}]}], 
            "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
           "tfuncs"}], "\[IndentingNewLine]", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"pwtfunc", "=", "\[IndentingNewLine]", 
        RowBox[{"Map", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"Function", "[", 
            RowBox[{
             RowBox[{"Evaluate", "[", "t", "]"}], ",", 
             RowBox[{"Evaluate", "[", "#", "]"}]}], "]"}], "&"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"Map", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{
             RowBox[{"Dot", "[", 
              RowBox[{"weights", ",", "#"}], "]"}], "&"}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"Map", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"#", "[", "t", "]"}], "&"}], ",", "pwtfuncs", ",", 
              RowBox[{"{", "2", "}"}]}], "]"}]}], "\[IndentingNewLine]", 
           "]"}]}], "\[IndentingNewLine]", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"ninterps", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"Min", "[", 
           RowBox[{
            RowBox[{"Max", "[", 
             RowBox[{"interppoints", ",", "3"}], "]"}], ",", 
            RowBox[{"Ceiling", "[", 
             RowBox[{
              RowBox[{"Abs", "[", 
               RowBox[{
                RowBox[{"First", "[", "#", "]"}], "-", 
                RowBox[{"Last", "[", "#", "]"}]}], "]"}], "/", 
              "maxstepsize"}], "]"}]}], "]"}], "&"}], "/@", "tintervals"}]}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"tinterps", "=", 
        RowBox[{"MapThread", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Range", "[", 
            RowBox[{
             RowBox[{"Min", "[", "#1", "]"}], ",", 
             RowBox[{"Max", "[", "#1", "]"}], ",", 
             RowBox[{
              RowBox[{"Abs", "[", 
               RowBox[{
                RowBox[{"First", "[", "#1", "]"}], "-", 
                RowBox[{"Last", "[", "#1", "]"}]}], "]"}], "/", "#2"}]}], 
            "]"}], "&"}], ",", 
          RowBox[{"{", 
           RowBox[{"tintervals", ",", "ninterps"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"combtfuncs", "=", "\[IndentingNewLine]", 
        RowBox[{"MapThread", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"Interpolation", "[", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"Transpose", "[", 
              RowBox[{"{", 
               RowBox[{"#2", ",", 
                RowBox[{"Map", "[", 
                 RowBox[{"#1", ",", "#2"}], "]"}]}], "}"}], "]"}], ",", 
             "\[IndentingNewLine]", 
             RowBox[{"Sequence", "@@", 
              RowBox[{"Join", "[", "\[IndentingNewLine]", 
               RowBox[{
                RowBox[{"CurrentOptionsToPassDown", "[", 
                 RowBox[{"Trajectory", ",", "Interpolation"}], "]"}], ",", 
                "\[IndentingNewLine]", 
                RowBox[{"CurrentOptionsToPassDown", "[", 
                 RowBox[{"NPropagate", ",", "Interpolation"}], "]"}]}], 
               "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", "]"}],
            "&"}], ",", 
          RowBox[{"{", 
           RowBox[{"pwtfunc", ",", "tinterps"}], "}"}]}], 
         "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"NotebookDelete", "[", "temp", "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"TrajectoryFunction", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"{", 
           RowBox[{"tfin", ",", "tini"}], "}"}], "}"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"Function", "[", 
          RowBox[{"t", ",", "\[IndentingNewLine]", 
           RowBox[{"Evaluate", "@", 
            RowBox[{"Piecewise", "[", 
             RowBox[{"Transpose", "[", "\[IndentingNewLine]", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"Through", "[", 
                 RowBox[{"combtfuncs", "[", "t", "]"}], "]"}], ",", 
                "\[IndentingNewLine]", 
                RowBox[{"Join", "[", "\[IndentingNewLine]", 
                 RowBox[{
                  RowBox[{
                   RowBox[{
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"First", "[", "#", "]"}], "\[LessEqual]", "t", "<", 
                    RowBox[{"Last", "[", "#", "]"}]}], ")"}], "&"}], "/@", 
                   RowBox[{"Most", "[", "tintervals", "]"}]}], ",", 
                  "\[IndentingNewLine]", 
                  RowBox[{
                   RowBox[{
                    RowBox[{"(", 
                    RowBox[{
