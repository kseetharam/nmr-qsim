Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"TransformationAmplitudeTable", "[", "\[IndentingNewLine]", 
    RowBox[{"True", ",", 
     RowBox[{"{", 
      RowBox[{"True", ",", "True", ",", "False"}], "}"}], ",", 
     "\[IndentingNewLine]", "\[Rho]ini_", ",", "obs_", ",", "events_", ",", 
     "iterlists_", ",", "\[IndentingNewLine]", "opts___Rule"}], 
    "\[IndentingNewLine]", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "ensav", ",", "weights", ",", "rules", ",", "nens", ",", "nvar", ",", 
       "vars", ",", "maxbatchsize", ",", "nbatch", ",", "opbasis", ",", 
       "basis", ",", "ib", ",", "temp", ",", "tabvars", ",", "itervals", ",", 
       "rulesandweights", ",", "rulesandweightsbatches", ",", "coords", ",", 
       "amplitudes", ",", "batchresult", ",", "parallel", ",", 
       "optstopassdown"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{
         "opbasis", ",", "basis", ",", "ensav", ",", "maxbatchsize", ",", 
          "tabvars"}], "}"}], "=", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{
           "OperatorBasis", ",", "Basis", ",", "EnsembleAverage", ",", 
            "MaxBatchSize", ",", "TableVariables"}], "}"}], "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "TransformationAmplitudeTable", "]"}]}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"optstopassdown", "=", 
        RowBox[{"Sequence", "@@", 
         RowBox[{"CurrentOptionsToPassDown", "[", 
          RowBox[{
          "TransformationAmplitudeTable", ",", "TransformationAmplitude"}], 
          "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"parallel", "=", 
        RowBox[{"MatchQ", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Parallel", "/.", 
            RowBox[{"{", "opts", "}"}]}], "/.", 
           RowBox[{"Options", "[", "TransformationAmplitudeTable", "]"}]}], ",", 
          RowBox[{"True", "|", "All", "|", 
           RowBox[{"_", "?", "NumericQ"}]}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"nens", "=", 
        RowBox[{"Length", "[", 
         RowBox[{"Last", "[", "ensav", "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"nvar", "=", 
        RowBox[{"Map", "[", 
         RowBox[{
          RowBox[{"Function", "[", 
           RowBox[{"iter", ",", 
            RowBox[{"Length", "[", 
             RowBox[{"Range", "@@", 
              RowBox[{"iter", "\[LeftDoubleBracket]", 
               RowBox[{"2", ";;"}], "\[RightDoubleBracket]"}]}], "]"}]}], 
           "]"}], ",", "iterlists"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"vars", "=", 
        RowBox[{"Join", "[", 
         RowBox[{"tabvars", ",", 
          RowBox[{"First", "[", "ensav", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"itervals", "=", 
        RowBox[{"Flatten", "[", 
         RowBox[{
          RowBox[{"Table", "[", 
           RowBox[{"tabvars", ",", 
            RowBox[{"Evaluate", "[", 
             RowBox[{"Sequence", "@@", "iterlists"}], "]"}]}], "]"}], ",", 
          RowBox[{
           RowBox[{"Length", "[", "tabvars", "]"}], "-", "1"}]}], "]"}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"rulesandweights", "=", "\[IndentingNewLine]", 
        RowBox[{"Flatten", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Outer", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"Map", "[", 
                RowBox[{
                 RowBox[{"Apply", "[", "Rule", "]"}], ",", 
                 "\[IndentingNewLine]", 
                 RowBox[{"Transpose", "[", 
                  RowBox[{"{", 
                   RowBox[{"vars", ",", 
                    RowBox[{"Join", "[", 
                    RowBox[{"#1", ",", 
                    RowBox[{"First", "[", "#2", "]"}]}], "]"}]}], "}"}], 
                  "]"}]}], "\[IndentingNewLine]", "]"}], ",", 
               "\[IndentingNewLine]", 
               RowBox[{"Last", "[", "#2", "]"}]}], "\[IndentingNewLine]", 
              "}"}], "&"}], ",", "\[IndentingNewLine]", "itervals", ",", 
            RowBox[{"Last", "[", "ensav", "]"}], ",", "1"}], 
           "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", "1"}], 
         "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"rulesandweightsbatches", "=", 
        RowBox[{"Partition", "[", 
         RowBox[{
         "rulesandweights", ",", "maxbatchsize", ",", "maxbatchsize", ",", 
          RowBox[{"{", 
           RowBox[{"1", ",", "1"}], "}"}], ",", 
          RowBox[{"{", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"nbatch", "=", 
        RowBox[{"Length", "[", "rulesandweightsbatches", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"nbatch", "==", "1"}], ",", "\[IndentingNewLine]", 
         RowBox[{
         "PrintTemporary", "[", "\"\<computing using 1 batch ..\>\"", "]"}], ",",
          "\[IndentingNewLine]", 
         RowBox[{"PrintTemporary", "[", 
          RowBox[{"\"\<computing using \>\"", "<>", 
           RowBox[{"ToString", "[", "nbatch", "]"}], 
           "<>", "\"\< batches..\>\""}], "]"}]}], "\[IndentingNewLine]", 
        "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"CombineAndSort", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Monitor", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"(", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"rules", ",", "weights"}], "}"}], "=", 
                RowBox[{"Transpose", "[", 
                 RowBox[{
                 "rulesandweightsbatches", "\[LeftDoubleBracket]", "ib", 
                  "\[RightDoubleBracket]"}], "]"}]}], ";", 
               "\[IndentingNewLine]", 
               RowBox[{"temp", "=", 
                RowBox[{"PrintTemporary", "[", 
                 RowBox[{
                  RowBox[{"If", "[", 
                   RowBox[{
                   "parallel", ",", "\"\<parallel computing batch \>\"", 
                    ",", "\"\<computing batch \>\""}], "]"}], "<>", 
                  RowBox[{"ToString", "[", "ib", "]"}], "<>", "\"\< of \>\"", 
                  "<>", 
                  RowBox[{"ToString", "[", "nbatch", "]"}], 
                  "<>", "\"\< with \>\"", "<>", 
                  RowBox[{"ToString", "[", 
                   RowBox[{"Length", "[", "weights", "]"}], "]"}], 
                  "<>", "\"\< elements..\>\""}], "]"}]}], ";", 
               "\[IndentingNewLine]", 
               RowBox[{"If", "[", 
                RowBox[{"parallel", ",", 
                 RowBox[{
                 "DistributeDefinitions", "[", "optstopassdown", "]"}]}], 
                "]"}], ";", "\[IndentingNewLine]", 
               RowBox[{"amplitudes", "=", 
                RowBox[{
                 RowBox[{"If", "[", 
                  RowBox[{"parallel", ",", "ParallelMap", ",", "Map"}], "]"}],
                  "[", "\[IndentingNewLine]", 
                 RowBox[{
                  RowBox[{"Function", "[", 
                   RowBox[{"rule", ",", "\[IndentingNewLine]", 
                    RowBox[{"Module", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"newoptlist", ",", "newbackg"}], "}"}], ",", 
                    RowBox[{"(", "\[IndentingNewLine]", 
                    RowBox[{
                    RowBox[{"newoptlist", "=", 
                    RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
                    RowBox[{"FilterRules", "[", "\[IndentingNewLine]", 
                    RowBox[{
                    RowBox[{"ReplaceEverywhere", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"EnsembleAverage", "\[Rule]", "None"}], ",", 
                    "opts", ",", "optstopassdown"}], "}"}], ",", "rule"}], 
                    "]"}], ",", "\[IndentingNewLine]", 
                    RowBox[{"Join", "[", 
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"Options", "[", "TransformationAmplitude", "]"}], 
                    ",", 
                    RowBox[{"Options", "[", "NPropagate", "]"}], ",", 
                    RowBox[{"Options", "[", "NDSolve", "]"}]}], "}"}], 
                    "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
                    "]"}], "\[IndentingNewLine]", "]"}]}], ";", 
                    "\[IndentingNewLine]", 
                    RowBox[{"TransformationAmplitude", "[", 
                    RowBox[{
                    "True", ",", "True", ",", "True", ",", 
                    "\[IndentingNewLine]", 
                    RowBox[{"Evaluate", "[", "\[Rho]ini", "]"}], ",", 
                    RowBox[{"Evaluate", "[", "obs", "]"}], ",", 
                    "\[IndentingNewLine]", 
                    RowBox[{"Evaluate", "[", 
                    RowBox[{"events", "/.", "rule"}], "]"}], ",", 
                    "\[IndentingNewLine]", 
                    RowBox[{"Evaluate", "[", 
                    RowBox[{"Sequence", "@@", "newoptlist"}], "]"}]}], 
                    "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
                    ")"}]}], "]"}]}], "\[IndentingNewLine]", "]"}], ",", 
                  "\[IndentingNewLine]", "rules"}], "\[IndentingNewLine]", 
                 "]"}]}], ";", "\[IndentingNewLine]", 
               RowBox[{"coords", "=", 
                RowBox[{
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{"tabvars", "/.", "#"}], ")"}], "&"}], "/@", 
                 "rules"}]}], ";", "\[IndentingNewLine]", 
               RowBox[{"batchresult", "=", 
                RowBox[{"MapThread", "[", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"Join", "[", 
                    RowBox[{"#1", ",", 
                    RowBox[{"Times", "[", 
                    RowBox[{"#2", ",", 
                    RowBox[{"{", "#3", "}"}]}], "]"}]}], "]"}], "&"}], ",", 
                  RowBox[{"{", 
                   RowBox[{"coords", ",", "weights", ",", "amplitudes"}], 
                   "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
               RowBox[{"NotebookDelete", "[", "temp", "]"}], ";", 
               "\[IndentingNewLine]", "batchresult"}], "\[IndentingNewLine]", 
              ")"}], ",", "\[IndentingNewLine]", 
             RowBox[{"{", 
              RowBox[{"ib", ",", "1", ",", "nbatch"}], "}"}]}], 
            "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
           RowBox[{"ProgressIndicator", "[", 
            RowBox[{"ib", ",", 
             RowBox[{"{", 
              RowBox[{"1", ",", 
               RowBox[{"nbatch", "+", "1"}]}], "}"}]}], "]"}]}], 
          "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", "opts"}], 
        "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", ")"}]}], 
    "]"}]}], ";"}]], "Input",
 InitializationCell->True,
