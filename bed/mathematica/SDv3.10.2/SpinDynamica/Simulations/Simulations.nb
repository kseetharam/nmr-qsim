5dafdb6ac99e"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"DividedEventPropagators", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"Operator", ",", "T_", ",", "n_"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"divevent", ":", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", 
          RowBox[{"EventSpecifications", "[", 
           RowBox[{"True", ",", 
            RowBox[{"{", 
             RowBox[{"{", 
              RowBox[{"None", ",", "_"}], "}"}], "}"}], ",", 
            "evopts___Rule"}], "]"}]}], "}"}], ".."}], "}"}]}], ",", 
     "opbasis_", ",", "basis_", ",", "opts___Rule"}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "tinivals", ",", "tini", ",", "evspeclist", ",", "UonePeriod", ",", 
       "\[Tau]list"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"tini", "=", 
        RowBox[{
         RowBox[{"InitialTimePoint", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "DividedEventPropagators", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"evspeclist", "=", 
        RowBox[{
         RowBox[{"Last", "[", 
          RowBox[{
          "divevent", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], 
          "]"}], "/.", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"EventSpecifications", "[", 
            RowBox[{"bool_", ",", 
             RowBox[{"{", 
              RowBox[{"{", 
               RowBox[{"a_", ",", "\[Delta]t_"}], "}"}], "}"}], ",", 
             "opts$___Rule"}], "]"}], "\[RuleDelayed]", 
           RowBox[{"EventSpecifications", "[", 
            RowBox[{"bool", ",", 
             RowBox[{"{", 
              RowBox[{"{", 
               RowBox[{"a", ",", 
                RowBox[{
                 RowBox[{"Length", "[", "divevent", "]"}], "*", 
