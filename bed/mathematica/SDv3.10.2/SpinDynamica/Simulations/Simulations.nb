Cell[CellGroupData[{

Cell["BackgroundGenerator is a None event", "Subsubsection",
 InitializationCell->True,
 CellChangeTimes->{{3.626008750478898*^9, 3.626008800543957*^9}, {
   3.62600959867705*^9, 3.626009614920927*^9}, {3.626010373304895*^9, 
   3.6260103920352573`*^9}, 3.626015323118098*^9, 3.626016984398726*^9, 
   3.709375555147832*^9, {3.7136042226690807`*^9, 
