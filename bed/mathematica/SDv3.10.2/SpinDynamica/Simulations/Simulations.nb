Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ConstrainPositive", "::", "usage"}], 
   "=", "\"\<ConstrainPositive is an option for \
MaximizeTransformationAmplitude. If ConstrainPositive\[Rule]True or \
ConstrainPositive\[Rule]All, all variable parameters of  \
MaximizeTransformationAmplitude are constrained to positive values. This is \
frequently required for pulse sequence delays, etc., which cannot take \
negative values. The syntax ConstrainPositive\[Rule]{p1,p2..} may be used to \
constrain only a subset of parameters to positive values.\>\""}], 
  ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.744277503360028*^9, 3.744277590832155*^9}, {
  3.744277631926694*^9, 
  3.744277684721187*^9}},ExpressionUUID->"68d3f213-08c3-493c-b2ed-\
271322d31942"]
}, Closed]],

