Cell["propagation over a single time-independent generator", "Text",
 CellChangeTimes->{{3.70110185289501*^9, 
  3.70110188199165*^9}},ExpressionUUID->"2ddfda02-8d3d-4f5e-a090-\
9d526ddf17f9"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Signal1D", "[", 
     RowBox[{"True", ",", "timing_", ",", "acqevents_", ",", "opts___Rule"}], 
     "]"}], "/;", "\[IndentingNewLine]", 
    RowBox[{"(", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"MatchQ", "[", 
       RowBox[{"acqevents", ",", 
        RowBox[{"EventSpecifications", "[", 
         RowBox[{"True", ",", 
          RowBox[{"{", 
           RowBox[{"{", 
            RowBox[{"evgen_", ",", "T_"}], "}"}], "}"}], ",", "___Rule"}], 
         "]"}]}], "]"}], "&&", 
      RowBox[{"MatchQ", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"SignalCalculationMethod", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "Signal1D", "]"}]}], 
        ",", "\"\<Diagonalization\>\""}], "]"}], "&&", "\[IndentingNewLine]", 
      
      RowBox[{"MatchQ", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"EnsembleAverage", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "Signal1D", "]"}]}], ",", 
        RowBox[{"False", "|", "None"}]}], "]"}], "&&", "\[IndentingNewLine]", 
      
      RowBox[{"MatchQ", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Preparation", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "Signal1D", "]"}]}], ",", 
        RowBox[{"None", "|", 
         RowBox[{"EventSpecifications", "@", 
          RowBox[{"UnitySuperoperator", "[", "]"}]}]}]}], "]"}], "&&", 
      "\[IndentingNewLine]", 
      RowBox[{"MatchQ", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"InitialDensityOperator", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "Signal1D", "]"}]}], ",", "_Operator"}], 
       "]"}]}], "\[IndentingNewLine]", ")"}]}], ":=", 
   RowBox[{"Signal1DCore", "[", 
    RowBox[{"\"\<Diagonalization\>\"", ",", "timing", ",", "acqevents", ",", 
     "opts"}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.506261007346991*^9, 3.506261023717424*^9}, 
