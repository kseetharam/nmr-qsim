 RowBox[{
  RowBox[{
   RowBox[{"TransformationAmplitudeTable", "[", 
    RowBox[{
     RowBox[{"Evaluate", "@", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"prefix", ":", 
         RowBox[{"StatusPatternPrefix", "[", 
          RowBox[{
          "TransformationAmplitudeTable", 
           ",", "\"\<BackgroundGenerator\>\""}], "]"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"locst", ":", 
