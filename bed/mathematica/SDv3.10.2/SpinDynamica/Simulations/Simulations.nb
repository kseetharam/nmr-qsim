Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Signal1DCore", "[", 
    RowBox[{"\"\<COMPUTE\>\"", ",", 
     RowBox[{"{", 
      RowBox[{"tmin_", ",", "tmax_", ",", "\[Delta]t_"}], "}"}], ",", 
     "acqevents_", ",", "opts___Rule"}], "]"}], "/;", 
   RowBox[{"(", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"UseHilbertSpaceWhenPossible", "/.", 
        RowBox[{"{", "opts", "}"}]}], "/.", 
       RowBox[{"Options", "[", "Signal1D", "]"}]}], ")"}], "&&", 
     "\[IndentingNewLine]", 
     RowBox[{"HilbertSpaceCompatibility", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"PeriodicDetectionEvents", "/.", 
         RowBox[{"{", "opts", "}"}]}], "/.", 
        RowBox[{"Options", "[", "Signal1D", "]"}]}], ",", 
       "\[IndentingNewLine]", "opts"}], "\[IndentingNewLine]", "]"}]}], 
    "\[IndentingNewLine]", ")"}]}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "\[Rho]0", ",", "\[Rho]0mat", ",", "Qobs", ",", "Qadjmat", ",", 
      "opbasis", ",", "basis", ",", "T", ",", "n", ",", "nH", ",", 
      "dividedevents", ",", "Ajset", ",", "An", ",", "evals", ",", "evecs", ",",
       "X", ",", "Xinv", ",", "norm", ",", "carav", ",", "perdetevents", ",", 
      "prepbackg", ",", "detbackg", ",", "\[Omega]rvec", ",", "AjXset", ",", 
      "QadjTjset", ",", "rspairs", ",", "\[Delta]rsk", ",", "\[Epsilon]rsk", ",",
       "Ers", ",", "arsk", ",", "\[Rho]0Tjset", ",", "\[Omega]rs", ",", 
      "\[Omega]rsk", ",", "expmi\[Omega]j\[Tau]rs", ",", "normCOMPUTE"}], 
     "}"}], ",", 
    RowBox[{"(", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "\[Rho]0", ",", "Qobs", ",", "opbasis", ",", "basis", ",", "T", ",", 
         "norm", ",", "carav", ",", "perdetevents"}], "}"}], "=", 
       RowBox[{"ReleaseHold", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{
           "InitialDensityOperator", ",", "Observable", ",", "OperatorBasis", 
            ",", "Basis", ",", "SignalGeneratorPeriod", ",", 
            "NormalizationFactor", ",", "CarouselAverage", ",", 
            "PeriodicDetectionEvents"}], "}"}], "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "Signal1D", "]"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"nH", "=", 
       RowBox[{"BasisDimension", "[", "basis", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"n", "=", 
       RowBox[{"Max", "[", 
        RowBox[{"1", ",", 
         RowBox[{"Round", "[", 
          RowBox[{"T", "/", "\[Delta]t"}], "]"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"normCOMPUTE", "=", 
       RowBox[{"norm", "\[Times]", 
        RowBox[{"Log", "[", 
         RowBox[{"2", ",", "nH"}], "]"}], "\[Times]", 
        RowBox[{"If", "[", 
         RowBox[{"carav", ",", "n", ",", "1"}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"detbackg", "=", 
       RowBox[{"ReleaseHold", "[", 
        RowBox[{
         RowBox[{"BackgroundGenerator", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "Signal1D", "]"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Qadjmat", "=", 
       RowBox[{"ConjugateTranspose", "@", 
        RowBox[{"MatrixRepresentation", "[", 
         RowBox[{"Qobs", ",", "basis"}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"\[Rho]0mat", "=", 
       RowBox[{"MatrixRepresentation", "[", 
        RowBox[{"\[Rho]0", ",", "basis"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"dividedevents", "=", 
       RowBox[{"DivideEventSpecifications", "[", 
        RowBox[{"perdetevents", ",", "n", ",", 
         RowBox[{"IncludeRepetitionNumbers", "\[Rule]", "True"}]}], "]"}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"Ajset", "=", 
       RowBox[{"DividedEventPropagators", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"Operator", ",", "T", ",", "n"}], "}"}], ",", 
         "\[IndentingNewLine]", "dividedevents", ",", "\[IndentingNewLine]", 
         "opbasis", ",", "basis", ",", "\[IndentingNewLine]", 
         RowBox[{"InitialTimePoint", "\[Rule]", "tmin"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"BackgroundGenerator", "\[Rule]", "detbackg"}], ",", 
         "opts"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"An", "=", 
       RowBox[{"Last", "@", "Ajset"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"X", ",", "evals", ",", "Xinv"}], "}"}], "=", 
       RowBox[{"NDiagonalize", "[", 
        RowBox[{"An", ",", 
         RowBox[{"Assumptions", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{"OrthogonalEigenvectors", "\[Rule]", "True"}], "}"}]}]}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"\[Omega]rvec", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "I"}], " ", "T"}], ")"}], "^", 
         RowBox[{"-", "1"}]}], " ", 
        RowBox[{"Log", "/@", "evals"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"AjXset", "=", 
       RowBox[{"Chop", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"#", ".", "X"}], ")"}], "&"}], "/@", 
         RowBox[{"Most", "[", "Ajset", "]"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"QadjTjset", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"Chop", "[", 
          RowBox[{
           RowBox[{"ConjugateTranspose", "[", "#", "]"}], ".", "Qadjmat", ".",
            "#"}], "]"}], "&"}], "/@", "AjXset"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"rspairs", "=", 
       RowBox[{"Union", "[", 
        RowBox[{"Flatten", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"First", "/@", 
              RowBox[{"Most", "@", 
               RowBox[{"ArrayRules", "[", "#", "]"}]}]}], ")"}], "&"}], "/@", 
           "QadjTjset"}], ",", "1"}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"\[Omega]rs", "=", 
       RowBox[{"Chop", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"\[Omega]rvec", "\[LeftDoubleBracket]", 
             RowBox[{"First", "[", "#", "]"}], "\[RightDoubleBracket]"}], "-", 
            RowBox[{"\[Omega]rvec", "\[LeftDoubleBracket]", 
             RowBox[{"Last", "[", "#", "]"}], "\[RightDoubleBracket]"}]}], 
           ")"}], "&"}], "/@", "rspairs"}], "]"}]}], ";", " ", 
      "\[IndentingNewLine]", 
      RowBox[{"expmi\[Omega]j\[Tau]rs", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "I"}], " ", "#", " ", "j", " ", "\[Delta]t"}], 
            "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"j", ",", "0", ",", 
             RowBox[{"n", "-", "1"}]}], "}"}]}], "]"}], "&"}], "/@", 
        "\[Omega]rs"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"\[Delta]rsk", "=", 
       RowBox[{
        SuperscriptBox["n", 
         RowBox[{"-", "1"}]], "\[Times]", 
        RowBox[{"(", 
         RowBox[{"Chop", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"RotateRight", "[", 
             RowBox[{
              RowBox[{"Fourier", "[", 
               RowBox[{"#", ",", 
                RowBox[{"FourierParameters", "\[Rule]", 
                 RowBox[{"{", 
                  RowBox[{"1", ",", 
                   RowBox[{"-", "1"}]}], "}"}]}]}], "]"}], ",", 
              RowBox[{
               RowBox[{"Floor", "[", 
                RowBox[{"n", "/", "2"}], "]"}], "-", "1"}]}], "]"}], "&"}], "/@", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"Outer", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"Extract", "[", 
                 RowBox[{"#2", ",", "#1"}], "]"}], "&"}], ",", "rspairs", ",",
                "QadjTjset", ",", "1"}], "]"}], "*", 
             "expmi\[Omega]j\[Tau]rs"}], ")"}]}], "]"}], ")"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"If", "[", "\[IndentingNewLine]", 
       RowBox[{"carav", ",", "\[IndentingNewLine]", 
        RowBox[{"(", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"\[Rho]0Tjset", "=", 
           RowBox[{"Chop", "@", 
            RowBox[{"Transpose", "[", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"ConjugateTranspose", "[", "#", "]"}], ".", 
                  "\[Rho]0mat", ".", "#"}], ")"}], "&"}], "/@", "AjXset"}], ",", 
              RowBox[{"{", 
               RowBox[{"3", ",", "1", ",", "2"}], "}"}]}], "]"}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"\[Epsilon]rsk", "=", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"RotateRight", "[", 
               RowBox[{
                RowBox[{"Fourier", "[", 
                 RowBox[{"#", ",", 
                  RowBox[{"FourierParameters", "\[Rule]", 
                   RowBox[{"{", 
                    RowBox[{"1", ",", 
                    RowBox[{"-", "1"}]}], "}"}]}]}], "]"}], ",", 
                RowBox[{
                 RowBox[{"Floor", "[", 
                  RowBox[{"n", "/", "2"}], "]"}], "-", "1"}]}], "]"}], "&"}], 
             "/@", 
             RowBox[{"Chop", "[", 
              RowBox[{
               RowBox[{"Extract", "[", 
                RowBox[{"\[Rho]0Tjset", ",", "rspairs"}], "]"}], "*", 
               "expmi\[Omega]j\[Tau]rs"}], "]"}]}], ")"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"arsk", "=", 
           RowBox[{"Chop", "[", 
            RowBox[{"\[Delta]rsk", "*", 
             RowBox[{
              RowBox[{"Conjugate", "[", "\[Epsilon]rsk", "]"}], "/", 
              RowBox[{"(", 
               RowBox[{"normCOMPUTE", "\[Times]", 
                RowBox[{
                 RowBox[{"Norm", "[", 
                  RowBox[{"N", "@", "Qadjmat"}], "]"}], "^", "2"}]}], 
               ")"}]}]}], "]"}]}]}], "\[IndentingNewLine]", ")"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"(", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Ers", "=", 
           RowBox[{"Chop", "@", 
            RowBox[{"Extract", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"ConjugateTranspose", "[", "X", "]"}], ".", 
               "\[Rho]0mat", ".", "X"}], ",", "rspairs"}], "]"}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"arsk", "=", 
           RowBox[{"Chop", "[", 
            RowBox[{"\[Delta]rsk", "\[Times]", 
             RowBox[{
              RowBox[{"Conjugate", "[", "Ers", "]"}], "/", 
              RowBox[{"(", 
               RowBox[{"normCOMPUTE", "\[Times]", 
                RowBox[{
                 RowBox[{"Norm", "[", 
                  RowBox[{"N", "@", "Qadjmat"}], "]"}], "^", "2"}]}], 
               ")"}]}]}], "]"}]}]}], "\[IndentingNewLine]", ")"}]}], 
       "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"\[Omega]rsk", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"Plus", "[", 
          RowBox[{"#", ",", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"EvenQ", "[", "n", "]"}], ",", 
              RowBox[{"Range", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{
                  RowBox[{"-", "n"}], "/", "2"}], "+", "1"}], ",", 
                RowBox[{"n", "/", "2"}]}], "]"}], ",", 
              RowBox[{"Range", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"-", 
                  RowBox[{"(", 
                   RowBox[{"n", "-", "1"}], ")"}]}], "/", "2"}], ",", 
                RowBox[{
                 RowBox[{"+", 
                  RowBox[{"(", 
                   RowBox[{"n", "-", "1"}], ")"}]}], "/", "2"}]}], "]"}]}], 
             "]"}], "\[Times]", "2", 
            RowBox[{"\[Pi]", "/", "T"}]}]}], "\[IndentingNewLine]", "]"}], 
         "&"}], "/@", "\[Omega]rs"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Signal", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"tmin", ",", "tmax", ",", "\[Delta]t"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"\"\<Lorentzian\>\"", ",", 
          RowBox[{"Transpose", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Flatten", "[", "arsk", "]"}], ",", 
             RowBox[{"Flatten", "[", "\[Omega]rsk", "]"}], ",", 
             RowBox[{"Table", "[", 
              RowBox[{"0", ",", 
               RowBox[{"{", 
                RowBox[{"Length", "@", 
                 RowBox[{"Flatten", "[", "\[Omega]rsk", "]"}]}], "}"}]}], 
              "]"}]}], "}"}], "]"}]}], "\[IndentingNewLine]", "}"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
         RowBox[{"Sequence", "@@", 
          RowBox[{"FilterRules", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"Join", "[", 
             RowBox[{
              RowBox[{"{", "opts", "}"}], ",", 
              RowBox[{"Options", "@", "Signal1D"}]}], "]"}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"Options", "[", "Signal", "]"}]}], "\[IndentingNewLine]", 
           "]"}]}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
       "]"}]}], "\[IndentingNewLine]", ")"}]}], "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.544032860758041*^9, 3.544032873291316*^9}, {
