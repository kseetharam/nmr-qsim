Cell[CellGroupData[{

Cell["MatchSamplingToPeriod", "Subsection",
 InitializationCell->True,
 CellChangeTimes->{
  3.629384641320005*^9},ExpressionUUID->"d2bae161-2678-4d17-a4df-\
24c5a85ae35a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"MatchSamplingToPeriod", "::", "usage"}], 
   "=", "\"\<MatchSamplingToPeriod is an option for Signal1D. If set to True \
(default), and the events during signal detection are periodic, Signal1D will \
adjust the sampling interval to match the next highest even subdivisor of the \
period.\>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 CellChangeTimes->{{3.470654305519123*^9, 3.470654326509406*^9}, {
  3.470654378859114*^9, 3.47065442129324*^9}, {3.470654451702224*^9, 
