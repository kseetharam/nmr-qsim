Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"TrajectoryFunction", "::", "usage"}], 
   "=", "\"\<TrajectoryFunction[timerange,trajectory] is a function which \
provides the value of an observable when evaluated at any time point within \
timerange. It is provided as the output of a Trajectory routine. A trajectory \
function trajfun may be plotted using syntax of the form \
Plot[trajfun[t],{t,tmin,tmax}]\n\>\""}], ";"}]], "Input",
