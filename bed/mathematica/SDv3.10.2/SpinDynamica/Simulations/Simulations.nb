Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Signal1DCore", "[", 
     RowBox[{"\"\<COMPUTE\>\"", ",", 
      RowBox[{"{", 
       RowBox[{"tmin_", ",", "tmax_", ",", "\[Delta]t_"}], "}"}], ",", 
      "acqevents_", ",", "opts___Rule"}], "]"}], "/;", 
    RowBox[{"(", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"!", "UseHilbertSpaceWhenPossible"}], "/.", 
         RowBox[{"{", "opts", "}"}]}], "/.", 
        RowBox[{"Options", "[", "Signal1D", "]"}]}], ")"}], "||", 
      "\[IndentingNewLine]", 
      RowBox[{"!", 
       RowBox[{"HilbertSpaceCompatibility", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"PeriodicDetectionEvents", "/.", 
           RowBox[{"{", "opts", "}"}]}], "/.", 
          RowBox[{"Options", "[", "Signal1D", "]"}]}], ",", 
         "\[IndentingNewLine]", "opts"}], "\[IndentingNewLine]", "]"}]}]}], 
     "\[IndentingNewLine]", ")"}]}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Rho]0", ",", "\[Rho]0vec", ",", "Qobs", ",", "Qobsvec", ",", 
       "opbasis", ",", "basis", ",", "T", ",", "n", ",", "ns", ",", "Ajset", ",",
        "Ajinvset", ",", "An", ",", "evals", ",", "rekets", ",", "lebras", ",",
        "X", ",", "Xinv", ",", "zsset", ",", "Excs0", ",", "Excsj", ",", 
       "Detsj", ",", "\[Epsilon]sk", ",", "\[Epsilon]smk", ",", "\[Delta]sk", 
       ",", "ask", ",", "kvals", ",", "zsk", ",", "zvals", ",", "avals", ",", 
       "\[Omega]vals", ",", "\[Lambda]vals", ",", "norm", ",", "carav", ",", 
       "perdetevents", ",", "assumeorthogevecs", ",", "prepbackg", ",", 
       "detbackg", ",", "divpereventlists", ",", "normCOMPUTE", ",", 
       "dividedevents", ",", "peaks"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{
         "\[Rho]0", ",", "Qobs", ",", "opbasis", ",", "basis", ",", "T", ",", 
          "norm", ",", "carav", ",", "perdetevents"}], "}"}], "=", 
        RowBox[{"ReleaseHold", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{
            "InitialDensityOperator", ",", "Observable", ",", "OperatorBasis",
              ",", "Basis", ",", "SignalGeneratorPeriod", ",", 
             "NormalizationFactor", ",", "CarouselAverage", ",", 
             "PeriodicDetectionEvents"}], "}"}], "/.", 
           RowBox[{"{", "opts", "}"}]}], "/.", 
          RowBox[{"Options", "[", "Signal1D", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"normCOMPUTE", "=", 
        RowBox[{"norm", "\[Times]", 
         RowBox[{"Log", "[", 
          RowBox[{"2", ",", 
           RowBox[{"BasisDimension", "[", "basis", "]"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"detbackg", "=", 
        RowBox[{"ReleaseHold", "[", 
         RowBox[{
          RowBox[{"BackgroundGenerator", "/.", 
           RowBox[{"{", "opts", "}"}]}], "/.", 
          RowBox[{"Options", "[", "Signal1D", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"ns", "=", 
        RowBox[{"OperatorBasisDimension", "[", "opbasis", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"n", "=", 
        RowBox[{"Max", "[", 
         RowBox[{"1", ",", 
          RowBox[{"Round", "[", 
           RowBox[{"T", "/", "\[Delta]t"}], "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Qobsvec", "=", 
        RowBox[{"OperatorVectorRepresentation", "[", 
         RowBox[{"Qobs", ",", "opbasis", ",", "basis"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"\[Rho]0vec", "=", 
        RowBox[{"OperatorVectorRepresentation", "[", 
         RowBox[{"\[Rho]0", ",", "opbasis", ",", "basis"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"dividedevents", "=", 
        RowBox[{"DivideEventSpecifications", "[", 
         RowBox[{"perdetevents", ",", "n", ",", 
          RowBox[{"IncludeRepetitionNumbers", "\[Rule]", "True"}]}], "]"}]}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"Ajset", "=", 
        RowBox[{"DividedEventPropagators", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"Superoperator", ",", "T", ",", "n"}], "}"}], ",", 
          "\[IndentingNewLine]", "dividedevents", ",", "\[IndentingNewLine]", 
          "opbasis", ",", "basis", ",", "\[IndentingNewLine]", 
          RowBox[{"InitialTimePoint", "\[Rule]", "tmin"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"BackgroundGenerator", "\[Rule]", "detbackg"}], ",", 
          "opts"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"An", "=", 
        RowBox[{"Last", "@", "Ajset"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"X", ",", "evals", ",", "Xinv"}], "}"}], "=", 
        RowBox[{"First", "@", 
         RowBox[{"NDiagonalize", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"Superoperator", "[", 
            RowBox[{"An", ",", "opbasis", ",", "basis"}], "]"}], ",", 
           "\[IndentingNewLine]", "opbasis", ",", "basis", ",", 
           "\[IndentingNewLine]", 
           RowBox[{"Sequence", "@@", 
            RowBox[{"FilterRules", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{"Assumptions", "\[Rule]", "None"}], ",", "opts"}], 
               "}"}], ",", 
              RowBox[{"Options", "[", "NDiagonalize", "]"}]}], "]"}]}]}], 
          "\[IndentingNewLine]", "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"rekets", "=", 
        RowBox[{"Transpose", "[", "X", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"lebras", "=", "Xinv"}], ";", "\[IndentingNewLine]", 
       RowBox[{"zsset", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"Log", "/@", "evals"}], ")"}], "/", "T"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Detsj", "=", 
        RowBox[{"MapThread", "[", "\[IndentingNewLine]", 
         RowBox[{"Times", ",", "\[IndentingNewLine]", 
