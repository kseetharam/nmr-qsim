     RowBox[{"more", ":", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Except", "[", "_Rule", "]"}], "..."}], ")"}]}], ",", 
     "opts___Rule"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "backg", "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"backg", "=", 
        RowBox[{"StandardizeGenerator", "[", 
         RowBox[{"(", 
          RowBox[{"ReleaseHold", "[", 
           RowBox[{
            RowBox[{"BackgroundGenerator", "/.", 
             RowBox[{"{", "opts", "}"}]}], "/.", 
            RowBox[{"Options", "[", "TransformationAmplitudeTable", "]"}]}], 
           "]"}], ")"}], "]"}]}], ";", "\[IndentingNewLine]", 
