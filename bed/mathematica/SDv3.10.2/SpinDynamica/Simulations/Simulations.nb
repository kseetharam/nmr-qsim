Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"DividedEventPropagators", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"type_", ",", "T_", ",", "n_"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"divevent", ":", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"_Integer", ",", "_EventSpecifications"}], "}"}], ".."}], 
       "}"}]}], ",", 
     RowBox[{"more", ":", 
      RowBox[{
       RowBox[{"Except", "[", "_Rule", "]"}], "..."}]}], ",", "opts___Rule"}],
     "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"evbackg", ",", "standevbackg"}], "}"}], ",", 
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{"DividedEventPropagators", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"type", ",", "T", ",", "n"}], "}"}], ",", 
         RowBox[{"divevent", "/.", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"nrep", ":", 
              RowBox[{"Except", "[", "1", "]"}]}], ",", 
             "evspeclist_EventSpecifications"}], "}"}], "\[RuleDelayed]", 
           RowBox[{"Sequence", "@@", 
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"1", ",", "evspeclist"}], "}"}], ",", 
              RowBox[{"{", "nrep", "}"}]}], "]"}]}]}]}], ",", 
         "\[IndentingNewLine]", "more", ",", "\[IndentingNewLine]", "opts"}], 
        "\[IndentingNewLine]", "]"}], "\[IndentingNewLine]", ")"}], "/;", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"!", 
         RowBox[{"MatchQ", "[", 
          RowBox[{
           RowBox[{"First", "/@", "divevent"}], ",", 
           RowBox[{"{", 
            RowBox[{"1", ".."}], "}"}]}], "]"}]}], "&&", 
        RowBox[{"(", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"evbackg", "=", 
           RowBox[{
            RowBox[{"BackgroundGenerator", "/.", 
             RowBox[{"{", "opts", "}"}]}], "/.", 
            RowBox[{"Options", "[", "DividedEventPropagators", "]"}]}]}], ";",
           "\[IndentingNewLine]", 
          RowBox[{"standevbackg", "=", 
           RowBox[{"StandardizeGenerator", "[", "evbackg", "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"!", 
           RowBox[{"MatchQ", "[", 
            RowBox[{"standevbackg", ",", 
             RowBox[{
              RowBox[{"_", "?", "OperatorQ"}], "|", 
              RowBox[{"_", "?", "SuperoperatorQ"}], "|", 
              "NullGeneratorPattern"}]}], "]"}]}]}], "\[IndentingNewLine]", 
         ")"}]}], "\[IndentingNewLine]", ")"}]}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
