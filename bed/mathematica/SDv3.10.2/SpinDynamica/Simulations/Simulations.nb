Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Signal1D", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"prefix", ":", 
        RowBox[{"StatusPatternPrefix", "[", 
         RowBox[{"Signal1D", ",", "\"\<Sampling\>\""}], "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"sampst", ":", 
        RowBox[{"{", 
         RowBox[{"True", ",", "True", ",", 
          RowBox[{"{", 
           RowBox[{"True", ",", "False", ",", "moresubcatst___"}], "}"}], ",",
           "moresampst___"}], "}"}]}], ",", "acqevst_", ",", "prepst_", ",", 
       "ensavst_", ",", "normfacst_", ",", "obsst_", ",", "evbackgst_", ",", 
       RowBox[{"sigcalcst", ":", "True"}], ",", "morest___"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"timing", ":", 
      RowBox[{"{", 
       RowBox[{"tmin_", ",", "tmax_", ",", "\[Delta]t_"}], "}"}]}], ",", 
     "acqevents_", ",", "opts___Rule"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "T", ",", "nsub", ",", "nsup", ",", "new\[Delta]t", ",", "newT"}], 
      "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"T", "=", 
        RowBox[{
         RowBox[{"SignalGeneratorPeriod", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "Signal1D", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"nsub", "=", 
        RowBox[{"2", 
         RowBox[{"Max", "[", 
          RowBox[{"1", ",", 
           RowBox[{"Round", "@", 
            RowBox[{"Abs", "[", 
             RowBox[{"T", "/", 
              RowBox[{"(", 
               RowBox[{"2", "\[Delta]t"}], ")"}]}], "]"}]}]}], "]"}]}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"nsup", "=", 
        RowBox[{"Max", "[", 
         RowBox[{"1", ",", 
          RowBox[{"Round", "@", 
           RowBox[{"Abs", "[", 
            RowBox[{"\[Delta]t", "/", "T"}], "]"}]}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"new\[Delta]t", ",", "newT"}], "}"}], "=", 
        "\[IndentingNewLine]", 
        RowBox[{"Which", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"nsub", ">", "1"}], ",", "\[IndentingNewLine]", "\t", 
          RowBox[{"(", "\[IndentingNewLine]", "\t", 
           RowBox[{
            RowBox[{"Message", "[", 
             RowBox[{
              RowBox[{"Signal1D", "::", "new\[Delta]t"}], ",", 
              RowBox[{
               RowBox[{"N", "[", 
                RowBox[{"T", "/", "nsub"}], "]"}], "//", 
               "EngineeringForm"}]}], "]"}], ";", "\[IndentingNewLine]", "\t", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"T", "/", "nsub"}], ",", "T"}], "}"}]}], 
           "\[IndentingNewLine]", "\t", ")"}], ",", "\[IndentingNewLine]", 
          RowBox[{"nsup", ">", "1"}], ",", "\[IndentingNewLine]", "\t", 
          RowBox[{"(", "\[IndentingNewLine]", "\t", 
           RowBox[{
            RowBox[{"Message", "[", 
             RowBox[{
              RowBox[{"Signal1D", "::", "new\[Delta]t"}], ",", 
              RowBox[{
               RowBox[{"N", "[", 
                RowBox[{"T", "\[Times]", "nsup"}], "]"}], "//", 
               "EngineeringForm"}]}], "]"}], ";", "\[IndentingNewLine]", "\t", 
            RowBox[{"{", 
             RowBox[{"\[Delta]t", ",", 
              RowBox[{"T", "\[Times]", "nsup"}]}], "}"}]}], 
           "\[IndentingNewLine]", "\t", ")"}], ",", "\[IndentingNewLine]", 
          "True", ",", "\[IndentingNewLine]", "\t", 
          RowBox[{"{", 
           RowBox[{"\[Delta]t", ",", "T"}], "}"}]}], "\[IndentingNewLine]", 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Signal1D", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"prefix", ",", 
           RowBox[{"{", 
            RowBox[{"True", ",", "True", ",", 
             RowBox[{"{", 
              RowBox[{"True", ",", "True", ",", "moresubcatst"}], "}"}], ",", 
             "moresampst"}], "}"}], ",", "acqevst", ",", "prepst", ",", 
           "ensavst", ",", "normfacst", ",", "obsst", ",", "evbackgst", ",", 
           "sigcalcst", ",", "morest"}], "}"}], ",", "\[IndentingNewLine]", 
         RowBox[{"Evaluate", "@", 
          RowBox[{"{", 
           RowBox[{"tmin", ",", "tmax", ",", "new\[Delta]t"}], "}"}]}], ",", 
         "\[IndentingNewLine]", "acqevents", ",", "\[IndentingNewLine]", 
         RowBox[{"Evaluate", "@", 
          RowBox[{"SimplifyRules", "[", 
           RowBox[{
            RowBox[{"SignalGeneratorPeriod", "\[Rule]", "newT"}], ",", 
            "opts"}], "]"}]}]}], "\[IndentingNewLine]", "]"}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.7010898582075167`*^9, 3.701089939366161*^9}, {
  3.701090616288413*^9, 3.701090626720011*^9}},
