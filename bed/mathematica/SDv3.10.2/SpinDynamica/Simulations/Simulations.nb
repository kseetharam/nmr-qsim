            RowBox[{
             RowBox[{"subcat1st", ":", "True"}], ",", 
             RowBox[{"subcat2st", ":", "True"}], ",", 
             RowBox[{"{", 
              RowBox[{"True", ",", "False"}], "}"}], ",", "moresubcatst___"}],
             "}"}], ",", "morelocst___"}], "}"}]}], ",", "morest___"}], "}"}],
       ",", "timing_List", ",", "evspecs_EventSpecifications", ",", 
      "opts___Rule"}], "]"}], "/;", 
    RowBox[{"MatchQ", "[", 
     RowBox[{"evspecs", ",", 
      RowBox[{"EventSpecifications", "[", 
       RowBox[{"True", ",", 
        RowBox[{"{", 
         RowBox[{"{", "_Repeat", "}"}], "}"}], ",", "evopts___Rule"}], 
       "]"}]}], "]"}]}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "period", ",", "repev", ",", "nrepdet", ",", "evopts", ",", 
       "repevopts"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"period", "=", 
        RowBox[{
         RowBox[{"SignalGeneratorPeriod", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "Signal1D", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"repev", "=", 
        RowBox[{"evspecs", "\[LeftDoubleBracket]", 
         RowBox[{"2", ",", "1", ",", "1", ",", "1"}], 
         "\[RightDoubleBracket]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"evopts", "=", 
        RowBox[{"Sequence", "@@", 
         RowBox[{"Cases", "[", 
          RowBox[{"evspecs", ",", "_Rule"}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"repevopts", "=", 
        RowBox[{"Sequence", "@@", 
         RowBox[{"Cases", "[", 
          RowBox[{
           RowBox[{"evspecs", "\[LeftDoubleBracket]", 
            RowBox[{"2", ",", "1", ",", "1"}], "\[RightDoubleBracket]"}], ",",
            "_Rule"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"nrepdet", "=", 
        RowBox[{"Max", "[", 
         RowBox[{
          RowBox[{"Ceiling", "[", 
           RowBox[{"period", "/", 
            RowBox[{"Duration", "[", "repev", "]"}]}], "]"}], ",", "1"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Signal1D", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "chronst", ",", "sampst", ",", "acqevst", ",", "prepst", ",", 
           "ensavst", ",", "normfacst", ",", "obsst", ",", "evbackgst", ",", 
           RowBox[{"{", 
            RowBox[{"True", ",", 
             RowBox[{"{", 
              RowBox[{"subcat1st", ",", "subcat2st", ",", 
               RowBox[{"{", 
                RowBox[{"True", ",", "True"}], "}"}], ",", "moresubcatst"}], 
              "}"}], ",", "morelocst"}], "}"}], ",", "morest"}], "}"}], ",", 
         "\[IndentingNewLine]", "timing", ",", "evspecs", ",", 
         "\[IndentingNewLine]", 
         RowBox[{"Evaluate", "@", 
          RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
           RowBox[{
           "PeriodicDetectionEvents", "\[Rule]", "\[IndentingNewLine]", 
            RowBox[{"EventSpecifications", "[", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"Repeat", "[", 
                RowBox[{"repev", ",", "nrepdet", ",", "repevopts"}], "]"}], 
               "}"}], ",", "\[IndentingNewLine]", 
              RowBox[{"ExpandRepeatedEvents", "\[Rule]", "True"}], ",", 
              "\[IndentingNewLine]", "evopts"}], "\[IndentingNewLine]", 
             "]"}]}], "\[IndentingNewLine]", "]"}]}], ",", 
         "\[IndentingNewLine]", "opts"}], "\[IndentingNewLine]", "]"}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
