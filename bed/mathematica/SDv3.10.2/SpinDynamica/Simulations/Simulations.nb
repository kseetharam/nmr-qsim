Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Signal1D", "[", 
    RowBox[{"True", ",", "timing_", ",", "acqevents_", ",", "opts___Rule"}], 
    "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "ensav", ",", "prep", ",", "backg", ",", "prepbackg", ",", "detbackg", ",",
        "\[Rho]ini", ",", "var", ",", "vals", ",", "weights", ",", "nens", ",",
        "maxbatchsize", ",", "valwbatches", ",", "nbatch", ",", "opbasis", ",",
        "basis", ",", "i", ",", "vardim", ",", "varsubrules", ",", "temp", ",",
        "sig"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"temp", "=", 
         RowBox[{"PrintTemporary", "[", "\"\<setting up batch..\>\"", "]"}]}],
         ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"opbasis", ",", "basis"}], "}"}], "=", 
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{"OperatorBasis", ",", "Basis"}], "}"}], "/.", 
           RowBox[{"{", "opts", "}"}]}], "/.", 
          RowBox[{"Options", "[", "Signal1D", "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"nens", "=", 
         RowBox[{"Length", "[", 
          RowBox[{"Last", "[", "ensav", "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"varsubrules", "=", 
         RowBox[{"EnsembleSubstitutionRules", "[", "ensav", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"weights", "=", 
         RowBox[{"EnsembleWeights", "[", "ensav", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"NotebookDelete", "[", "temp", "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"CombineData", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Monitor", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"Table", "[", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"Signal1D", "[", "\[IndentingNewLine]", 
               RowBox[{"True", ",", "timing", ",", "\[IndentingNewLine]", 
                RowBox[{"Evaluate", "@", 
                 RowBox[{"ReleaseHold", "[", 
                  RowBox[{"ReplaceEverywhere", "[", 
                   RowBox[{
                    RowBox[{"Hold", "[", "acqevents", "]"}], ",", 
                    RowBox[{
                    "varsubrules", "\[LeftDoubleBracket]", "i", 
                    "\[RightDoubleBracket]"}]}], "]"}], "]"}]}], ",", 
                "\[IndentingNewLine]", 
                RowBox[{"Evaluate", "@", 
                 RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
                  RowBox[{
                   RowBox[{"EnsembleAverage", "\[Rule]", "False"}], ",", 
                   "\[IndentingNewLine]", 
                   RowBox[{"OperatorBasis", "\[Rule]", "opbasis"}], ",", 
                   "\[IndentingNewLine]", 
                   RowBox[{"Basis", "\[Rule]", "basis"}], ",", 
                   "\[IndentingNewLine]", 
                   RowBox[{"ReleaseHold", "[", 
                    RowBox[{"ReplaceEverywhere", "[", 
                    RowBox[{
                    RowBox[{"Hold", "[", "opts", "]"}], ",", 
                    RowBox[{
                    "varsubrules", "\[LeftDoubleBracket]", "i", 
                    "\[RightDoubleBracket]"}]}], "]"}], "]"}], ",", 
                   "\[IndentingNewLine]", 
                   RowBox[{
                   "WarnAboutMissingPreparationBackground", "\[Rule]", 
                    "False"}]}], "\[IndentingNewLine]", "]"}]}]}], 
               "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
              RowBox[{"{", 
               RowBox[{"i", ",", "1", ",", "nens"}], "}"}]}], 
             "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
            RowBox[{"ProgressIndicator", "[", 
             RowBox[{"i", ",", 
              RowBox[{"{", 
               RowBox[{"1", ",", 
                RowBox[{"nens", "+", "1"}]}], "}"}]}], "]"}]}], 
           "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
          "weights", ",", "\[IndentingNewLine]", 
          RowBox[{"Sequence", "@@", 
           RowBox[{"FilterRules", "[", 
            RowBox[{
             RowBox[{"{", "opts", "}"}], ",", 
             RowBox[{"Options", "[", "Signal", "]"}]}], "]"}]}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"Parallel", "\[Rule]", "False"}]}], "\[IndentingNewLine]", 
         "]"}]}], "\[IndentingNewLine]", ")"}], "/;", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"!", 
         RowBox[{"TrueQ", "[", 
          RowBox[{
           RowBox[{"Parallel", "/.", 
            RowBox[{"{", "opts", "}"}]}], "/.", 
           RowBox[{"Options", "[", "Signal1D", "]"}]}], "]"}]}], "&&", 
        "\[IndentingNewLine]", 
        RowBox[{"(", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{
            "ensav", ",", "prep", ",", "backg", ",", "\[Rho]ini", ",", 
             "maxbatchsize"}], "}"}], "=", 
           RowBox[{
            RowBox[{
             RowBox[{"{", 
              RowBox[{
              "EnsembleAverage", ",", "Preparation", ",", 
               "BackgroundGenerator", ",", "InitialDensityOperator", ",", 
               "MaxBatchSize"}], "}"}], "/.", 
             RowBox[{"{", "opts", "}"}]}], "/.", 
            RowBox[{"Options", "[", "Signal1D", "]"}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"detbackg", ",", "prepbackg"}], "}"}], "=", 
           RowBox[{"ReleaseHold", "[", "backg", "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"MatchQ", "[", 
            RowBox[{"ensav", ",", 
             RowBox[{"{", 
              RowBox[{"_", ",", "_"}], "}"}]}], "]"}], "&&", 
           "\[IndentingNewLine]", 
           RowBox[{"(", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"nens", "=", 
              RowBox[{"Length", "[", 
               RowBox[{"Last", "[", "ensav", "]"}], "]"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"maxbatchsize", "=", 
              RowBox[{"Min", "[", 
               RowBox[{
                RowBox[{"Max", "[", 
                 RowBox[{"maxbatchsize", ",", "1"}], "]"}], ",", "nens"}], 
               "]"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"maxbatchsize", ">=", "nens"}], "&&", 
              "\[IndentingNewLine]", 
              RowBox[{"(", "\[IndentingNewLine]", 
               RowBox[{
                RowBox[{"MatchQ", "[", 
                 RowBox[{"prep", ",", 
                  RowBox[{"None", "|", 
                   RowBox[{"EventSpecifications", "@", 
                    RowBox[{"UnitySuperoperator", "[", "]"}]}]}]}], "]"}], "||",
                 "\[IndentingNewLine]", 
                RowBox[{"(", "\[IndentingNewLine]", 
                 RowBox[{
                  RowBox[{"!", 
                   RowBox[{"EnsembleVariablesFreeQ", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"prep", ",", "\[Rho]ini"}], "}"}], ",", "ensav"}],
                     "]"}]}], "||", "\[IndentingNewLine]", 
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"Chop", "[", 
                    RowBox[{"Duration", "[", "prep", "]"}], "]"}], "\[NotEqual]",
                     "0"}], ")"}], "&&", 
                    RowBox[{"!", 
                    RowBox[{"EnsembleVariablesFreeQ", "[", 
                    RowBox[{"prepbackg", ",", "ensav"}], "]"}]}]}], ")"}]}], 
                 "\[IndentingNewLine]", ")"}]}], "\[IndentingNewLine]", 
               ")"}]}]}], "\[IndentingNewLine]", ")"}]}]}], 
         "\[IndentingNewLine]", ")"}]}], "\[IndentingNewLine]", ")"}]}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
