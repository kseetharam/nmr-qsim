    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Rho]func", ",", "\[Rho]funclist", ",", "\[Rho]funct", ",", "tfin", ",",
        "tini", ",", "norm", ",", "opnormsqlist", ",", "conjgopvecs", ",", 
       "tval", ",", "t", ",", "tintervals", ",", "ninterps", ",", 
       "\[Rho]intervalfuncs", ",", "interppoints", ",", "maxstepsize", ",", 
       "opbasis", ",", "basis", ",", "ndiagoutput", ",", "attemptdiag", ",", 
       "backg", ",", "backg2"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{
         "norm", ",", "opbasis", ",", "basis", ",", "interppoints", ",", 
