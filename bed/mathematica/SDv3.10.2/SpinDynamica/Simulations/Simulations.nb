Cell["\<\
SignalCalculationMethod\[Rule]\"Direct\"(fully general; uses a Trajectory \
function running through the whole evolution)\
\>", "Section",
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.4483607649589667`*^9, 3.448360776920339*^9}, {
