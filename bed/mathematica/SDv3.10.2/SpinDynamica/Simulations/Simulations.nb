   3.470139107379881*^9},ExpressionUUID->"9d66feb9-0d2b-4607-9c08-\
2f56558c0c8e"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Signal1D", "[", 
     RowBox[{"True", ",", "timing_", ",", "acqevents_", ",", "opts___Rule"}], 
     "]"}], "/;", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"MatchQ", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"SignalCalculationMethod", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "Signal1D", "]"}]}], ",", "\"\<Direct\>\""}],
        "]"}], "&&", 
      RowBox[{"MatchQ", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"EnsembleAverage", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "Signal1D", "]"}]}], ",", 
        RowBox[{"False", "|", "None"}]}], "]"}], "&&", "\[IndentingNewLine]", 
      
      RowBox[{"MatchQ", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Preparation", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "Signal1D", "]"}]}], ",", 
        RowBox[{"None", "|", 
         RowBox[{"EventSpecifications", "@", 
          RowBox[{"UnitySuperoperator", "[", "]"}]}]}]}], "]"}], "&&", 
      "\[IndentingNewLine]", 
      RowBox[{"MatchQ", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"InitialDensityOperator", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "Signal1D", "]"}]}], ",", "_Operator"}], 
       "]"}]}], "\[IndentingNewLine]", ")"}]}], ":=", 
   RowBox[{"Signal1DCore", "[", 
    RowBox[{"\"\<Direct\>\"", ",", "timing", ",", "acqevents", ",", "opts"}], 
    "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{
  3.506249453091873*^9, 3.506250315189757*^9, 3.5131867841668468`*^9, {
   3.513190418064509*^9, 3.513190433568109*^9}, {3.514453501713839*^9, 
   3.514453511013501*^9}, 3.5150662444971538`*^9, 3.515066311104985*^9, 
   3.515066691359253*^9, 3.5150667246961527`*^9, {3.53214746544799*^9, 
