  RowBox[{
   RowBox[{"Trajectory", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Evaluate", "@", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"prefix", ":", 
         RowBox[{"Repeated", "[", 
          RowBox[{"_", ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"StatusPosition", "[", 
              RowBox[{"Trajectory", ",", "\"\<InitialDensityOperator\>\""}], 
              "]"}], "-", "1"}], "}"}]}], "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"locst", ":", 
         RowBox[{"{", 
          RowBox[{"True", ",", "False", ",", "morelocst___"}], "}"}]}], ",", 
        "\[IndentingNewLine]", "morest___"}], "}"}]}], ",", 
     "\[IndentingNewLine]", "\[Rho]0_", ",", "more___", ",", "opts___Rule"}], 
    "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"\[Rho]0vec", ",", "opbasis", ",", "basis"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"opbasis", ",", "basis"}], "}"}], "=", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{"OperatorBasis", ",", "Basis"}], "}"}], "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "Trajectory", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Trajectory", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"{", 
