Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"TransformationAmplitude", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Evaluate", "@", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"prefix", ":", 
         RowBox[{"Repeated", "[", 
          RowBox[{"_", ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"StatusPosition", "[", 
              RowBox[{
              "TransformationAmplitude", 
               ",", "\"\<InitialDensityOperator\>\""}], "]"}], "-", "1"}], 
            "}"}]}], "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"locst", ":", 
         RowBox[{"{", 
          RowBox[{"True", ",", "False", ",", "morelocst___"}], "}"}]}], ",", 
        "\[IndentingNewLine]", "morest___"}], "}"}]}], ",", 
     "\[IndentingNewLine]", "\[Rho]0_", ",", "more___", ",", "opts___Rule"}], 
    "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"\[Rho]0vec", ",", "opbasis", ",", "basis"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"opbasis", ",", "basis"}], "}"}], "=", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{"OperatorBasis", ",", "Basis"}], "}"}], "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "TransformationAmplitude", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"TransformationAmplitude", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"prefix", ",", 
           RowBox[{"{", 
            RowBox[{"True", ",", "True", ",", "morelocst"}], "}"}], ",", 
           "morest"}], "}"}], ",", "\[IndentingNewLine]", 
         RowBox[{"Evaluate", "@", 
          RowBox[{"Operator", "[", 
           RowBox[{"\[Rho]0", ",", 
            RowBox[{"ZeemanBasis", "[", "]"}], ",", "\[IndentingNewLine]", 
            RowBox[{"Sequence", "@@", 
             RowBox[{"FilterRules", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"CheckOperatorType", "\[Rule]", "False"}], ",", 
                 "opts"}], "}"}], ",", 
               RowBox[{"Options", "[", "Operator", "]"}]}], "]"}]}]}], 
           "]"}]}], ",", "\[IndentingNewLine]", "more", ",", "opts"}], 
        "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", ")"}]}], 
