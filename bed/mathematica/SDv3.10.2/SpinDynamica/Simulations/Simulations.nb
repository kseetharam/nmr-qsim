Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Signal1D", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"chronst_", ",", 
       RowBox[{"sampst", ":", 
        RowBox[{"True", "|", 
         RowBox[{"{", 
          RowBox[{"True", ",", "True", ",", "___"}], "}"}]}]}], ",", 
       "acqevst_", ",", 
       RowBox[{"prepst", ":", "True"}], ",", 
       RowBox[{"ensavst", ":", "True"}], ",", "normfacst_", ",", "obsst_", ",", 
       RowBox[{"locst", ":", 
        RowBox[{"{", 
         RowBox[{"True", ",", "True", ",", "False", ",", "morelocst___"}], 
         "}"}]}], ",", "morest___"}], "}"}], ",", 
     RowBox[{"more", ":", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Except", "[", "_Rule", "]"}], "..."}], ")"}]}], ",", 
     "opts___Rule"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "backg", ",", "ensav", ",", "diagfunc", ",", "opbasis", ",", "basis", ",",
        "shouldnotdiag", ",", "diagbackg", ",", "ndiagoutput"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"backg", "=", 
        RowBox[{"StandardizeGenerator", "[", 
         RowBox[{"(", 
          RowBox[{"ReleaseHold", "[", 
           RowBox[{
            RowBox[{"BackgroundGenerator", "/.", 
             RowBox[{"{", "opts", "}"}]}], "/.", 
            RowBox[{"Options", "[", "Signal1D", "]"}]}], "]"}], ")"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"ensav", "=", 
        RowBox[{
         RowBox[{"EnsembleAverage", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "Signal1D", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"opbasis", ",", "basis"}], "}"}], "=", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{"OperatorBasis", ",", "Basis"}], "}"}], "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "Signal1D", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"shouldnotdiag", "=", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"!", 
           RowBox[{"FreeQ", "[", 
            RowBox[{
             RowBox[{"{", "more", "}"}], ",", "_PrecalculatedEvent"}], 
            "]"}]}], "||", 
          RowBox[{
           RowBox[{"Length", "[", 
            RowBox[{"UnassignedSymbols", "[", 
             RowBox[{"backg", ",", 
              RowBox[{"PermittedSymbols", "\[Rule]", 
               RowBox[{"LocalGeneratorSymbols", "[", "backg", "]"}]}]}], 
             "]"}], "]"}], ">", "0"}]}], ")"}]}], ";", "\[IndentingNewLine]", 
       
       RowBox[{"diagfunc", "=", 
        RowBox[{"Function", "[", 
         RowBox[{"gen", ",", "\[IndentingNewLine]", 
          RowBox[{"Which", "[", "\[IndentingNewLine]", 
           RowBox[{"shouldnotdiag", ",", "gen", ",", "\[IndentingNewLine]", 
            RowBox[{"OperatorQ", "[", "gen", "]"}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"ndiagoutput", "=", 
               RowBox[{"NDiagonalize", "[", 
                RowBox[{"gen", ",", "basis"}], "]"}]}], ";", 
              "\[IndentingNewLine]", "\t", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{"MatchQ", "[", 
                 RowBox[{"ndiagoutput", ",", "$Failed"}], "]"}], ",", 
                "\[IndentingNewLine]", 
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"Message", "[", 
                   RowBox[{"Trajectory", "::", "noprediag"}], "]"}], ";", 
                  "gen"}], ")"}], ",", "ndiagoutput"}], "]"}]}], ")"}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"SuperoperatorQ", "[", "gen", "]"}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"ndiagoutput", "=", 
               RowBox[{"NDiagonalize", "[", 
                RowBox[{"gen", ",", "opbasis", ",", "basis"}], "]"}]}], ";", 
              "\[IndentingNewLine]", "\t", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{"MatchQ", "[", 
                 RowBox[{"ndiagoutput", ",", "$Failed"}], "]"}], ",", 
                "\[IndentingNewLine]", 
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"Message", "[", 
                   RowBox[{"Signal1D", "::", "noprediag"}], "]"}], ";", 
                  "gen"}], ")"}], ",", "ndiagoutput"}], "]"}]}], ")"}], ",", 
            "\[IndentingNewLine]", "True", ",", "gen"}], "]"}]}], 
         "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Signal1D", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "chronst", ",", "sampst", ",", "acqevst", ",", "prepst", ",", 
           "ensavst", ",", "normfacst", ",", "obsst", ",", 
           "\[IndentingNewLine]", 
           RowBox[{"{", 
            RowBox[{"True", ",", "True", ",", "True", ",", "morelocst"}], 
            "}"}], ",", "morest"}], "}"}], ",", "more", ",", 
         "\[IndentingNewLine]", 
         RowBox[{"Evaluate", "@", 
          RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"BackgroundGenerator", "\[Rule]", "\[IndentingNewLine]", 
             RowBox[{"Switch", "[", 
              RowBox[{"backg", ",", "\[IndentingNewLine]", 
               RowBox[{"Except", "[", "_List", "]"}], ",", 
               RowBox[{"diagfunc", "[", "backg", "]"}], ",", 
               "\[IndentingNewLine]", "_List", ",", 
               RowBox[{"diagfunc", "/@", "backg"}], ",", 
               "\[IndentingNewLine]", "_", ",", "$Failed"}], 
              "\[IndentingNewLine]", "]"}]}], ",", "\[IndentingNewLine]", 
            "opts"}], "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]",
         "]"}]}], "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
