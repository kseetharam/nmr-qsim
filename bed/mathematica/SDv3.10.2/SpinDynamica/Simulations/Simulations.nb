           RowBox[{"backg", ",", "opbasis", ",", "basis"}], "]"}]}], 
         "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"backg2", "=", 
        RowBox[{"Switch", "[", 
