Cell[CellGroupData[{

Cell["Preparation", "Subsection",
 InitializationCell->True,
 CellChangeTimes->{3.629384641320005*^9, 3.6293847218083897`*^9, 
  3.629384751905472*^9},ExpressionUUID->"a419f03e-a450-41ec-83ab-\
dff0b28abfa4"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Preparation", "::", "usage"}], 
   "=", "\"\<Preparation is an option for Signal1D, defining the set of \
events applied to the initial density operator before signal acquisition. The \
default is RotationSuperoperator[{\[Pi]/2,\\\"x\\\"}], corresponding to a \
strong non-selective 90\[Degree] pulse with phase 0.\>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 CellChangeTimes->{{3.469877991470448*^9, 3.46987801563752*^9}, {
  3.46989467279669*^9, 3.469894700225692*^9}, {3.469895601753048*^9, 
