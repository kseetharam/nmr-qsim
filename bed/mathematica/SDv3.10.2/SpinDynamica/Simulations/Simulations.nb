Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"TransformationAmplitude", "::", "usage"}], 
   "=", "\"\<TransformationAmplitude[\[Rho]ini\[Rule]obs,events] generates \
the amplitude for transformation of an initial density operator \[Rho]ini \
into an observable obs. TransformationAmplitude[\[Rho]ini\[Rule]{op1,op2..}, \
events] generates a list of transformation amplitudes. The option \
BackgroundGenerator specifies the background generator for the calculation. \
The option EnsembleAverage may be used to specify a weighted average over an \
arbitrary variable involved in the event specifications or in the option \
BackgroundGenerator. See the usage message for EnsembleAverage.\>\""}], 
  ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
