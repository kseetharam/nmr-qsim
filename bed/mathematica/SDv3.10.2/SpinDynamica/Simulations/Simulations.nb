Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Signal1D", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"chronst", ":", "True"}], ",", 
        RowBox[{"sampst", ":", 
         RowBox[{"True", "|", 
          RowBox[{"{", 
           RowBox[{"True", ",", "True", ",", "___"}], "}"}]}]}], ",", 
        RowBox[{"acqevst", ":", "True"}], ",", 
        RowBox[{"prepst", ":", "True"}], ",", 
        RowBox[{"ensavst", ":", "True"}], ",", 
        RowBox[{"normfacst", ":", "True"}], ",", 
        RowBox[{"obsst", ":", "True"}], ",", 
        RowBox[{"evbackgst", ":", "True"}], ",", 
        RowBox[{"locst", ":", 
         RowBox[{"{", 
          RowBox[{"True", ",", 
