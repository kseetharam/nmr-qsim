Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Signal1D", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"prefix", ":", 
        RowBox[{"Repeated", "[", 
         RowBox[{"_", ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"StatusPosition", "[", 
             RowBox[{"Signal1D", ",", "\"\<SignalCalculation\>\""}], "]"}], "-",
             "1"}], "}"}]}], "]"}]}], ",", 
       RowBox[{"locst", ":", 
        RowBox[{"{", 
         RowBox[{"True", ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"True", ",", "False", ",", "False", ",", "False"}], 
             "}"}], ",", 
            RowBox[{"sgenperst", ":", "True"}], ",", "moresubcatst__"}], 
           "}"}], ",", "morelocst___"}], "}"}]}], ",", "morest___"}], "}"}], ",",
      "\[IndentingNewLine]", 
     RowBox[{"timing", ":", 
      RowBox[{"{", 
       RowBox[{"tmin_", ",", "tmax_", ",", "\[Delta]t_"}], "}"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"HoldPattern", "@", 
      RowBox[{"EventSpecifications", "[", 
       RowBox[{"True", ",", "events_", ",", "evopts___Rule"}], "]"}]}], ",", 
     "opts___Rule"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "evbackg", ",", "detbackg", ",", "period", ",", "Nspace", ",", 
       "Nsubdiv", ",", "Nperiods", ",", "carav"}], "}"}], ",", 
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"detbackg", "=", 
         RowBox[{"First", "@", "evbackg"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"period", ",", "carav"}], "}"}], "=", 
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{"SignalGeneratorPeriod", ",", "CarouselAverage"}], "}"}], 
           "/.", 
           RowBox[{"{", "opts", "}"}]}], "/.", 
          RowBox[{"Options", "[", "Signal1D", "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Nspace", "=", 
         RowBox[{"BasisDimension", "[", 
          RowBox[{"Basis", "[", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"NumericQ", "[", "period", "]"}], ",", 
          RowBox[{"(", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"Nsubdiv", "=", 
             RowBox[{"Max", "[", 
              RowBox[{
               RowBox[{"Round", "[", 
                RowBox[{"period", "/", "\[Delta]t"}], "]"}], ",", "1"}], 
              "]"}]}], ";", "\[IndentingNewLine]", 
            RowBox[{"Nperiods", "=", 
             RowBox[{"Max", "[", 
              RowBox[{
               RowBox[{"Round", "[", 
                RowBox[{
                 RowBox[{"Abs", "[", 
                  RowBox[{"tmax", "-", "tmin"}], "]"}], "/", "period"}], 
                "]"}], ",", "1"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
           ")"}]}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"Signal1D", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"prefix", ",", 
            RowBox[{"{", 
             RowBox[{"True", ",", 
              RowBox[{"{", 
               RowBox[{
