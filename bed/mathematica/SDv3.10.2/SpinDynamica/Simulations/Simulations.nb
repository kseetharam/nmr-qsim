Cell[CellGroupData[{

Cell["CarouselAverage", "Subsection",
 InitializationCell->True,
 CellChangeTimes->{3.629384641320005*^9, 3.6293847218083897`*^9, 
  3.629384751905472*^9, 3.629384821495875*^9, 
  3.62938504961034*^9},ExpressionUUID->"0f6e9eb4-ce94-45a2-ac34-d25b1fead152"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"CarouselAverage", "::", "usage"}], 
   "=", "\"\<CarouselAverage is an option for Signal1D. \
CarouselAverage\[Rule]True may be used with the \
SignalCalculationMethod\[Rule]\\\"COMPUTE\\\" option, in which case a fast \
implementation of the carousel average is used (i.e. \
\\\"\[Gamma]-COMPUTE\\\"). This if often used for computing the NMR spectra \
of rotating powders, where use of the carousel average allows a rapid \
estimate of the average over the \[Gamma]MR Euler angle. This option must be \
used with care since it is only valid if the density operator at the start of \
signal acquisition is independent of the \[Gamma]MR Euler angle.\n \>\""}], 
  ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 CellChangeTimes->{{3.469878218285511*^9, 3.469878219035956*^9}, {
  3.469882329319214*^9, 3.46988233483611*^9}, {3.469882378889137*^9, 
