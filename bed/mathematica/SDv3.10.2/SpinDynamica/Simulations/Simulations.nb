Cell[CellGroupData[{

Cell["ConvertOperatorTrajectoryFunctionToTrajectoryFunction", "Subsection",
 InitializationCell->True,
 CellChangeTimes->{{3.623337190645422*^9, 3.623337205579728*^9}, {
   3.623339866225156*^9, 3.6233398691192493`*^9}, 
   3.755596275724055*^9},ExpressionUUID->"1418d2ea-f882-4dae-8495-\
c97a52e0e70c"],

Cell["\<\
ExpToTrig is desirable for simplifying complex exponentials into sines and \
cosines, removing imaginary factors. However the generation of hyperbolic \
trig functions causes bad rounding errors on evaluation in some circumstances \
(see bug 141221-MHL-2111b2-Trajectory). The conversion is therefore reversed \
if hyperbolic trig functions are generated.\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.6314290734959993`*^9, 
  3.631429267388995*^9}},ExpressionUUID->"70c9b8d3-5dca-4802-97bf-\
7686478caa79"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"HoldPattern", "@", 
    RowBox[{
    "ConvertOperatorTrajectoryFunctionToTrajectoryFunction", "[", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"OperatorTrajectoryFunction", "[", 
       RowBox[{"timing_", ",", 
        RowBox[{"Function", "[", 
         RowBox[{"t_", ",", "arg_"}], "]"}], ",", "more___"}], "]"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"obsop_", "?", "OperatorQ"}], ",", "\[IndentingNewLine]", 
      "opts___Rule"}], "\[IndentingNewLine]", "]"}]}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "norm", "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"norm", "=", 
        RowBox[{
         RowBox[{"NormalizationFactor", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"{", 
          RowBox[{"NormalizationFactor", "\[Rule]", "1"}], "}"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"TrajectoryFunction", "[", 
        RowBox[{"timing", ",", "\[IndentingNewLine]", 
         RowBox[{"Function", "[", 
          RowBox[{"t", ",", 
           RowBox[{"Evaluate", "[", 
            RowBox[{"arg", "/.", "\[IndentingNewLine]", 
             RowBox[{"{", 
              RowBox[{
              "op_Operator", "\[RuleDelayed]", "\[IndentingNewLine]", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{
                  RowBox[{"If", "[", 
                   RowBox[{
                    RowBox[{"FreeQ", "[", 
                    RowBox[{"#", ",", 
                    RowBox[{"Cosh", "|", "Sinh"}]}], "]"}], ",", "#", ",", 
                    RowBox[{"TrigToExp", "[", "#", "]"}]}], "]"}], "&"}], "@", 
                 RowBox[{"ExpToTrig", "[", 
                  RowBox[{
                   RowBox[{"OperatorAmplitude", "[", 
                    RowBox[{"op", "\[Rule]", "obsop"}], "]"}], "/", "norm"}], 
                  "]"}]}], ")"}]}], "\[IndentingNewLine]", "}"}]}], 
            "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", "]"}]}], 
        "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", ")"}]}], 
    "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.62333721557078*^9, 3.6233372180923176`*^9}, {
   3.62333726658293*^9, 3.623337335024548*^9}, {3.623337365173994*^9, 
   3.623337420519058*^9}, 3.623337482425338*^9, {3.623337514402156*^9, 
   3.6233375988777127`*^9}, {3.62333773219913*^9, 3.623337798183189*^9}, {
   3.62333809219481*^9, 3.623338094853349*^9}, {3.623338454784726*^9, 
   3.623338455333288*^9}, {3.6233394650763693`*^9, 3.623339473869177*^9}, {
   3.631429274460902*^9, 3.631429351353907*^9}, {3.699561897952251*^9, 
   3.699561903564548*^9}, {3.699564205362108*^9, 3.699564205710395*^9}, 
   3.6995643195307407`*^9},
 CellLabel->
