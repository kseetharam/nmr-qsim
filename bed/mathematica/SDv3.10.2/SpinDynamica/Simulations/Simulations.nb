Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"TransformationAmplitudeTable", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Evaluate", "@", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"prefix", ":", 
         RowBox[{"StatusPatternPrefix", "[", 
          RowBox[{"TransformationAmplitudeTable", ",", "\"\<Iterators\>\""}], 
          "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"locst", ":", 
         RowBox[{"{", 
          RowBox[{
          "True", ",", "True", ",", "True", ",", "True", ",", "False", ",", 
           "morelocst___"}], "}"}]}], ",", "\[IndentingNewLine]", 
        "morest___"}], "}"}]}], ",", "\[IndentingNewLine]", "\[Rho]ini_", ",",
      "obs_", ",", "events_", ",", "\[IndentingNewLine]", 
     RowBox[{"iterlists", ":", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"Except", "[", "_List", "]"}], ".."}], ",", 
          RowBox[{
           RowBox[{"Except", "[", "_List", "]"}], "|", 
           RowBox[{"{", "_Integer", "}"}]}]}], "}"}], ".."}], "}"}]}], ",", 
     "\[IndentingNewLine]", "opts___Rule"}], "\[IndentingNewLine]", "]"}], ":=",
    "\[IndentingNewLine]", 
   RowBox[{"TransformationAmplitudeTable", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"prefix", ",", 
       RowBox[{"{", 
        RowBox[{
        "True", ",", "True", ",", "True", ",", "True", ",", "True", ",", 
         "morelocst"}], "}"}], ",", "morest"}], "}"}], ",", 
     "\[IndentingNewLine]", "\[Rho]ini", ",", "obs", ",", "events", ",", 
     "\[IndentingNewLine]", 
     RowBox[{"Evaluate", "[", "\[IndentingNewLine]", 
      RowBox[{"Map", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"#", "//.", 
           RowBox[{"{", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{
              RowBox[{"{", 
               RowBox[{"v_Symbol", ",", 
                RowBox[{"vmax", ":", 
                 RowBox[{"Except", "[", "_List", "]"}]}]}], "}"}], "\[RuleDelayed]", 
              RowBox[{"{", 
               RowBox[{"v", ",", "0", ",", "vmax"}], "}"}]}], ",", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"v_Symbol", ",", 
                RowBox[{"vmin", ":", 
                 RowBox[{"Except", "[", "_List", "]"}]}], ",", 
                RowBox[{"vmax", ":", 
                 RowBox[{"Except", "[", "_List", "]"}]}]}], "}"}], "\[RuleDelayed]", 
              RowBox[{"{", 
               RowBox[{"v", ",", "vmin", ",", "vmax", ",", "1"}], "}"}]}], ",",
              "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"v_Symbol", ",", 
                RowBox[{"vmin", ":", 
                 RowBox[{"Except", "[", "_List", "]"}]}], ",", 
                RowBox[{"vmax", ":", 
                 RowBox[{"Except", "[", "_List", "]"}]}], ",", 
                RowBox[{"{", "nv_", "}"}]}], "}"}], "\[RuleDelayed]", 
              "\[IndentingNewLine]", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"If", "[", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{"!", 
                    RowBox[{"IntegerQ", "[", "nv", "]"}]}], ")"}], "||", 
                   RowBox[{"(", 
                    RowBox[{"nv", "<", "1"}], ")"}]}], ",", 
                  RowBox[{"Message", "[", 
                   RowBox[{
                   "TransformationAmplitudeTable", "::", "badnumincr"}], 
                   "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
                RowBox[{"{", 
                 RowBox[{"v", ",", "vmin", ",", "vmax", ",", 
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{"vmax", "-", "vmin"}], ")"}], "/", 
                   RowBox[{"Max", "[", 
                    RowBox[{
                    RowBox[{"nv", "-", "1"}], ",", "1"}], "]"}]}]}], "}"}]}], 
               ")"}]}], ",", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"v_Symbol", ",", 
                RowBox[{"vmax", ":", 
                 RowBox[{"Except", "[", "_List", "]"}]}], ",", 
