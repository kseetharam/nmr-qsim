Cell["RtoL chronology is imposed by EventSpecifications", "Text",
 CellChangeTimes->{{3.700885070727372*^9, 
  3.7008850824776382`*^9}},ExpressionUUID->"49c8147e-9d0e-4fc7-88a9-\
06f0b33335d2"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Signal1D", "[", 
    RowBox[{
     RowBox[{"status", ":", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"prefix", ":", 
         RowBox[{"StatusPatternPrefix", "[", 
          RowBox[{"Signal1D", ",", "\"\<Preparation\>\""}], "]"}]}], ",", 
        RowBox[{"locst", ":", 
         RowBox[{"{", 
          RowBox[{"True", ",", "False", ",", "morelocst___"}], "}"}]}], ",", 
        "morest___"}], "}"}]}], ",", "sampling_List", ",", "more___", ",", 
     "opts___Rule"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"prep", ",", "standprep"}], "}"}], ",", 
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"standprep", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"Switch", "[", 
            RowBox[{"#", ",", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"_", "?", "ValidEventSpecificationQ"}], "|", 
              "_PulseSequence"}], ",", "\[IndentingNewLine]", "\t", 
             RowBox[{"StandardizeEventSpecification", "[", "#", "]"}], ",", 
             "\[IndentingNewLine]", 
             RowBox[{"_", "?", "PulseSequenceQ"}], ",", "\[IndentingNewLine]", 
             RowBox[{"StandardizeEventSpecification", "@", 
              RowBox[{"PulseSequence", "[", 
               RowBox[{"#", ",", "opts"}], "]"}]}], ",", 
             "\[IndentingNewLine]", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"_", "?", "ValidEventSpecificationQ"}], "..."}], "}"}],
              ",", "\[IndentingNewLine]", "\t", 
             RowBox[{"StandardizeEventSpecification", "/@", "#"}], ",", 
             "\[IndentingNewLine]", "_", ",", "$Failed"}], "]"}], "&"}], "@", 
          "prep"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"Signal1D", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"prefix", ",", 
            RowBox[{"{", 
             RowBox[{"True", ",", "True", ",", "morelocst"}], "}"}], ",", 
            "morest"}], "}"}], ",", "sampling", ",", "more", ",", 
          "\[IndentingNewLine]", 
          RowBox[{"Evaluate", "@", 
           RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"Preparation", "\[Rule]", "\[IndentingNewLine]", 
              RowBox[{"EventSpecifications", "[", "\[IndentingNewLine]", 
               RowBox[{"standprep", ",", "\[IndentingNewLine]", 
                RowBox[{"Sequence", "@@", 
                 RowBox[{"FilterRules", "[", "\[IndentingNewLine]", 
                  RowBox[{
                   RowBox[{"SimplifyRules", "[", 
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"Chronology", "\[Rule]", 
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"Chronology", "/.", 
                    RowBox[{"{", "opts", "}"}]}], "/.", 
                    RowBox[{"Options", "[", "Signal1D", "]"}]}], ")"}]}], ",",
                     "opts"}], "}"}], "]"}], ",", "\[IndentingNewLine]", 
                   RowBox[{"Options", "[", "EventSpecifications", "]"}]}], 
                  "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", 
               "]"}]}], ",", "\[IndentingNewLine]", "opts"}], 
            "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", "]"}]}], 
       "\[IndentingNewLine]", ")"}], "/;", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"prep", "=", 
         RowBox[{
          RowBox[{"Preparation", "/.", 
           RowBox[{"{", "opts", "}"}]}], "/.", 
          RowBox[{"Options", "[", "Signal1D", "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"MatchQ", "[", 
         RowBox[{"prep", ",", 
          RowBox[{
           RowBox[{"_", "?", "ValidEventSpecificationQ"}], "|", 
           "_PulseSequence", "|", 
           RowBox[{"_", "?", "PulseSequenceQ"}], "|", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"_", "?", "ValidEventSpecificationQ"}], "..."}], 
            "}"}]}]}], "]"}]}], "\[IndentingNewLine]", ")"}]}]}], "]"}]}], 
  ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.699963672135429*^9, 3.699963720454352*^9}, {
   3.699963770159423*^9, 3.699963794682675*^9}, {3.6999641987233458`*^9, 
