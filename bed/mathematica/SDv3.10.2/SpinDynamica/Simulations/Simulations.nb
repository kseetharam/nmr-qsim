Cell[CellGroupData[{

Cell["BackgroundGenerator is compatible with repetitions", "Subsection",
 InitializationCell->True,
 CellChangeTimes->{{3.626008750478898*^9, 3.626008800543957*^9}, {
   3.62600959867705*^9, 3.626009614920927*^9}, {3.626010373304895*^9, 
   3.6260103920352573`*^9}, 3.626015323118098*^9, 3.626016984398726*^9, 
   3.709375555147832*^9},ExpressionUUID->"9b3d362a-2e6a-4bba-a77b-\
5dafdb6ac99e"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"DividedEventPropagators", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"type_", ",", "T_", ",", "n_"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"divevent", ":", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"_Integer", ",", "_EventSpecifications"}], "}"}], ".."}], 
       "}"}]}], ",", "opbasis_", ",", "basis_", ",", "opts___Rule"}], "]"}], ":=",
    "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "dim", ",", "evbackg", ",", "standevbackg", ",", "nreps", ",", 
       "evspeclists", ",", "evlists", ",", "props", ",", "Sjset"}], "}"}], ",", 
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{"nreps", ",", "evspeclists"}], "}"}], "=", 
         RowBox[{"Transpose", "[", "divevent", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"evlists", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"EventList", "[", 
            RowBox[{"#", ",", "opts"}], "]"}], "&"}], "/@", "evspeclists"}]}],
         ";", "\[IndentingNewLine]", 
        RowBox[{"props", "=", 
         RowBox[{"Switch", "[", 
          RowBox[{
          "type", ",", "\[IndentingNewLine]", "Superoperator", ",", 
           "\[IndentingNewLine]", "\t", 
           RowBox[{
            RowBox[{
             RowBox[{"NPropagationSuperoperator", "[", 
              RowBox[{"#", ",", "opbasis", ",", "basis", ",", "opts"}], "]"}],
              "&"}], "/@", "evlists"}], ",", "\[IndentingNewLine]", 
           "Operator", ",", "\[IndentingNewLine]", "\t", 
           RowBox[{
            RowBox[{
             RowBox[{"NPropagationOperator", "[", 
              RowBox[{"#", ",", "basis", ",", "opts"}], "]"}], "&"}], "/@", 
            "evlists"}]}], "\[IndentingNewLine]", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Sjset", "=", 
         RowBox[{"Switch", "[", 
          RowBox[{"type", ",", "\[IndentingNewLine]", "Superoperator", ",", 
           RowBox[{
            RowBox[{"dim", "=", 
             RowBox[{
              RowBox[{"BasisDimension", "[", "basis", "]"}], "^", "2"}]}], ";", 
            RowBox[{
             RowBox[{
              RowBox[{"SuperoperatorMatrixRepresentation", "[", 
               RowBox[{"#", ",", "opbasis"}], "]"}], "&"}], "/@", 
             RowBox[{"Flatten", "@", 
              RowBox[{"MapThread", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"Table", "[", 
                  RowBox[{"#2", ",", 
                   RowBox[{"{", "#1", "}"}]}], "]"}], "&"}], ",", 
                RowBox[{"{", 
                 RowBox[{"nreps", ",", "props"}], "}"}]}], "]"}]}]}]}], ",", 
           "\[IndentingNewLine]", "Operator", ",", 
           RowBox[{
            RowBox[{"dim", "=", 
             RowBox[{"BasisDimension", "[", "basis", "]"}]}], ";", 
            RowBox[{
             RowBox[{
              RowBox[{"MatrixRepresentation", "[", 
               RowBox[{"#", ",", "basis"}], "]"}], "&"}], "/@", 
             RowBox[{"Flatten", "@", 
              RowBox[{"MapThread", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"Table", "[", 
                  RowBox[{"#2", ",", 
                   RowBox[{"{", "#1", "}"}]}], "]"}], "&"}], ",", 
                RowBox[{"{", 
                 RowBox[{"nreps", ",", "props"}], "}"}]}], "]"}]}]}]}]}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"FoldList", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"Dot", "[", 
            RowBox[{"#2", ",", "#1"}], "]"}], "&"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"SparseArray", "@", 
           RowBox[{"DiagonalMatrix", "[", 
            RowBox[{"Table", "[", 
             RowBox[{"1", ",", 
              RowBox[{"{", "dim", "}"}]}], "]"}], "]"}]}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"Reverse", "@", "Sjset"}]}], "]"}]}], "\[IndentingNewLine]",
        ")"}], "/;", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"evbackg", "=", 
         RowBox[{
          RowBox[{"BackgroundGenerator", "/.", 
           RowBox[{"{", "opts", "}"}]}], "/.", 
          RowBox[{"Options", "[", "DividedEventPropagators", "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"standevbackg", "=", 
         RowBox[{"StandardizeGenerator", "[", "evbackg", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"MatchQ", "[", 
         RowBox[{"standevbackg", ",", 
          RowBox[{
           RowBox[{"_", "?", "OperatorQ"}], "|", 
           RowBox[{"_", "?", "SuperoperatorQ"}], "|", 
           "NullGeneratorPattern"}]}], "]"}]}], "\[IndentingNewLine]", 
       ")"}]}]}], "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.62601534244963*^9, 3.626015363971154*^9}, {
   3.626015394718357*^9, 3.626015415769844*^9}, {3.626015490966639*^9, 
