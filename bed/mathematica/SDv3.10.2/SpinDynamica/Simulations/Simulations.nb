Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Options", "[", "Signal1D", "]"}], "=", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"OperatorBasis", "\[RuleDelayed]", 
      RowBox[{"ZeemanKetBraOperatorBasis", "[", "]"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"Basis", "\[RuleDelayed]", 
      RowBox[{"ZeemanBasis", "[", "]"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"InitialDensityOperator", "\[RuleDelayed]", 
      RowBox[{"opI", "[", "\"\<z\>\"", "]"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"Preparation", "\[RuleDelayed]", 
      RowBox[{"RotationSuperoperator", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\[Pi]", "/", "2"}], ",", "\"\<x\>\""}], "}"}], "]"}]}], ",",
      "\[IndentingNewLine]", 
     RowBox[{"Observable", "\[Rule]", "All"}], ",", "\[IndentingNewLine]", 
     RowBox[{"NormalizationFactor", "\[Rule]", "None"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"BackgroundGenerator", "\[Rule]", "None"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"LineBroadening", "\[Rule]", "Automatic"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"SignalCalculationMethod", "\[Rule]", "Automatic"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"UseHilbertSpaceWhenPossible", "\[Rule]", "True"}], ",", 
     "\[IndentingNewLine]", 
