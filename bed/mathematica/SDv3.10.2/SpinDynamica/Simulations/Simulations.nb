Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Signal1D", "[", 
    RowBox[{"True", ",", 
     RowBox[{"timing", ":", 
      RowBox[{"{", 
       RowBox[{"tmin_", ",", "tmax_", ",", "\[Delta]t_"}], "}"}]}], ",", 
     "acqevents_", ",", "opts___Rule"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "ensav", ",", "prep", ",", "backg", ",", "prepbackg", ",", "detbackg", ",",
        "\[Rho]ini", ",", "var", ",", "vals", ",", "weights", ",", 
       "\[Rho]afterprep", ",", "temp"}], "}"}], ",", 
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"temp", "=", 
          RowBox[{
          "PrintTemporary", "[", "\"\<implementing preparation..\>\"", 
           "]"}]}], ";"}], "*)"}], "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"\[Rho]afterprep", "=", 
         RowBox[{
          RowBox[{"NPropagate", "[", "\[IndentingNewLine]", 
           RowBox[{"prep", ",", "\[IndentingNewLine]", 
            RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"InitialTimePoint", "\[Rule]", "Automatic"}], ",", 
              "\[IndentingNewLine]", 
              RowBox[{"FinalTimePoint", "\[Rule]", "tmin"}], ",", 
              "\[IndentingNewLine]", 
              RowBox[{"BackgroundGenerator", "\[Rule]", "prepbackg"}], ",", 
              "\[IndentingNewLine]", 
              RowBox[{"Continuous", "\[Rule]", "False"}], ",", 
              "\[IndentingNewLine]", 
              RowBox[{"Sequence", "@@", 
               RowBox[{"FilterRules", "[", 
                RowBox[{
                 RowBox[{"{", "opts", "}"}], ",", 
                 RowBox[{"Options", "[", "NPropagate", "]"}]}], "]"}]}], ",", 
              "\[IndentingNewLine]", 
              RowBox[{"Sequence", "@@", 
               RowBox[{"CurrentOptionsToPassDown", "[", 
                RowBox[{"Signal1D", ",", "NPropagate"}], "]"}]}]}], 
             "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", "]"}], "[", 
          RowBox[{"Operator", "@", "\[Rho]ini"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Signal1D", "[", 
         RowBox[{
         "True", ",", "timing", ",", "acqevents", ",", "\[IndentingNewLine]", 
          
          RowBox[{"Evaluate", "@", 
           RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"InitialDensityOperator", "\[Rule]", "\[Rho]afterprep"}],
              ",", "\[IndentingNewLine]", 
             RowBox[{"Preparation", "\[Rule]", "None"}], ",", 
             "\[IndentingNewLine]", "opts"}], "\[IndentingNewLine]", 
            "]"}]}]}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
       ")"}], "/;", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{"(", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{"ensav", ",", "prep", ",", "backg", ",", "\[Rho]ini"}], 
           "}"}], "=", 
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{
             "EnsembleAverage", ",", "Preparation", ",", 
              "BackgroundGenerator", ",", "InitialDensityOperator"}], "}"}], "/.", 
            RowBox[{"{", "opts", "}"}]}], "/.", 
           RowBox[{"Options", "[", "Signal1D", "]"}]}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"detbackg", ",", "prepbackg"}], "}"}], "=", 
          RowBox[{"ReleaseHold", "[", "backg", "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"!", 
            RowBox[{"MatchQ", "[", 
             RowBox[{"prep", ",", 
              RowBox[{"None", "|", 
               RowBox[{"EventSpecifications", "@", 
                RowBox[{"UnitySuperoperator", "[", "]"}]}]}]}], "]"}]}], 
           ")"}], "&&", "\[IndentingNewLine]", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"MatchQ", "[", 
               RowBox[{"ensav", ",", 
                RowBox[{"{", 
                 RowBox[{"_", ",", "_"}], "}"}]}], "]"}], "&&", 
              "\[IndentingNewLine]", 
              RowBox[{"EnsembleVariablesFreeQ", "[", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"prep", ",", "\[Rho]ini"}], "}"}], ",", "ensav"}], 
               "]"}], "&&", "\[IndentingNewLine]", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"Chop", "[", 
                   RowBox[{"Duration", "[", "prep", "]"}], "]"}], "\[Equal]", 
                  "0"}], ")"}], "||", 
                RowBox[{"EnsembleVariablesFreeQ", "[", 
                 RowBox[{"prepbackg", ",", "ensav"}], "]"}]}], ")"}]}], ")"}],
             "||", 
            RowBox[{"MatchQ", "[", 
             RowBox[{"ensav", ",", 
              RowBox[{"False", "|", "None"}]}], "]"}]}], ")"}]}]}], 
        "\[IndentingNewLine]", ")"}], "\[IndentingNewLine]", ")"}]}]}], 
    "]"}]}], ";"}]], "Input",
 InitializationCell->True,
