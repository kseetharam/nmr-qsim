Cell[CellGroupData[{

Cell["SignalCalculationMethod", "Subsection",
 InitializationCell->True,
 CellChangeTimes->{
  3.629384618820071*^9},ExpressionUUID->"66935e0a-6249-4019-8b51-\
4d5cff5ff9a7"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SignalCalculationMethod", "::", "usage"}], 
   "=", "\"\<SignalCalculationMethod is an option for Signal1D. The default \
is SignalCalculationMethod\[Rule]Automatic, in which case the most \
appropriate method is chosen automatically. The currently available choices \
are:\n\nSignalCalculationMethod\[Rule]\\\"Direct\\\", which uses an explicit \
calculation of the spin evolution during the acquisition interval. Although \
the direct method is fully general, it is usually not the most efficient \
method for time-independent or periodic problems. \n\nSignalCalculationMethod\
\[Rule]\\\"Diagonalization\\\", which diagonalizes a time-independent \
Liouvillian or Hamiltonian. This is only appropriate for time-independent \
evolution generators.\n\nSignalCalculationMethod\[Rule]\\\"COMPUTE\\\" which \
assumes a periodic time-dependent Liouvillian or Hamiltonian.\>\""}], 
  ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 CellChangeTimes->{{3.470139140981426*^9, 3.4701393096101727`*^9}, {
   3.470654157533765*^9, 3.470654292400275*^9}, {3.470654345496424*^9, 
   3.4706543718474693`*^9}, 3.4993747484266386`*^9, {3.5002577197044287`*^9, 
   3.500257735119004*^9}, {3.5902204921821833`*^9, 3.590220503641452*^9}, {
   3.629384485032661*^9, 3.629384515870825*^9}},
 CellLabel->
  "In[1709]:=",ExpressionUUID->"b429a310-eeda-4eec-9597-4451d81a15c3"]
}, Closed]],

