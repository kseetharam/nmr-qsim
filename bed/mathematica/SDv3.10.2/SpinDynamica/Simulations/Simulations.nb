          "}"}]}], ",", "morest___"}], "}"}]}], ",", "timing_List", ",", 
     RowBox[{"events", ":", 
      RowBox[{"Except", "[", "_Rule", "]"}]}], ",", "opts___Rule"}], "]"}], ":=",
    "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
