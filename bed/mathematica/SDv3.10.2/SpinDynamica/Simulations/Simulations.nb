}, Closed]],

Cell[CellGroupData[{

Cell["Observable", "Subsection",
 InitializationCell->True,
 CellChangeTimes->{3.629384641320005*^9, 3.6293847218083897`*^9, 
  3.629384751905472*^9, 
  3.629384821495875*^9},ExpressionUUID->"039b1b50-d963-48b4-89e1-\
bc4ae58fa212"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Observable", "::", "usage"}], 
   "=", "\"\<Observable is an option for Signal1D. The option value may be an \
operator, or a list of spins in the current spin system. \nIf Observable is \
an operator, then this operator is used as the observable quantity operator \
during signal detection. If Observable\[Rule]{j,k..} is used, where the list \
{j,k..} defines spins in the current spin system, then the Observable is set \
to the operator for quadrature detection signal of that set of spins. The \
default value of Observable is -(I/2)opI[\\\"-\\\"], representing quadrature \
detection of all spins. \n\>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 CellChangeTimes->{{3.469877991470448*^9, 3.469878038523985*^9}, {
   3.469967701907137*^9, 3.469967737634742*^9}, {3.469967773430297*^9, 
   3.469967781101982*^9}, 3.544621851062533*^9, {3.544621945346339*^9, 
