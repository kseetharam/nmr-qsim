Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Signal1D", "[", 
    RowBox[{
     RowBox[{"status", ":", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"prefix", ":", 
         RowBox[{"StatusPatternPrefix", "[", 
          RowBox[{"Signal1D", ",", "\"\<AcquisitionEvents\>\""}], "]"}]}], ",", 
        RowBox[{"locst", ":", 
         RowBox[{"{", 
          RowBox[{"True", ",", "False", ",", "morelocst___"}], "}"}]}], ",", 
        "morest___"}], "}"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"tmin_", ",", "tmax_", ",", "\[Delta]t_"}], "}"}], ",", 
     RowBox[{"evgen_", "?", "ValidGeneratorQ"}], ",", "opts___Rule"}], "]"}], 
   ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "backg", "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"backg", "=", 
        RowBox[{"ReleaseHold", "[", 
         RowBox[{
          RowBox[{"BackgroundGenerator", "/.", 
           RowBox[{"{", "opts", "}"}]}], "/.", 
          RowBox[{"Options", "[", "Signal1D", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Signal1D", "[", "\[IndentingNewLine]", 
        RowBox[{"status", ",", "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"tmin", ",", "tmax", ",", "\[Delta]t"}], "}"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"Evaluate", "@", 
          RowBox[{"{", 
           RowBox[{"{", 
            RowBox[{"None", ",", 
             RowBox[{"tmax", "-", "tmin"}]}], "}"}], "}"}]}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"Evaluate", "@", 
          RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"BackgroundGenerator", "\[Rule]", "\[IndentingNewLine]", 
             RowBox[{"Switch", "[", "\[IndentingNewLine]", 
              RowBox[{"backg", ",", "\[IndentingNewLine]", 
               RowBox[{"Except", "[", "_List", "]"}], ",", 
               "\[IndentingNewLine]", "\t", 
               RowBox[{"CombineGenerators", "[", 
                RowBox[{"evgen", ",", "backg"}], "]"}], ",", 
               "\[IndentingNewLine]", "_List", ",", "\[IndentingNewLine]", 
               "\t", 
               RowBox[{
                RowBox[{
                 RowBox[{"CombineGenerators", "[", 
                  RowBox[{"evgen", ",", "#"}], "]"}], "&"}], "/@", "backg"}], 
               ",", "\[IndentingNewLine]", "_", ",", "\[IndentingNewLine]", 
               "\t", "$Failed"}], "\[IndentingNewLine]", "]"}]}], ",", 
            "\[IndentingNewLine]", "opts"}], "\[IndentingNewLine]", "]"}]}]}],
         "\[IndentingNewLine]", "]"}]}], ")"}]}], "\[IndentingNewLine]", 
    "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.499327730269598*^9, 3.499327782132303*^9}, {
