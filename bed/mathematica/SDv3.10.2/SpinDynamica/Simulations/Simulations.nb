837155802212"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ForceEvenNumberOfPoints", "::", "usage"}], 
   "=", "\"\<ForceEvenNumberOfPoints is an option for Signal1D. The default \
is ForceEvenNumberOfPoints\[Rule]True, in which case the last acquisition \
point is dropped if the requested number of acquired points is odd. An even \
number of sampling points is usually required by the fast Fourier \
transform.\>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
