Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"TransformationAmplitude", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Evaluate", "@", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"prefix", ":", 
         RowBox[{"StatusPatternPrefix", "[", 
          RowBox[{
          "TransformationAmplitude", ",", "\"\<InitialTimePoint\>\""}], 
          "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"True", ",", "False", ",", "morelocst___"}], "}"}], ",", 
        "morest___"}], "}"}]}], ",", "\[IndentingNewLine]", "\[Rho]ini_", ",",
      "ops_", ",", "events_", ",", "more___", ",", "opts___Rule"}], "]"}], ":=",
    "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "tinispec", ",", "tfinspec", ",", "tinispecnodefault", ",", 
       "tfinspecnodefault", ",", "tini", ",", "dur"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"tinispec", ",", "tfinspec"}], "}"}], "=", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{"InitialTimePoint", ",", "FinalTimePoint"}], "}"}], "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "TransformationAmplitude", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"tinispecnodefault", ",", "tfinspecnodefault"}], "}"}], "=", 
        
        RowBox[{
         RowBox[{"{", 
          RowBox[{"InitialTimePoint", ",", "FinalTimePoint"}], "}"}], "/.", 
         RowBox[{"{", "opts", "}"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"dur", "=", 
        RowBox[{"Duration", "[", "events", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"tini", "=", "\[IndentingNewLine]", 
        RowBox[{"Which", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"MatchQ", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"tinispec", ",", "tfinspec"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"_", "?", "NumericQ"}], ",", "Automatic"}], "}"}]}], 
           "]"}], ",", "\[IndentingNewLine]", "\t\t", "tinispec", ",", 
          "\[IndentingNewLine]", 
          RowBox[{"MatchQ", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"tinispec", ",", "tfinspec"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"Automatic", ",", 
              RowBox[{"_", "?", "NumericQ"}]}], "}"}]}], "]"}], ",", 
          "\[IndentingNewLine]", "\t\t", 
          RowBox[{"tfinspec", "-", "dur"}], ",", "\[IndentingNewLine]", 
          RowBox[{"MatchQ", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"tinispecnodefault", ",", "tfinspec"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"_", "?", "NumericQ"}], ",", 
              RowBox[{"Except", "[", 
               RowBox[{"_", "?", "NumericQ"}], "]"}]}], "}"}]}], "]"}], ",", 
          "\[IndentingNewLine]", "\t", "tinispecnodefault", ",", 
          "\[IndentingNewLine]", 
          RowBox[{"MatchQ", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"tinispec", ",", "tfinspecnodefault"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"Except", "[", 
               RowBox[{"_", "?", "NumericQ"}], "]"}], ",", 
              RowBox[{"_", "?", "NumericQ"}]}], "}"}]}], "]"}], ",", 
          "\[IndentingNewLine]", "\t", 
          RowBox[{"tfinspecnodefault", "-", "dur"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"MatchQ", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"tinispecnodefault", ",", "tfinspecnodefault"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"_", "?", "NumericQ"}], ",", 
              RowBox[{"_", "?", "NumericQ"}]}], "}"}]}], "]"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"(", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"Chop", "[", 
               RowBox[{
               "tfinspecnodefault", "-", "dur", "-", "tinispecnodefault"}], 
               "]"}], "\[Equal]", "0"}], ",", "\[IndentingNewLine]", 
             "tinispecnodefault", ",", "\[IndentingNewLine]", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"Message", "[", 
                RowBox[{"TransformationAmplitude", "::", "tlimsincompat"}], 
                "]"}], ";", "$Failed"}], ")"}]}], "\[IndentingNewLine]", 
            "]"}], ")"}], ",", "\[IndentingNewLine]", 
          RowBox[{"MatchQ", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"tinispecnodefault", ",", "tfinspecnodefault"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"_", "?", "NumericQ"}], ",", 
              RowBox[{"Except", "[", 
               RowBox[{"_", "?", "NumericQ"}], "]"}]}], "}"}]}], "]"}], ",", 
          "\[IndentingNewLine]", "tinispecnodefault", ",", 
          "\[IndentingNewLine]", 
          RowBox[{"MatchQ", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"tinispecnodefault", ",", "tfinspecnodefault"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"Except", "[", 
               RowBox[{"_", "?", "NumericQ"}], "]"}], ",", 
              RowBox[{"_", "?", "NumericQ"}]}], "}"}]}], "]"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"tfinspecnodefault", "-", "dur"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"MatchQ", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"tinispecnodefault", ",", "tfinspec"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"_", "?", "NumericQ"}], ",", 
              RowBox[{"_", "?", "NumericQ"}]}], "}"}]}], "]"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"Chop", "[", 
                RowBox[{"tfinspec", "-", "dur", "-", "tinispecnodefault"}], 
                "]"}], "\[NotEqual]", "0"}], ",", 
              RowBox[{"Message", "[", 
               RowBox[{"TransformationAmplitude", "::", "tiniprecedence"}], 
               "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
            "tinispecnodefault"}], ")"}], ",", "\[IndentingNewLine]", 
          RowBox[{"MatchQ", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"tinispec", ",", "tfinspecnodefault"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"_", "?", "NumericQ"}], ",", 
              RowBox[{"_", "?", "NumericQ"}]}], "}"}]}], "]"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"Chop", "[", 
                RowBox[{"tfinspecnodefault", "-", "dur", "-", "tinispec"}], 
                "]"}], "\[NotEqual]", "0"}], ",", 
              RowBox[{"Message", "[", 
               RowBox[{"TransformationAmplitude", "::", "tfinprecedence"}], 
               "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
            RowBox[{"tfinspecnodefault", "-", "dur"}]}], ")"}], ",", 
          "\[IndentingNewLine]", "True", ",", "\[IndentingNewLine]", "\t", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Message", "[", 
             RowBox[{"TransformationAmplitude", "::", "tlimsinval"}], "]"}], ";",
             "$Failed"}], ")"}]}], "\[IndentingNewLine]", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"MatchQ", "[", 
          RowBox[{"tini", ",", "$Failed"}], "]"}], ",", "$Failed", ",", 
         "\[IndentingNewLine]", 
         RowBox[{"TransformationAmplitude", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"Evaluate", "@", 
            RowBox[{"{", 
             RowBox[{"prefix", ",", 
              RowBox[{"{", 
               RowBox[{"True", ",", "True", ",", "morelocst"}], "}"}], ",", 
              "morest"}], "}"}]}], ",", "\[IndentingNewLine]", "\[Rho]ini", ",",
            "ops", ",", "events", ",", "more", ",", "\[IndentingNewLine]", 
           RowBox[{"Evaluate", "[", 
            RowBox[{"Sequence", "@@", 
             RowBox[{"FilterRules", "[", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"SimplifyRules", "[", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"InitialTimePoint", "\[Rule]", "tini"}], ",", 
                  "opts"}], "}"}], "]"}], ",", "\[IndentingNewLine]", 
               RowBox[{"Except", "[", "FinalTimePoint", "]"}]}], "]"}]}], 
            "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", "]"}]}], 
        "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", ")"}]}], 
    "]"}]}], ";"}]], "Input",
 InitializationCell->True,
