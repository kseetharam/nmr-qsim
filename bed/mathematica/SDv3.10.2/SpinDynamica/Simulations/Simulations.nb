Cell[CellGroupData[{

Cell["Signal1DCore", "Subsubsection",
 CellChangeTimes->{{3.7011037702229166`*^9, 
  3.701103781922637*^9}},ExpressionUUID->"94280f7d-fa4c-4342-9221-\
8cd90a7e071c"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Signal1DCore", "[", 
    RowBox[{"\"\<Direct\>\"", ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"tmin_", "?", "NumericQ"}], ",", 
       RowBox[{"tmax_", "?", "NumericQ"}], ",", 
       RowBox[{"\[Delta]t_", "?", "NumericQ"}]}], "}"}], ",", 
     RowBox[{"EventSpecifications", "[", 
      RowBox[{"boole_", ",", "events_", ",", "evopts___"}], "]"}], ",", 
     "opts___Rule"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Rho]ini", ",", "Qobs", ",", "tvals", ",", "prepbackg", ",", 
       "detbackg", ",", "traj", ",", "norm", ",", "opbasis", ",", "basis"}], 
      "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"\[Rho]ini", ",", "opbasis", ",", "basis", ",", "Qobs"}], 
         "}"}], "=", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{
           "InitialDensityOperator", ",", "OperatorBasis", ",", "Basis", ",", 
            "Observable"}], "}"}], "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "Signal1D", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"detbackg", ",", "prepbackg"}], "}"}], "=", 
        RowBox[{
         RowBox[{
          RowBox[{"Which", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"MatchQ", "[", 
             RowBox[{"#", ",", 
              RowBox[{"_", "?", "OperatorQ"}]}], "]"}], ",", "#", ",", 
            "\[IndentingNewLine]", 
            RowBox[{"MatchQ", "[", 
             RowBox[{"#", ",", 
              RowBox[{"_", "?", "SuperoperatorQ"}]}], "]"}], ",", "#", ",", 
            "\[IndentingNewLine]", "True", ",", "#"}], "\[IndentingNewLine]", 
           "]"}], "&"}], "@", "\[IndentingNewLine]", 
         RowBox[{"(", 
          RowBox[{"ReleaseHold", "[", 
           RowBox[{
            RowBox[{"BackgroundGenerator", "/.", 
             RowBox[{"{", "opts", "}"}]}], "/.", 
            RowBox[{"Options", "[", "Signal1D", "]"}]}], "]"}], ")"}]}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"tvals", "=", 
        RowBox[{"Range", "[", 
         RowBox[{"tmin", ",", "tmax", ",", "\[Delta]t"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"traj", "=", "\[IndentingNewLine]", 
        RowBox[{"Trajectory", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"\[Rho]ini", "\[Rule]", "Qobs"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"Chronology", "/.", 
               RowBox[{"{", "evopts", "}"}]}], ")"}], 
             "\[Equal]", "\"\<LeftToRight\>\""}], ",", "events", ",", 
            RowBox[{"Reverse", "[", "events", "]"}]}], "]"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"Evaluate", "@", 
           RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"BackgroundGenerator", "\[Rule]", "detbackg"}], ",", 
             "\[IndentingNewLine]", 
             RowBox[{"InitialTimePoint", "\[Rule]", "tmin"}], ",", 
             "\[IndentingNewLine]", "opts", ",", "\[IndentingNewLine]", 
             RowBox[{"NormalizationFactor", "\[Rule]", 
              RowBox[{"norm", "\[Times]", 
               RowBox[{
                RowBox[{"OperatorNorm", "[", "Qobs", "]"}], "^", "2"}]}]}], ",",
              "\[IndentingNewLine]", 
             RowBox[{"Sequence", "@@", 
              RowBox[{"CurrentOptionsToPassDown", "[", 
               RowBox[{"Signal1D", ",", "Trajectory"}], "]"}]}]}], 
            "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", "]"}]}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"Signal", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"tmin", ",", "tmax", ",", "\[Delta]t"}], "}"}], ",", 
         RowBox[{"traj", "/@", "tvals"}], ",", "\[IndentingNewLine]", 
         RowBox[{"SimplifyRules", "[", "\[IndentingNewLine]", 
          RowBox[{"Sequence", "@@", 
           RowBox[{"FilterRules", "[", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"Join", "[", 
              RowBox[{
               RowBox[{"{", "opts", "}"}], ",", 
               RowBox[{"Options", "@", "Signal1D"}]}], "]"}], ",", 
             "\[IndentingNewLine]", 
             RowBox[{"Options", "[", "Signal", "]"}]}], "\[IndentingNewLine]",
             "]"}]}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
        "]"}]}], "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
