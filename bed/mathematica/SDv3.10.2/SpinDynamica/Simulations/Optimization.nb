Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"MaximizeTransformationAmplitude", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"\[Rho]ini_", "\[Rule]", "obs_"}], ",", "\[IndentingNewLine]", 
     "events_", ",", "\[IndentingNewLine]", 
     RowBox[{"varspecs", ":", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"_", ",", "_", ",", 
          RowBox[{"{", 
           RowBox[{"_", ",", "_"}], "}"}]}], "}"}], ".."}], "}"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"opts", ":", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"_Rule", "|", "_RuleDelayed"}], ")"}], "..."}]}]}], 
    "\[IndentingNewLine]", "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "negta", ",", "minval", ",", "varrules", ",", "vars", ",", "varinivals",
        ",", "nvar", ",", "method", ",", "varbounds", ",", "varminvals", ",", 
       "varmaxvals", ",", "constraints"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"vars", ",", "varinivals", ",", "varbounds"}], "}"}], "=", 
        RowBox[{"Transpose", "[", "varspecs", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"varminvals", ",", "varmaxvals"}], "}"}], "=", 
        RowBox[{"Transpose", "[", "varbounds", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"constraints", "=", 
        RowBox[{"And", "@@", 
         RowBox[{"MapThread", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"#1", "\[LessEqual]", "#2", "\[LessEqual]", "#3"}], 
             ")"}], "&"}], ",", 
           RowBox[{"{", 
            RowBox[{"varminvals", ",", "vars", ",", "varmaxvals"}], "}"}]}], 
          "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Message", "[", 
        RowBox[{
         RowBox[{"MaximizeTransformationAmplitude", "::", "constr"}], ",", 
         "constraints"}], "]"}], ";", 
       RowBox[{"nvar", "=", 
        RowBox[{"Length", "[", "vars", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"negta", "[", 
         RowBox[{"vars", ":", 
          RowBox[{"Repeated", "[", 
           RowBox[{
            RowBox[{"_", "?", "NumericQ"}], ",", 
            RowBox[{"{", "nvar", "}"}]}], "]"}]}], "]"}], ":=", 
        "\[IndentingNewLine]", 
        RowBox[{"Module", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"varvals", ",", "reflvarvals"}], "}"}], ",", 
          RowBox[{"(", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"varvals", "=", 
             RowBox[{"{", "vars", "}"}]}], ";", "\[IndentingNewLine]", 
            RowBox[{"reflvarvals", "=", 
             RowBox[{"MapThread", "[", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{
                RowBox[{"Which", "[", "\[IndentingNewLine]", 
                 RowBox[{
                  RowBox[{"#1", ">", "#2"}], ",", 
                  RowBox[{"#1", "+", 
                   RowBox[{"Abs", "[", 
                    RowBox[{"#2", "-", "#1"}], "]"}]}], ",", 
                  "\[IndentingNewLine]", 
                  RowBox[{"#2", ">", "#3"}], ",", 
                  RowBox[{"#3", "-", 
                   RowBox[{"Abs", "[", 
                    RowBox[{"#2", "-", "#3"}], "]"}]}], ",", 
                  "\[IndentingNewLine]", "True", ",", "#2"}], "]"}], "&"}], 
               ",", "\[IndentingNewLine]", 
               RowBox[{"{", 
                RowBox[{"varminvals", ",", "varvals", ",", "varmaxvals"}], 
                "}"}]}], "\[IndentingNewLine]", "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"-", 
              RowBox[{"TransformationAmplitude", "[", 
               RowBox[{
                RowBox[{"\[Rho]ini", "\[Rule]", "obs"}], ",", 
                "\[IndentingNewLine]", "events", ",", "\[IndentingNewLine]", 
                RowBox[{"Evaluate", "[", 
                 RowBox[{"Sequence", "@@", 
                  RowBox[{"FilterRules", "[", 
                   RowBox[{
                    RowBox[{"{", "opts", "}"}], ",", 
                    RowBox[{
                    "Options", "[", "TransformationAmplitude", "]"}]}], 
                   "]"}]}], "]"}]}], "\[IndentingNewLine]", "]"}]}], "/.", 
             RowBox[{"MapThread", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"#1", "\[Rule]", "#2"}], ")"}], "&"}], ",", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"{", "vars", "}"}], ",", "reflvarvals"}], "}"}]}], 
              "]"}]}]}], "\[IndentingNewLine]", ")"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"method", "=", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Method", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "MaximizeTransformationAmplitude", "]"}]}]}],
        ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"MatchQ", "[", 
           RowBox[{"method", ",", "Automatic"}], "]"}]}], ",", 
         RowBox[{"Message", "[", 
          RowBox[{
           RowBox[{"MaximizeTransformationAmplitude", "::", "meth"}], ",", 
           "method"}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Check", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{"minval", ",", "varrules"}], "}"}], "=", 
            "\[IndentingNewLine]", 
            RowBox[{"FindMinimum", "[", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{"negta", "[", 
                 RowBox[{"Sequence", "@@", "vars"}], "]"}], ",", 
                "constraints"}], "}"}], ",", "\[IndentingNewLine]", 
              RowBox[{"Transpose", "[", 
               RowBox[{"{", 
                RowBox[{"vars", ",", "varinivals"}], "}"}], "]"}], ",", 
              "\[IndentingNewLine]", 
              RowBox[{"Evaluate", "[", 
               RowBox[{"Sequence", "@@", 
                RowBox[{"FilterRules", "[", "\[IndentingNewLine]", 
                 RowBox[{
                  RowBox[{"Join", "[", "\[IndentingNewLine]", 
                   RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"Method", "\[Rule]", "method"}], ",", "opts"}], 
                    "}"}], ",", "\[IndentingNewLine]", 
                    RowBox[{
                    "Options", "[", "MaximizeTransformationAmplitude", 
                    "]"}]}], "\[IndentingNewLine]", "]"}], ",", 
                  "\[IndentingNewLine]", 
                  RowBox[{"Options", "[", "FindMinimum", "]"}]}], 
                 "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
               "]"}]}], "\[IndentingNewLine]", "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "minval"}], ",", "varrules"}], "}"}]}], ")"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Message", "[", 
            RowBox[{"MaximizeTransformationAmplitude", "::", "fail"}], "]"}], 
           ";", "\[IndentingNewLine]", "$Failed"}], ")"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Event", "::", "negdur"}], ",", 
           RowBox[{"Delay", "::", "negdur"}], ",", 
           RowBox[{"Pulse", "::", "inval\[Beta]"}], ",", 
           RowBox[{"Pulse", "::", "inval\[Phi]"}], ",", 
           RowBox[{"Pulse", "::", "neg\[Tau]"}], ",", 
           RowBox[{"ShapedPulse", "::", "invaldur"}], ",", 
           RowBox[{"FindMinimum", "::", "nrnum"}]}], "}"}]}], 
        "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", ")"}]}], 
    "]"}]}], ";"}]], "Input",
 InitializationCell->True,
