Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"MaximizeTransformationAmplitude", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"\[Rho]ini_", "\[Rule]", "obs_"}], ",", "\[IndentingNewLine]", 
     "events_", ",", "\[IndentingNewLine]", 
     RowBox[{"varspecs", ":", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"_", ",", "_"}], "}"}], ".."}], "}"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"opts", ":", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"_Rule", "|", "_RuleDelayed"}], ")"}], "..."}]}]}], 
    "\[IndentingNewLine]", "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "negta", ",", "minval", ",", "varrules", ",", "vars", ",", "varinivals",
        ",", "nvar", ",", "method", ",", "constrpos"}], "}"}], ",", 
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{"vars", ",", "varinivals"}], "}"}], "=", 
         RowBox[{"Transpose", "[", "varspecs", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"nvar", "=", 
         RowBox[{"Length", "[", "vars", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"negta", "[", 
          RowBox[{"Repeated", "[", 
           RowBox[{
            RowBox[{"_", "?", "NumericQ"}], ",", 
            RowBox[{"{", "nvar", "}"}]}], "]"}], "]"}], ":=", 
         "\[IndentingNewLine]", 
         RowBox[{"-", 
          RowBox[{"TransformationAmplitude", "[", 
           RowBox[{
            RowBox[{"\[Rho]ini", "\[Rule]", "obs"}], ",", 
            "\[IndentingNewLine]", "events", ",", "\[IndentingNewLine]", 
            RowBox[{"Evaluate", "[", 
             RowBox[{"Sequence", "@@", 
              RowBox[{"FilterRules", "[", 
               RowBox[{
                RowBox[{"{", "opts", "}"}], ",", 
                RowBox[{"Options", "[", "TransformationAmplitude", "]"}]}], 
               "]"}]}], "]"}]}], "\[IndentingNewLine]", "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Message", "[", 
         RowBox[{"MaximizeTransformationAmplitude", "::", "unconstr"}], "]"}],
         ";", "\[IndentingNewLine]", 
        RowBox[{"method", "=", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"Method", "/.", 
            RowBox[{"{", "opts", "}"}]}], "/.", 
           RowBox[{"Options", "[", "MaximizeTransformationAmplitude", "]"}]}],
           "/.", 
          RowBox[{"{", 
           RowBox[{"Automatic", "\[Rule]", "\"\<InteriorPoint\>\""}], 
           "}"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"!", 
           RowBox[{"MatchQ", "[", 
            RowBox[{"method", ",", "Automatic"}], "]"}]}], ",", 
          RowBox[{"Message", "[", 
           RowBox[{
            RowBox[{"MaximizeTransformationAmplitude", "::", "meth"}], ",", 
            "method"}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"Check", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"{", 
              RowBox[{"minval", ",", "varrules"}], "}"}], "=", 
             "\[IndentingNewLine]", 
             RowBox[{"FindMinimum", "[", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"negta", "[", 
                RowBox[{"Sequence", "@@", "vars"}], "]"}], ",", 
               "\[IndentingNewLine]", "varspecs", ",", "\[IndentingNewLine]", 
               
               RowBox[{"Evaluate", "[", 
                RowBox[{"Sequence", "@@", 
                 RowBox[{"FilterRules", " ", "[", "\[IndentingNewLine]", 
                  RowBox[{
                   RowBox[{"Join", "[", "\[IndentingNewLine]", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"Method", "\[Rule]", "method"}], ",", "opts"}], 
                    "}"}], ",", "\[IndentingNewLine]", 
                    RowBox[{
                    "Options", "[", "MaximizeTransformationAmplitude", 
                    "]"}]}], "\[IndentingNewLine]", "]"}], ",", 
                   "\[IndentingNewLine]", 
                   RowBox[{"Options", "[", "FindMinimum", "]"}]}], 
                  "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
                "]"}]}], "\[IndentingNewLine]", "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "minval"}], ",", "varrules"}], "}"}]}], ")"}], ",",
           "\[IndentingNewLine]", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Message", "[", 
             RowBox[{"MaximizeTransformationAmplitude", "::", "fail"}], "]"}],
             ";", "\[IndentingNewLine]", "$Failed"}], ")"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Event", "::", "negdur"}], ",", 
            RowBox[{"Delay", "::", "negdur"}], ",", 
            RowBox[{"Pulse", "::", "inval\[Beta]"}], ",", 
            RowBox[{"Pulse", "::", "inval\[Phi]"}], ",", 
            RowBox[{"Pulse", "::", "neg\[Tau]"}], ",", 
            RowBox[{"ShapedPulse", "::", "invaldur"}], ",", 
            RowBox[{"FindMinimum", "::", "nrnum"}]}], "}"}]}], 
         "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", ")"}], "/;", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"constrpos", "=", 
         RowBox[{
          RowBox[{"ConstrainPositive", "/.", 
           RowBox[{"{", "opts", "}"}]}], "/.", 
          RowBox[{
          "Options", "[", "MaximizeTransformationAmplitude", "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"MatchQ", "[", 
         RowBox[{"constrpos", ",", "False"}], "]"}]}], "\[IndentingNewLine]", 
       ")"}]}]}], "]"}]}], ";"}]], "Input",
