Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"MaximizeTransformationAmplitude", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"\[Rho]ini_", "\[Rule]", "obs_"}], ",", "events_", ",", 
     RowBox[{"varspecs", ":", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Except", "[", "_List", "]"}], ",", 
          RowBox[{"Except", "[", "_List", "]"}]}], "}"}], ".."}], "}"}]}], 
     ",", 
     RowBox[{"more", ":", 
      RowBox[{
       RowBox[{"Except", "[", 
        RowBox[{"(", 
         RowBox[{"_Rule", "|", "_RuleDelayed"}], ")"}], "]"}], "..."}]}], ",",
      "\[IndentingNewLine]", "opts___Rule"}], "\[IndentingNewLine]", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"constrpos", ",", "constrposvars"}], "}"}], ",", 
     RowBox[{
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"constrposvars", "=", "constrpos"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"!", 
           RowBox[{"SubsetQ", "[", 
            RowBox[{
             RowBox[{"First", "/@", "varspecs"}], ",", "constrposvars"}], 
            "]"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Message", "[", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{
              "MaximizeTransformationAmplitude", "::", "badconstrvar"}], ",", 
              "constrposvars"}], "]"}], ";", "\[IndentingNewLine]", 
            "$Failed"}], "\[IndentingNewLine]", ")"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{
          "MaximizeTransformationAmplitude", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"\[Rho]ini", "\[Rule]", "obs"}], ",", "events", ",", 
            "\[IndentingNewLine]", 
            RowBox[{"varspecs", "/.", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"{", 
                   RowBox[{"#1", ",", "inival_"}], "}"}], ":>", 
                  RowBox[{"{", 
                   RowBox[{"#1", ",", "inival", ",", 
                    RowBox[{"{", "0", "}"}]}], "}"}]}], ")"}], "&"}], "/@", 
               "constrposvars"}], ")"}]}], ",", "\[IndentingNewLine]", "more",
             ",", "\[IndentingNewLine]", 
            RowBox[{"SimplifyRules", "[", 
             RowBox[{
              RowBox[{"ConstrainPositive", "\[Rule]", "Automatic"}], ",", 
              "opts"}], "]"}]}], "\[IndentingNewLine]", "]"}]}], 
         "\[IndentingNewLine]", "]"}]}], ")"}], "/;", 
      RowBox[{"(", "\[IndentingNewLine]", 
