Cell[CellGroupData[{

Cell["Cartesian matrix form", "Subsection",
 InitializationCell->True,
 CellChangeTimes->{{3.8201696543537903`*^9, 3.820169670248342*^9}, {
  3.820330874390428*^9, 3.820330875977873*^9}, {3.820333974690846*^9, 
