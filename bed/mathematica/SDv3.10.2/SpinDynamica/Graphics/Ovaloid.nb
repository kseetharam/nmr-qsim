a805b5cbb4b1"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Ovaloid", "[", 
    RowBox[{"r_", ",", 
     RowBox[{"mat_", "?", "MatrixQ"}], ",", "opts___Rule"}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"oic", ",", "iso"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"oic", "=", 
        RowBox[{
         RowBox[{"OvaloidIsotropicComponent", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "Ovaloid", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"iso", "=", 
        RowBox[{"Switch", "[", 
         RowBox[{"oic", ",", 
          RowBox[{"Automatic", "|", "True"}], ",", 
          RowBox[{
           RowBox[{"Plus", "@@", 
            RowBox[{"Diagonal", "[", "mat", "]"}]}], "/", "3"}], ",", 
          RowBox[{"_", "?", "NumericQ"}], ",", "oic", ",", "_", ",", "0"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Ovaloid", "[", 
        RowBox[{"r", ",", 
         RowBox[{"CartesianToSpherical", "[", 
          RowBox[{"2", ",", "mat"}], "]"}], ",", "\[IndentingNewLine]", 
         RowBox[{"Sequence", "@@", 
          RowBox[{"SimplifyRules", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"OvaloidIsotropicComponent", "\[Rule]", "iso"}], ",", 
             "opts"}], "}"}], "]"}]}]}], "]"}]}], "\[IndentingNewLine]", 
      ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.820331265688251*^9, 3.8203313749299173`*^9}, {
  3.8203314215369787`*^9, 3.8203314853739853`*^9}, {3.820331521827495*^9, 
