Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Ovaloid", "::", "usage"}], "=", 
   "\"\<\!\(\*StyleBox[\"Ovaloid\",FontSlant->\"Italic\"]\)\!\(\*StyleBox[\"[\
\",FontSlant->\"Italic\"]\)\!\(\*StyleBox[\"r\",FontSlant->\"Italic\"]\)\!\(\*\
StyleBox[\",\",FontSlant->\"Italic\"]\)\!\(\*StyleBox[\"tensor\",FontSlant->\"\
Italic\"]\)\!\(\*StyleBox[\",\",FontSlant->\"Italic\"]\)\!\(\*StyleBox[\"opts\
\",FontSlant->\"Italic\"]\)\!\(\*StyleBox[\"]\",FontSlant->\"Italic\"]\) \
generates a \!\(\*StyleBox[\"Graphics3D\",FontSlant->\"Italic\"]\) object \
representing a rank-2 spherical tensor, centred  at position \
\!\(\*StyleBox[\"r\",FontSlant->\"Italic\"]\). The \
\!\(\*StyleBox[\"tensor\",FontSlant->\"Italic\"]\) may be a \
\!\(\*StyleBox[\"SphericalTensor\",FontSlant->\"Italic\"]\) object of rank 2, \
or a 3\[Times]3 real matrix. In the case of a 3\[Times]3 real matrix, the \
traceless symmetric part of the matrix is extracted in order to define the \
rank-2 spherical tensor. If the vector \
\!\(\*StyleBox[\"r\",FontSlant->\"Italic\"]\) is omitted, the value \
\!\(\*StyleBox[\"r\",FontSlant->\"Italic\"]\)\!\(\*StyleBox[\" \",FontSlant->\
\"Italic\"]\)\!\(\*StyleBox[\"=\",FontSlant->\"Italic\"]\)\!\(\*StyleBox[\" \
\",FontSlant->\"Italic\"]\)\!\(\*StyleBox[\"{\",FontSlant->\"Italic\"]\)\!\(\*\
StyleBox[\"0\",FontSlant->\"Italic\"]\)\!\(\*StyleBox[\",\",FontSlant->\"\
Italic\"]\)\!\(\*StyleBox[\"0\",FontSlant->\"Italic\"]\)\!\(\*StyleBox[\",\",\
FontSlant->\"Italic\"]\)\!\(\*StyleBox[\"0\",FontSlant->\"Italic\"]\)\!\(\*\
StyleBox[\"}\",FontSlant->\"Italic\"]\) is assumed. The options may include \
rules for \
\!\(\*StyleBox[\"OvaloidScale\",FontSlant->\"Italic\"]\)\!\(\*StyleBox[\",\",\
FontSlant->\"Italic\"]\) \!\(\*StyleBox[\"OvaloidColors\",FontSlant->\"Italic\
\"]\)\!\(\*StyleBox[\",\",FontSlant->\"Italic\"]\)\!\(\*StyleBox[\" \
\",FontSlant->\"Italic\"]\)and\!\(\*StyleBox[\" \",FontSlant->\"Italic\"]\)\!\
\(\*StyleBox[\"OvaloidIsotropicComponent\",FontSlant->\"Italic\"]\)\!\(\*\
StyleBox[\".\",FontSlant->\"Italic\"]\) The option \
\!\(\*StyleBox[\"OvaloidIsotropicComponent\",FontSlant->\"Italic\"]\)\!\(\*\
StyleBox[\"\[Rule]\",FontSlant->\"Italic\"]\)\!\(\*StyleBox[\"iso\",FontSlant-\
>\"Italic\"]\), incorporates an isotropic component in the graphical \
depiction of the tensor. See the usage messages for these options. The \
ovaloid graphical representation is described by Len Mueller in \
https://doi.org/10.1002/mrc.4793 and used in his program TensorView, \
https://sites.google.com/ucr.edu/Mueller/home/tensorview\n\>\""}], 
  ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.820169073250615*^9, 3.8201692874384537`*^9}, {
   3.8201693611663446`*^9, 3.820169422163175*^9}, {3.820170931112063*^9, 
   3.820170978562566*^9}, {3.820329809783102*^9, 3.820330035619597*^9}, {
   3.8203300744940968`*^9, 3.820330208411778*^9}, {3.820330242235446*^9, 
   3.8203302445739937`*^9}, {3.82033027688137*^9, 3.8203303025653687`*^9}, 
   3.820330532827957*^9, {3.82033283718963*^9, 3.820332842640563*^9}},
 CellLabel->"In[61]:=",ExpressionUUID->"c234159c-ec28-48a2-b355-805cb81a99f4"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"OvaloidScale", "::", "usage"}], "=", 
   "\"\<\!\(\*StyleBox[\"OvaloidScale\",FontSlant->\"Italic\"]\) defines the \
ratio between the graphical coordinates and the tensor values in the \
\!\(\*StyleBox[\"Ovaloid\",FontSlant->\"Italic\"]\) representation of a \
second-rank spherical tensor.  For example, if the coordinates of a molecule \
are specified in units of \[CapitalARing], and the tensor is specified in \
units of ppm, then \!\(\*StyleBox[\"OvaloidScale\",FontSlant->\"Italic\"]\)\!\
\(\*StyleBox[\"->\",FontSlant->\"Italic\"]\)\!\(\*StyleBox[\"0.1\",FontSlant->\
\"Italic\"]\)\!\(\*StyleBox[\" \",FontSlant->\"Italic\"]\)would generate an \
ovaloid with a tensor value of 10ppm stretching a distance of \
1\[CapitalARing] from the centre of the ovaloid. \n\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.820169306625429*^9, 3.820169353516323*^9}, 
   3.820169438776121*^9, {3.820330315498486*^9, 3.820330509064279*^9}},
 CellLabel->"In[62]:=",ExpressionUUID->"852b0c15-7209-45ff-97e2-280186f32e75"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"OvaloidColors", "::", "usage"}], "=", 
   "\"\<\!\(\*StyleBox[\"OvaloidColors\",FontSlant->\"Italic\"]\) defines the \
colouring of the \!\(\*StyleBox[\"OvaloidGraphics\",FontSlant->\"Italic\"]\) \
representation of a 3\[Times]3 Cartesian matrix. \
\!\(\*StyleBox[\"OvaloidColors\",FontSlant->\"Italic\"]\)\!\(\*StyleBox[\"\
\[Rule]\",FontSlant->\"Italic\"]\)\!\(\*StyleBox[\"{\",FontSlant->\"Italic\"]\
\)\!\(\*StyleBox[\"poscolor\",FontSlant->\"Italic\"]\)\!\(\*StyleBox[\",\",\
FontSlant->\"Italic\"]\)\!\(\*StyleBox[\"negcolor\",FontSlant->\"Italic\"]\)\!\
\(\*StyleBox[\"}\",FontSlant->\"Italic\"]\) uses \
\!\(\*StyleBox[\"poscolor\",FontSlant->\"Italic\"]\) for the colour of the \
positive lobes and \!\(\*StyleBox[\"negcolor\",FontSlant->\"Italic\"]\) for \
the colour of the negative lobes. \
\!\(\*StyleBox[\"OvaloidColors\",FontSlant->\"Italic\"]\)\!\(\*StyleBox[\"\
\[Rule]\",FontSlant->\"Italic\"]\)\!\(\*StyleBox[\"color\",FontSlant->\"\
Italic\"]\)\!\(\*StyleBox[\" \",FontSlant->\"Italic\"]\)\!\(\*StyleBox[\"uses\
\",FontSlant->\"Italic\"]\)\!\(\*StyleBox[\" \
\",FontSlant->\"Italic\"]\)\!\(\*StyleBox[\"color\",FontSlant->\"Italic\"]\) \
for both lobes.\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.820169306625429*^9, 3.820169353516323*^9}, {
  3.820169438776121*^9, 3.820169554325672*^9}},
 CellLabel->"In[63]:=",ExpressionUUID->"f90b15b2-3a56-4245-9e43-620462daeb2e"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"OvaloidIsotropicComponent", "::", "usage"}], "=", 
   "\"\<\!\(\*StyleBox[\"OvaloidIsotropicComponent\",FontSlant->\"Italic\"]\) \
is an option for \
\!\(\*StyleBox[\"Ovaloid\",FontSlant->\"Italic\"]\)\!\(\*StyleBox[\".\",\
FontSlant->\"Italic\"]\) The default is \
\!\(\*StyleBox[\"OvaloidIsotropicComponent\",FontSlant->\"Italic\"]\)\!\(\*\
StyleBox[\"\[Rule]\",FontSlant->\"Italic\"]\)\!\(\*StyleBox[\"False\",\
FontSlant->\"Italic\"]\), in which case no isotropic component is included in \
the graphical representation. If \
\!\(\*StyleBox[\"OvaloidIsotropicComponent\",FontSlant->\"Italic\"]\) equals \
a number, that number is added to the second-rank tensor when calculating the \
graphical representation. If \
\!\(\*StyleBox[\"OvaloidIsotropicComponent\",FontSlant->\"Italic\"]\)\!\(\*\
StyleBox[\"\[Rule]\",FontSlant->\"Italic\"]\)\!\(\*StyleBox[\"Automatic\",\
FontSlant->\"Italic\"]\)\!\(\*StyleBox[\",\",FontSlant->\"Italic\"]\)\!\(\*\
StyleBox[\" \",FontSlant->\"Italic\"]\)and the second-rank tensor is \
specified by a 3\[Times]3 Cartesian matrix, the isotropic component of the \
matrix is used.\>\""}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.820169306625429*^9, 3.820169353516323*^9}, {
  3.820169438776121*^9, 3.820169647737997*^9}, {3.8203305366783247`*^9, 
  3.8203307010462646`*^9}},
 CellLabel->"In[64]:=",ExpressionUUID->"ace29f5f-7e40-4d9e-a50d-bbc9d3162792"]
}, Closed]],

