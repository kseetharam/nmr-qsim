Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Ovaloid", "[", 
    RowBox[{"r_", ",", "\[Sigma]2_SphericalTensor", ",", "opts___Rule"}], 
    "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Sigma]iso", ",", "radius", ",", "scale", ",", "poscolor", ",", 
       "negcolor", ",", "colorfunc", ",", "iso"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"scale", "=", 
        RowBox[{
         RowBox[{"OvaloidScale", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "Ovaloid", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"poscolor", ",", "negcolor"}], "}"}], "=", 
        RowBox[{
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"MatchQ", "[", "#", "]"}], ",", 
            RowBox[{"Except", "[", "_List", "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"#", ",", "#"}], "}"}], ",", "#"}], "]"}], "&"}], "@", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"OvaloidColors", "/.", 
            RowBox[{"{", "opts", "}"}]}], "/.", 
           RowBox[{"Options", "[", "Ovaloid", "]"}]}], ")"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"\[Sigma]iso", "=", 
        RowBox[{
         RowBox[{"OvaloidIsotropicComponent", "/.", 
          RowBox[{"{", "opts", "}"}]}], "/.", 
         RowBox[{"Options", "[", "Ovaloid", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"radius", "[", 
         RowBox[{"\[Theta]_", ",", "\[Phi]_"}], "]"}], "=", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"scale", "*", 
           RowBox[{"(", "\[IndentingNewLine]", 
            RowBox[{"\[Sigma]iso", "+", "\[IndentingNewLine]", 
             RowBox[{"Sum", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"\[Sigma]2", "[", "m1", "]"}], 
                RowBox[{
                 RowBox[{"WignerD", "[", 
                  RowBox[{"2", ",", 
                   RowBox[{"{", 
                    RowBox[{"m1", ",", "m2"}], "}"}]}], "]"}], "[", 
                 RowBox[{"{", 
                  RowBox[{"\[Phi]", ",", "\[Theta]", ",", "0"}], "}"}], "]"}],
                 " ", 
                RowBox[{"CG", "[", 
                 RowBox[{
                  RowBox[{"{", 
                   RowBox[{"2", ",", "m2"}], "}"}], ",", 
                  RowBox[{"{", 
                   RowBox[{"1", ",", "0"}], "}"}], ",", 
                  RowBox[{"{", 
                   RowBox[{"1", ",", "0"}], "}"}]}], "]"}]}], ",", 
               RowBox[{"{", 
                RowBox[{"m1", ",", 
                 RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
               RowBox[{"{", 
                RowBox[{"m2", ",", 
                 RowBox[{"-", "2"}], ",", "2"}], "}"}]}], "]"}]}], ")"}]}], "//",
           "ExpToTrig"}], "//", "Simplify"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"colorfunc", "=", 
        RowBox[{"Function", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"\[Theta]", ",", "\[Phi]"}], "}"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"Evaluate", "@", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"Chop", "[", 
               RowBox[{"radius", "[", 
                RowBox[{"\[Theta]", ",", "\[Phi]"}], "]"}], "]"}], ">", "0"}],
              ",", "poscolor", ",", "negcolor"}], "]"}]}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Graphics3D", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Translate", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"First", "@", 
            RowBox[{"SphericalPlot3D", "[", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"Evaluate", "[", 
               RowBox[{"radius", "[", 
                RowBox[{"\[Theta]", ",", "\[Phi]"}], "]"}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"\[Theta]", ",", "0", ",", "\[Pi]"}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"\[Phi]", ",", "0", ",", 
                RowBox[{"2", "\[Pi]"}]}], "}"}], ",", "\[IndentingNewLine]", 
              RowBox[{"Evaluate", "[", 
               RowBox[{"Sequence", "@@", 
                RowBox[{"FilterRules", "[", "\[IndentingNewLine]", 
                 RowBox[{
                  RowBox[{"Join", "[", 
                   RowBox[{
                    RowBox[{"{", "opts", "}"}], ",", "\[IndentingNewLine]", 
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"ColorFunction", "\[Rule]", 
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"colorfunc", "[", 
                    RowBox[{"#4", ",", "#5"}], "]"}], "&"}], ")"}]}], ",", 
                    "\[IndentingNewLine]", 
                    RowBox[{"ColorFunctionScaling", "\[Rule]", "False"}]}], 
                    "}"}], ",", "\[IndentingNewLine]", 
                    RowBox[{"Options", "[", "Ovaloid", "]"}]}], 
                   "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
                  RowBox[{"Options", "[", "SphericalPlot3D", "]"}]}], 
                 "\[IndentingNewLine]", "]"}]}], "]"}]}], 
             "\[IndentingNewLine]", "]"}]}], ",", "\[IndentingNewLine]", 
           "r"}], "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
         RowBox[{"Evaluate", "[", 
          RowBox[{"Sequence", "@@", 
           RowBox[{"FilterRules", "[", 
            RowBox[{
             RowBox[{"Join", "[", 
              RowBox[{
               RowBox[{"{", "opts", "}"}], ",", 
               RowBox[{"Options", "[", "Ovaloid", "]"}]}], "]"}], ",", 
             RowBox[{"Options", "[", "Graphics3D", "]"}]}], "]"}]}], "]"}]}], 
        "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", ")"}]}], 
    "]"}]}], ";"}]], "Input",
