Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"AnnotateArrow", "[", 
     RowBox[{"begin_List", ",", "end_List", ",", "opts___Rule"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "ann", ",", "annpos", ",", "annfont", ",", "annrad", ",", "clockwise", 
        ",", "vpc", ",", "x", ",", "y", ",", "z", ",", "l", ",", "pos"}], 
       "}"}], ",", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "vpc", ",", "ann", ",", "annpos", ",", "annfont", ",", "annrad", 
           ",", "clockwise"}], "}"}], "=", 
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{
            "ViewPoint", ",", "Annotation", ",", "AnnotationPosition", ",", 
             "AnnotationFont", ",", "AnnotationRadius", ",", "Clockwise"}], 
            "}"}], "/.", 
           RowBox[{"{", "opts", "}"}]}], "/.", 
          RowBox[{"Options", "[", "Graphics3D", "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"l", "=", 
           RowBox[{"Norm", "[", 
            RowBox[{"end", "-", "begin"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"x", ",", "y", ",", "z"}], "}"}], "=", 
           RowBox[{"AxisSystem", "[", 
            RowBox[{"vpc", ",", 
             RowBox[{"end", "-", "begin"}]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"pos", "=", 
           RowBox[{"begin", "+", 
            RowBox[{"annpos", "*", "l", "*", "z"}], "+", 
            RowBox[{"l", "*", "annrad", "*", 
             RowBox[{"If", "[", 
              RowBox[{"clockwise", ",", 
               RowBox[{"-", "y"}], ",", "y"}], "]"}]}]}]}], ";", 
          "\[IndentingNewLine]", 
