 InitializationGroup->True,
 AspectRatioFixed->
  True,ExpressionUUID->"f7c1aa51-a95c-4263-aab6-6b79b47ae8fc"],

Cell["\<\
Options[LShape]=
\t{\tLShapeDimensions->{0.5, 0.8, 0.2, 0.2, 0.2},
\t\tLShapeLineStyle->Thin
  };\
\>", "Input",
 PageWidth->WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 AspectRatioFixed->
  True,ExpressionUUID->"3b0e82e8-bdc3-48ec-a272-49ecad9f4b9f"],

Cell["\<\
LShape[opts___]:=
\tModule[
\t{\tlinestyle,\t
\t\ta,b,c,d,e,\t
\t\tv1,v2,v3,v4,v5,v6,v7,v8,v9,v10,v11,v12,
\t\tv13, v14, v15, v16,
\t\tavec, bvec, cvec, dvec, evec,
\t\tface1a, face1b, face1c,
\t\tface2, face3, face4, face5, face6, 
\t\tface7a, face7b, face7c,
\t\tface8,
\t\tedge1, edge7
\t},(
\t\t{a,b,c,d,e} = LShapeDimensions/.{opts}/.Options[LShape];
\t\tlinestyle = LShapeLineStyle/.{opts}/.Options[LShape];
\t\tavec = {a,0,0};
\t\tbvec = {0,0,b};
\t\tcvec = {c,0,0};
\t\tdvec = {0,d,0};
\t\tevec = {0,0,e};
\t\tv1 = dvec + avec;
\t\tv2 = dvec;
\t\tv3 = v2 + bvec;
\t\tv4 = v3 + cvec;
\t\tv5 = v4 - bvec + evec;
\t\tv6 = v1 + evec;
\t\tv7 = v1 - dvec;
\t\tv8 = v2 - dvec;
\t\tv9 = v3 - dvec;
\t\tv10 = v4 - dvec;
\t\tv11 = v5 - dvec;
\t\tv12 = v6 - dvec;
\t\tv13 = v2 + cvec;
\t\tv14 = v2 + evec;
\t\tv15 = v8 + cvec;
\t\tv16 = v8 + evec;
\t\tface1a = { v1, v13, v5, v6 };
\t\tface1b = { v13, v2, v14, v5 };
\t\tface1c = { v14, v3, v4, v5 };
\t\tface2 = { v1, v2, v8, v7 };
\t\tface3 = { v2, v3, v9, v8 };
\t\tface4 = { v4, v3, v9, v10 };
\t\tface5 = { v11, v5, v4, v10 };
\t\tface6 = { v6, v5, v11, v12};
\t\tface7a = { v7, v15, v11, v12};
\t\tface7b = { v15, v8, v16, v11 };
\t\tface7c = {v16, v9, v10, v11 };
\t\tface8 = { v1, v6, v12, v7 };
\t\tedge1 = { v1, v2, v3, v4, v5, v6, v1 };
\t\tedge7 = { v7, v8, v9, v10, v11, v12, v7 };
\t\tGraphics3D[
\t\tFlatten[{
\t\t\tMap[{EdgeForm[],FaceForm[White],Polygon[#]}&,
\t\t\t\t{ face1a, face1b, face1c,
\t\t\t\t\tface7a, face7b, face7c
\t\t\t\t}
\t\t\t],
\t\t\tMap[Polygon,
\t\t\t\t{\t
\t\t\t\t\tface2, face3, face4, 
\t\t\t\t\tface5, face6,  face8
\t\t\t\t}
\t\t\t],
\t\t\tlinestyle,
\t\t\tMap[Line,
\t\t\t\t{ edge1, edge7 }
\t\t\t]
\t\t}]]
\t)];\t\t
\t\t\
\>", "Input",
 PageWidth->WindowWidth,
 CellGroupingRules->"NormalGrouping",
