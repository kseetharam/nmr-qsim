Cell[CellGroupData[{

Cell["Axes3D", "Subsection",
 PageWidth->WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 AspectRatioFixed->
  True,ExpressionUUID->"6d9ff35d-c2be-4df0-81a7-d754d84917e2"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Axes3D", "::", "\"\<usage\>\""}], "=", 
   "\"\<Axes3D[{x,y,z}, pt, opts] draws a set of arrowed axes centred at pt, \
along the vectors specified by {x,y,z}.If pt is absent, the origin is \
assumed.\nAn incomplete axes specification may be given, i.e. Axes3D[{x,z}, \
pt, opts] or Axes3D[{z}, pt, opts],as in AxisSystem.\nThe axis orientations \
may also be specified using Euler angles, as in Axes3D[{\[Alpha],\[Beta],\
\[Gamma]},pt,opts] (orientation relative to the default coordinate system), \
or Axes3D[{\[Alpha],\[Beta],\[Gamma]},{x,y,z},pt,ops] (orientation relative \
to the coordinate system {x,y,z})\>\""}], ";"}]], "Input",
 PageWidth->WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.40937182509269*^9, 3.4093718512875757`*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"960d166a-2980-4ce6-9a16-9d77fab75a01"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Axes3DLength", "::", "\"\<usage\>\""}], "=", 
   "\"\<length of arrows to use for the axes.\\n \>\""}], ";"}]], "Input",
 PageWidth->WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 AspectRatioFixed->
  True,ExpressionUUID->"79b9a147-3d57-4f40-8378-b0cb75945120"]
}, Closed]],

Cell[CellGroupData[{

Cell["Arrow3D", "Subsection",
 PageWidth->WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 AspectRatioFixed->
  True,ExpressionUUID->"9171d38b-d1a9-4cd1-9947-b63972027d10"],

Cell["\<\
Arrow3D::usage=
\t\"Arrow3D[begin, end, opts] generates graphics primitives for an arrow in \
3D space. Arrow3D[end, opts] draws from the origin. Arrow3D now uses the \
inbuilt functionality of Arrow in Mathematica 7 to specify the arrow head. \
The option Tube \[Rule] True can be used to specify that the arrow and heads \
are drawn as tubes. If a numeric value is used for the Tube option, that \
value is used as the tube radius.\";\
\>", "Input",
 PageWidth->WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.4093596797370358`*^9, 3.4093597651388893`*^9}, {
  3.409359883539916*^9, 3.409359888875039*^9}, {3.409362058321216*^9, 
  3.409362058662327*^9}, {3.409382969123086*^9, 3.409382975180401*^9}, {
  3.4541425871872597`*^9, 3.4541427195927143`*^9}, {3.454142795631155*^9, 
  3.454142833529429*^9}, {3.45414481570472*^9, 3.454144849930483*^9}, {
  3.6414752092176*^9, 3.6414752335110483`*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"5dc29553-0213-420b-baf9-004ff5b15ce8"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"HeadSize", "::", "\"\<usage\>\""}], "=", 
   "\"\<Size of Arrow Head\>\""}], ";"}]], "Input",
 PageWidth->WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 AspectRatioFixed->
  True,ExpressionUUID->"de4b1201-7034-4360-8ec0-e604e994dfa3"]
}, Closed]],

