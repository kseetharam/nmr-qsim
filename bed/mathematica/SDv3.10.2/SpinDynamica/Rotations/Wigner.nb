Cell[CellGroupData[{

Cell["set to zero outside permissible ranges", "Subsubsection",
 InitializationCell->True,
 CellChangeTimes->{{3.52957511982174*^9, 3.5295751357480793`*^9}, {
  3.816350702861741*^9, 
  3.816350708552409*^9}},ExpressionUUID->"2b8cd875-46bc-48a0-aeed-\
d3091988ba9b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"UserLevelDependentDefinition", "[", 
   RowBox[{"WignerD", ",", "Infinity", ",", 
    RowBox[{"(", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Unprotect", "[", "WignerD", "]"}], ";", "\[IndentingNewLine]", 
      
      RowBox[{
       RowBox[{"HoldPattern", "@", 
        RowBox[{
         RowBox[{"WignerD", "[", 
          RowBox[{"\[Lambda]_", ",", 
           RowBox[{"{", 
            RowBox[{"\[Mu]2_", ",", "\[Mu]1_"}], "}"}]}], "]"}], "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"\[Alpha]", ":", 
            RowBox[{"Except", "[", "_List", "]"}]}], ",", 
           RowBox[{"\[Beta]", ":", 
            RowBox[{"Except", "[", "_List", "]"}]}], ",", 
           RowBox[{"\[Gamma]", ":", 
            RowBox[{"Except", "[", "_List", "]"}]}]}], "}"}], "]"}]}], ":=", 
       RowBox[{"0", "/;", 
        RowBox[{
         RowBox[{"IntegerQ", "[", 
          RowBox[{"2", "\[Lambda]"}], "]"}], "&&", 
         RowBox[{"IntegerQ", "[", 
          RowBox[{"2", "\[Mu]2"}], "]"}], "&&", 
         RowBox[{"IntegerQ", "[", 
          RowBox[{"2", "\[Mu]1"}], "]"}], "&&", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"Abs", "[", 
              RowBox[{"2", "\[Mu]2"}], "]"}], ">", 
             RowBox[{"2", "\[Lambda]"}]}], ")"}], "||", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"Abs", "[", 
              RowBox[{"2", "\[Mu]1"}], "]"}], ">", 
             RowBox[{"2", "\[Lambda]"}]}], ")"}]}], ")"}]}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Protect", "[", "WignerD", "]"}]}], "\[IndentingNewLine]", 
     ")"}]}], "]"}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.5295749294280987`*^9, 3.529575086548819*^9}, {
   3.529690737920681*^9, 3.529690743354352*^9}, 3.5622163293922863`*^9, {
   3.7489428293628073`*^9, 3.7489428378095827`*^9}, {3.748943155888976*^9, 
   3.74894316065659*^9}, 3.7491056952632008`*^9, 3.749105730375719*^9, {
   3.7491067794603786`*^9, 3.7491067976120977`*^9}, 3.749106900601964*^9, {
   3.8163506638584137`*^9, 
   3.816350671199113*^9}},ExpressionUUID->"c1b3a087-3e6a-493c-ad0c-\
f68df53feacd"]
}, Closed]],

Cell[CellGroupData[{

Cell["pass down to built-in routine, if valid.", "Subsubsection",
 InitializationCell->True,
 CellChangeTimes->{{3.52957511982174*^9, 3.5295751357480793`*^9}, 
   3.81635069227805*^9},ExpressionUUID->"9b38c517-2eb2-4ca8-bbc2-\
e84f138c1652"],

Cell[BoxData[
 RowBox[{
  RowBox[{"UserLevelDependentDefinition", "[", 
   RowBox[{"WignerD", ",", "Infinity", ",", 
    RowBox[{"(", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Unprotect", "[", "WignerD", "]"}], ";", "\[IndentingNewLine]", 
      
      RowBox[{
       RowBox[{
        RowBox[{"HoldPattern", "@", 
         RowBox[{
          RowBox[{"WignerD", "[", 
           RowBox[{"\[Lambda]_", ",", 
            RowBox[{"{", 
             RowBox[{"\[Mu]2_", ",", "\[Mu]1_"}], "}"}]}], "]"}], "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"\[Alpha]", ":", 
             RowBox[{"Except", "[", "_List", "]"}]}], ",", 
            RowBox[{"\[Beta]", ":", 
             RowBox[{"Except", "[", "_List", "]"}]}], ",", 
            RowBox[{"\[Gamma]", ":", 
             RowBox[{"Except", "[", "_List", "]"}]}]}], "}"}], "]"}]}], "/;", 
        
        RowBox[{
         RowBox[{"IntegerQ", "[", 
          RowBox[{"2", "\[Lambda]"}], "]"}], "&&", 
         RowBox[{"IntegerQ", "[", 
          RowBox[{"2", "\[Mu]2"}], "]"}], "&&", 
         RowBox[{"IntegerQ", "[", 
          RowBox[{"2", "\[Mu]1"}], "]"}]}]}], ":=", 
       RowBox[{"TrigExpand", "@", 
        RowBox[{"WignerD", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"\[Lambda]", ",", 
            RowBox[{"-", "\[Mu]2"}], ",", 
            RowBox[{"-", "\[Mu]1"}]}], "}"}], ",", "\[Alpha]", ",", "\[Beta]",
           ",", "\[Gamma]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Protect", "[", "WignerD", "]"}]}], "\[IndentingNewLine]", 
     ")"}]}], "]"}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.5295141567094297`*^9, 3.5295142421928053`*^9}, 
