Cell[CellGroupData[{

Cell["Wignerd", "Subsection",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.4525316744726467`*^9, 3.452531683156207*^9}, 
   3.5295119960465183`*^9},
 AspectRatioFixed->
  False,ExpressionUUID->"c5689da5-ee1e-4eb5-88a4-c5da92912d25"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Wignerd", "::", "usage"}], "=", "\n", "\t", 
   "\"\<Wignerd[J][\[Beta]] is the reduced Wigner matrix (J integral or \
half-integral). Wignerd[J,{m2,m1}][\[Beta]] is the reduced Wigner function \
(element of the reduced Wigner matrix). Wignerd[J,{m}][\[Beta]] is the mth \
row of the reduced Wigner matrix; Wignerd[J,{{m}}][\[Beta]] is the mth column \
of the reduced Wigner matrix. In all cases the row and column indices run \
from +J to -J in descending order.\>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.409832515467456*^9, 3.409832517709145*^9}, {
  3.409832624398933*^9, 3.4098326272321873`*^9}, {3.45253374798892*^9, 
  3.4525337738038597`*^9}, {3.452533933068924*^9, 3.452533933841942*^9}, {
  3.4992978494593143`*^9, 3.4992979004021387`*^9}, {3.499298021542108*^9, 
  3.499298071435951*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"eb754342-a395-4459-9a1f-0e82c539c8ea"]
}, Closed]],

Cell[CellGroupData[{

Cell["WignerD", "Subsection",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.4525316744726467`*^9, 3.452531683156207*^9}, 
   3.529512959705841*^9, 3.529572762463851*^9},
 AspectRatioFixed->
  False,ExpressionUUID->"be905b80-325d-4836-9a3f-54dcc8171806"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"WignerD", "::", "usage"}], "=", "\n", 
   "\"\<WignerD is a built-in function in Mathematica 2.0 but has been given \
enhanced functionality in SpinDynamica, in order to maintain compatibility \
with previous code. The SpinDynamica definitions are as follows:\n\
WignerD[J][{\[Alpha],\[Beta],\[Gamma]}] is the three-angle Wigner matrix for \
integral or half-integral J. WignerD[J]{{\[Alpha]2,\[Beta]2,\[Gamma]2},{\
\[Alpha]1,\[Beta]1,\[Gamma]1}..}] is the Wigner matrix for the overall \
rotation corresponding to the specified sequence of Euler rotations. \
WignerD[J,{m2,m1}][{\[Alpha],\[Beta],\[Gamma]}] is a three-angle Wigner \
function (Wigner matrix element). WignerD[J,{m}][{\[Alpha],\[Beta],\[Gamma]}] \
is the mth row of the Wigner matrix; WignerD[J,{{m}}][{\[Alpha],\[Beta],\
\[Gamma]}] is the mth column of the Wigner matrix. In all cases the row and \
column indices run from +J to -J in descending order.\>\""}], ";"}]], "Input",\

 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.409832521789256*^9, 3.4098325385822887`*^9}, {
  3.409832629812295*^9, 3.409832641336506*^9}, {3.452531687883738*^9, 
  3.4525317445624733`*^9}, {3.45253180949253*^9, 3.452531949856708*^9}, {
  3.452533778472732*^9, 3.452533847335246*^9}, {3.4992973298875113`*^9, 
  3.4992974197349253`*^9}, {3.499298087824766*^9, 3.49929809370401*^9}, {
  3.5295129603902693`*^9, 3.5295129653471403`*^9}, {3.529572762511054*^9, 
