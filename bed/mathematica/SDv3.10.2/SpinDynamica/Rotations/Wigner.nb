 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Wignerd", "[", 
     RowBox[{"\[Lambda]_", ",", 
      RowBox[{"{", 
       RowBox[{"\[Mu]2_", ",", "\[Mu]1_"}], "}"}]}], "]"}], "[", "\[Beta]_", 
