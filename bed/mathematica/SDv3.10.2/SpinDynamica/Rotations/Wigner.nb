Cell[BoxData[
 RowBox[{
  RowBox[{"UserLevelDependentDefinition", "[", 
   RowBox[{"WignerD", ",", "Infinity", ",", 
    RowBox[{"(", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Unprotect", "[", "WignerD", "]"}], ";", 
      RowBox[{
       RowBox[{
        RowBox[{"WignerD", "[", "args___", "]"}], "/;", 
        RowBox[{
         RowBox[{"TrueQ", "[", "FirstCallToWignerD", "]"}], "&&", 
         RowBox[{"(", 
          RowBox[{"$KernelID", "\[Equal]", "0"}], ")"}]}]}], ":=", 
       "\[IndentingNewLine]", 
       RowBox[{"(", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Message", "[", 
          RowBox[{"WignerD", "::", "mod"}], "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"Print", "[", 
          RowBox[{
           RowBox[{"Button", "[", 
            RowBox[{"\"\<For ?WignerD click <here>\>\"", ",", 
             RowBox[{"Print", "[", 
              RowBox[{"Style", "[", 
               RowBox[{
                RowBox[{"WignerD", "::", "usage"}], ",", "\"\<Usage\>\""}], 
               "]"}], "]"}]}], "]"}], "//", "DisplayForm"}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"FirstCallToWignerD", "=", "False"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"Protect", "[", "WignerD", "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"WignerD", "[", "args", "]"}]}], "\[IndentingNewLine]", 
        ")"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Protect", "[", "WignerD", "]"}]}], "\[IndentingNewLine]", 
     ")"}]}], "]"}], ";"}]], "Input",
 InitializationCell->True,
