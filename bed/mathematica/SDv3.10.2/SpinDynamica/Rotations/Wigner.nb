Cell[BoxData[
 RowBox[{
  RowBox[{"UserLevelDependentDefinition", "[", 
   RowBox[{"WignerD", ",", "Infinity", ",", 
    RowBox[{"(", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Unprotect", "[", "WignerD", "]"}], ";", "\[IndentingNewLine]", 
      
      RowBox[{
       RowBox[{"HoldPattern", "@", 
        RowBox[{
         RowBox[{"WignerD", "[", "\[Lambda]_", "]"}], "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"\[Alpha]", ":", 
            RowBox[{"Except", "[", "_List", "]"}]}], ",", 
           RowBox[{"\[Beta]", ":", 
            RowBox[{"Except", "[", "_List", "]"}]}], ",", 
           RowBox[{"\[Gamma]", ":", 
            RowBox[{"Except", "[", "_List", "]"}]}]}], "}"}], "]"}]}], ":=", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"WignerD", "[", 
            RowBox[{"\[Lambda]", ",", 
             RowBox[{"{", 
              RowBox[{"\[Mu]2", ",", "\[Mu]1"}], "}"}]}], "]"}], "[", 
           RowBox[{"{", 
            RowBox[{"\[Alpha]", ",", "\[Beta]", ",", "\[Gamma]"}], "}"}], 
           "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"\[Mu]2", ",", 
            RowBox[{"+", "\[Lambda]"}], ",", 
            RowBox[{"-", "\[Lambda]"}], ",", 
            RowBox[{"-", "1"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"\[Mu]1", ",", 
            RowBox[{"+", "\[Lambda]"}], ",", 
            RowBox[{"-", "\[Lambda]"}], ",", 
            RowBox[{"-", "1"}]}], "}"}]}], "]"}], "/;", 
        RowBox[{"IntegerQ", "[", 
         RowBox[{"2", "\[Lambda]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Protect", "[", "WignerD", "]"}]}], "\[IndentingNewLine]", 
     ")"}]}], "]"}], ";"}]], "Input",
