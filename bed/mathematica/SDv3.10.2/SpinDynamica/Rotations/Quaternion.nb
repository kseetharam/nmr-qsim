  True,ExpressionUUID->"b7f4849a-4dbe-4647-817d-eb997bf7bf79"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuaternionProduct", "[", "q_", "]"}], ":=", "q"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.409831723749902*^9, 3.409831731883574*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"2993e0c7-d740-437d-8e3c-b21f085e65a3"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"QuaternionProduct", "[", 
    RowBox[{"q2_", ",", "q1_"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"v1", ",", "v2"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"v1", "=", 
       RowBox[{"q1", "\[LeftDoubleBracket]", 
        RowBox[{"{", 
         RowBox[{"2", ",", "3", ",", "4"}], "}"}], 
        "\[RightDoubleBracket]"}]}], ";", 
      RowBox[{"v2", "=", 
       RowBox[{"q2", "\[LeftDoubleBracket]", 
        RowBox[{"{", 
         RowBox[{"2", ",", "3", ",", "4"}], "}"}], 
        "\[RightDoubleBracket]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Normalize", "[", "\[IndentingNewLine]", 
       RowBox[{"Flatten", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
            "q1", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], " ", 
            RowBox[{
            "q2", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]}], 
           "-", 
           RowBox[{"v1", ".", "v2"}]}], ",", 
          RowBox[{
           RowBox[{"v1", " ", 
            RowBox[{
            "q2", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]}], 
           "+", 
           RowBox[{
            RowBox[{
            "q1", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], " ",
             "v2"}], "-", 
           RowBox[{"v1", "\[Cross]", "v2"}]}]}], "}"}], "]"}], 
       "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.409831737961763*^9, 3.409831833684124*^9}, {
   3.409831960321128*^9, 3.4098319621309547`*^9}, 3.473577184209469*^9, {
   3.4735776218870983`*^9, 3.47357763557631*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"8b70866c-210a-4874-99a5-f3e95b1492d5"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"QuaternionProduct", "[", 
    RowBox[{"qn__", ",", "q2_", ",", "q1_"}], "]"}], ":=", 
   RowBox[{"QuaternionProduct", "[", 
    RowBox[{"qn", ",", 
     RowBox[{"QuaternionProduct", "[", 
      RowBox[{"q2", ",", "q1"}], "]"}]}], "]"}]}], ";"}]], "Input",
 PageWidth:>WindowWidth,
