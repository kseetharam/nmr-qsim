Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"PolarToQuaternion", "::", "\"\<usage\>\""}], "=", 
   "\"\<PolarToQuaternion[{\[Xi],\[Theta],\[Phi]}] converts a PolarRotation \
to a unit Quaternion of the form {cos(\[Xi]/2), \!\(\*SubscriptBox[\(n\), \(x\
\)]\)sin(\[Xi]/2), \!\(\*SubscriptBox[\(n\), \(y\)]\)sin(\[Xi]/2), \
\!\(\*SubscriptBox[\(n\), \(z\)]\)sin(\[Xi]/2)} where n is the rotation axis.\
\>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.409831469949232*^9, 3.409831505379078*^9}, {
  3.409831595478774*^9, 3.409831595925449*^9}, {3.473576794108927*^9, 
  3.473576932389448*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"d1abbd56-bdee-4160-a5a3-1d6d5c792538"]
}, Open  ]],

