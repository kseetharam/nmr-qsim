Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"QuaternionToEuler", "::", "\"\<usage\>\""}], "=", 
   "\"\<QuaternionToEuler[{q1,q2,q3,q4}] converts a unit Quaternion to Euler \
angles {\[Alpha],\[Beta],\[Gamma]}. The quaternion is defined {cos(\[Xi]/2), \
\!\(\*SubscriptBox[\(n\), \(x\)]\)sin(\[Xi]/2), \!\(\*SubscriptBox[\(n\), \(y\
\)]\)sin(\[Xi]/2), \!\(\*SubscriptBox[\(n\), \(z\)]\)sin(\[Xi]/2)} where n is \
the rotation axis.\>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
