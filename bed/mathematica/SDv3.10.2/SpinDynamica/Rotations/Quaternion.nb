Cell[CellGroupData[{

Cell[BoxData["QuaternionToPolar"], "Subsection",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 AspectRatioFixed->
  True,ExpressionUUID->"486d70a9-07c0-4091-99ff-a66b88555255"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"QuaternionToPolar", "[", 
    RowBox[{"{", 
     RowBox[{"q1_", ",", "q2_", ",", "q3_", ",", "q4_"}], "}"}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Xi]", ",", "\[Theta]", ",", "\[Phi]", ",", "c", ",", "s", ",", "cth",
        ",", "sth"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"c", "=", "q1"}], ";", 
      RowBox[{"s", "=", 
       SqrtBox[
        RowBox[{
         SuperscriptBox["q2", "2"], "+", 
         SuperscriptBox["q3", "2"], "+", 
         SuperscriptBox["q4", "2"]}]]}], ";", "\[IndentingNewLine]", 
      RowBox[{"\[Xi]", "=", 
       RowBox[{"2", " ", 
        RowBox[{"ArcTan", "[", 
         RowBox[{"c", ",", "s"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"\[Theta]", "=", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"q2", "\[Equal]", "q3", "\[Equal]", "q4", "\[Equal]", "0"}], 
         ",", "\[IndentingNewLine]", 
         RowBox[{"2", " ", 
          RowBox[{"ArcCos", "[", "q1", "]"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"ArcTan", "[", 
          RowBox[{"q4", ",", 
           SqrtBox[
            RowBox[{
             SuperscriptBox["q2", "2"], "+", 
             SuperscriptBox["q3", "2"]}]]}], "]"}]}], "\[IndentingNewLine]", 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"\[Phi]", "=", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"q2", "\[Equal]", "q3", "\[Equal]", "0"}], ",", 
         "\[IndentingNewLine]", "0", ",", "\[IndentingNewLine]", 
         RowBox[{"ArcTan", "[", 
          RowBox[{"q2", ",", "q3"}], "]"}]}], "\[IndentingNewLine]", "]"}]}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"\[Xi]", ",", "\[Theta]", ",", "\[Phi]"}], "}"}]}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.4098322361497793`*^9, 3.409832248986352*^9}, {
   3.4735772067591667`*^9, 3.473577277039583*^9}, 3.473577349922995*^9, {
   3.473577416719573*^9, 3.4735774835625353`*^9}, {3.473577773933062*^9, 
   3.473577775330233*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"f54384d4-4ccb-4843-8c13-e00b934e4f28"]
}, Closed]],

