Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"QuaternionToPolar", "::", "\"\<usage\>\""}], "=", 
   "\"\<QuaternionToPolar[{q1,q2,q3,q4}] converts a unit Quaternion to polar \
rotation angles {\[Xi],\[Theta],\[Phi]}. The quaternion is defined \
{cos(\[Xi]/2), \!\(\*SubscriptBox[\(n\), \(x\)]\)sin(\[Xi]/2), \
\!\(\*SubscriptBox[\(n\), \(y\)]\)sin(\[Xi]/2), \!\(\*SubscriptBox[\(n\), \(z\
\)]\)sin(\[Xi]/2)} where n is the rotation axis.\>\""}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.4098314741968603`*^9, 3.409831477554788*^9}, {
