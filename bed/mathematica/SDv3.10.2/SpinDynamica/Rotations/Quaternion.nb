Cell[BoxData["PolarToQuaternion"], "Subsection",
 PageWidth:>WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 AspectRatioFixed->
  True,ExpressionUUID->"6b78ad36-6920-455c-869e-6c58e531fada"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"PolarToQuaternion", "[", 
    RowBox[{"{", 
     RowBox[{"\[Xi]_", ",", "\[Theta]_", ",", "\[Phi]_"}], "}"}], "]"}], ":=",
    "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "nvec", "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"nvec", "=", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"Sin", "[", "\[Theta]", "]"}], 
           RowBox[{"Cos", "[", "\[Phi]", "]"}]}], ",", 
          RowBox[{
           RowBox[{"Sin", "[", "\[Theta]", "]"}], 
           RowBox[{"Sin", "[", "\[Phi]", "]"}]}], ",", 
          RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "}"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Flatten", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Cos", "[", 
           RowBox[{"\[Xi]", "/", "2"}], "]"}], ",", 
          RowBox[{
           RowBox[{"Sin", "[", 
            RowBox[{"\[Xi]", "/", "2"}], "]"}], "nvec"}]}], "}"}], "]"}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
 PageWidth:>WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.4098316529375553`*^9, 3.4098316628871193`*^9}, {
  3.4735770099044523`*^9, 3.473577030237793*^9}, {3.4735770618639307`*^9, 
  3.473577174174262*^9}, {3.473577370144238*^9, 3.4735773875368443`*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"f8edbdc8-84ab-494e-aa48-fb06eef166b9"]
}, Closed]],

