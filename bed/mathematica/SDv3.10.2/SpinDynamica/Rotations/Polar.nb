Cell[CellGroupData[{

Cell["PolarRotationMatrix", "Section",
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 AspectRatioFixed->
  True,ExpressionUUID->"cdcfe66f-ce96-4a9b-b966-09c47fe038a5"],

Cell["\<\
PolarRotationMatrix::usage =
\t\"PolarRotationMatrix[{\[Xi],\[Theta],\[Phi]}] gives the 3D rotation matrix \
for a rotation through xi around the axis with polar angles \
{\[Theta],\[Phi]}.\";
\t\
\>", "Input",
 PageWidth->WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.409830390404861*^9, 3.409830413680032*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"a361cc05-a0ee-4c48-bac1-31a3bb4534f9"]
}, Closed]],

Cell[CellGroupData[{

Cell["RotatePolar", "Section",
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 AspectRatioFixed->
  True,ExpressionUUID->"81bedcbe-ad62-46c1-9075-cffa2df44d9c"],

Cell["\<\
RotatePolar::usage =
\t\"RotatePolar[obj,{\[Xi],\[Theta],\[Phi]}] rotates the object by \[Xi] \
around the axis with polar angles (\[Theta],\[Phi]).

RotatePolar[obj,{\[Xi],vec}] rotates the object by xi around the vector vec.

The object obj may be a 3-vector, or contain lines, polygons, and text.
\";\
\>", "Input",
 PageWidth->WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.409830425492941*^9, 3.409830460825782*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"1ce5fce6-9633-4d1f-9f01-33a03ef02e0c"]
}, Closed]]
}, Closed]],

Cell[CellGroupData[{

Cell["main", "Subsubtitle",
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 AspectRatioFixed->
  True,ExpressionUUID->"58ccd97c-e84c-494b-b72a-049202097e2c"],

Cell["Begin[\"`Private`\"];", "Input",
 PageWidth->WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 AspectRatioFixed->
  True,ExpressionUUID->"dbfea755-c51a-4a12-a214-2a6a172c1a23"],

Cell[CellGroupData[{

Cell[" PolarRotationMatrix", "Section",
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{3.4098304875847816`*^9},
 AspectRatioFixed->
  True,ExpressionUUID->"e4e654a3-6696-4f5e-9d8c-44c2067b9a2b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"PolarRotationMatrix", "[", 
   RowBox[{"{", 
    RowBox[{"\[Xi]_", ",", "\[Theta]_", ",", "\[Phi]_"}], "}"}], "]"}], ":=", 
  
  RowBox[{
   RowBox[{"EulerRotationMatrix", "[", 
    RowBox[{"{", 
     RowBox[{"\[Phi]", ",", "\[Theta]", ",", "\[Xi]"}], "}"}], "]"}], ".", 
   RowBox[{"EulerRotationMatrix", "[", 
    RowBox[{"{", 
     RowBox[{"0", ",", 
      RowBox[{"-", "\[Theta]"}], ",", 
      RowBox[{"-", "\[Phi]"}]}], "}"}], "]"}]}]}]], "Input",
 PageWidth->WindowWidth,
 InitializationGroup->True,
 CellChangeTimes->{{3.409830513163254*^9, 
  3.409830607175077*^9}},ExpressionUUID->"bacfd3c7-74a2-494f-87f6-\
69e09b2805cc"]
}, Closed]],

Cell[CellGroupData[{

Cell["RotatePolar", "Section",
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.409830644737568*^9, 3.4098306454569473`*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"cc14b9b4-19aa-40bf-8349-2fdf6a29ec88"],

Cell[BoxData[
 RowBox[{
  RowBox[{"RotatePolar", "[", 
   RowBox[{"obj_", ",", 
    RowBox[{"{", 
     RowBox[{"\[Xi]_", ",", 
      RowBox[{"vec", ":", 
       RowBox[{"{", 
        RowBox[{"_", ",", "_", ",", "_"}], "}"}]}]}], "}"}], ",", 
    "opts___Rule"}], " ", "]"}], ":=", "\[IndentingNewLine]", 
  RowBox[{"RotatePolar", "[", 
   RowBox[{"obj", ",", 
    RowBox[{"Flatten", "@", 
     RowBox[{"{", 
      RowBox[{"\[Xi]", ",", 
       RowBox[{"Last", "@", 
        RowBox[{"VectorToPolar", "[", "vec", "]"}]}]}], "}"}]}], ",", 
    "opts"}], "]"}]}]], "Input",
 PageWidth->WindowWidth,
 InitializationGroup->True,
 CellChangeTimes->{{3.409830747581408*^9, 
  3.4098308276729183`*^9}},ExpressionUUID->"fb7431d2-112b-4ecb-9421-\
f65f1dbe25c9"],

Cell[CellGroupData[{

Cell["rotate vectors", "Subsection",
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.4098239328365393`*^9, 3.409823939240077*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"909caee1-5721-467e-b5c6-49f280364af3"],

Cell[CellGroupData[{

Cell["rotations of ordinary vector", "Subsubsection",
 InitializationCell->True,
 InitializationGroup->True,
 AspectRatioFixed->
  True,ExpressionUUID->"b99e45e5-5d70-490b-ac6e-32123e21609e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"RotatePolar", "[", 
   RowBox[{
    RowBox[{"vec", ":", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Except", "[", "_List", "]"}], ",", 
       RowBox[{"Except", "[", "_List", "]"}], ",", 
       RowBox[{"Except", "[", "_List", "]"}]}], "}"}]}], ",", "\n", "\t", 
    RowBox[{"{", 
     RowBox[{"\[Xi]_", ",", " ", "\[Theta]_", ",", " ", "\[Phi]_"}], "}"}], 
    ",", "opts___Rule"}], " ", "]"}], ":=", "\n", "\t", 
  RowBox[{
   RowBox[{"PolarRotationMatrix", "[", 
    RowBox[{"{", 
     RowBox[{"\[Xi]", ",", " ", "\[Theta]", ",", " ", "\[Phi]"}], "}"}], 
    "]"}], ".", "vec"}]}]], "Input",
 PageWidth->WindowWidth,
 InitializationGroup->True,
 CellChangeTimes->{{3.409823353165832*^9, 3.409823364811503*^9}, {
  3.409830652795816*^9, 
  3.409830707290387*^9}},ExpressionUUID->"cb087e47-96da-4c34-8e11-\
a782342aae2e"]
}, Closed]]
}, Closed]],

Cell[CellGroupData[{

Cell["go into lists that are not vectors", "Subsection",
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.409823987671809*^9, 3.409823994076367*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"8b5b4e59-46e0-4dff-a9e3-a59f2797fdbb"],

Cell["\<\
RotatePolar[obj_List,ang:{_, _, _},opts___]:=
\t\tMap[ 
\t\t\tRotatePolar[#,ang,opts]&, 
\t\t\tobj 
\t\t] \
\>", "Input",
 PageWidth->WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.4098308497568207`*^9, 3.409830851180266*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"48b26465-bafa-4782-9317-bca3ff4cd38a"]
}, Closed]],

Cell[CellGroupData[{

Cell["graphics3D", "Subsection",
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.40982596546175*^9, 3.409825965940111*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"5d9508a7-fede-42a3-8a2e-f4fe2f30e0c0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"RotatePolar", "[", 
   RowBox[{
    RowBox[{"Graphics3D", "[", "obj___", "]"}], ",", 
    RowBox[{"\[CapitalOmega]", ":", 
     RowBox[{"{", 
      RowBox[{"\[Xi]_", ",", "\[Theta]_", ",", "\[Phi]_"}], "}"}]}]}], "]"}], 
  ":=", "\[IndentingNewLine]", 
  RowBox[{"Graphics3D", "@", 
   RowBox[{"GeometricTransformation", "[", 
    RowBox[{
     RowBox[{"Normal", "@", "obj"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"PolarRotationMatrix", "[", "\[CapitalOmega]", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", "0"}], "}"}]}], "}"}]}], 
    "]"}]}]}]], "Input",
 PageWidth->WindowWidth,
 InitializationGroup->True,
 CellChangeTimes->{{3.409824992423657*^9, 3.40982510579807*^9}, {
  3.4098251615081587`*^9, 3.409825170724739*^9}, {3.4098255305650673`*^9, 
  3.409825546319705*^9}, {3.40982967914592*^9, 3.409829685290476*^9}, {
  3.409830868662887*^9, 
  3.4098308956576242`*^9}},ExpressionUUID->"bf1c8a61-5fe1-4dfa-b59f-\
76600a058ac8"]
}, Closed]],

Cell[CellGroupData[{

Cell["if object not known, and not a list, do nothing", "Subsection",
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 AspectRatioFixed->
  True,ExpressionUUID->"c4ce3d3d-b27a-4a59-8866-0c5149c14054"],

Cell["\<\
RotatePolar[obj_,ang:{_, _, _},opts___ ]:=
\tobj/; !TrueQ[ Head[obj]==List ]\
\>", "Input",
 PageWidth->WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{3.4098309070103197`*^9},
 AspectRatioFixed->
  True,ExpressionUUID->"5c4ab8b5-e55f-479d-b53e-6cbf9446c772"]
}, Closed]]
}, Closed]]
}, Closed]],

