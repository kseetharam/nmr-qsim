Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"AxesToEuler", "[", 
     RowBox[{
      RowBox[{"system2", ":", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"_", ",", "_", ",", "_"}], "}"}], ".."}], "}"}]}], ",", 
      RowBox[{"system1", ":", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"_", ",", "_", ",", "_"}], "}"}], ".."}], "}"}]}], ",", 
      "opts___Rule"}], "]"}], "/;", 
    RowBox[{"And", "@@", 
     RowBox[{"(", 
      RowBox[{"NumericQ", "/@", 
       RowBox[{"Flatten", "[", 
        RowBox[{"{", 
         RowBox[{"system1", ",", "system2"}], "}"}], "]"}]}], ")"}]}]}], ":=",
    "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "ex1", ",", "ey1", ",", "ez1", ",", "ex2", ",", "ey2", ",", "ez2", ",", 
       "Rzz"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"ex1", ",", "ey1", ",", "ez1"}], "}"}], "=", 
        RowBox[{"AxisSystem", "@@", "system1"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"ex2", ",", "ey2", ",", "ez2"}], "}"}], "=", 
        RowBox[{"AxisSystem", "@@", "system2"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Rzz", "=", 
        RowBox[{"ez2", ".", "ez1"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"RoundAngles", "/@", "\[IndentingNewLine]", 
        RowBox[{"Which", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"Chop", "@", 
            RowBox[{"N", "@", 
             RowBox[{"(", 
              RowBox[{"Rzz", "-", "1"}], ")"}]}]}], "==", "0"}], ",", 
          "\[IndentingNewLine]", "\t", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"ArcTan", "[", 
             RowBox[{
              RowBox[{"ex2", ".", "ex1"}], ",", 
              RowBox[{"-", 
               RowBox[{"ex2", ".", "ey1"}]}]}], "]"}], ",", "0", ",", "0"}], 
           "}"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"Chop", "@", 
            RowBox[{"N", "@", 
             RowBox[{"(", 
              RowBox[{"Rzz", "+", "1"}], ")"}]}]}], "==", "0"}], ",", 
          "\[IndentingNewLine]", "\t", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"ArcTan", "[", 
             RowBox[{
              RowBox[{"-", 
               RowBox[{"ex2", ".", "ex1"}]}], ",", 
              RowBox[{"-", 
               RowBox[{"ex2", ".", "ey1"}]}]}], "]"}], ",", "\[Pi]", ",", 
            "0"}], "}"}], ",", "\[IndentingNewLine]", "True", ",", 
          "\[IndentingNewLine]", "\t", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"ArcTan", "[", 
             RowBox[{
              RowBox[{"ex2", ".", "ez1"}], ",", 
              RowBox[{"ey2", ".", "ez1"}]}], "]"}], ",", 
            "\[IndentingNewLine]", "\t", 
            RowBox[{"ArcCos", "[", "Rzz", "]"}], ",", "\[IndentingNewLine]", 
            "\t", 
            RowBox[{"ArcTan", "[", 
             RowBox[{
              RowBox[{"-", 
               RowBox[{"ez2", ".", "ex1"}]}], ",", 
              RowBox[{"ez2", ".", "ey1"}]}], "]"}]}], "\[IndentingNewLine]", 
           "\t", "}"}]}], "\[IndentingNewLine]", "]"}]}]}], 
      "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
