d5f642e3662d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"AxesToEuler", "[", 
    RowBox[{
     RowBox[{"system2", ":", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"_", ",", "_", ",", "_"}], "}"}], ".."}], "}"}]}], ",", 
     RowBox[{"system1", ":", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"_", ",", "_", ",", "_"}], "}"}], ".."}], "}"}]}], ",", 
     "opts___Rule"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "ex1", ",", "ey1", ",", "ez1", ",", "ex2", ",", "ey2", ",", "ez2", ",", 
       "Rzz", ",", "symbols", ",", "assumptions"}], "}"}], ",", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"ex1", ",", "ey1", ",", "ez1"}], "}"}], "=", 
        RowBox[{"AxisSystem", "@@", "system1"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"ex2", ",", "ey2", ",", "ez2"}], "}"}], "=", 
        RowBox[{"AxisSystem", "@@", "system2"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"symbols", "=", 
        RowBox[{"Union", "@", 
         RowBox[{"Cases", "[", 
          RowBox[{
           RowBox[{"Flatten", "[", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"ex1", ",", "ey1", ",", "ez1"}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"ex2", ",", "ey2", ",", "ez2"}], "}"}]}], "}"}], "]"}],
            ",", "_Symbol", ",", "Infinity"}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"assumptions", "=", 
        RowBox[{"And", "@@", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"0", "<", "#", "<", 
              RowBox[{"\[Pi]", "/", "2"}]}], ")"}], "&"}], "/@", "symbols"}], 
          ")"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Rzz", "=", 
        RowBox[{"ez2", ".", "ez1"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Refine", "@", 
        RowBox[{"Simplify", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Which", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"TrueQ", "[", 
             RowBox[{
              RowBox[{"Chop", "@", 
               RowBox[{"N", "@", 
                RowBox[{"(", 
                 RowBox[{"Rzz", "-", "1"}], ")"}]}]}], "==", "0"}], "]"}], 
            ",", "\[IndentingNewLine]", "\t", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"ArcTan", "[", 
               RowBox[{
                RowBox[{"ex2", ".", "ex1"}], ",", 
                RowBox[{"-", 
                 RowBox[{"ex2", ".", "ey1"}]}]}], "]"}], ",", "0", ",", "0"}],
              "}"}], ",", "\[IndentingNewLine]", 
            RowBox[{"TrueQ", "[", 
             RowBox[{
              RowBox[{"Chop", "@", 
               RowBox[{"N", "@", 
                RowBox[{"(", 
                 RowBox[{"Rzz", "+", "1"}], ")"}]}]}], "==", "0"}], "]"}], 
            ",", "\[IndentingNewLine]", "\t", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"ArcTan", "[", 
               RowBox[{
                RowBox[{"-", 
                 RowBox[{"ex2", ".", "ex1"}]}], ",", 
                RowBox[{"-", 
                 RowBox[{"ex2", ".", "ey1"}]}]}], "]"}], ",", "\[Pi]", ",", 
              "0"}], "}"}], ",", "\[IndentingNewLine]", "True", ",", 
            "\[IndentingNewLine]", "\t", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"ArcTan", "[", 
               RowBox[{
                RowBox[{"ex2", ".", "ez1"}], ",", 
                RowBox[{"ey2", ".", "ez1"}]}], "]"}], ",", 
              "\[IndentingNewLine]", "\t", 
              RowBox[{"ArcCos", "[", "Rzz", "]"}], ",", "\[IndentingNewLine]",
               "\t", 
              RowBox[{"ArcTan", "[", 
               RowBox[{
                RowBox[{"-", 
                 RowBox[{"ez2", ".", "ex1"}]}], ",", 
                RowBox[{"ez2", ".", "ey1"}]}], "]"}]}], "\[IndentingNewLine]",
              "\t", "}"}]}], "\[IndentingNewLine]", "]"}], ",", 
          "\[IndentingNewLine]", "assumptions"}], "\[IndentingNewLine]", 
         "]"}]}]}], "\[IndentingNewLine]", ")"}]}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
