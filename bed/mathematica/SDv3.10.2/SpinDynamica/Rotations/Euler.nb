Cell[CellGroupData[{

Cell["EulerRotationMatrix (VMK p30)", "Section",
 PageWidth->WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 AspectRatioFixed->
  True,ExpressionUUID->"b1185bd6-4198-4ee8-ba54-a8535f31f991"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"EulerRotationMatrix", "[", 
    RowBox[{"{", 
     RowBox[{"a_", ",", "b_", ",", "g_"}], "}"}], "]"}], ":=", "\n", "\t", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Cos", "[", "a", "]"}], 
         RowBox[{"Cos", "[", "b", "]"}], 
         RowBox[{"Cos", "[", "g", "]"}]}], "-", 
        RowBox[{
         RowBox[{"Sin", "[", "a", "]"}], 
         RowBox[{"Sin", "[", "g", "]"}]}]}], ",", "\n", "\t\t\t", 
       RowBox[{
        RowBox[{
         RowBox[{"-", 
          RowBox[{"Cos", "[", "a", "]"}]}], 
         RowBox[{"Cos", "[", "b", "]"}], 
         RowBox[{"Sin", "[", "g", "]"}]}], "-", 
        RowBox[{
         RowBox[{"Sin", "[", "a", "]"}], 
         RowBox[{"Cos", "[", "g", "]"}]}]}], ",", "\n", "\t\t\t", 
       RowBox[{
        RowBox[{"Cos", "[", "a", "]"}], 
        RowBox[{"Sin", "[", "b", "]"}]}]}], "}"}], ",", "\n", "\t\t", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Sin", "[", "a", "]"}], 
         RowBox[{"Cos", "[", "b", "]"}], 
         RowBox[{"Cos", "[", "g", "]"}]}], "+", 
        RowBox[{
         RowBox[{"Cos", "[", "a", "]"}], 
         RowBox[{"Sin", "[", "g", "]"}]}]}], ",", "\n", "\t\t\t", 
       RowBox[{
        RowBox[{
         RowBox[{"-", 
          RowBox[{"Sin", "[", "a", "]"}]}], 
         RowBox[{"Cos", "[", "b", "]"}], 
         RowBox[{"Sin", "[", "g", "]"}]}], "+", 
        RowBox[{
         RowBox[{"Cos", "[", "a", "]"}], 
         RowBox[{"Cos", "[", "g", "]"}]}]}], ",", "\n", "\t\t\t", 
       RowBox[{
        RowBox[{"Sin", "[", "a", "]"}], 
        RowBox[{"Sin", "[", "b", "]"}]}]}], "}"}], ",", "\n", "\t\t", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"-", 
         RowBox[{"Sin", "[", "b", "]"}]}], 
        RowBox[{"Cos", "[", "g", "]"}]}], ",", " ", 
       RowBox[{
        RowBox[{"Sin", "[", "b", "]"}], 
        RowBox[{"Sin", "[", "g", "]"}]}], ",", " ", 
       RowBox[{"Cos", "[", "b", "]"}]}], "}"}]}], "}"}]}], ";"}]], "Input",
 PageWidth->WindowWidth,
 InitializationCell->True,
 InitializationGroup->
  True,ExpressionUUID->"163997e6-fd63-48ec-bdb3-7068ef1ee39b"]
}, Closed]],

