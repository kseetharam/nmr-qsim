  True,ExpressionUUID->"82b3e675-e693-4695-996c-1a1ae15d3f58"]
}, Closed]],

Cell[CellGroupData[{

Cell["Graphics3D", "Subsection",
 PageWidth->WindowWidth,
 Evaluatable->False,
 InitializationCell->True,
 InitializationGroup->True,
 CellChangeTimes->{{3.40982596546175*^9, 3.409825965940111*^9}, 
   3.673956435913225*^9},
 AspectRatioFixed->
  True,ExpressionUUID->"ce4cd8d9-ed5c-4c3e-870a-073a22fd778e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"RotateEuler", "[", 
   RowBox[{
    RowBox[{"Graphics3D", "[", "obj___", "]"}], ",", 
    RowBox[{"\[CapitalOmega]", ":", 
     RowBox[{"{", 
      RowBox[{"\[Alpha]_", ",", "\[Beta]_", ",", "\[Gamma]_"}], "}"}]}]}], 
   "]"}], ":=", 
  RowBox[{"Graphics3D", "@", 
   RowBox[{"GeometricTransformation", "[", 
    RowBox[{
     RowBox[{"Normal", "@", "obj"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"EulerRotationMatrix", "[", "\[CapitalOmega]", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", "0"}], "}"}]}], "}"}]}], 
    "]"}]}]}]], "Input",
 InitializationGroup->True,
 CellChangeTimes->{{3.409824992423657*^9, 3.40982510579807*^9}, {
  3.4098251615081587`*^9, 3.409825170724739*^9}, {3.4098255305650673`*^9, 
