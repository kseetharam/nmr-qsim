Cell[CellGroupData[{

Cell["rotations of ordinary vector", "Subsubsection",
 PageWidth->WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 AspectRatioFixed->
  True,ExpressionUUID->"01deb66d-f566-43a2-8e34-e17b6ac59420"],

Cell[BoxData[
 RowBox[{
  RowBox[{"RotateEuler", "[", 
   RowBox[{
    RowBox[{"vec", ":", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Except", "[", "_List", "]"}], ",", 
       RowBox[{"Except", "[", "_List", "]"}], ",", 
       RowBox[{"Except", "[", "_List", "]"}]}], "}"}]}], ",", "\n", "\t", 
    RowBox[{"{", 
     RowBox[{"\[Alpha]_", ",", " ", "\[Beta]_", ",", " ", "\[Gamma]_"}], 
     "}"}], ",", "opts___Rule"}], " ", "]"}], ":=", "\n", "\t", 
  RowBox[{
   RowBox[{"EulerRotationMatrix", "[", 
    RowBox[{"{", 
     RowBox[{"\[Alpha]", ",", "\[Beta]", ",", "\[Gamma]"}], "}"}], "]"}], ".",
    "vec"}]}]], "Input",
 InitializationGroup->True,
 CellChangeTimes->{{3.409823353165832*^9, 
  3.409823364811503*^9}},ExpressionUUID->"71d92afa-5c88-4ec8-bad4-\
cf96ffc3da0f"]
}, Closed]],

Cell[CellGroupData[{

Cell["rotations of ordinary vector around arbitrary system", "Subsubsection",
 PageWidth->WindowWidth,
 InitializationCell->True,
 InitializationGroup->True,
 AspectRatioFixed->
  True,ExpressionUUID->"c8853937-b470-4ce2-8a14-40ebaf474a5c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"RotateEuler", "[", 
   RowBox[{
    RowBox[{"vec", ":", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Except", "[", "_List", "]"}], ",", 
       RowBox[{"Except", "[", "_List", "]"}], ",", 
       RowBox[{"Except", "[", "_List", "]"}]}], "}"}]}], ",", 
    RowBox[{"\[CapitalOmega]", ":", 
     RowBox[{"{", 
      RowBox[{"\[Alpha]_", ",", "\[Beta]_", ",", "\[Gamma]_"}], "}"}]}], ",", 
    "axes_", ",", "opts___Rule"}], " ", "]"}], ":=", "\n", "\t", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "\[CapitalOmega]FE", "}"}], ",", 
    RowBox[{"(", "\n", "\t\t", 
     RowBox[{
      RowBox[{"\[CapitalOmega]FE", " ", "=", " ", 
       RowBox[{"AxesToEuler", "[", 
        RowBox[{"AxisSystem", "@@", "axes"}], "]"}]}], ";", 
      "\[IndentingNewLine]", "\t", 
      RowBox[{"Fold", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"RotateEuler", "[", 
          RowBox[{"#1", ",", "#2"}], "]"}], "&"}], ",", "vec", ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", 
           RowBox[{"Reverse", "[", "\[CapitalOmega]FE", "]"}]}], ",", 
          "\[CapitalOmega]", ",", "\[CapitalOmega]FE"}], "}"}]}], "]"}]}], 
     "\n", "\t", ")"}]}], "]"}]}]], "Input",
 InitializationGroup->True,
 CellChangeTimes->{{3.4098235450418873`*^9, 3.409823858299131*^9}, {
  3.673940447828677*^9, 
  3.673940448142976*^9}},ExpressionUUID->"7012dbd8-43bb-4c0e-8312-\
1337633f0572"]
}, Closed]]
}, Closed]],

Cell[CellGroupData[{

Cell["go into lists that are not vectors", "Subsection",
 PageWidth->WindowWidth,
 InitializationCell->True,
