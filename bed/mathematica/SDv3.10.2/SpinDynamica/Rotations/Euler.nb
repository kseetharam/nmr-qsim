Cell["\<\
RotateEuler[obj_List,ang:{_, _, _},opts___]:=
\t\tMap[ 
\t\t\tRotateEuler[#,ang,opts]&, 
\t\t\tobj 
\t\t] \
\>", "Input",
 PageWidth->WindowWidth,
 InitializationCell->True,
