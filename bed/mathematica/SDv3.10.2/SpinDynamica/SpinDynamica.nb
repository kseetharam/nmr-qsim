   3.534398189837288*^9, 3.534398202089366*^9}, {3.545050244004449*^9, 
   3.545050294446129*^9}, {3.564597541225168*^9, 3.564597551886457*^9}, {
   3.657111496888939*^9, 
   3.657111497094153*^9}},ExpressionUUID->"ed394047-f643-4de3-a102-\
04a89011aec4"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"$Chronology", "::", "usage"}], "=", 
   "\"\<$Chronology is the default setting for Chronology. The value of \
$Chronology must be \\\"LeftToRight\\\" or \\\"RightToLeft\\\".\>\""}], 
  ";"}]], "Input",
