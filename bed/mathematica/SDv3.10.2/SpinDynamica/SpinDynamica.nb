   3.6571115456381006`*^9},ExpressionUUID->"e8372736-5e73-473e-8117-\
65298176ed41"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Chronology", "::", "usage"}], "=", 
   "\"\<Chronology is an option for many routines in SpinDynamica, which \
controls the temporal order of events in all event sequences used by the \
routines. The value of Chronology must be \\\"LeftToRight\\\" or \
\\\"RightToLeft\\\". The default value is set by $Chronology.\>\""}], 
  ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.511426287376344*^9, 3.5114263253503933`*^9}, {
   3.511429076592346*^9, 3.5114290995119877`*^9}, {3.513610254929747*^9, 
   3.513610333494897*^9}, {3.513610366936887*^9, 3.513610368414483*^9}, {
